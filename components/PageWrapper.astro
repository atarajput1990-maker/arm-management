---
// PageWrapper.astro — thin shell used by every translated page
// Handles Base layout wiring; child content goes in <slot />
import Base from '../layouts/Base.astro';
import { t, localePath } from '../i18n/translations';
import type { Locale } from '../i18n/translations';

interface Props {
  lang:          Locale;
  title:         string;
  description:   string;
  canonicalPath: string;
}
const { lang, title, description, canonicalPath } = Astro.props;
---
<Base title={title} description={description} lang={lang} canonicalPath={canonicalPath}>
  <slot />
</Base>
