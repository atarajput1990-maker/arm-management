      <p class="reveal">ARM Management advises international groups and founders on Japanese entity selection, incorporation, tax registration and cross-border structuring. Begin with a confidential conversation.</p>
      <div class="btn-row reveal">
        <a href="/contact" class="btn-primary">Schedule a Consultation →</a>
        <a href="/services/company-formation" class="btn-secondary">Company Formation Services</a>
      </div>
    </section>
  </main>

