---
import Base from '../../../layouts/Base.astro';
---
<Base
  title="Services | ARM Management"
  description="ARM Management offre six disciplines de conseil intégrées : conseil en transactions, création de sociétés, comptabilité, paie, mobilité internationale et crypto/Web3 — dans plus de 40 juridictions."
  lang="fr"
  canonicalPath="/services"
>
<main>
  <section class="page-hero">
    <div class="page-hero__bg" style="background-image:url('https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=1600&q=80&auto=format&fit=crop')"></div>
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content container">
      <span class="eyebrow">Services</span>
      <h1>Une relation unique. Six disciplines.</h1>
      <div class="btn-row" style="justify-content:flex-start;margin-top:30px">
        <a href="/fr/contact" class="btn-primary">Parler à un conseiller senior →</a>
      </div>
    </div>
  </section>
  <section class="section section--cream">
    <div class="container">
      <div class="grid-3" style="margin-top:20px">
        <a href="/fr/services/transaction-advisory" class="card reveal reveal-delay-1"><h3>Conseil en transactions</h3></a>
        <a href="/fr/services/company-formation" class="card reveal reveal-delay-2"><h3>Création de sociétés</h3></a>
        <a href="/fr/services/accounting-tax" class="card reveal reveal-delay-3"><h3>Comptabilité & Fiscalité</h3></a>
        <a href="/fr/services/payroll-hr" class="card reveal reveal-delay-1"><h3>Paie & RH</h3></a>
        <a href="/fr/services/global-mobility" class="card reveal reveal-delay-2"><h3>Mobilité internationale</h3></a>
        <a href="/fr/services/crypto-web3" class="card reveal reveal-delay-3"><h3>Crypto & Web3</h3></a>
      </div>
    </div>
  </section>
</main>
</Base>
