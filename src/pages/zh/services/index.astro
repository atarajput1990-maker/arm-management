---
import Base from '../../../layouts/Base.astro';
---
<Base
  title="服务 | ARM Management"
  description="ARM Management提供六大综合咨询服务：交易咨询、公司注册、会计、薪酬、全球移民及加密货币/Web3——覆盖40余个司法管辖区。"
  lang="zh"
  canonicalPath="/services"
>
<main>
  <section class="page-hero">
    <div class="page-hero__bg" style="background-image:url('https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=1600&q=80&auto=format&fit=crop')"></div>
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content container">
      <span class="eyebrow">服务</span>
      <h1>一个关系。六大专业。</h1>
      <div class="btn-row" style="justify-content:flex-start;margin-top:30px">
        <a href="/zh/contact" class="btn-primary">与资深顾问交流 →</a>
      </div>
    </div>
  </section>
  <section class="section section--cream">
    <div class="container">
      <div class="grid-3" style="margin-top:20px">
        <a href="/zh/services/transaction-advisory" class="card reveal reveal-delay-1"><h3>交易咨询</h3></a>
        <a href="/zh/services/company-formation" class="card reveal reveal-delay-2"><h3>公司注册</h3></a>
        <a href="/zh/services/accounting-tax" class="card reveal reveal-delay-3"><h3>会计与税务</h3></a>
        <a href="/zh/services/payroll-hr" class="card reveal reveal-delay-1"><h3>薪酬与人力资源</h3></a>
        <a href="/zh/services/global-mobility" class="card reveal reveal-delay-2"><h3>全球移民</h3></a>
        <a href="/zh/services/crypto-web3" class="card reveal reveal-delay-3"><h3>加密货币与Web3</h3></a>
      </div>
    </div>
  </section>
</main>
</Base>
