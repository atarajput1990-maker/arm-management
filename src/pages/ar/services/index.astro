---
import Base from '../../../layouts/Base.astro';
---
<Base
  title="الخدمات | ARM Management"
  description="تقدّم ARM Management ست تخصصات استشارية متكاملة: استشارات المعاملات، وتأسيس الشركات، والمحاسبة، والرواتب، والتنقل الدولي، والعملات الرقمية/Web3 — في أكثر من 40 ولاية قضائية."
  lang="ar"
  canonicalPath="/services"
>
<main dir="rtl">
  <section class="page-hero">
    <div class="page-hero__bg" style="background-image:url('https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=1600&q=80&auto=format&fit=crop')"></div>
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content container">
      <span class="eyebrow">الخدمات</span>
      <h1>علاقة واحدة. ست تخصصات.</h1>
      <div class="btn-row" style="justify-content:flex-start;margin-top:30px">
        <a href="/ar/contact" class="btn-primary">تحدّث مع مستشار متخصص ←</a>
      </div>
    </div>
  </section>
  <section class="section section--cream">
    <div class="container">
      <div class="grid-3" style="margin-top:20px">
        <a href="/ar/services/transaction-advisory" class="card reveal reveal-delay-1"><h3>استشارات المعاملات</h3></a>
        <a href="/ar/services/company-formation" class="card reveal reveal-delay-2"><h3>تأسيس الشركات</h3></a>
        <a href="/ar/services/accounting-tax" class="card reveal reveal-delay-3"><h3>المحاسبة والضرائب</h3></a>
        <a href="/ar/services/payroll-hr" class="card reveal reveal-delay-1"><h3>الرواتب والموارد البشرية</h3></a>
        <a href="/ar/services/global-mobility" class="card reveal reveal-delay-2"><h3>التنقل الدولي</h3></a>
        <a href="/ar/services/crypto-web3" class="card reveal reveal-delay-3"><h3>العملات الرقمية وWeb3</h3></a>
      </div>
    </div>
  </section>
</main>
</Base>
