---
import Base from '../../../layouts/Base.astro';
---
<Base
  title="Услуги | ARM Management"
  description="ARM Management предлагает шесть интегрированных направлений консалтинга: транзакционный консалтинг, регистрация компаний, бухучёт, расчёт зарплат, международная мобильность и крипто/Web3 — в 40+ юрисдикциях."
  lang="ru"
  canonicalPath="/services"
>
<main>
  <section class="page-hero">
    <div class="page-hero__bg" style="background-image:url('https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=1600&q=80&auto=format&fit=crop')"></div>
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content container">
      <span class="eyebrow">Услуги</span>
      <h1>Одни отношения. Шесть направлений.</h1>
      <div class="btn-row" style="justify-content:flex-start;margin-top:30px">
        <a href="/ru/contact" class="btn-primary">Связаться со старшим консультантом →</a>
      </div>
    </div>
  </section>
  <section class="section section--cream">
    <div class="container">
      <div class="grid-3" style="margin-top:20px">
        <a href="/ru/services/transaction-advisory" class="card reveal reveal-delay-1"><h3>Транзакционный консалтинг</h3></a>
        <a href="/ru/services/company-formation" class="card reveal reveal-delay-2"><h3>Регистрация компаний</h3></a>
        <a href="/ru/services/accounting-tax" class="card reveal reveal-delay-3"><h3>Учёт и налоги</h3></a>
        <a href="/ru/services/payroll-hr" class="card reveal reveal-delay-1"><h3>Расчёт зарплат и HR</h3></a>
        <a href="/ru/services/global-mobility" class="card reveal reveal-delay-2"><h3>Международная мобильность</h3></a>
        <a href="/ru/services/crypto-web3" class="card reveal reveal-delay-3"><h3>Крипто и Web3</h3></a>
      </div>
    </div>
  </section>
</main>
</Base>
