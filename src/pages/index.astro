---
import Base from '../layouts/Base.astro';
---
<Base
  title="International Business Advisory | ARM Management"
  description="ARM Management delivers cross-border transaction advisory, company formation, global mobility, and compliance services across the EU, GCC, Asia, and Latin America."
>
<main class="ed">

  <!-- HERO -->
  <header class="ed-hero">
    <div class="ed-ph" style="background-image:url('/images/ed-hero.jpg')"></div>
    <div class="ed-veil"></div>
    <div class="ed-wrap">
      <div class="ed-eyebrow is-light ed-fade">International Business Advisory · UAE Headquartered</div>
      <h1 class="ed-h ed-rise"><span>Empowering innovation — quietly, across every border.</span></h1>
      <p class="ed-sub ed-fade">ARM Management advises international companies, investment funds, family offices, and private principals on cross-border transactions, company formation, global mobility, and compliance — across the EU, GCC, Asia, and Latin America.</p>
      <div class="ed-btns ed-fade">
        <a href="/contact" class="ed-btn ed-btn--g">Speak With a Senior Advisor →</a>
        <a href="/services" class="ed-btn ed-btn--o">Explore Our Services</a>
      </div>
      <div class="ed-crow ed-fade">Brussels &nbsp;·&nbsp; Zurich &nbsp;·&nbsp; Riyadh &nbsp;·&nbsp; Dubai &nbsp;·&nbsp; Shenzhen</div>
    </div>
  </header>

  <!-- STATEMENT -->
  <section class="ed-sec ed-paper ed-pad">
    <div class="ed-wrap">
      <div class="ed-eyebrow ed-fade">The Practice</div>
      <div class="ed-two">
        <h2 class="ed-display ed-rise"><span>Six disciplines. One relationship.</span></h2>
        <div><p class="ed-lead ed-fade">ARM Management was built to answer a specific frustration: that businesses operating across borders are forced to manage five different firms, with no single advisor who understands the full picture. We are that single, accountable point of contact.</p></div>
      </div>
    </div>
  </section>

  <!-- TRUST -->
  <section class="ed-trust">
    <div class="ed-wrap">
      <div class="ed-stat ed-fade"><span class="n">40+</span><span class="l">Jurisdictions Covered</span></div>
      <div class="ed-stat ed-fade"><span class="n">15+</span><span class="l">Years Senior Experience</span></div>
      <div class="ed-stat ed-fade"><span class="n">24/7</span><span class="l">Direct Advisor Access</span></div>
      <div class="ed-stat ed-fade"><span class="n">100%</span><span class="l">Enquiry Confidentiality</span></div>
    </div>
  </section>

  <!-- FIVE GATEWAYS -->
  <section class="ed-gateways" aria-label="Our offices">
    <a class="ed-plate" href="/regions/european-union">
      <div class="ed-ph" style="background-image:url('/images/ed-brussels.jpg')"></div><div class="ed-veil"></div>
      <div class="ed-wrap ed-cap"><span class="num">01 — Europe</span><div class="ed-city ed-rise"><span>Brussels</span></div><span class="ctry ed-fade">Belgium · European Union</span><span class="go">Explore region →</span></div>
    </a>
    <a class="ed-plate" href="/regions/european-union">
      <div class="ed-ph" style="background-image:url('/images/ed-zurich.jpg')"></div><div class="ed-veil"></div>
      <div class="ed-wrap ed-cap"><span class="num">02 — Europe</span><div class="ed-city ed-rise"><span>Zurich</span></div><span class="ctry ed-fade">Switzerland</span><span class="go">Explore region →</span></div>
    </a>
    <a class="ed-plate" href="/regions/gcc-middle-east">
      <div class="ed-ph" style="background-image:url('/images/ed-riyadh.jpg')"></div><div class="ed-veil"></div>
      <div class="ed-wrap ed-cap"><span class="num">03 — Gulf</span><div class="ed-city ed-rise"><span>Riyadh</span></div><span class="ctry ed-fade">Kingdom of Saudi Arabia</span><span class="go">Explore region →</span></div>
    </a>
    <a class="ed-plate" href="/regions/gcc-middle-east">
      <div class="ed-ph" style="background-image:url('/images/ed-dubai.jpg')"></div><div class="ed-veil"></div>
      <div class="ed-wrap ed-cap"><span class="num">04 — Gulf · Headquarters</span><div class="ed-city ed-rise"><span>Dubai</span></div><span class="ctry ed-fade">United Arab Emirates</span><span class="go">Explore region →</span></div>
    </a>
    <a class="ed-plate" href="/regions/asia-pacific">
      <div class="ed-ph" style="background-image:url('/images/ed-shenzhen.jpg')"></div><div class="ed-veil"></div>
      <div class="ed-wrap ed-cap"><span class="num">05 — Asia</span><div class="ed-city ed-rise"><span>Shenzhen</span></div><span class="ctry ed-fade">People's Republic of China</span><span class="go">Explore region →</span></div>
    </a>
  </section>

  <!-- CAPABILITIES -->
  <section class="ed-sec ed-warm ed-pad">
    <div class="ed-wrap">
      <div class="ed-eyebrow ed-fade">Practice Areas</div>
      <h2 class="ed-display ed-rise"><span>Built around the decision.</span></h2>
      <div class="ed-rows">
        <a class="ed-row ed-fade" href="/services/transaction-advisory"><span class="ri">01</span><h3>Cross-Border Transaction Advisory</h3><p>Private investment, M&amp;A and deal structuring across 40+ jurisdictions. Advisory-first, success-aligned.</p><span class="ar">→</span></a>
        <a class="ed-row ed-fade" href="/services/company-formation"><span class="ri">02</span><h3>International Company Formation</h3><p>Incorporation across the EU, GCC, Asia and Latin America — entity selection, VAT/EORI, director services, fully coordinated.</p><span class="ar">→</span></a>
        <a class="ed-row ed-fade" href="/services/accounting-tax"><span class="ri">03</span><h3>Accounting, Tax &amp; Compliance</h3><p>Monthly bookkeeping, VAT, corporate tax and annual accounts across countries — one ARM contact coordinates everything.</p><span class="ar">→</span></a>
        <a class="ed-row ed-fade" href="/services/payroll-hr"><span class="ri">04</span><h3>Payroll &amp; HR Advisory</h3><p>Global payroll structure, HR compliance, international assignment planning and multi-country workforce strategy.</p><span class="ar">→</span></a>
        <a class="ed-row ed-fade" href="/services/global-mobility"><span class="ri">05</span><h3>Global Mobility &amp; Residence</h3><p>UAE and EU Golden Visa, investor permits, company-sponsored residency and family applications, managed end to end.</p><span class="ar">→</span></a>
        <a class="ed-row ed-fade" href="/services/crypto-web3"><span class="ri">06</span><h3>Crypto &amp; Web3 Advisory</h3><p>VARA licensing, MiCA compliance, token structuring and corporate setup across leading digital-asset jurisdictions.</p><span class="ar">→</span></a>
      </div>
    </div>
  </section>

  <!-- ARM VERIFY -->
  <section class="ed-verify">
    <div class="ed-wrap ed-verify-in">
      <div>
        <div class="ed-eyebrow is-light ed-fade">ARM Verify — Live</div>
        <h2 class="ed-display ed-rise" style="color:#fff"><span>Verify any entity, instantly.</span></h2>
        <p class="ed-sub ed-fade" style="color:rgba(247,243,236,.72);max-width:46ch">Real-time KYC, sanctions screening and UBO mapping across 35+ jurisdictions — OFAC, UN, EU and UK HMT lists, from $0.50 per check.</p>
      </div>
      <div class="ed-verify-cta ed-fade">
        <a href="https://verify.arm-management.com" class="ed-btn ed-btn--g" target="_blank" rel="noopener">Verify an Entity →</a>
        <div class="ed-pills"><span>OFAC · UN · EU · UK HMT</span><span>35+ Jurisdictions</span><span>From $0.50</span></div>
      </div>
    </div>
  </section>

  <!-- THE ARM STANDARD -->
  <section class="ed-sec ed-paper ed-pad">
    <div class="ed-wrap">
      <div class="ed-eyebrow ed-fade">The ARM Standard</div>
      <h2 class="ed-display ed-rise" style="max-width:18ch"><span>Not the largest firm. The most committed one.</span></h2>
      <div class="ed-principles">
        <div class="ed-principle ed-fade"><h4>Honest Assessment First</h4><p>We evaluate every mandate and tell you directly what is realistic — and have declined engagements we could not serve well.</p></div>
        <div class="ed-principle ed-fade"><h4>Senior Advisors. Always.</h4><p>The advisor in your first conversation is the person managing your engagement. No handoffs, no junior associates.</p></div>
        <div class="ed-principle ed-fade"><h4>We Find the Alternative</h4><p>When the primary route is blocked, we identify the next viable path. We have never closed an engagement without one.</p></div>
        <div class="ed-principle ed-fade"><h4>Available Around the Clock</h4><p>Cross-border business does not keep to one time zone. Active clients have direct access to their advisor at any hour.</p></div>
      </div>
    </div>
  </section>

  <!-- QUOTE -->
  <section class="ed-quote ed-pad">
    <div class="ed-wrap">
      <blockquote class="ed-fade">The most valuable thing an international advisor can offer is not a network, and it is not a process. It is the courage to tell you the truth about what is possible — and the expertise to find a better way when the obvious path fails.</blockquote>
      <cite class="ed-fade">— ARM Management</cite>
    </div>
  </section>

  <!-- REGIONS -->
  <section class="ed-sec ed-cream ed-pad">
    <div class="ed-wrap" style="text-align:center">
      <div class="ed-eyebrow is-center ed-fade">Global Reach</div>
      <h2 class="ed-display ed-rise" style="margin:0 auto"><span>Four regions. Forty jurisdictions. One point of contact.</span></h2>
      <div class="ed-reglist ed-fade">
        <a class="ed-reglink" href="/regions/european-union">European Union</a>
        <a class="ed-reglink" href="/regions/gcc-middle-east">GCC &amp; Middle East</a>
        <a class="ed-reglink" href="/regions/asia-pacific">Asia Pacific</a>
        <a class="ed-reglink" href="/regions/latin-america">Latin America</a>
      </div>
    </div>
  </section>

  <!-- CLOSE -->
  <section class="ed-close ed-pad">
    <div class="ed-wrap">
      <div class="ed-eyebrow is-center ed-fade">Enquiries</div>
      <h2 class="ed-display ed-rise" style="margin:0 auto;max-width:16ch"><span>Begin a private conversation.</span></h2>
      <div class="ed-rule" style="margin:30px auto"></div>
      <p class="ed-lead ed-fade" style="margin:0 auto 36px;max-width:60ch;text-align:center">Every ARM engagement begins with a confidential conversation. No obligation, no generic advice — a senior advisor will assess your situation honestly and tell you exactly what is achievable, and at what cost.</p>
      <div class="ed-btns ed-fade" style="justify-content:center">
        <a href="/contact" class="ed-btn ed-btn--g">Schedule a Consultation →</a>
        <a href="mailto:info@arm-management.com" class="ed-btn ed-btn--n">info@arm-management.com</a>
      </div>
    </div>
  </section>

</main>

<style>
  .ed { background: var(--warm); }
  .ed-wrap { max-width: 1240px; margin: 0 auto; padding: 0 clamp(24px,7vw,110px); }
  .ed-pad  { padding: clamp(88px,13vh,164px) 0; }
  .ed-paper{ background: var(--warm); } .ed-warm{ background:#FBF7EF; } .ed-cream{ background: var(--cream); }

  .ed-eyebrow{ font-family:'Inter',sans-serif; font-weight:500; font-size:10.5px; letter-spacing:.4em; text-transform:uppercase; color:var(--gold); display:flex; align-items:center; gap:14px; margin-bottom:30px; }
  .ed-eyebrow::before{ content:""; width:30px; height:1px; background:var(--gold); }
  .ed-eyebrow.is-light{ color:#E9C766; } .ed-eyebrow.is-light::before{ background:#E9C766; }
  .ed-eyebrow.is-center{ justify-content:center; }

  .ed-display{ font-family:'Cormorant Garamond',serif; font-weight:300; line-height:1.04; letter-spacing:.004em; color:var(--navy); font-size:clamp(32px,5vw,64px); }

  .ed-rise{ display:block; overflow:hidden; padding-bottom:.12em; }
  .ed-rise > span{ display:block; transform:translateY(112%); transition:transform 1.1s cubic-bezier(.16,1,.3,1); }
  .ed-rise.in > span{ transform:translateY(0); }
  .ed-fade{ opacity:0; transform:translateY(26px); transition:opacity 1.1s cubic-bezier(.16,1,.3,1), transform 1.1s cubic-bezier(.16,1,.3,1); }
  .ed-fade.in{ opacity:1; transform:none; }

  /* HERO */
  .ed-hero{ position:relative; height:100vh; min-height:620px; overflow:hidden; color:#fff; display:flex; align-items:flex-end; }
  .ed-hero .ed-ph{ position:absolute; inset:0; background-position:center; background-size:cover; transform:scale(1.06); animation:edken 22s ease-out forwards; }
  @keyframes edken{ to{ transform:scale(1.16) translateY(-1.5%); } }
  .ed-hero .ed-veil{ position:absolute; inset:0; background:linear-gradient(180deg,rgba(8,14,20,.36),rgba(8,14,20,.06) 32%,rgba(8,14,20,.5) 76%,rgba(8,14,20,.8)); }
  .ed-hero .ed-wrap{ position:relative; z-index:2; width:100%; padding-bottom:clamp(60px,11vh,118px); }
  .ed-hero .ed-h{ font-family:'Cormorant Garamond',serif; font-weight:300; line-height:.98; font-size:clamp(40px,7vw,100px); color:#fff; max-width:15ch; margin:0; }
  .ed-sub{ font-family:'Inter',sans-serif; font-weight:300; font-size:clamp(14px,1.3vw,17px); line-height:1.85; color:rgba(255,255,255,.82); max-width:56ch; margin:24px 0 0; }
  .ed-rule{ width:66px; height:1px; background:#E9C766; margin:28px 0; }
  .ed-btns{ display:flex; gap:14px; flex-wrap:wrap; margin-top:30px; }
  .ed-btn{ font-family:'Inter',sans-serif; font-weight:600; font-size:12px; letter-spacing:.1em; text-transform:uppercase; padding:15px 26px; border-radius:2px; transition:background .25s,color .25s,opacity .25s; }
  .ed-btn--g{ background:var(--gold); color:var(--navy); } .ed-btn--g:hover{ background:#cca91d; }
  .ed-btn--o{ border:1px solid rgba(255,255,255,.5); color:#fff; } .ed-btn--o:hover{ background:#fff; color:var(--navy); }
  .ed-btn--n{ border:1px solid var(--navy); color:var(--navy); } .ed-btn--n:hover{ background:var(--navy); color:#fff; }
  .ed-crow{ margin-top:30px; font-family:'Inter',sans-serif; font-size:11px; letter-spacing:.26em; text-transform:uppercase; color:rgba(255,255,255,.72); }

  /* STATEMENT */
  .ed-two{ display:grid; grid-template-columns:1.35fr .9fr; gap:clamp(28px,5vw,76px); align-items:end; margin-top:4px; }
  .ed-lead{ font-size:clamp(15px,1.15vw,17px); line-height:1.95; color:#2C3240; max-width:48ch; }
  @media (max-width:820px){ .ed-two{ grid-template-columns:1fr; align-items:start; } }

  /* TRUST */
  .ed-trust{ background:var(--navy); }
  .ed-trust .ed-wrap{ display:grid; grid-template-columns:repeat(4,1fr); gap:30px; padding-top:48px; padding-bottom:48px; }
  .ed-stat .n{ display:block; font-family:'Cormorant Garamond',serif; font-weight:600; font-size:clamp(2rem,3.4vw,2.6rem); color:var(--gold); }
  .ed-stat .l{ display:block; font-family:'Inter',sans-serif; font-weight:500; font-size:11px; letter-spacing:.16em; text-transform:uppercase; color:rgba(247,243,236,.6); margin-top:8px; }
  @media (max-width:680px){ .ed-trust .ed-wrap{ grid-template-columns:1fr 1fr; gap:30px; } }

  /* GATEWAYS */
  .ed-plate{ position:relative; display:block; height:100vh; min-height:560px; overflow:hidden; color:#fff; }
  .ed-plate .ed-ph{ position:absolute; left:0; right:0; top:-14%; height:128%; background-position:center; background-size:cover; will-change:transform; }
  .ed-plate .ed-veil{ position:absolute; inset:0; background:linear-gradient(180deg,rgba(8,14,20,.26),rgba(8,14,20,.12) 40%,rgba(8,14,20,.62) 88%,rgba(8,14,20,.82)); }
  .ed-cap{ position:absolute; left:0; right:0; bottom:clamp(54px,10vh,106px); z-index:2; }
  .ed-cap .num{ display:block; font-family:'Inter',sans-serif; font-weight:500; font-size:12px; letter-spacing:.3em; text-transform:uppercase; color:#E9C766; margin-bottom:14px; }
  .ed-city{ font-family:'Cormorant Garamond',serif; font-weight:300; line-height:.9; font-size:clamp(54px,11vw,148px); color:#fff; }
  .ed-cap .ctry{ display:block; font-family:'Inter',sans-serif; font-size:12px; letter-spacing:.22em; text-transform:uppercase; color:rgba(255,255,255,.82); margin-top:14px; }
  .ed-cap .go{ display:inline-block; font-family:'Inter',sans-serif; font-weight:500; font-size:11px; letter-spacing:.18em; text-transform:uppercase; color:#fff; margin-top:22px; opacity:0; transform:translateY(8px); transition:opacity .4s,transform .4s; }
  .ed-plate:hover .go{ opacity:.92; transform:none; }

  /* CAPABILITIES */
  .ed-rows{ margin-top:46px; border-top:1px solid var(--border); }
  .ed-row{ display:grid; grid-template-columns:58px 1.05fr 1.45fr 30px; gap:clamp(14px,3vw,42px); align-items:baseline; padding:30px 6px; border-bottom:1px solid var(--border); transition:padding-left .5s cubic-bezier(.16,1,.3,1),background .5s; }
  .ed-row:hover{ padding-left:20px; background:rgba(184,150,12,.06); }
  .ed-row .ri{ font-family:'Inter',sans-serif; font-weight:500; font-size:11px; letter-spacing:.2em; color:var(--gold); }
  .ed-row h3{ font-family:'Cormorant Garamond',serif; font-weight:400; font-size:clamp(22px,2.4vw,31px); color:var(--navy); margin:0; }
  .ed-row p{ font-size:14px; line-height:1.7; color:var(--text); margin:0; }
  .ed-row .ar{ font-family:'Inter',sans-serif; font-size:18px; color:var(--gold); text-align:right; }
  @media (max-width:780px){ .ed-row{ grid-template-columns:34px 1fr; } .ed-row p{ grid-column:2; } .ed-row .ar{ display:none; } }

  /* VERIFY */
  .ed-verify{ background:var(--navy); padding:clamp(72px,10vh,120px) 0; }
  .ed-verify-in{ display:grid; grid-template-columns:1.3fr .9fr; gap:clamp(30px,5vw,70px); align-items:center; }
  .ed-verify-cta{ display:flex; flex-direction:column; gap:18px; align-items:flex-start; }
  .ed-pills{ display:flex; flex-wrap:wrap; gap:10px; }
  .ed-pills span{ font-family:'Inter',sans-serif; font-size:10.5px; letter-spacing:.12em; text-transform:uppercase; color:rgba(247,243,236,.66); border:1px solid rgba(184,150,12,.4); border-radius:30px; padding:7px 14px; }
  @media (max-width:780px){ .ed-verify-in{ grid-template-columns:1fr; } }

  /* STANDARD */
  .ed-principles{ display:grid; grid-template-columns:1fr 1fr; gap:38px 56px; margin-top:50px; }
  .ed-principle{ border-top:1.5px solid var(--gold); padding-top:18px; }
  .ed-principle h4{ font-family:'Inter',sans-serif; font-weight:600; font-size:13px; letter-spacing:.1em; text-transform:uppercase; color:var(--navy); margin:0 0 12px; }
  .ed-principle p{ font-size:15px; line-height:1.75; color:var(--text); margin:0; }
  @media (max-width:680px){ .ed-principles{ grid-template-columns:1fr; gap:30px; } }

  /* QUOTE */
  .ed-quote{ background:#fff; text-align:center; }
  .ed-quote blockquote{ font-family:'Cormorant Garamond',serif; font-style:italic; font-weight:300; font-size:clamp(22px,3vw,38px); line-height:1.42; color:var(--navy); max-width:900px; margin:0 auto; }
  .ed-quote cite{ display:block; font-family:'Inter',sans-serif; font-style:normal; font-weight:600; font-size:12px; letter-spacing:.14em; text-transform:uppercase; color:var(--gold); margin-top:28px; }

  /* REGIONS */
  .ed-reglist{ display:flex; flex-wrap:wrap; gap:14px 30px; justify-content:center; margin-top:34px; }
  .ed-reglink{ font-family:'Cormorant Garamond',serif; font-weight:400; font-size:clamp(20px,2.4vw,31px); color:var(--navy); border-bottom:1px solid transparent; padding-bottom:2px; transition:color .3s,border-color .3s; }
  .ed-reglink:hover{ color:var(--gold); border-color:var(--gold); }

  /* CLOSE */
  .ed-close{ background:var(--cream); text-align:center; }
</style>

<script>
  // editorial reveals
  const io = new IntersectionObserver((es) => {
    es.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
  }, { threshold: 0.18 });
  document.querySelectorAll('.ed-rise, .ed-fade').forEach((el) => io.observe(el));

  // parallax on full-bleed photo plates + hero handled by CSS
  const phs = Array.prototype.slice.call(document.querySelectorAll('.ed-plate .ed-ph'));
  function loop() {
    const vh = window.innerHeight;
    for (let i = 0; i < phs.length; i++) {
      const ph = phs[i];
      const r = ph.parentElement.getBoundingClientRect();
      if (r.bottom < -200 || r.top > vh + 200) continue;
      const c = (r.top + r.height / 2 - vh / 2);
      ph.style.transform = 'translate3d(0,' + (c * -0.08).toFixed(1) + 'px,0)';
    }
    requestAnimationFrame(loop);
  }
  requestAnimationFrame(loop);
</script>
</Base>
