---
import Base from '../layouts/Base.astro';
---
<Base
  title="Thank You | ARM Management"
  description="Your message has been received. A senior ARM advisor will respond within one business day."
>
<main>
  <section class="page-hero" style="min-height:60vh">
    <div class="page-hero__bg" style="background-image:url('https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=1600&q=80&auto=format&fit=crop')"></div>
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content container" style="text-align:center;max-width:720px;margin:0 auto">
      <span class="eyebrow">Message Received</span>
      <h1>Thank You.</h1>
      <p>A senior ARM advisor will review your enquiry and respond within one business day. All communications are treated with complete confidentiality.</p>
      <div style="margin-top:36px;display:flex;gap:16px;justify-content:center;flex-wrap:wrap">
        <a href="/" class="btn-primary">Return Home →</a>
        <a href="/services" class="btn-secondary">Explore Our Services</a>
      </div>
    </div>
  </section>
</main>
</Base>
