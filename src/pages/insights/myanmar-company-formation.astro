  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Can a foreigner own 100% of a Myanmar company?","acceptedAnswer":{"@type":"Answer","text":"Yes, for most activities with an MIC Permit. Sanctions screening is essential before proceeding."}},{"@type":"Question","name":"What sanctions apply to Myanmar?","acceptedAnswer":{"@type":"Answer","text":"US, EU and UK sanctions target military-linked entities and certain sectors. Specialist legal advice is essential before investment."}}]})} />
</Base>
