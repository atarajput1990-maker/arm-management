  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context":"https://schema.org",
    "@type":"FAQPage",
    "mainEntity":[
      {"@type":"Question","name":"What is the corporate tax rate in the UAE?","acceptedAnswer":{"@type":"Answer","text":"0% on taxable income up to AED 375,000 and 9% above that. A separate 15% minimum top-up tax can apply to very large multinational groups."}},
      {"@type":"Question","name":"Do free-zone companies pay corporate tax?","acceptedAnswer":{"@type":"Answer","text":"Not necessarily. A Qualifying Free Zone Person can apply 0% to qualifying income if strict conditions are met; non-qualifying income is taxed at 9%."}},
      {"@type":"Question","name":"What is the VAT rate in the UAE?","acceptedAnswer":{"@type":"Answer","text":"The standard VAT rate is 5%. Some supplies are zero-rated and some are exempt."}},
      {"@type":"Question","name":"When must a business register for VAT?","acceptedAnswer":{"@type":"Answer","text":"Registration is mandatory once taxable turnover exceeds AED 375,000 and voluntary from AED 187,500."}},
      {"@type":"Question","name":"When are corporate tax returns due?","acceptedAnswer":{"@type":"Answer","text":"Within nine months of the end of the financial year."}}
