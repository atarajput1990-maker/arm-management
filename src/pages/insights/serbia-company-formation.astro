  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is the corporate tax rate in Serbia?","acceptedAnswer":{"@type":"Answer","text":"A flat 15% on profits, with no surcharges or minimum tax."}},{"@type":"Question","name":"How much capital do I need for a Serbian d.o.o.?","acceptedAnswer":{"@type":"Answer","text":"Nominal — from RSD 100 (about €1)."}},{"@type":"Question","name":"What is the Serbian VAT rate?","acceptedAnswer":{"@type":"Answer","text":"20% standard with a 10% reduced rate; registration applies above RSD 8,000,000 (about €68,000) turnover."}}]})} />
</Base>
