  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is the corporate tax rate in Slovenia?","acceptedAnswer":{"@type":"Answer","text":"22% for tax years 2024–2028 (raised from 19% to fund flood reconstruction), scheduled to revert to 19% in 2029."}},{"@type":"Question","name":"How much capital do I need for a Slovenian d.o.o.?","acceptedAnswer":{"@type":"Answer","text":"€7,500 minimum share capital."}},{"@type":"Question","name":"What is the Slovenian VAT rate?","acceptedAnswer":{"@type":"Answer","text":"22% standard, with a 9.5% reduced and 5% super-reduced rate; registration applies above €50,000 turnover."}}]})} />
</Base>
