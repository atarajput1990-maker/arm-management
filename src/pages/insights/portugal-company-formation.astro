  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is the corporate tax rate in Portugal?","acceptedAnswer":{"@type":"Answer","text":"The standard IRC has been reduced in stages toward 19–20% (confirm the current year), with a reduced ~15–16% rate on the first €50,000 of taxable profit for SMEs; the Madeira free zone offers 5% for qualifying companies."}},{"@type":"Question","name":"How much capital do I need for a Portuguese Lda?","acceptedAnswer":{"@type":"Answer","text":"€1 minimum, though a larger amount is advisable in practice."}},{"@type":"Question","name":"What is the Portuguese VAT rate?","acceptedAnswer":{"@type":"Answer","text":"23% standard, with reduced rates of 13% and 6%."}}]})} />
</Base>
