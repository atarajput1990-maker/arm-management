---
import Base from '../../layouts/Base.astro';
const reviewed = "June 2026";

const ENT = {
  "uae":"LLC / Free Zone", "saudi-arabia":"LLC", "united-kingdom":"Ltd", "netherlands":"B.V.",
  "france":"SAS / SARL", "germany":"GmbH", "belgium":"BV / SRL", "switzerland":"GmbH / AG",
  "italy":"S.r.l.", "spain":"S.L.", "portugal":"Lda", "estonia":"OÜ", "sweden":"AB", "finland":"Oy",
  "norway":"AS", "denmark":"ApS", "latvia":"SIA", "lithuania":"UAB", "poland":"Sp. z o.o.",
  "czech-republic":"s.r.o.", "slovakia":"s.r.o.", "hungary":"Kft.", "austria":"GmbH",
  "slovenia":"d.o.o.", "romania":"SRL", "bulgaria":"EOOD", "croatia":"d.o.o.", "serbia":"d.o.o.",
  "montenegro":"d.o.o.", "north-macedonia":"DOO", "albania":"SHPK", "turkey":"Limited Şirket",
  "greece":"IKE", "cyprus":"Ltd", "malta":"Ltd", "georgia":"LLC"
};
const J = [
  {n:"United Arab Emirates", r:"Middle East · GCC", ct:"9%", vat:"5%", s:"uae"},
  {n:"Saudi Arabia", r:"Middle East · GCC", ct:"20%", vat:"15%", s:"saudi-arabia"},
  {n:"United Kingdom", r:"Western Europe", ct:"19–25%", vat:"20%", s:"united-kingdom"},
  {n:"Netherlands", r:"Western Europe", ct:"19–25.8%", vat:"21%", s:"netherlands"},
  {n:"France", r:"Western Europe", ct:"25%", vat:"20%", s:"france"},
  {n:"Germany", r:"Western Europe", ct:"~30%", vat:"19%", s:"germany"},
  {n:"Belgium", r:"Western Europe", ct:"25%", vat:"21%", s:"belgium"},
  {n:"Switzerland", r:"Western Europe", ct:"12–21%", vat:"8.1%", s:"switzerland"},
  {n:"Italy", r:"Western Europe", ct:"~28%", vat:"22%", s:"italy"},
  {n:"Spain", r:"Western Europe", ct:"25%", vat:"21%", s:"spain"},
  {n:"Portugal", r:"Western Europe", ct:"20%", vat:"23%", s:"portugal"},
  {n:"Estonia", r:"Northern Europe", ct:"0 / 22%", vat:"24%", s:"estonia"},
  {n:"Sweden", r:"Northern Europe", ct:"20.6%", vat:"25%", s:"sweden"},
  {n:"Finland", r:"Northern Europe", ct:"20%", vat:"25.5%", s:"finland"},
  {n:"Norway", r:"Northern Europe", ct:"22%", vat:"25%", s:"norway"},
  {n:"Denmark", r:"Northern Europe", ct:"22%", vat:"25%", s:"denmark"},
  {n:"Latvia", r:"Northern Europe", ct:"0 / 20%", vat:"21%", s:"latvia"},
  {n:"Lithuania", r:"Northern Europe", ct:"17%", vat:"21%", s:"lithuania"},
  {n:"Poland", r:"Central Europe", ct:"19 / 9%", vat:"23%", s:"poland"},
  {n:"Czech Republic", r:"Central Europe", ct:"21%", vat:"21%", s:"czech-republic"},
  {n:"Slovakia", r:"Central Europe", ct:"10–24%", vat:"23%", s:"slovakia"},
  {n:"Hungary", r:"Central Europe", ct:"9%", vat:"27%", s:"hungary"},
  {n:"Austria", r:"Central Europe", ct:"23%", vat:"20%", s:"austria"},
  {n:"Slovenia", r:"Central Europe", ct:"22%", vat:"22%", s:"slovenia"},
  {n:"Romania", r:"Southeast Europe", ct:"16% / 1%", vat:"21%", s:"romania"},
  {n:"Bulgaria", r:"Southeast Europe", ct:"10%", vat:"20%", s:"bulgaria"},
  {n:"Croatia", r:"Southeast Europe", ct:"10 / 18%", vat:"25%", s:"croatia"},
  {n:"Serbia", r:"Balkans & Türkiye", ct:"15%", vat:"20%", s:"serbia"},
  {n:"Montenegro", r:"Balkans & Türkiye", ct:"9–15%", vat:"21%", s:"montenegro"},
  {n:"North Macedonia", r:"Balkans & Türkiye", ct:"10%", vat:"18%", s:"north-macedonia"},
  {n:"Albania", r:"Balkans & Türkiye", ct:"0 / 15%", vat:"20%", s:"albania"},
  {n:"Turkey", r:"Balkans & Türkiye", ct:"25%", vat:"20%", s:"turkey"},
  {n:"Greece", r:"Mediterranean", ct:"22%", vat:"24%", s:"greece"},
  {n:"Cyprus", r:"Mediterranean", ct:"15%", vat:"19%", s:"cyprus"},
  {n:"Malta", r:"Mediterranean", ct:"35% / 5%", vat:"18%", s:"malta"},
  {n:"Georgia", r:"Caucasus", ct:"15%", vat:"18%", s:"georgia"},
];
const rows = J.map(x => ({...x, entity: ENT[x.s] || "—"}));

const faqs = [
  ["Which country has the lowest corporate tax in 2026?",
   "Among these 36 jurisdictions, the UAE and Hungary have the lowest headline corporate tax at 9%. Estonia and Latvia effectively charge 0% on retained (reinvested) profits, taxing only distributed profits at around 20–22%. Bulgaria applies a 10% flat rate."],
  ["Which country has the lowest VAT?",
   "The UAE (5%) and Switzerland (8.1%) have the lowest VAT in this set. Within the EU, Malta (18%), then Cyprus and Germany (19%) are among the lowest."],
  ["Which countries do not tax retained earnings?",
   "Estonia and Latvia operate a distributed-profit tax system: profits kept inside the company are taxed at 0%, and corporate tax (around 20–22%) is only due when profits are distributed."],
  ["What is Cyprus's corporate tax rate in 2026?",
   "15% from 1 January 2026, raised from 12.5% to align with the OECD Pillar Two minimum — still among the lowest in the EU, with no withholding tax on outbound dividends."],
  ["Is Malta's corporate tax really 5%?",
   "Malta's headline rate is 35%, but a shareholder refund of 6/7ths on trading income can bring the effective rate to about 5%. It requires correct structuring and is increasingly scrutinised under CFC and substance rules."],
  ["Which country has the highest VAT?",
   "Hungary has the highest VAT in this set at 27%, followed by Finland at 25.5% and Sweden, Norway, Denmark and Croatia at 25%."],
];
---
<Base
  title="2026 Corporate Tax & VAT Comparison: 36 Jurisdictions | ARM Management"
  description="Compare 2026 corporate tax and VAT rates across 36 jurisdictions in the EU, GCC, Balkans, Mediterranean and beyond. Sortable and searchable, with links to full company-formation guides. Reviewed June 2026."
>
  <main>
    <section class="page-hero">
      <div class="page-hero__bg" style="background-image:url('/images/ed-zurich.jpg')"></div>
      <div class="page-hero__overlay"></div>
      <div class="page-hero__content container">
        <span class="eyebrow">Comparison · 2026</span>
        <h1>2026 Corporate Tax &amp; VAT,<br>Compared Across 36 Jurisdictions</h1>
        <p>Headline corporate income tax and standard VAT for every jurisdiction ARM covers — sortable, searchable, and current as at June 2026.</p>
        <div class="btn-row" style="justify-content:flex-start;margin-top:30px">
          <a href="/contact" class="btn-primary">Speak With a Senior Advisor →</a>
          <a href="/services/company-formation" class="btn-secondary">Company Formation Services</a>
        </div>
      </div>
    </section>

    <section class="section section--warm">
      <div class="container">
        <div class="guide-meta reveal" style="max-width:760px;margin:0 auto 8px">
          <span><strong>Last reviewed:</strong> {reviewed}</span>
          <span><strong>Scope:</strong> 36 jurisdictions · headline rates</span>
        </div>

        <div class="prose" style="max-width:760px;margin:0 auto">
          <p class="reveal lede">Across the 36 jurisdictions below, 2026 headline corporate income tax ranges from <strong>0%</strong> on retained earnings (Estonia, Latvia) and <strong>9%</strong> (UAE, Hungary) up to roughly <strong>30%</strong> (Germany), while standard VAT runs from <strong>5%</strong> (UAE) to <strong>27%</strong> (Hungary). The table is sortable and searchable; every row links to a full, sourced guide for that jurisdiction.</p>
        </div>

        <div class="cmp-stats reveal">
          <div class="cmp-stat"><div class="cmp-stat__n">36</div><div class="cmp-stat__l">Jurisdictions</div></div>
          <div class="cmp-stat"><div class="cmp-stat__n">9% / 0%*</div><div class="cmp-stat__l">Lowest corporate tax<br><span>UAE &amp; Hungary · *0% on retained earnings (EE, LV)</span></div></div>
          <div class="cmp-stat"><div class="cmp-stat__n">5%</div><div class="cmp-stat__l">Lowest VAT<br><span>United Arab Emirates</span></div></div>
          <div class="cmp-stat"><div class="cmp-stat__n">27%</div><div class="cmp-stat__l">Highest VAT<br><span>Hungary</span></div></div>
        </div>

        <div class="cmp-tools reveal">
          <input id="cmpSearch" type="search" placeholder="Search country, entity or region…" aria-label="Search the comparison table" />
          <span class="cmp-count" id="cmpCount"></span>
        </div>

        <div class="cmp-tablewrap reveal">
          <table class="cmp-table" id="cmpTable">
            <thead>
              <tr>
                <th data-key="n" data-type="text" aria-sort="none">Jurisdiction</th>
                <th data-key="entity" data-type="text">Common entity</th>
                <th data-key="ct" data-type="num">Corporate tax</th>
                <th data-key="vat" data-type="num">VAT</th>
                <th data-key="r" data-type="text">Region</th>
                <th class="cmp-guidecol">Guide</th>
              </tr>
            </thead>
            <tbody>
              {rows.map(x => (
                <tr>
                  <td data-v={x.n}><a href={`/insights/${x.s}-company-formation`}>{x.n}</a></td>
                  <td data-v={x.entity}>{x.entity}</td>
                  <td data-v={x.ct}>{x.ct}</td>
                  <td data-v={x.vat}>{x.vat}</td>
                  <td data-v={x.r}>{x.r}</td>
                  <td class="cmp-guidecol"><a href={`/insights/${x.s}-company-formation`}>View →</a></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div class="prose" style="max-width:760px;margin:36px auto 0">
          <p class="reveal" style="font-size:14px;color:#6B7280">Rates shown are headline figures and shorthand (for example, "0 / 22%" denotes a distributed-profit system where retained earnings are untaxed; "35% / 5%" denotes a headline rate with an effective rate after refunds). Several rates are mid-transition in 2026. Always confirm the current figure and your specific position in the linked guide, which cites each jurisdiction's tax authority.</p>

          <h2 class="reveal">Frequently asked questions</h2>
          {faqs.map(([q,a]) => (
            <div class="faq-item reveal"><h4>{q}</h4><p>{a}</p></div>
          ))}

          <p class="reveal disclaimer">This comparison is general information prepared by ARM Management and is current as at {reviewed}. It is not legal or tax advice; rates and rules change, and several are mid-transition. Confirm against the relevant tax authority, or with an advisor, before acting.</p>
        </div>
      </div>
    </section>

    <section class="cta-section guide-cta">
      <span class="eyebrow is-center reveal" style="justify-content:center">Speak With ARM</span>
      <h2 class="reveal">Choosing where to establish?</h2>
      <p class="reveal">ARM Management advises international companies and investors on jurisdiction selection, formation and ongoing tax compliance across all 36 markets above. Begin with a confidential conversation.</p>
      <div class="btn-row reveal">
        <a href="/contact" class="btn-primary">Schedule a Consultation →</a>
        <a href="/services/company-formation" class="btn-secondary">Company Formation Services</a>
      </div>
    </section>
  </main>

  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":"2026 Corporate Tax & VAT Comparison: 36 Jurisdictions","description":"Sortable comparison of 2026 headline corporate income tax and standard VAT across 36 jurisdictions in the EU, GCC, Balkans, Mediterranean and beyond.","author":{"@type":"Organization","name":"ARM Management"},"publisher":{"@type":"Organization","name":"ARM Management","logo":{"@type":"ImageObject","url":"https://arm-management.com/images/logo.png"}},"dateModified":"2026-06-01","mainEntityOfPage":"https://arm-management.com/insights/2026-corporate-tax-vat-comparison"})} />
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Dataset","name":"2026 Corporate Tax & VAT Rates — 36 Jurisdictions","description":"Headline corporate income tax and standard VAT rates for 36 jurisdictions across the EU, GCC, Balkans, Mediterranean and Caucasus, current as at June 2026.","creator":{"@type":"Organization","name":"ARM Management"},"dateModified":"2026-06-01","keywords":["corporate tax 2026","VAT rates 2026","company formation","EU corporate tax","GCC tax"]})} />
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":faqs.map(([q,a]) => ({"@type":"Question","name":q,"acceptedAnswer":{"@type":"Answer","text":a}}))})} />
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://arm-management.com/"},{"@type":"ListItem","position":2,"name":"Insights","item":"https://arm-management.com/insights"},{"@type":"ListItem","position":3,"name":"2026 Corporate Tax & VAT Comparison","item":"https://arm-management.com/insights/2026-corporate-tax-vat-comparison"}]})} />

  <style>
    .cmp-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;max-width:1000px;margin:34px auto 30px}
    .cmp-stat{background:var(--ww,#FDFAF6);border:1px solid var(--bone,#E2DDD6);border-top:2px solid var(--gold,#B8960C);border-radius:4px;padding:18px 18px 16px;text-align:center}
    .cmp-stat__n{font-family:'Cormorant Garamond',serif;font-size:30px;color:var(--navy,#0D1B2A);line-height:1}
    .cmp-stat__l{font-size:12px;color:var(--gray,#6B7280);margin-top:8px;line-height:1.4}
    .cmp-stat__l span{font-size:10.5px;opacity:.8}
    .cmp-tools{display:flex;align-items:center;gap:16px;max-width:1000px;margin:0 auto 14px}
    #cmpSearch{flex:1;padding:13px 16px;border:1px solid var(--bone,#E2DDD6);border-radius:3px;font-family:'Inter',sans-serif;font-size:15px;background:#fff}
    #cmpSearch:focus{outline:none;border-color:var(--gold,#B8960C)}
    .cmp-count{font-size:13px;color:var(--gray,#6B7280);white-space:nowrap}
    .cmp-tablewrap{max-width:1000px;margin:0 auto;overflow-x:auto;border:1px solid var(--bone,#E2DDD6);border-radius:4px}
    .cmp-table{width:100%;border-collapse:collapse;font-size:15px;background:#fff;min-width:680px}
    .cmp-table th{font-family:'Inter',sans-serif;font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--gray,#6B7280);text-align:left;padding:14px 16px;border-bottom:2px solid var(--bone,#E2DDD6);cursor:pointer;user-select:none;white-space:nowrap;background:var(--cream,#F7F3EC)}
    .cmp-table th.cmp-guidecol{cursor:default}
    .cmp-table th[data-key]:hover{color:var(--navy,#0D1B2A)}
    .cmp-table th[aria-sort="ascending"]::after{content:" ▲";color:var(--gold,#B8960C)}
    .cmp-table th[aria-sort="descending"]::after{content:" ▼";color:var(--gold,#B8960C)}
    .cmp-table td{padding:13px 16px;border-bottom:1px solid #efeae2;color:var(--char,#2C3240)}
    .cmp-table tbody tr:hover{background:var(--cream,#F7F3EC)}
    .cmp-table td a{color:var(--navy,#0D1B2A);text-decoration:none;font-weight:500;border-bottom:1px solid var(--gold,#B8960C)}
    .cmp-table td a:hover{color:var(--gold,#B8960C)}
    .cmp-guidecol{text-align:right;white-space:nowrap}
    @media(max-width:640px){.cmp-stats{grid-template-columns:repeat(2,1fr)}.cmp-tools{flex-direction:column;align-items:stretch}}
  </style>

  <script is:inline>
    (function(){
      var table=document.getElementById('cmpTable');
      if(!table) return;
      var tbody=table.querySelector('tbody');
      var search=document.getElementById('cmpSearch');
      var count=document.getElementById('cmpCount');
      var allRows=Array.prototype.slice.call(tbody.querySelectorAll('tr'));
      function num(v){ if(v==null) return -1; var m=String(v).replace(',', '.').match(/-?\d+(\.\d+)?/); return m?parseFloat(m[0]):-1; }
      function tally(){ var vis=allRows.filter(function(r){return r.style.display!=='none';}).length; count.textContent=vis+' of '+allRows.length+' shown'; }
      function filter(){ var q=(search.value||'').toLowerCase().trim();
        allRows.forEach(function(r){ var t=r.textContent.toLowerCase(); r.style.display=(!q||t.indexOf(q)>-1)?'':'none'; }); tally(); }
      search.addEventListener('input', filter);
      var ths=table.querySelectorAll('th[data-key]');
      ths.forEach(function(th){ th.addEventListener('click', function(){
        var key=th.getAttribute('data-key'); var type=th.getAttribute('data-type');
        var idx=Array.prototype.indexOf.call(th.parentNode.children, th);
        var asc=th.getAttribute('aria-sort')!=='ascending';
        ths.forEach(function(o){o.setAttribute('aria-sort','none');});
        th.setAttribute('aria-sort', asc?'ascending':'descending');
        var sorted=allRows.slice().sort(function(a,b){
          var av=a.children[idx].getAttribute('data-v')||a.children[idx].textContent;
          var bv=b.children[idx].getAttribute('data-v')||b.children[idx].textContent;
          if(type==='num'){ av=num(av); bv=num(bv); return asc?av-bv:bv-av; }
          av=String(av).toLowerCase(); bv=String(bv).toLowerCase();
          return asc?(av<bv?-1:av>bv?1:0):(av>bv?-1:av<bv?1:0);
        });
        sorted.forEach(function(r){tbody.appendChild(r);});
      }); });
      tally();
    })();
  </script>
</Base>
