---
import Base from '../../../layouts/Base.astro';
---
<Base
  title="Servicios | ARM Management"
  description="ARM Management ofrece seis disciplinas de asesoría integradas: asesoría en transacciones, constitución de sociedades, contabilidad, nómina, movilidad global y cripto/Web3 — en más de 40 jurisdicciones."
  lang="es"
  canonicalPath="/services"
>
<main>
  <section class="page-hero">
    <div class="page-hero__bg" style="background-image:url('https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=1600&q=80&auto=format&fit=crop')"></div>
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content container">
      <span class="eyebrow">Servicios</span>
      <h1>Una sola relación. Seis disciplinas.</h1>
      <div class="btn-row" style="justify-content:flex-start;margin-top:30px">
        <a href="/es/contact" class="btn-primary">Hablar con un asesor senior →</a>
      </div>
    </div>
  </section>
  <section class="section section--cream">
    <div class="container">
      <div class="grid-3" style="margin-top:20px">
        <a href="/es/services/transaction-advisory" class="card reveal reveal-delay-1"><h3>Asesoría en Transacciones</h3></a>
        <a href="/es/services/company-formation" class="card reveal reveal-delay-2"><h3>Constitución de Sociedades</h3></a>
        <a href="/es/services/accounting-tax" class="card reveal reveal-delay-3"><h3>Contabilidad e Impuestos</h3></a>
        <a href="/es/services/payroll-hr" class="card reveal reveal-delay-1"><h3>Nómina y RRHH</h3></a>
        <a href="/es/services/global-mobility" class="card reveal reveal-delay-2"><h3>Movilidad Global</h3></a>
        <a href="/es/services/crypto-web3" class="card reveal reveal-delay-3"><h3>Cripto y Web3</h3></a>
      </div>
    </div>
  </section>
</main>
</Base>
