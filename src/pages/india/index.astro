---
import Base from '../../layouts/Base.astro';

const speaksWith = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "ARM Management India — Cross-Border Advisory for Indian Founders, Investors & Businesses",
  description: "ARM Management provides cross-border business advisory for Indian nationals, NRIs, Indian founders, and Indian corporates expanding internationally — UAE company formation, Golden Visa, Singapore structures, EU expansion, and international compliance.",
  url: "https://arm-management.com/india",
  inLanguage: "en",
  about: [
    { "@type": "Thing", name: "UAE Golden Visa for Indians" },
    { "@type": "Thing", name: "UAE company formation for Indian nationals" },
    { "@type": "Thing", name: "Singapore company formation for Indians" },
    { "@type": "Thing", name: "India outbound investment advisory" },
    { "@type": "Thing", name: "NRI business advisory" },
    { "@type": "Country", name: "India" }
  ],
  audience: {
    "@type": "Audience",
    geographicArea: { "@type": "Country", name: "India" },
    audienceType: "Indian founders, NRIs, Indian HNIs, Indian corporates expanding internationally"
  }
};
---
<Base
  title="ARM Management India — UAE, Singapore & EU Advisory for Indian Founders & Investors"
  description="ARM Management advises Indian founders, NRIs, and Indian businesses on UAE company formation, UAE Golden Visa, Singapore structures, EU expansion, and international compliance. Senior-led, cross-border advisory for India's internationally ambitious."
  canonicalPath="/india"
>
  <main>
    <section class="page-hero">
      <div class="page-hero__bg" style="background-image:url('/images/ed-hero.jpg')"></div>
      <div class="page-hero__overlay"></div>
      <div class="page-hero__content container">
        <span class="eyebrow">India</span>
        <h1>Cross-Border Advisory for Indian Founders, Investors & Businesses</h1>
        <p>ARM Management advises Indian nationals, NRIs, and Indian corporates on building internationally — UAE, Singapore, EU, and beyond. Senior-led. Confidential. Done properly.</p>
        <div class="btn-row" style="justify-content:flex-start;margin-top:30px">
          <a href="/contact" class="btn-primary">Speak With a Senior Advisor →</a>
          <a href="/services" class="btn-secondary">Our Services</a>
        </div>
      </div>
    </section>

    <section class="section section--cream">
      <div class="container--narrow">
        <span class="eyebrow reveal">Who We Work With</span>
        <h2 class="reveal">Indian Founders, HNIs, and Businesses Going Global</h2>
        <div class="gold-rule reveal"></div>
        <p class="reveal">India produces some of the most internationally ambitious founders and investors in the world. ARM Management works with clients across three broad profiles:</p>
        <div class="grid-3" style="margin-top:40px">
          <div class="card reveal reveal-delay-1">
            <h3>Founders & Startups</h3>
            <p>Indian-origin founders building internationally — UAE or Singapore holdco structures, international fundraising, cross-border payroll and compliance as the team scales globally.</p>
          </div>
          <div class="card reveal reveal-delay-2">
            <h3>HNIs & Family Offices</h3>
            <p>Indian high-net-worth individuals and family offices investing internationally — UAE Golden Visa, Dubai property structuring, offshore holding companies, EU investment residency.</p>
          </div>
          <div class="card reveal reveal-delay-3">
            <h3>Indian Corporates</h3>
            <p>Established Indian businesses expanding internationally — UAE distribution entities, EU market entry, Singapore holding structures, and international payroll compliance.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section section--warm" style="border-top:1px solid #E2DDD6">
      <div class="container">
        <span class="eyebrow reveal">What We Advise On</span>
        <h2 class="reveal">Most Common Mandates from Indian Clients</h2>
        <div class="gold-rule reveal"></div>
        <div class="grid-3" style="margin-top:40px">
          <div class="card reveal reveal-delay-1">
            <h3><a href="/india/uae-golden-visa-for-indians" style="color:inherit;text-decoration:none">UAE Golden Visa →</a></h3>
            <p>10-year UAE residency for Indian investors, professionals, and entrepreneurs. Property route (AED 2M), salary route (AED 30k/month), and entrepreneur route. Indians are the #1 Golden Visa applicant group.</p>
          </div>
          <div class="card reveal reveal-delay-2">
            <h3><a href="/india/uae-company-formation-for-indians" style="color:inherit;text-decoration:none">UAE Company Formation →</a></h3>
            <p>Mainland LLC, DIFC, ADGM, or free zone — 100% Indian ownership, 9% corporate tax, zero personal tax. The startup flip structure for raising international capital.</p>
          </div>
          <div class="card reveal reveal-delay-3">
            <h3><a href="/india/singapore-company-formation-for-indians" style="color:inherit;text-decoration:none">Singapore Company →</a></h3>
            <p>Pte. Ltd. for Indian founders targeting APAC or raising from US/Asian VCs. 17% corporate tax (4% effective for startups). MAS licensing for fintech and Web3.</p>
          </div>
          <div class="card reveal reveal-delay-1">
            <h3>EU Expansion</h3>
            <p>Indian IT companies, software firms, and consultancies entering the EU — Netherlands BV, Germany GmbH, Ireland Ltd, or Belgium SPRL. Entity formation, VAT registration, EU employment law.</p>
          </div>
          <div class="card reveal reveal-delay-2">
            <h3>International Payroll</h3>
            <p>Multi-country payroll compliance for Indian companies with teams in UAE, Singapore, UK, and EU — employer of record, shadow payroll, assignment planning, and ESOP cross-border structuring.</p>
          </div>
          <div class="card reveal reveal-delay-3">
            <h3>EU Residency Programmes</h3>
            <p>Portugal D7/D8, Spain non-lucrative and digital nomad, Greece Golden Visa, Malta residency — EU long-term residence options for Indian nationals and families.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section section--navy">
      <div class="container--narrow">
        <span class="eyebrow reveal" style="color:#B8960C">Key Numbers</span>
        <h2 class="reveal" style="color:#F7F3EC">India — UAE — Singapore at a Glance</h2>
        <div class="gold-rule reveal"></div>
        <div style="margin-top:48px;display:grid;grid-template-columns:repeat(2,1fr);gap:32px">
          <div class="reveal reveal-delay-1" style="border-top:1px solid rgba(184,150,12,.3);padding-top:20px">
            <h4 style="font-family:'Inter',sans-serif;font-size:12px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:#B8960C;margin-bottom:10px">UAE Corporate Tax</h4>
            <p style="color:rgba(247,243,236,.65);font-size:15px;line-height:1.75">9% (0% below AED 375,000 / ~₹86 lakh). Compare: India 22–25% + surcharges.</p>
          </div>
          <div class="reveal reveal-delay-2" style="border-top:1px solid rgba(184,150,12,.3);padding-top:20px">
            <h4 style="font-family:'Inter',sans-serif;font-size:12px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:#B8960C;margin-bottom:10px">UAE Personal Income Tax</h4>
            <p style="color:rgba(247,243,236,.65);font-size:15px;line-height:1.75">0%. No personal income tax in the UAE. Compare: India up to 30% + surcharge.</p>
          </div>
          <div class="reveal reveal-delay-1" style="border-top:1px solid rgba(184,150,12,.3);padding-top:20px">
            <h4 style="font-family:'Inter',sans-serif;font-size:12px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:#B8960C;margin-bottom:10px">Golden Visa Investment</h4>
            <p style="color:rgba(247,243,236,.65);font-size:15px;line-height:1.75">AED 2 million (~₹4.6 crore) for property or capital route. Indians are the #1 recipient group.</p>
          </div>
          <div class="reveal reveal-delay-2" style="border-top:1px solid rgba(184,150,12,.3);padding-top:20px">
            <h4 style="font-family:'Inter',sans-serif;font-size:12px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:#B8960C;margin-bottom:10px">Singapore Startup Tax</h4>
            <p style="color:rgba(247,243,236,.65);font-size:15px;line-height:1.75">~4% effective for first SGD 100,000 income in first 3 years (partial exemption scheme). 17% standard rate.</p>
          </div>
          <div class="reveal reveal-delay-1" style="border-top:1px solid rgba(184,150,12,.3);padding-top:20px">
            <h4 style="font-family:'Inter',sans-serif;font-size:12px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:#B8960C;margin-bottom:10px">UAE Capital Gains Tax</h4>
            <p style="color:rgba(247,243,236,.65);font-size:15px;line-height:1.75">0%. No capital gains tax in the UAE. India: 10–20% LTCG / STCG on investment exits.</p>
          </div>
          <div class="reveal reveal-delay-2" style="border-top:1px solid rgba(184,150,12,.3);padding-top:20px">
            <h4 style="font-family:'Inter',sans-serif;font-size:12px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:#B8960C;margin-bottom:10px">ARM Jurisdictions</h4>
            <p style="color:rgba(247,243,236,.65);font-size:15px;line-height:1.75">46 jurisdictions covered. UAE, Singapore, Hong Kong, UK, EU (27 member states), and more.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section section--cream" style="border-top:1px solid #E2DDD6">
      <div class="container--narrow">
        <span class="eyebrow reveal">Guides for Indian Clients</span>
        <h2 class="reveal">Start Here</h2>
        <div class="gold-rule reveal"></div>
        <div style="margin-top:32px;display:grid;grid-template-columns:repeat(1,1fr);gap:16px">
          <a class="jdir__row reveal" href="/india/uae-golden-visa-for-indians" style="display:flex;justify-content:space-between;align-items:baseline;gap:10px;padding:16px 16px;border-radius:3px;border-left:2px solid transparent;text-decoration:none;transition:background .15s,border-color .15s;border:1px solid #E2DDD6">
            <span style="font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:500;color:#0D1B2A">UAE Golden Visa for Indian Nationals</span>
            <span style="font-size:12px;color:#6B7280;white-space:nowrap">Property · Salary · Entrepreneur routes</span>
          </a>
          <a class="jdir__row reveal" href="/india/uae-company-formation-for-indians" style="display:flex;justify-content:space-between;align-items:baseline;gap:10px;padding:16px 16px;border-radius:3px;border-left:2px solid transparent;text-decoration:none;transition:background .15s,border-color .15s;border:1px solid #E2DDD6">
            <span style="font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:500;color:#0D1B2A">UAE Company Formation for Indian Nationals</span>
            <span style="font-size:12px;color:#6B7280;white-space:nowrap">LLC · DIFC · ADGM · Free zones</span>
          </a>
          <a class="jdir__row reveal" href="/india/singapore-company-formation-for-indians" style="display:flex;justify-content:space-between;align-items:baseline;gap:10px;padding:16px 16px;border-radius:3px;border-left:2px solid transparent;text-decoration:none;transition:background .15s,border-color .15s;border:1px solid #E2DDD6">
            <span style="font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:500;color:#0D1B2A">Singapore Company Formation for Indian Nationals</span>
            <span style="font-size:12px;color:#6B7280;white-space:nowrap">Pte. Ltd. · MAS licensing · APAC</span>
          </a>
          <a class="jdir__row reveal" href="/insights/uae-golden-visa" style="display:flex;justify-content:space-between;align-items:baseline;gap:10px;padding:16px 16px;border-radius:3px;border-left:2px solid transparent;text-decoration:none;transition:background .15s,border-color .15s;border:1px solid #E2DDD6">
            <span style="font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:500;color:#0D1B2A">UAE Golden Visa — Full Guide</span>
            <span style="font-size:12px;color:#6B7280;white-space:nowrap">All categories · Thresholds · Process</span>
          </a>
          <a class="jdir__row reveal" href="/insights/uae-company-formation" style="display:flex;justify-content:space-between;align-items:baseline;gap:10px;padding:16px 16px;border-radius:3px;border-left:2px solid transparent;text-decoration:none;transition:background .15s,border-color .15s;border:1px solid #E2DDD6">
            <span style="font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:500;color:#0D1B2A">UAE Company Formation — Full Guide</span>
            <span style="font-size:12px;color:#6B7280;white-space:nowrap">Entity types · Tax · Licensing</span>
          </a>
        </div>
      </div>
    </section>

    <section class="cta-section">
      <h2 class="reveal">Speak with ARM Management.</h2>
      <p class="reveal">Whether you are an Indian founder setting up your first international entity, an HNI planning UAE residency, or a corporate expanding into Europe — ARM Management provides the senior-led advisory to get it done properly.</p>
      <div class="btn-row reveal">
        <a href="/contact" class="btn-primary">Schedule a Confidential Consultation →</a>
        <a href="/services" class="btn-secondary">Our Services</a>
      </div>
    </section>
  </main>

  <script type="application/ld+json" set:html={JSON.stringify(speaksWith)} />
</Base>
