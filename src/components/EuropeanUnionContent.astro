---
import PageWrapper from './PageWrapper.astro';
import { localePath } from '../i18n/translations';
import type { Locale } from '../i18n/translations';
interface Props { lang: Locale; }
const { lang } = Astro.props;
const lp = (p: string) => localePath(lang, p);
const isRTL = lang === 'ar';
const DATA: Record<string, any> = {"en": {"title": "European Union | ARM Management", "desc": "ARM Management advises across all 27 EU member states plus UK and Switzerland.", "eyebrow": "EU Region", "h1": "European Union", "hero": "All 27 EU member states plus UK and Switzerland.", "s2h": "ARM Management in European Union", "s2p1": "ARM Management has operated across the European Union since the firm's founding. We advise on company formation across all 27 member states plus the UK and Switzerland, coordinate VAT and corporate tax compliance, manage payroll across EU jurisdictions, and handle EU Golden Visa residency applications.", "s2p2": "Our Brussels office is our European hub, staffed by advisors with direct experience in EU regulatory affairs, market access strategy, and cross-border structuring across the Single Market.", "svcsEye": "Services in EU", "svcsH": "What ARM Management Does Here", "svcs": [["Company Formation", "All 27 EU member states. SE companies, holdings, branches, VAT registration, and registered office services."], ["Accounting & Tax", "VAT OSS, corporate tax, statutory accounts, IFRS, and audit coordination across EU jurisdictions."], ["Payroll & HR", "EU employment law, social security coordination, posted worker rules, and cross-border workforce management."], ["Transaction Advisory", "EU M&A, private equity, and joint ventures. Foreign investment screening and regulatory compliance."], ["Global Mobility", "Portugal, Spain, Greece, Malta Golden Visa programmes. EU Blue Card and national skilled worker visas."], ["Crypto & Web3", "MiCA CASP authorisation across EU member states. Passporting and ongoing EU regulatory compliance."]]}, "fr": {"title": "Union européenne | ARM Management", "desc": "ARM Management conseille dans les 27 États membres de l'UE plus le Royaume-Uni et la Suisse.", "eyebrow": "Région UE", "h1": "Union européenne", "hero": "Les 27 États membres de l'UE plus le Royaume-Uni et la Suisse.", "s2h": "ARM Management dans l'Union européenne", "s2p1": "ARM Management opère dans l'Union européenne depuis sa création. Nous conseillons sur la création de sociétés dans les 27 États membres ainsi qu'au Royaume-Uni et en Suisse, coordonnons la conformité TVA et fiscale, gérons la paie dans les juridictions européennes et traitons les demandes de résidence du Visa doré européen.", "s2p2": "Notre bureau de Bruxelles est notre hub européen, avec des conseillers ayant une expérience directe en affaires réglementaires européennes.", "svcsEye": "Services dans l'UE", "svcsH": "Ce qu'ARM Management fait ici", "svcs": [["Création de sociétés", "Les 27 États membres. Sociétés SE, holdings, succursales, TVA et siège social."], ["Comptabilité & Fiscalité", "TVA OSS, impôt sur les sociétés, comptes statutaires, IFRS et coordination d'audit."], ["Paie & RH", "Droit du travail européen, sécurité sociale, règles sur les travailleurs détachés."], ["Conseil en transactions", "M&A, private equity et joint-ventures. Filtrage des investissements étrangers."], ["Mobilité internationale", "Portugal, Espagne, Grèce, Malte — visa doré. Carte Bleue UE et visas nationaux."], ["Crypto & Web3", "Autorisation CASP MiCA dans les États membres. Passeportisation et conformité continue."]]}, "es": {"title": "Unión Europea | ARM Management", "desc": "ARM Management asesora en los 27 Estados miembros de la UE más Reino Unido y Suiza.", "eyebrow": "Región UE", "h1": "Unión Europea", "hero": "Los 27 Estados miembros de la UE más Reino Unido y Suiza.", "s2h": "ARM Management en la Unión Europea", "s2p1": "ARM Management ha operado en la Unión Europea desde la fundación de la firma. Asesoramos sobre constitución de sociedades en los 27 Estados miembros más el Reino Unido y Suiza, coordinamos el cumplimiento del IVA e impuesto de sociedades, y gestionamos solicitudes de residencia de visa dorada.", "s2p2": "Nuestra oficina de Bruselas es nuestro hub europeo, con asesores con experiencia directa en asuntos regulatorios europeos.", "svcsEye": "Servicios en la UE", "svcsH": "Lo que hace ARM Management aquí", "svcs": [["Constitución de sociedades", "Los 27 Estados miembros. SE, holdings, sucursales, IVA y domicilio social."], ["Contabilidad & Impuestos", "IVA OSS, impuesto de sociedades, cuentas estatutarias, NIIF y auditoría."], ["Nómina & RRHH", "Derecho laboral europeo, seguridad social, trabajadores desplazados."], ["Asesoría en Transacciones", "M&A, private equity y joint ventures. Revisión de inversiones extranjeras UE."], ["Movilidad Global", "Portugal, España, Grecia, Malta — visa dorada. Tarjeta Azul UE y visados nacionales."], ["Crypto & Web3", "Autorización CASP MiCA en Estados miembros. Pasaportización y cumplimiento continuo."]]}, "ar": {"title": "الاتحاد الأوروبي | ARM Management", "desc": "تقدّم ARM Management المشورة في جميع الدول الأعضاء الـ27 في الاتحاد الأوروبي إضافةً إلى المملكة المتحدة وسويسرا.", "eyebrow": "منطقة الاتحاد الأوروبي", "h1": "الاتحاد الأوروبي", "hero": "جميع الدول الأعضاء الـ27 في الاتحاد الأوروبي إضافةً إلى المملكة المتحدة وسويسرا.", "s2h": "ARM Management في الاتحاد الأوروبي", "s2p1": "تعمل ARM Management عبر الاتحاد الأوروبي منذ تأسيسها. نقدّم المشورة بشأن تأسيس الشركات في جميع الدول الأعضاء الـ27 إضافةً إلى المملكة المتحدة وسويسرا، وننسّق الامتثال الضريبي وضريبة القيمة المضافة، وندير الرواتب في الولايات القضائية الأوروبية.", "s2p2": "يُعدّ مكتبنا في بروكسل مركزنا الأوروبي، بمستشارين ذوي خبرة مباشرة في الشؤون التنظيمية الأوروبية.", "svcsEye": "الخدمات في الاتحاد الأوروبي", "svcsH": "ما تفعله ARM Management هنا", "svcs": [["تأسيس الشركات", "الدول الأعضاء الـ27. شركات SE والهياكل القابضة والفروع وضريبة القيمة المضافة والمكاتب المسجّلة."], ["المحاسبة والضرائب", "ضريبة القيمة المضافة OSS وضريبة الشركات والحسابات القانونية ومعايير IFRS وتنسيق المراجعة."], ["الرواتب والموارد البشرية", "قانون العمل الأوروبي وتنسيق الضمان الاجتماعي وقواعد العمال المنقولين."], ["استشارات المعاملات", "الاندماجات والاستحواذات والأسهم الخاصة والمشاريع المشتركة. فحص الاستثمار الأجنبي."], ["التنقل الدولي", "التأشيرة الذهبية — البرتغال وإسبانيا واليونان ومالطا. البطاقة الزرقاء الأوروبية."], ["العملات الرقمية وWeb3", "ترخيص CASP وفق MiCA في الدول الأعضاء. التجوازية والامتثال التنظيمي المستمر."]]}, "ru": {"title": "Европейский союз | ARM Management", "desc": "ARM Management консультирует во всех 27 государствах-членах ЕС, а также в Великобритании и Швейцарии.", "eyebrow": "Регион ЕС", "h1": "Европейский союз", "hero": "Все 27 государств-членов ЕС, а также Великобритания и Швейцария.", "s2h": "ARM Management в Европейском союзе", "s2p1": "ARM Management работает в Европейском союзе с момента основания. Мы консультируем по регистрации компаний во всех 27 государствах-членах, а также в Великобритании и Швейцарии, координируем НДС и корпоративный комплаенс, управляем расчётом зарплат и сопровождаем заявки на резидентство по Золотой визе.", "s2p2": "Наш офис в Брюсселе — европейский хаб с консультантами, имеющими непосредственный опыт в EU-регулировании.", "svcsEye": "Услуги в ЕС", "svcsH": "Что ARM Management делает здесь", "svcs": [["Регистрация компаний", "Все 27 государств-членов. SE-компании, холдинги, филиалы, НДС и юридический адрес."], ["Учёт и налоги", "НДС OSS, корпоративный налог, установленная отчётность, МСФО и координация аудита."], ["Расчёт зарплат и HR", "Трудовое право ЕС, социальное обеспечение, правила командированных работников."], ["Транзакционный консалтинг", "M&A, прямые инвестиции и СП в ЕС. Проверка иностранных инвестиций."], ["Международная мобильность", "Золотая виза — Португалия, Испания, Греция, Мальта. Голубая карта ЕС."], ["Крипто и Web3", "Авторизация CASP по MiCA в государствах-членах. Паспортизация и текущий комплаенс."]]}, "zh": {"title": "欧盟 | ARM Management", "desc": "ARM Management在欧盟全部27个成员国及英国、瑞士提供咨询服务。", "eyebrow": "欧盟地区", "h1": "欧盟", "hero": "欧盟全部27个成员国及英国、瑞士。", "s2h": "ARM Management在欧盟", "s2p1": "ARM Management自创立以来一直在欧盟全境运营。我们在全部27个成员国及英国和瑞士提供公司注册咨询，协调增值税和企业所得税合规，管理欧盟司法管辖区薪酬事务，并处理欧盟黄金签证居留申请。", "s2p2": "我们的布鲁塞尔办公室是欧洲业务中心，顾问团队在欧盟监管事务方面具有丰富的直接经验。", "svcsEye": "欧盟服务", "svcsH": "ARM Management在此的服务", "svcs": [["公司注册", "欧盟全部27个成员国。SE公司、控股架构、分支机构、增值税登记及注册办公地址。"], ["会计与税务", "增值税OSS、企业税、法定账户、国际财务报告准则及各司法管辖区审计协调。"], ["薪酬与人力资源", "欧盟劳动法、社会保障协调、外派工人规则及跨境劳动力管理。"], ["交易咨询", "欧盟并购、私募股权和合资企业。外商投资审查及监管合规。"], ["全球移民", "葡萄牙、西班牙、希腊、马耳他黄金签证项目。欧盟蓝卡及国家签证。"], ["加密货币与Web3", "欧盟成员国MiCA CASP授权。通行权及持续欧盟合规。"]]}};
const c = DATA[lang];
---
<PageWrapper lang={lang} title={c.title} description={c.desc} canonicalPath="/regions/european-union">
<main dir={isRTL ? 'rtl' : 'ltr'}>
  <section class="page-hero">
    <div class="page-hero__bg" style="background-image:url('https://images.unsplash.com/photo-1467269204594-9661b134dd2b?w=1600&q=80&auto=format&fit=crop')"></div>
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content container">
      <span class="eyebrow">{c.eyebrow}</span>
      <h1>{c.h1}</h1>
      <p>{c.hero}</p>
    </div>
  </section>
  <section class="section section--cream">
    <div class="container--narrow">
      <h2 class="reveal">{c.s2h}</h2>
      <div class="gold-rule reveal"></div>
      <p class="reveal">{c.s2p1}</p>
      <p class="reveal" style="margin-top:20px">{c.s2p2}</p>
    </div>
  </section>
  <section class="section section--warm" style="border-top:1px solid #E2DDD6">
    <div class="container">
      <span class="eyebrow reveal">{c.svcsEye}</span>
      <h2 class="reveal">{c.svcsH}</h2>
      <div class="gold-rule reveal"></div>
      <div class="grid-3" style="margin-top:40px">
        {c.svcs.map(([sh, sp]: [string,string], i: number) => (
          <div class={`card reveal reveal-delay-${(i%3)+1}`}><h3>{sh}</h3><p>{sp}</p></div>
        ))}
      </div>
    </div>
  </section>
  <section class="cta-section">
    <h2 class="reveal">{c.ctaH}</h2>
    <p class="reveal reveal-delay-1">{c.ctaP}</p>
    <div class="btn-row reveal reveal-delay-2">
      <a href={lp('/contact')} class="btn-primary">{c.ctaBtn}</a>
      <a href={lp('/services')} class="btn-secondary">{c.btn2}</a>
    </div>
  </section>
</main>
</PageWrapper>
