---
import PageWrapper from './PageWrapper.astro';
import { localePath } from '../i18n/translations';
import type { Locale } from '../i18n/translations';
interface Props { lang: Locale; }
const { lang } = Astro.props;
const lp = (p: string) => localePath(lang, p);
const isRTL = lang === 'ar';
const DATA: Record<string, any> = {"en": {"title": "Accounting, Tax & Compliance | ARM Management", "desc": "Monthly bookkeeping, VAT returns, corporate tax filings, and statutory accounts across multiple jurisdictions.", "eye": "Accounting & Tax", "h1": "Accounting, Tax &\nMonthly Compliance", "hero": "One relationship. All jurisdictions. Every deadline met.", "whatEye": "What We Do", "whatH": "A Single Relationship Across Every Jurisdiction", "whatP1": "Managing accounting and tax compliance across multiple jurisdictions is one of the most operationally demanding aspects of running an international business. Deadlines, reporting formats, VAT regimes, and audit requirements vary dramatically — and the consequences of missed filings extend beyond penalties to damaged banking relationships and regulatory standing.", "whatP2": "ARM Management offers a single relationship: one senior contact who coordinates local accountants and tax advisors across all your jurisdictions, ensures nothing is missed, and translates compliance requirements into actionable management information.", "svcEye": "Our Services", "svcH": "What We Handle", "svcs": [["Monthly Bookkeeping", "Full-cycle bookkeeping across all operating jurisdictions, coded to your management reporting requirements and delivered on a consistent monthly schedule."], ["VAT & Indirect Tax Returns", "Preparation and filing of VAT, GST, and other indirect tax returns across jurisdictions, including reconciliations and supporting documentation."], ["Corporate Tax Filings", "Annual corporate income tax filings, computations, and supporting schedules prepared in compliance with local rules and coordinated with your advisors."], ["Financial Statements", "Statutory financial statements prepared in accordance with local GAAP or IFRS, coordinated with local auditors where required."], ["Payroll Tax Compliance", "Employer payroll tax withholding, social security contributions, and related filings across multiple employment jurisdictions."], ["Tax Advisory", "Ongoing tax advisory on cross-border structures, transfer pricing, permanent establishment risk, and tax efficiency across your operating footprint."]], "ctaH": "Discuss Your Compliance Requirements", "ctaP": "Tell us which jurisdictions you operate in and we will give you a clear picture of what needs to be filed, by when, and at what cost.", "ctaBtn": "Schedule a Consultation →", "btn2": "Our Services"}, "fr": {"title": "Comptabilité, Fiscalité & Conformité | ARM Management", "desc": "Tenue de comptes mensuelle, TVA, déclarations fiscales et comptes annuels dans plusieurs juridictions.", "eye": "Comptabilité & Fiscalité", "h1": "Comptabilité, Fiscalité\net Conformité", "hero": "Une seule relation. Toutes les juridictions. Chaque échéance respectée.", "whatEye": "Ce que nous faisons", "whatH": "Une relation unique dans chaque juridiction", "whatP1": "Gérer la comptabilité et la conformité fiscale dans plusieurs juridictions est l'un des aspects les plus exigeants opérationnellement de la gestion d'une entreprise internationale. Les délais, formats de reporting, régimes TVA et exigences d'audit varient considérablement — et les conséquences des dépôts manqués dépassent les pénalités.", "whatP2": "ARM Management offre une relation unique : un interlocuteur senior qui coordonne les comptables et conseillers fiscaux locaux dans toutes vos juridictions, s'assure que rien n'est manqué, et traduit les exigences de conformité en informations de gestion exploitables.", "svcEye": "Nos services", "svcH": "Ce que nous gérons", "svcs": [["Tenue de comptes mensuelle", "Comptabilité à cycle complet dans toutes les juridictions d'exploitation, codée selon vos exigences de reporting de gestion et livrée mensuellement."], ["Déclarations TVA & taxes indirectes", "Préparation et dépôt des déclarations de TVA, TPS et autres taxes indirectes dans les juridictions, incluant les réconciliations et la documentation justificative."], ["Déclarations d'impôt sur les sociétés", "Déclarations annuelles d'impôt sur les sociétés, calculs et annexes préparés en conformité avec les règles locales."], ["États financiers", "États financiers statutaires préparés conformément aux GAAP locaux ou aux IFRS, coordonnés avec les auditeurs locaux le cas échéant."], ["Conformité fiscale de la paie", "Retenue à la source sur les salaires, cotisations sociales et déclarations connexes dans plusieurs juridictions d'emploi."], ["Conseil fiscal", "Conseil fiscal continu sur les structures transfrontalières, prix de transfert, risque d'établissement stable et efficacité fiscale."]], "ctaH": "Discutez de vos exigences de conformité", "ctaP": "Dites-nous dans quelles juridictions vous opérez et nous vous donnerons une image claire de ce qui doit être déposé, quand et à quel coût.", "ctaBtn": "Planifier une consultation →", "btn2": "Nos services"}, "es": {"title": "Contabilidad, Impuestos y Cumplimiento | ARM Management", "desc": "Contabilidad mensual, declaraciones de IVA, declaraciones fiscales y cuentas estatutarias en múltiples jurisdicciones.", "eye": "Contabilidad & Impuestos", "h1": "Contabilidad, Impuestos\ny Cumplimiento", "hero": "Una relación. Todas las jurisdicciones. Cada plazo cumplido.", "whatEye": "Lo que hacemos", "whatH": "Una única relación en cada jurisdicción", "whatP1": "Gestionar la contabilidad y el cumplimiento fiscal en múltiples jurisdicciones es uno de los aspectos operativamente más exigentes de gestionar un negocio internacional. Los plazos, formatos de informes, regímenes de IVA y requisitos de auditoría varían enormemente.", "whatP2": "ARM Management ofrece una única relación: un contacto senior que coordina a los contadores y asesores fiscales locales en todas sus jurisdicciones, garantizando que nada se omita.", "svcEye": "Nuestros servicios", "svcH": "Lo que gestionamos", "svcs": [["Contabilidad mensual", "Contabilidad de ciclo completo en todas las jurisdicciones operativas, codificada según sus requisitos de informes de gestión y entregada mensualmente."], ["Declaraciones de IVA e impuestos indirectos", "Preparación y presentación de declaraciones de IVA y otros impuestos indirectos en todas las jurisdicciones, incluyendo conciliaciones y documentación de respaldo."], ["Declaraciones de impuesto de sociedades", "Declaraciones anuales de impuesto de sociedades, cálculos y cuadros de apoyo preparados conforme a las normas locales."], ["Estados financieros", "Estados financieros estatutarios preparados de acuerdo con GAAP local o NIIF, coordinados con auditores locales cuando sea necesario."], ["Cumplimiento fiscal de nómina", "Retención de impuestos de empleadores, cotizaciones a la seguridad social y declaraciones relacionadas en múltiples jurisdicciones de empleo."], ["Asesoría fiscal", "Asesoría fiscal continua sobre estructuras transfronterizas, precios de transferencia, riesgo de establecimiento permanente y eficiencia fiscal."]], "ctaH": "Discuta sus requisitos de cumplimiento", "ctaP": "Díganos en qué jurisdicciones opera y le daremos una imagen clara de qué debe presentarse, cuándo y a qué costo.", "ctaBtn": "Programar una consulta →", "btn2": "Nuestros servicios"}, "ar": {"title": "المحاسبة والضرائب والامتثال | ARM Management", "desc": "مسك الدفاتر الشهري، وإقرارات ضريبة القيمة المضافة، والإقرارات الضريبية، والحسابات القانونية عبر ولايات قضائية متعددة.", "eye": "المحاسبة والضرائب", "h1": "المحاسبة والضرائب\nوالامتثال الشهري", "hero": "علاقة واحدة. جميع الولايات القضائية. كل موعد نهائي محترَم.", "whatEye": "ما نقدّمه", "whatH": "علاقة واحدة عبر كل ولاية قضائية", "whatP1": "إدارة المحاسبة والامتثال الضريبي عبر ولايات قضائية متعددة هي من أكثر جوانب إدارة الأعمال الدولية تطلباً. تتباين المواعيد النهائية وصيغ الإبلاغ وأنظمة ضريبة القيمة المضافة ومتطلبات المراجعة بشكل كبير.", "whatP2": "تقدّم ARM Management علاقة واحدة: جهة تواصل كبيرة واحدة تنسّق المحاسبين والمستشارين الضريبيين المحليين في جميع ولاياتك القضائية، وتضمن عدم تفويت أي شيء.", "svcEye": "خدماتنا", "svcH": "ما ندير", "svcs": [["مسك الدفاتر الشهري", "محاسبة كاملة الدورة عبر جميع ولايات قضائية التشغيل، مرمّزة وفق متطلبات تقارير إدارتك ومُسلَّمة بجدول شهري ثابت."], ["إقرارات ضريبة القيمة المضافة والضرائب غير المباشرة", "إعداد وتقديم إقرارات ضريبة القيمة المضافة والضرائب غير المباشرة الأخرى عبر الولايات القضائية."], ["إقرارات ضريبة الشركات", "إقرارات ضريبة الشركات السنوية والحسابات والجداول الداعمة المُعدَّة وفقاً للقواعد المحلية."], ["البيانات المالية", "البيانات المالية القانونية المُعدَّة وفقاً للمعايير المحلية أو IFRS، منسّقة مع المراجعين المحليين عند الحاجة."], ["الامتثال الضريبي للرواتب", "استقطاع الضرائب على الرواتب واشتراكات الضمان الاجتماعي والإقرارات ذات الصلة عبر ولايات قضائية التوظيف المتعددة."], ["الاستشارة الضريبية", "استشارة ضريبية مستمرة حول الهياكل العابرة للحدود وأسعار التحويل ومخاطر المنشأة الدائمة والكفاءة الضريبية."]], "ctaH": "ناقش متطلبات امتثالك", "ctaP": "أخبرنا في أي ولايات قضائية تعمل وسنمنحك صورة واضحة عمّا يجب تقديمه ومتى وبأي تكلفة.", "ctaBtn": "جدوِّل استشارة ←", "btn2": "خدماتنا"}, "ru": {"title": "Бухучёт, налоги и комплаенс | ARM Management", "desc": "Ежемесячное ведение учёта, НДС, налоговые декларации и годовая отчётность в нескольких юрисдикциях.", "eye": "Учёт и налоги", "h1": "Бухучёт, налоги\nи комплаенс", "hero": "Один контакт. Все юрисдикции. Все сроки соблюдены.", "whatEye": "Что мы делаем", "whatH": "Один контакт в каждой юрисдикции", "whatP1": "Управление бухгалтерским учётом и налоговым комплаенс в нескольких юрисдикциях — один из наиболее операционно сложных аспектов международного бизнеса. Сроки, форматы отчётности, режимы НДС и требования к аудиту существенно различаются.", "whatP2": "ARM Management предлагает единый контакт: один старший куратор координирует местных бухгалтеров и налоговых консультантов во всех ваших юрисдикциях, гарантируя, что ничего не будет упущено.", "svcEye": "Услуги", "svcH": "Что мы ведём", "svcs": [["Ежемесячное ведение учёта", "Полный цикл бухгалтерского учёта во всех операционных юрисдикциях, закодированный под ваши управленческие отчёты и предоставляемый ежемесячно."], ["НДС и косвенные налоги", "Подготовка и подача деклараций НДС и других косвенных налогов по юрисдикциям."], ["Налоговые декларации", "Ежегодные декларации по налогу на прибыль, расчёты и вспомогательные таблицы в соответствии с местными правилами."], ["Финансовая отчётность", "Установленная финансовая отчётность в соответствии с местными GAAP или МСФО, координируемая с местными аудиторами."], ["Налоговый комплаенс по зарплатам", "Налоговые удержания работодателя, взносы на социальное страхование и связанные подачи в нескольких юрисдикциях."], ["Налоговое консультирование", "Текущее налоговое консультирование по трансграничным структурам, трансфертному ценообразованию и налоговой эффективности."]], "ctaH": "Обсудите требования комплаенс", "ctaP": "Расскажите нам, в каких юрисдикциях вы работаете, и мы дадим чёткую картину того, что нужно подавать, когда и по какой цене.", "ctaBtn": "Записаться на консультацию →", "btn2": "Наши услуги"}, "zh": {"title": "会计、税务与合规 | ARM Management", "desc": "在多个司法管辖区提供月度记账、增值税申报、企业所得税申报及年度财务报告服务。", "eye": "会计与税务", "h1": "会计、税务\n与月度合规", "hero": "一个联络人。所有司法管辖区。每个截止日期均按时完成。", "whatEye": "我们的服务内容", "whatH": "覆盖每个司法管辖区的单一关系", "whatP1": "在多个司法管辖区管理会计和税务合规是运营国际业务最具挑战性的方面之一。截止日期、报告格式、增值税制度和审计要求差异巨大。", "whatP2": "ARM Management提供单一联络关系：一位资深联络人协调您所有司法管辖区的当地会计师和税务顾问，确保无遗漏。", "svcEye": "服务", "svcH": "我们处理的内容", "svcs": [["月度记账", "覆盖所有运营司法管辖区的完整记账，按您的管理报告要求编码，每月定期交付。"], ["增值税及间接税申报", "在各司法管辖区准备和申报增值税及其他间接税，包括对账和支持文件。"], ["企业所得税申报", "按当地规则准备的年度企业所得税申报、计算及附表。"], ["财务报表", "按当地公认会计准则或国际财务报告准则编制的法定财务报表，必要时与当地审计师协调。"], ["薪酬税务合规", "雇主薪酬税预扣、社会保险缴纳及多个雇用司法管辖区的相关申报。"], ["税务咨询", "关于跨境架构、转让定价、常设机构风险和税务效率的持续税务咨询。"]], "ctaH": "讨论您的合规要求", "ctaP": "告诉我们您在哪些司法管辖区运营，我们将提供关于需要申报什么、何时申报及成本的清晰说明。", "ctaBtn": "预约咨询 →", "btn2": "我们的服务"}};
const c = DATA[lang];
---
<PageWrapper lang={lang} title={c.title} description={c.desc} canonicalPath="/services/accounting-tax">
<main dir={isRTL ? 'rtl' : 'ltr'}>
  <section class="page-hero">
    <div class="page-hero__bg" style="background-image:url('https://images.unsplash.com/photo-1554224154-26032ffc0d07?w=1600&q=80&auto=format&fit=crop')"></div>
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content container">
      <span class="eyebrow">{c.eye}</span>
      <h1 set:html={c.h1.replace('\n','<br>')}></h1>
      <p>{c.hero}</p>
      <div class="btn-row" style="justify-content:flex-start;margin-top:30px">
        <a href={lp('/contact')} class="btn-primary">{c.ctaBtn}</a>
        <a href={lp('/services')} class="btn-secondary">{c.btn2}</a>
      </div>
    </div>
  </section>
  <section class="section section--cream">
    <div class="container--narrow">
      <span class="eyebrow reveal">{c.whatEye}</span>
      <h2 class="reveal">{c.whatH}</h2>
      <div class="gold-rule reveal"></div>
      <p class="reveal">{c.whatP1}</p>
      <p class="reveal" style="margin-top:20px">{c.whatP2}</p>
    </div>
  </section>
  <section class="section section--warm" style="border-top:1px solid #E2DDD6">
    <div class="container">
      <span class="eyebrow reveal">{c.svcEye}</span>
      <h2 class="reveal">{c.svcH}</h2>
      <div class="gold-rule reveal"></div>
      <div class="grid-3" style="margin-top:40px">
        {c.svcs.map(([h, p]: [string,string], i: number) => (
          <div class={`card reveal reveal-delay-${(i%3)+1}`}><h3>{h}</h3><p>{p}</p></div>
        ))}
      </div>
    </div>
  </section>
  <section class="cta-section">
    <h2 class="reveal">{c.ctaH}</h2>
    <p class="reveal reveal-delay-1">{c.ctaP}</p>
    <div class="btn-row reveal reveal-delay-2">
      <a href={lp('/contact')} class="btn-primary">{c.ctaBtn}</a>
    </div>
  </section>
</main>
</PageWrapper>
