---
import PageWrapper from './PageWrapper.astro';
import { localePath } from '../i18n/translations';
import type { Locale } from '../i18n/translations';
interface Props { lang: Locale; }
const { lang } = Astro.props;
const lp = (p: string) => localePath(lang, p);
const isRTL = lang === 'ar';
const DATA: Record<string, any> = {"en": {"title": "Accounting, Tax & Compliance | ARM Management", "desc": "Monthly bookkeeping, VAT returns, corporate tax filings, and statutory accounts across multiple jurisdictions.", "eye": "Accounting & Tax", "h1": "Accounting, Tax &\nMonthly Compliance", "hero": "One relationship. All jurisdictions. Every deadline met.", "whatEye": "What We Do", "whatH": "A Single Relationship Across Every Jurisdiction", "whatP1": "Managing accounting and tax compliance across multiple jurisdictions is one of the most operationally demanding aspects of running an international business. Deadlines, reporting formats, VAT regimes, and audit requirements vary dramatically — and the consequences of missed filings extend beyond penalties to damaged banking relationships and regulatory standing.", "whatP2": "ARM Management offers a single relationship: one senior contact who coordinates local accountants and tax advisors across all your jurisdictions, ensures nothing is missed, and translates compliance requirements into actionable management information.", "svcEye": "Our Services", "svcH": "What We Handle", "svcs": [["Monthly Bookkeeping", "Full-cycle bookkeeping across all operating jurisdictions, coded to your management reporting requirements and delivered on a consistent monthly schedule."], ["VAT & Indirect Tax Returns", "Preparation and filing of VAT, GST, and other indirect tax returns across jurisdictions, including reconciliations and supporting documentation."], ["Corporate Tax Filings", "Annual corporate income tax filings, computations, and supporting schedules prepared in compliance with local rules and coordinated with your advisors."], ["Financial Statements", "Statutory financial statements prepared in accordance with local GAAP or IFRS, coordinated with local auditors where required."], ["Payroll Tax Compliance", "Employer payroll tax withholding, social security contributions, and related filings across multiple employment jurisdictions."], ["Tax Advisory", "Ongoing tax advisory on cross-border structures, transfer pricing, permanent establishment risk, and tax efficiency across your operating footprint."]], "ctaH": "Discuss Your Compliance Requirements", "ctaP": "Tell us which jurisdictions you operate in and we will give you a clear picture of what needs to be filed, by when, and at what cost.", "ctaBtn": "Schedule a Consultation →", "btn2": "Our Services", "apprEye": "The ARM Approach", "apprH": "Compliance Without the Complexity.", "apprP": "Most accounting firms are organised by country. You engage a firm in each jurisdiction, manage multiple relationships, reconcile conflicting advice, and still risk gaps between entities. ARM Management reverses this model: one senior advisor holds the complete picture of your group structure and coordinates all local professionals on your behalf.", "principles": [["Deadline Ownership", "We track every filing deadline across every jurisdiction you operate in. You will not discover a missed VAT return from a penalty notice."], ["Local Expertise, Central Coordination", "We work with vetted local accountants and tax advisors in each jurisdiction — selected for track record — coordinated through a single ARM relationship."], ["Management Reporting", "Compliance output is translated into actionable management information — consolidated group reporting, entity-level P&L, and cash flow visibility."], ["Audit Coordination", "When local audits arise, ARM coordinates the process with local auditors on your behalf, minimising disruption to your operations."]], "jurEye": "Jurisdictions", "jurH": "Where We File", "regions": [["European Union", "All 27 member states plus UK and Switzerland. VAT OSS, corporate tax, statutory accounts, IFRS and local GAAP."], ["GCC & Middle East", "UAE corporate tax, VAT registration and returns, free zone and mainland compliance. Saudi Arabia, Qatar, Bahrain."], ["Asia Pacific", "Singapore GST and corporate tax, Hong Kong profits tax, Malaysia, India, Vietnam, and other APAC jurisdictions."], ["Latin America", "Mexico, Colombia, Brazil, Chile, Panama, and Uruguay. Local GAAP, transfer pricing, and tax compliance."]]}, "fr": {"title": "Comptabilité, Fiscalité & Conformité | ARM Management", "desc": "Tenue de comptes mensuelle, TVA, déclarations fiscales et comptes annuels dans plusieurs juridictions.", "eye": "Comptabilité & Fiscalité", "h1": "Comptabilité, Fiscalité\net Conformité", "hero": "Une seule relation. Toutes les juridictions. Chaque échéance respectée.", "whatEye": "Ce que nous faisons", "whatH": "Une relation unique dans chaque juridiction", "whatP1": "Gérer la comptabilité et la conformité fiscale dans plusieurs juridictions est l'un des aspects les plus exigeants opérationnellement de la gestion d'une entreprise internationale. Les délais, formats de reporting, régimes TVA et exigences d'audit varient considérablement — et les conséquences des dépôts manqués dépassent les pénalités.", "whatP2": "ARM Management offre une relation unique : un interlocuteur senior qui coordonne les comptables et conseillers fiscaux locaux dans toutes vos juridictions, s'assure que rien n'est manqué, et traduit les exigences de conformité en informations de gestion exploitables.", "svcEye": "Nos services", "svcH": "Ce que nous gérons", "svcs": [["Tenue de comptes mensuelle", "Comptabilité à cycle complet dans toutes les juridictions d'exploitation, codée selon vos exigences de reporting de gestion et livrée mensuellement."], ["Déclarations TVA & taxes indirectes", "Préparation et dépôt des déclarations de TVA, TPS et autres taxes indirectes dans les juridictions, incluant les réconciliations et la documentation justificative."], ["Déclarations d'impôt sur les sociétés", "Déclarations annuelles d'impôt sur les sociétés, calculs et annexes préparés en conformité avec les règles locales."], ["États financiers", "États financiers statutaires préparés conformément aux GAAP locaux ou aux IFRS, coordonnés avec les auditeurs locaux le cas échéant."], ["Conformité fiscale de la paie", "Retenue à la source sur les salaires, cotisations sociales et déclarations connexes dans plusieurs juridictions d'emploi."], ["Conseil fiscal", "Conseil fiscal continu sur les structures transfrontalières, prix de transfert, risque d'établissement stable et efficacité fiscale."]], "ctaH": "Discutez de vos exigences de conformité", "ctaP": "Dites-nous dans quelles juridictions vous opérez et nous vous donnerons une image claire de ce qui doit être déposé, quand et à quel coût.", "ctaBtn": "Planifier une consultation →", "btn2": "Nos services", "apprEye": "L'approche ARM", "apprH": "La conformité sans la complexité.", "apprP": "La plupart des cabinets comptables sont organisés par pays. Vous engagez un cabinet dans chaque juridiction, gérez de multiples relations, réconciliez des conseils contradictoires, et risquez toujours des lacunes entre entités. ARM Management inverse ce modèle : un conseiller senior détient la vue complète de votre structure de groupe et coordonne tous les professionnels locaux en votre nom.", "principles": [["Responsabilité des délais", "Nous suivons chaque délai de dépôt dans toutes les juridictions où vous opérez. Vous ne découvrirez pas un retard de TVA via une pénalité."], ["Expertise locale, coordination centrale", "Nous travaillons avec des comptables et conseillers fiscaux locaux vérifiés dans chaque juridiction — coordonnés via une relation ARM unique."], ["Reporting de gestion", "Les résultats de conformité sont traduits en informations de gestion exploitables — reporting consolidé du groupe, P&L par entité, visibilité sur les flux de trésorerie."], ["Coordination d'audit", "Lors d'audits locaux, ARM coordonne le processus avec les auditeurs locaux en votre nom, minimisant les perturbations de vos opérations."]], "jurEye": "Juridictions", "jurH": "Où nous déposons", "regions": [["Union européenne", "Les 27 États membres plus le Royaume-Uni et la Suisse. TVA OSS, impôt sur les sociétés, comptes statutaires, IFRS et GAAP locaux."], ["CCG & Moyen-Orient", "Impôt sur les sociétés des EAU, enregistrement et déclarations TVA, conformité en zone franche et continentale. Arabie Saoudite, Qatar, Bahreïn."], ["Asie-Pacifique", "TPS et impôt sur les sociétés à Singapour, taxe sur les bénéfices à Hong Kong, Malaisie, Inde, Vietnam et autres juridictions APAC."], ["Amérique latine", "Mexique, Colombie, Brésil, Chili, Panama et Uruguay. GAAP local, prix de transfert et conformité fiscale."]]}, "es": {"title": "Contabilidad, Impuestos y Cumplimiento | ARM Management", "desc": "Contabilidad mensual, declaraciones de IVA, declaraciones fiscales y cuentas estatutarias en múltiples jurisdicciones.", "eye": "Contabilidad & Impuestos", "h1": "Contabilidad, Impuestos\ny Cumplimiento", "hero": "Una relación. Todas las jurisdicciones. Cada plazo cumplido.", "whatEye": "Lo que hacemos", "whatH": "Una única relación en cada jurisdicción", "whatP1": "Gestionar la contabilidad y el cumplimiento fiscal en múltiples jurisdicciones es uno de los aspectos operativamente más exigentes de gestionar un negocio internacional. Los plazos, formatos de informes, regímenes de IVA y requisitos de auditoría varían enormemente.", "whatP2": "ARM Management ofrece una única relación: un contacto senior que coordina a los contadores y asesores fiscales locales en todas sus jurisdicciones, garantizando que nada se omita.", "svcEye": "Nuestros servicios", "svcH": "Lo que gestionamos", "svcs": [["Contabilidad mensual", "Contabilidad de ciclo completo en todas las jurisdicciones operativas, codificada según sus requisitos de informes de gestión y entregada mensualmente."], ["Declaraciones de IVA e impuestos indirectos", "Preparación y presentación de declaraciones de IVA y otros impuestos indirectos en todas las jurisdicciones, incluyendo conciliaciones y documentación de respaldo."], ["Declaraciones de impuesto de sociedades", "Declaraciones anuales de impuesto de sociedades, cálculos y cuadros de apoyo preparados conforme a las normas locales."], ["Estados financieros", "Estados financieros estatutarios preparados de acuerdo con GAAP local o NIIF, coordinados con auditores locales cuando sea necesario."], ["Cumplimiento fiscal de nómina", "Retención de impuestos de empleadores, cotizaciones a la seguridad social y declaraciones relacionadas en múltiples jurisdicciones de empleo."], ["Asesoría fiscal", "Asesoría fiscal continua sobre estructuras transfronterizas, precios de transferencia, riesgo de establecimiento permanente y eficiencia fiscal."]], "ctaH": "Discuta sus requisitos de cumplimiento", "ctaP": "Díganos en qué jurisdicciones opera y le daremos una imagen clara de qué debe presentarse, cuándo y a qué costo.", "ctaBtn": "Programar una consulta →", "btn2": "Nuestros servicios", "apprEye": "El enfoque ARM", "apprH": "Cumplimiento sin la complejidad.", "apprP": "La mayoría de las firmas contables están organizadas por país. Usted contrata una firma en cada jurisdicción, gestiona múltiples relaciones, reconcilia consejos contradictorios y aún arriesga brechas entre entidades. ARM Management invierte este modelo: un asesor senior tiene la visión completa de su estructura de grupo y coordina a todos los profesionales locales en su nombre.", "principles": [["Responsabilidad de plazos", "Rastreamos cada plazo de presentación en todas las jurisdicciones en las que opera. No descubrirá una declaración de IVA perdida a través de una penalización."], ["Experiencia local, coordinación central", "Trabajamos con contadores y asesores fiscales locales verificados en cada jurisdicción — coordinados a través de una única relación ARM."], ["Informes de gestión", "Los resultados de cumplimiento se traducen en información de gestión accionable — informes consolidados del grupo, P&L por entidad y visibilidad del flujo de caja."], ["Coordinación de auditoría", "Cuando surgen auditorías locales, ARM coordina el proceso con los auditores locales en su nombre, minimizando las interrupciones en sus operaciones."]], "jurEye": "Jurisdicciones", "jurH": "Dónde presentamos", "regions": [["Unión Europea", "Los 27 Estados miembros más Reino Unido y Suiza. IVA OSS, impuesto de sociedades, cuentas estatutarias, NIIF y GAAP local."], ["CCG & Oriente Medio", "Impuesto de sociedades de los EAU, registro y declaraciones de IVA, cumplimiento en zona franca y continental. Arabia Saudita, Qatar, Bahréin."], ["Asia-Pacífico", "GST e impuesto de sociedades en Singapur, impuesto sobre beneficios en Hong Kong, Malasia, India, Vietnam y otras jurisdicciones APAC."], ["América Latina", "México, Colombia, Brasil, Chile, Panamá y Uruguay. GAAP local, precios de transferencia y cumplimiento fiscal."]]}, "ar": {"title": "المحاسبة والضرائب والامتثال | ARM Management", "desc": "مسك الدفاتر الشهري، وإقرارات ضريبة القيمة المضافة، والإقرارات الضريبية، والحسابات القانونية عبر ولايات قضائية متعددة.", "eye": "المحاسبة والضرائب", "h1": "المحاسبة والضرائب\nوالامتثال الشهري", "hero": "علاقة واحدة. جميع الولايات القضائية. كل موعد نهائي محترَم.", "whatEye": "ما نقدّمه", "whatH": "علاقة واحدة عبر كل ولاية قضائية", "whatP1": "إدارة المحاسبة والامتثال الضريبي عبر ولايات قضائية متعددة هي من أكثر جوانب إدارة الأعمال الدولية تطلباً. تتباين المواعيد النهائية وصيغ الإبلاغ وأنظمة ضريبة القيمة المضافة ومتطلبات المراجعة بشكل كبير.", "whatP2": "تقدّم ARM Management علاقة واحدة: جهة تواصل كبيرة واحدة تنسّق المحاسبين والمستشارين الضريبيين المحليين في جميع ولاياتك القضائية، وتضمن عدم تفويت أي شيء.", "svcEye": "خدماتنا", "svcH": "ما ندير", "svcs": [["مسك الدفاتر الشهري", "محاسبة كاملة الدورة عبر جميع ولايات قضائية التشغيل، مرمّزة وفق متطلبات تقارير إدارتك ومُسلَّمة بجدول شهري ثابت."], ["إقرارات ضريبة القيمة المضافة والضرائب غير المباشرة", "إعداد وتقديم إقرارات ضريبة القيمة المضافة والضرائب غير المباشرة الأخرى عبر الولايات القضائية."], ["إقرارات ضريبة الشركات", "إقرارات ضريبة الشركات السنوية والحسابات والجداول الداعمة المُعدَّة وفقاً للقواعد المحلية."], ["البيانات المالية", "البيانات المالية القانونية المُعدَّة وفقاً للمعايير المحلية أو IFRS، منسّقة مع المراجعين المحليين عند الحاجة."], ["الامتثال الضريبي للرواتب", "استقطاع الضرائب على الرواتب واشتراكات الضمان الاجتماعي والإقرارات ذات الصلة عبر ولايات قضائية التوظيف المتعددة."], ["الاستشارة الضريبية", "استشارة ضريبية مستمرة حول الهياكل العابرة للحدود وأسعار التحويل ومخاطر المنشأة الدائمة والكفاءة الضريبية."]], "ctaH": "ناقش متطلبات امتثالك", "ctaP": "أخبرنا في أي ولايات قضائية تعمل وسنمنحك صورة واضحة عمّا يجب تقديمه ومتى وبأي تكلفة.", "ctaBtn": "جدوِّل استشارة ←", "btn2": "خدماتنا", "apprEye": "نهج ARM", "apprH": "الامتثال بلا تعقيد.", "apprP": "معظم شركات المحاسبة منظّمة حسب الدولة. تتعامل مع شركة في كل ولاية قضائية، وتدير علاقات متعددة، وتوفّق بين توجيهات متضاربة، مع خطر الثغرات بين الكيانات. ARM Management يعكس هذا النموذج: مستشار كبير واحد يمتلك الصورة الكاملة لهيكل مجموعتك وينسّق جميع المتخصصين المحليين نيابةً عنك.", "principles": [["مسؤولية المواعيد النهائية", "نتتبع كل موعد نهائي للإيداع في جميع الولايات القضائية التي تعمل بها. لن تكتشف إقراراً ضريبياً فائتاً عبر إشعار غرامة."], ["خبرة محلية، تنسيق مركزي", "نعمل مع محاسبين ومستشارين ضريبيين محليين موثوقين في كل ولاية قضائية — منسّقين من خلال علاقة ARM واحدة."], ["تقارير الإدارة", "تُترجَم نتائج الامتثال إلى معلومات إدارية قابلة للتنفيذ — تقارير موحّدة للمجموعة، وربحية وخسارة على مستوى الكيان، ورؤية التدفق النقدي."], ["تنسيق المراجعة", "عند إجراء مراجعات محلية، تنسّق ARM العملية مع المراجعين المحليين نيابةً عنك، مما يقلّل من تعطّل عملياتك."]], "jurEye": "الولايات القضائية", "jurH": "أين نُقدّم الإقرارات", "regions": [["الاتحاد الأوروبي", "جميع الدول الأعضاء الـ27 إضافةً إلى المملكة المتحدة وسويسرا. ضريبة القيمة المضافة OSS وضريبة الشركات والحسابات القانونية ومعايير IFRS."], ["دول الخليج والشرق الأوسط", "ضريبة الشركات الإماراتية وتسجيل وإقرارات ضريبة القيمة المضافة وامتثال المناطق الحرة والبر الرئيسي. السعودية وقطر والبحرين."], ["آسيا والمحيط الهادئ", "ضريبة GST وضريبة الشركات في سنغافورة، وضريبة الأرباح في هونغ كونغ، وماليزيا والهند وفيتنام وولايات قضائية آسيوية أخرى."], ["أمريكا اللاتينية", "المكسيك وكولومبيا والبرازيل وتشيلي وبنما والأوروغواي. GAAP المحلية وأسعار التحويل والامتثال الضريبي."]]}, "ru": {"title": "Бухучёт, налоги и комплаенс | ARM Management", "desc": "Ежемесячное ведение учёта, НДС, налоговые декларации и годовая отчётность в нескольких юрисдикциях.", "eye": "Учёт и налоги", "h1": "Бухучёт, налоги\nи комплаенс", "hero": "Один контакт. Все юрисдикции. Все сроки соблюдены.", "whatEye": "Что мы делаем", "whatH": "Один контакт в каждой юрисдикции", "whatP1": "Управление бухгалтерским учётом и налоговым комплаенс в нескольких юрисдикциях — один из наиболее операционно сложных аспектов международного бизнеса. Сроки, форматы отчётности, режимы НДС и требования к аудиту существенно различаются.", "whatP2": "ARM Management предлагает единый контакт: один старший куратор координирует местных бухгалтеров и налоговых консультантов во всех ваших юрисдикциях, гарантируя, что ничего не будет упущено.", "svcEye": "Услуги", "svcH": "Что мы ведём", "svcs": [["Ежемесячное ведение учёта", "Полный цикл бухгалтерского учёта во всех операционных юрисдикциях, закодированный под ваши управленческие отчёты и предоставляемый ежемесячно."], ["НДС и косвенные налоги", "Подготовка и подача деклараций НДС и других косвенных налогов по юрисдикциям."], ["Налоговые декларации", "Ежегодные декларации по налогу на прибыль, расчёты и вспомогательные таблицы в соответствии с местными правилами."], ["Финансовая отчётность", "Установленная финансовая отчётность в соответствии с местными GAAP или МСФО, координируемая с местными аудиторами."], ["Налоговый комплаенс по зарплатам", "Налоговые удержания работодателя, взносы на социальное страхование и связанные подачи в нескольких юрисдикциях."], ["Налоговое консультирование", "Текущее налоговое консультирование по трансграничным структурам, трансфертному ценообразованию и налоговой эффективности."]], "ctaH": "Обсудите требования комплаенс", "ctaP": "Расскажите нам, в каких юрисдикциях вы работаете, и мы дадим чёткую картину того, что нужно подавать, когда и по какой цене.", "ctaBtn": "Записаться на консультацию →", "btn2": "Наши услуги", "apprEye": "Подход ARM", "apprH": "Комплаенс без сложности.", "apprP": "Большинство бухгалтерских фирм организованы по странам. Вы нанимаете фирму в каждой юрисдикции, управляете множеством отношений, согласовываете противоречивые советы — и всё равно рискуете пробелами между структурами. ARM Management меняет эту модель: один старший консультант держит полную картину вашей групповой структуры и координирует всех местных специалистов от вашего имени.", "principles": [["Ответственность за сроки", "Мы отслеживаем каждый срок подачи во всех ваших юрисдикциях. Вы не узнаете о пропущенной декларации по НДС из уведомления о штрафе."], ["Местная экспертиза, центральная координация", "Мы работаем с проверенными местными бухгалтерами и налоговыми консультантами в каждой юрисдикции — координируемыми через единый контакт ARM."], ["Управленческая отчётность", "Результаты комплаенс переводятся в полезную управленческую информацию — консолидированная групповая отчётность, P&L по структурам, видимость денежных потоков."], ["Координация аудитов", "При проведении местных аудитов ARM координирует процесс с местными аудиторами от вашего имени, минимизируя сбои в работе."]], "jurEye": "Юрисдикции", "jurH": "Где мы подаём отчётность", "regions": [["Европейский союз", "Все 27 государств-членов плюс Великобритания и Швейцария. НДС OSS, корпоративный налог, установленная отчётность, МСФО и местные GAAP."], ["Залив и Ближний Восток", "Корпоративный налог ОАЭ, регистрация и декларации по НДС, комплаенс в свободных зонах и на материке. Саудовская Аравия, Катар, Бахрейн."], ["Азиатско-Тихоокеанский регион", "GST и корпоративный налог в Сингапуре, налог на прибыль в Гонконге, Малайзия, Индия, Вьетнам и другие юрисдикции АТР."], ["Латинская Америка", "Мексика, Колумбия, Бразилия, Чили, Панама и Уругвай. Местные GAAP, трансфертное ценообразование и налоговый комплаенс."]]}, "zh": {"title": "会计、税务与合规 | ARM Management", "desc": "在多个司法管辖区提供月度记账、增值税申报、企业所得税申报及年度财务报告服务。", "eye": "会计与税务", "h1": "会计、税务\n与月度合规", "hero": "一个联络人。所有司法管辖区。每个截止日期均按时完成。", "whatEye": "我们的服务内容", "whatH": "覆盖每个司法管辖区的单一关系", "whatP1": "在多个司法管辖区管理会计和税务合规是运营国际业务最具挑战性的方面之一。截止日期、报告格式、增值税制度和审计要求差异巨大。", "whatP2": "ARM Management提供单一联络关系：一位资深联络人协调您所有司法管辖区的当地会计师和税务顾问，确保无遗漏。", "svcEye": "服务", "svcH": "我们处理的内容", "svcs": [["月度记账", "覆盖所有运营司法管辖区的完整记账，按您的管理报告要求编码，每月定期交付。"], ["增值税及间接税申报", "在各司法管辖区准备和申报增值税及其他间接税，包括对账和支持文件。"], ["企业所得税申报", "按当地规则准备的年度企业所得税申报、计算及附表。"], ["财务报表", "按当地公认会计准则或国际财务报告准则编制的法定财务报表，必要时与当地审计师协调。"], ["薪酬税务合规", "雇主薪酬税预扣、社会保险缴纳及多个雇用司法管辖区的相关申报。"], ["税务咨询", "关于跨境架构、转让定价、常设机构风险和税务效率的持续税务咨询。"]], "ctaH": "讨论您的合规要求", "ctaP": "告诉我们您在哪些司法管辖区运营，我们将提供关于需要申报什么、何时申报及成本的清晰说明。", "ctaBtn": "预约咨询 →", "btn2": "我们的服务", "apprEye": "ARM方法", "apprH": "合规，而非复杂性。", "apprP": "大多数会计师事务所按国家组织。您在每个司法管辖区聘请一家事务所，管理多个关系，协调相互矛盾的建议，仍然面临实体间的漏洞风险。ARM Management颠覆了这一模式：一位资深顾问掌握您集团架构的完整全景，代表您协调所有当地专业人士。", "principles": [["截止日期责任", "我们跟踪您在所有司法管辖区的每个申报截止日期。您不会通过罚款通知发现错过的增值税申报。"], ["本地专业知识，集中协调", "我们在每个司法管辖区与经过核验的当地会计师和税务顾问合作——通过单一ARM关系进行协调。"], ["管理报告", "合规结果转化为可操作的管理信息——集团合并报告、实体级损益和现金流可见性。"], ["审计协调", "当出现本地审计时，ARM代表您与本地审计师协调流程，将对运营的干扰降至最低。"]], "jurEye": "司法管辖区", "jurH": "我们在哪里申报", "regions": [["欧盟", "全部27个成员国及英国、瑞士。增值税OSS、企业所得税、法定账户、国际财务报告准则及当地公认会计准则。"], ["海湾及中东", "阿联酋企业所得税、增值税注册和申报、自由区及大陆合规。沙特阿拉伯、卡塔尔、巴林。"], ["亚太地区", "新加坡商品及服务税和企业所得税、香港利得税、马来西亚、印度、越南及其他亚太司法管辖区。"], ["拉丁美洲", "墨西哥、哥伦比亚、巴西、智利、巴拿马和乌拉圭。当地公认会计准则、转让定价及税务合规。"]]}};
const c = DATA[lang];
---
<PageWrapper lang={lang} title={c.title} description={c.desc} canonicalPath="/services/accounting-tax">
<main dir={isRTL ? 'rtl' : 'ltr'}>
  <section class="page-hero">
    <div class="page-hero__bg" style="background-image:url('https://images.unsplash.com/photo-1554224154-26032ffc0d07?w=1600&q=80&auto=format&fit=crop')"></div>
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content container">
      <span class="eyebrow">{c.eye}</span>
      <h1 set:html={c.h1.replace('\n','<br>')}></h1>
      <p>{c.hero}</p>
      <div class="btn-row" style="justify-content:flex-start;margin-top:30px">
        <a href={lp('/contact')} class="btn-primary">{c.ctaBtn}</a>
        <a href={lp('/services')} class="btn-secondary">{c.btn2}</a>
      </div>
    </div>
  </section>
  <section class="section section--cream">
    <div class="container--narrow">
      <span class="eyebrow reveal">{c.whatEye}</span>
      <h2 class="reveal">{c.whatH}</h2>
      <div class="gold-rule reveal"></div>
      <p class="reveal">{c.whatP1}</p>
      <p class="reveal" style="margin-top:20px">{c.whatP2}</p>
    </div>
  </section>
  <section class="section section--warm" style="border-top:1px solid #E2DDD6">
    <div class="container">
      <span class="eyebrow reveal">{c.svcEye}</span>
      <h2 class="reveal">{c.svcH}</h2>
      <div class="gold-rule reveal"></div>
      <div class="grid-3" style="margin-top:40px">
        {c.svcs.map(([h, p]: [string,string], i: number) => (
          <div class={`card reveal reveal-delay-${(i%3)+1}`}><h3>{h}</h3><p>{p}</p></div>
        ))}
      </div>
    </div>
  </section>
  <section class="section section--navy">
    <div class="container--narrow">
      <span class="eyebrow reveal" style="color:#B8960C">{c.apprEye}</span>
      <h2 class="reveal" style="color:#F7F3EC">{c.apprH}</h2>
      <div class="gold-rule reveal"></div>
      <p class="reveal" style="color:rgba(247,243,236,.78)">{c.apprP}</p>
      <div style="margin-top:48px;display:grid;grid-template-columns:repeat(2,1fr);gap:32px">
        {c.principles.map(([h, p]: [string,string], i: number) => (
          <div class={`reveal reveal-delay-${(i%2)+1}`} style="border-top:1px solid rgba(184,150,12,.3);padding-top:20px">
            <h4 style="font-family:'Inter',sans-serif;font-size:12px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:#B8960C;margin-bottom:10px">{h}</h4>
            <p style="color:rgba(247,243,236,.65);font-size:15px;line-height:1.75">{p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  <section class="section section--cream" style="border-top:1px solid #E2DDD6">
    <div class="container--narrow">
      <span class="eyebrow reveal">{c.jurEye}</span>
      <h2 class="reveal">{c.jurH}</h2>
      <div class="gold-rule reveal"></div>
      <div class="reveal" style="display:grid;grid-template-columns:repeat(2,1fr);gap:24px;margin-top:32px">
        {c.regions.map(([h, p]: [string,string]) => (
          <div style="padding:24px;background:#FDFAF6;border:1px solid #E2DDD6;border-radius:2px">
            <h4 style="font-size:16px;margin-bottom:8px">{h}</h4>
            <p style="font-size:14px;color:#6B7280;line-height:1.65">{p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  <section class="cta-section">
    <h2 class="reveal">{c.ctaH}</h2>
    <p class="reveal reveal-delay-1">{c.ctaP}</p>
    <div class="btn-row reveal reveal-delay-2">
      <a href={lp('/contact')} class="btn-primary">{c.ctaBtn}</a>
    </div>
  </section>
</main>
</PageWrapper>
