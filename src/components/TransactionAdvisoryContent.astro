---
import PageWrapper from './PageWrapper.astro';
import { localePath } from '../i18n/translations';
import type { Locale } from '../i18n/translations';
interface Props { lang: Locale; }
const { lang } = Astro.props;
const lp = (p: string) => localePath(lang, p);
const isRTL = lang === 'ar';
const d = {
  en: { title:"Transaction Advisory | ARM Management", desc:"Senior-led cross-border transaction advisory — private investment, M&A, deal structuring, and acquisition support across 40+ jurisdictions.", eye:"Transaction Advisory", h1:"Cross-Border Transaction Advisory", hero:"Private investment, M&A, acquisition support, and deal structuring across 40+ jurisdictions. Advisory-first. Success-aligned.", whatEye:"What We Do", whatH:"Senior-Led Advisory on Every Transaction", whatP1:"ARM Management's Transaction Advisory practice provides senior-level guidance across the full lifecycle of cross-border transactions — from initial mandate assessment and deal structuring through to execution, closing, and post-transaction compliance. Every engagement is handled by a senior advisor with direct experience in the relevant jurisdiction and transaction type.", whatP2:"We advise on transactions across the EU, GCC, Asia Pacific, and Latin America. Our clients include private equity funds deploying capital into new markets, family offices acquiring operating businesses, founders seeking strategic investors, and multinational corporations expanding through acquisition.", svcEye:"Our Services", svcH:"What We Advise On", svcs:[["Private Investment Advisory","Structuring inbound and outbound private investments across jurisdictions. Legal entity selection, investment vehicle optimisation, regulatory compliance, and ongoing investor reporting coordination."],["Mergers & Acquisitions","Buy-side and sell-side M&A advisory including target identification, due diligence coordination, valuation support, deal structuring, and negotiation assistance across 40+ jurisdictions."],["Acquisition Support","End-to-end support for cross-border acquisitions — from initial market entry assessment and target screening through to regulatory filings, closing mechanics, and post-acquisition integration."],["Deal Structuring","Tax-efficient and commercially optimised transaction structures across multiple jurisdictions. Coordinating legal, tax, and regulatory requirements to protect value and minimise friction."],["Joint Ventures & Partnerships","Structuring, negotiating, and documenting joint ventures and strategic partnerships across international markets, including governance frameworks and exit mechanisms."],["Regulatory & Compliance Navigation","Navigating foreign investment regulations, sector-specific approvals, and jurisdiction-specific requirements that affect cross-border transactions in the EU, GCC, Asia, and Latin America."]], apprEye:"The ARM Approach", apprH:"Advisory-First. Not Process-First.", apprP:"Most transaction advisory firms are structured around process — they charge for steps, not outcomes. ARM Management operates differently. We assess every mandate honestly before accepting it. We tell clients directly when a transaction structure will not work, when a counterparty is not credible, or when a jurisdiction presents risks that outweigh the commercial upside.", principles:[["Honest Mandate Assessment","Before any engagement begins, we assess whether the transaction is achievable, at what cost, and on what timeline. We do not accept mandates we cannot execute."],["Senior Advisor Continuity","The advisor who assesses your transaction is the person who manages it. No handoffs to junior associates once the mandate is signed."],["Jurisdiction-Specific Expertise","We maintain active relationships with vetted legal, tax, and regulatory professionals in every jurisdiction we advise on — selected for track record, not commercial convenience."],["Transparent Fee Structure","Fees are agreed before work begins. For transaction advisory, we typically structure fees around deal milestones rather than hourly billing. No surprises."]], jurEye:"Jurisdictions", jurH:"Where We Advise", regions:[["European Union","All 27 member states plus UK and Switzerland. Cross-border M&A, private equity, joint ventures."],["GCC & Middle East","UAE (mainland, free zones, DIFC, ADGM), Saudi Arabia, Qatar, Bahrain, Kuwait, Oman."],["Asia Pacific","Singapore, Hong Kong, Malaysia, India, Vietnam, Thailand, Indonesia, Japan."],["Latin America","Mexico, Colombia, Brazil, Chile, Panama, Uruguay."]], ctaH:"Discuss Your Transaction", ctaP:"Every ARM transaction engagement begins with a confidential assessment. We will tell you honestly what is achievable, on what timeline, and at what cost — before any work begins.", ctaBtn:"Schedule a Confidential Consultation →", btn2:"Our Services" },
  fr: { title:"Conseil en transactions | ARM Management", desc:"Conseil en transactions transfrontalières de haut niveau — investissement privé, fusions-acquisitions et structuration dans 40+ juridictions.", eye:"Conseil en transactions", h1:"Conseil en transactions transfrontalières", hero:"Investissement privé, fusions-acquisitions, et structuration d'opérations dans plus de 40 juridictions. Advisory-first. Aligné sur la réussite.", whatEye:"Ce que nous faisons", whatH:"Un conseil senior à chaque transaction", whatP1:"La pratique Conseil en transactions d'ARM Management apporte une guidance de haut niveau sur tout le cycle de vie des transactions transfrontalières — de l'évaluation initiale du mandat et la structuration de l'opération jusqu'à l'exécution, le closing et la conformité post-transaction. Chaque mission est gérée par un conseiller senior ayant une expérience directe dans la juridiction et le type de transaction concernés.", whatP2:"Nous conseillons des transactions dans l'UE, le CCG, l'Asie-Pacifique et l'Amérique latine. Nos clients comprennent des fonds de private equity déployant des capitaux dans de nouveaux marchés, des family offices acquérant des entreprises opérationnelles, des fondateurs cherchant des investisseurs stratégiques, et des multinationales se développant par acquisition.", svcEye:"Nos services", svcH:"Ce sur quoi nous conseillons", svcs:[["Conseil en investissement privé","Structuration des investissements privés entrants et sortants entre juridictions. Sélection de l'entité juridique, optimisation du véhicule d'investissement, conformité réglementaire et coordination des rapports aux investisseurs."],["Fusions & Acquisitions","Conseil en M&A côté acheteur et vendeur, incluant l'identification de cibles, la coordination de due diligence, le support à la valorisation, la structuration et l'assistance à la négociation dans 40+ juridictions."],["Support à l'acquisition","Accompagnement de bout en bout pour les acquisitions transfrontalières — de l'évaluation initiale d'entrée sur le marché aux formalités réglementaires, mécanismes de closing et intégration post-acquisition."],["Structuration d'opérations","Structures de transactions fiscalement efficaces et optimisées commercialement dans plusieurs juridictions. Coordination des exigences légales, fiscales et réglementaires pour protéger la valeur et minimiser les frictions."],["Joint-ventures & Partenariats","Structuration, négociation et documentation de joint-ventures et partenariats stratégiques sur les marchés internationaux, incluant les cadres de gouvernance et les mécanismes de sortie."],["Navigation réglementaire & conformité","Navigation dans les réglementations sur les investissements étrangers, les approbations sectorielles et les exigences juridictionnelles affectant les transactions dans l'UE, le CCG, l'Asie et l'Amérique latine."]], apprEye:"L'approche ARM", apprH:"Advisory-first. Pas process-first.", apprP:"La plupart des cabinets de conseil en transactions sont structurés autour du processus — ils facturent des étapes, pas des résultats. ARM Management fonctionne différemment. Nous évaluons chaque mandat honnêtement avant de l'accepter. Nous disons directement aux clients quand une structure de transaction ne fonctionnera pas, quand une contrepartie n'est pas crédible, ou quand une juridiction présente des risques qui dépassent l'avantage commercial.", principles:[["Évaluation honnête du mandat","Avant tout engagement, nous évaluons si la transaction est réalisable, à quel coût et dans quel délai. Nous n'acceptons pas de mandats que nous ne pouvons pas exécuter."],["Continuité du conseiller senior","Le conseiller qui évalue votre transaction est celui qui la gère. Pas de transfert à des juniors une fois le mandat signé."],["Expertise juridictionnelle","Nous maintenons des relations actives avec des professionnels juridiques, fiscaux et réglementaires vérifiés dans chaque juridiction — sélectionnés pour leur bilan, pas pour leur commodité commerciale."],["Structure de fees transparente","Les honoraires sont convenus avant le début des travaux. Pour le conseil en transactions, nous structurons généralement les fees autour des jalons de la transaction plutôt qu'à l'heure."]], jurEye:"Juridictions", jurH:"Où nous conseillons", regions:[["Union européenne","Les 27 États membres plus le Royaume-Uni et la Suisse. M&A transfrontalier, private equity, joint-ventures."],["CCG & Moyen-Orient","EAU (continent, zones franches, DIFC, ADGM), Arabie Saoudite, Qatar, Bahreïn, Koweït, Oman."],["Asie-Pacifique","Singapour, Hong Kong, Malaisie, Inde, Vietnam, Thaïlande, Indonésie, Japon."],["Amérique latine","Mexique, Colombie, Brésil, Chili, Panama, Uruguay."]], ctaH:"Discutez de votre transaction", ctaP:"Chaque mission de conseil en transactions ARM commence par une évaluation confidentielle. Nous vous dirons honnêtement ce qui est réalisable, dans quel délai et à quel coût — avant tout début de travaux.", ctaBtn:"Planifier une consultation confidentielle →", btn2:"Nos services" },
  es: { title:"Asesoría en Transacciones | ARM Management", desc:"Asesoría en transacciones transfronterizas liderada por seniors — inversión privada, M&A y estructuración en 40+ jurisdicciones.", eye:"Asesoría en Transacciones", h1:"Asesoría en Transacciones Transfronterizas", hero:"Inversión privada, fusiones y adquisiciones, y estructuración en más de 40 jurisdicciones. Advisory-first. Alineado con el éxito.", whatEye:"Lo que hacemos", whatH:"Asesoría senior en cada transacción", whatP1:"La práctica de Asesoría en Transacciones de ARM Management proporciona orientación de alto nivel en todo el ciclo de vida de las transacciones transfronterizas — desde la evaluación inicial del mandato y la estructuración hasta la ejecución, el cierre y el cumplimiento post-transacción. Cada proyecto es gestionado por un asesor senior con experiencia directa en la jurisdicción y tipo de transacción relevantes.", whatP2:"Asesoramos en transacciones en la UE, el CCG, Asia Pacífico y América Latina. Nuestros clientes incluyen fondos de private equity desplegando capital en nuevos mercados, family offices adquiriendo empresas operativas, fundadores buscando inversores estratégicos, y multinacionales expandiéndose por adquisición.", svcEye:"Nuestros servicios", svcH:"En qué asesoramos", svcs:[["Asesoría en Inversión Privada","Estructuración de inversiones privadas entrantes y salientes entre jurisdicciones. Selección de entidad legal, optimización del vehículo de inversión, cumplimiento regulatorio y coordinación de informes a inversores."],["Fusiones & Adquisiciones","Asesoría en M&A del lado comprador y vendedor, incluyendo identificación de objetivos, coordinación de due diligence, apoyo en valoración, estructuración y asistencia en negociación en 40+ jurisdicciones."],["Apoyo en Adquisiciones","Apoyo integral para adquisiciones transfronterizas — desde la evaluación inicial de entrada al mercado hasta las presentaciones regulatorias, mecánicas de cierre e integración post-adquisición."],["Estructuración de Operaciones","Estructuras de transacciones fiscalmente eficientes y comercialmente optimizadas en múltiples jurisdicciones. Coordinación de requisitos legales, fiscales y regulatorios para proteger el valor."],["Joint Ventures & Alianzas","Estructuración, negociación y documentación de joint ventures y alianzas estratégicas en mercados internacionales, incluyendo marcos de gobernanza y mecanismos de salida."],["Navegación Regulatoria & Cumplimiento","Navegación en regulaciones de inversión extranjera, aprobaciones sectoriales y requisitos jurisdiccionales que afectan las transacciones transfronterizas."]], apprEye:"El enfoque ARM", apprH:"Advisory-first. No process-first.", apprP:"La mayoría de las firmas de asesoría en transacciones están estructuradas alrededor del proceso — cobran por pasos, no por resultados. ARM Management opera de manera diferente. Evaluamos cada mandato honestamente antes de aceptarlo. Le decimos directamente a los clientes cuando una estructura de transacción no funcionará, cuando una contraparte no es creíble, o cuando una jurisdicción presenta riesgos que superan el beneficio comercial.", principles:[["Evaluación honesta del mandato","Antes de cualquier proyecto, evaluamos si la transacción es alcanzable, a qué costo y en qué plazo. No aceptamos mandatos que no podemos ejecutar."],["Continuidad del asesor senior","El asesor que evalúa su transacción es quien la gestiona. Sin traspasos a junior una vez firmado el mandato."],["Experiencia jurisdiccional","Mantenemos relaciones activas con profesionales legales, fiscales y regulatorios verificados en cada jurisdicción — seleccionados por su trayectoria, no por conveniencia comercial."],["Estructura de honorarios transparente","Los honorarios se acuerdan antes de comenzar el trabajo. Para asesoría en transacciones, estructuramos los honorarios alrededor de hitos de la transacción en lugar de facturación por horas."]], jurEye:"Jurisdicciones", jurH:"Dónde asesoramos", regions:[["Unión Europea","Los 27 estados miembros más Reino Unido y Suiza. M&A transfronterizo, private equity, joint ventures."],["CCG & Oriente Medio","EAU (continente, zonas francas, DIFC, ADGM), Arabia Saudita, Qatar, Bahréin, Kuwait, Omán."],["Asia-Pacífico","Singapur, Hong Kong, Malasia, India, Vietnam, Tailandia, Indonesia, Japón."],["América Latina","México, Colombia, Brasil, Chile, Panamá, Uruguay."]], ctaH:"Discuta su transacción", ctaP:"Cada proyecto de asesoría en transacciones ARM comienza con una evaluación confidencial. Le diremos honestamente qué es alcanzable, en qué plazo y a qué costo — antes de que comience cualquier trabajo.", ctaBtn:"Programar una consulta confidencial →", btn2:"Nuestros servicios" },
  ar: { title:"استشارات المعاملات | ARM Management", desc:"استشارات معاملات عابرة للحدود بقيادة كبار المستشارين — استثمار خاص، اندماجات واستحواذات وهيكلة صفقات في 40+ ولاية قضائية.", eye:"استشارات المعاملات", h1:"استشارات المعاملات العابرة للحدود", hero:"الاستثمار الخاص، وعمليات الاندماج والاستحواذ، ودعم الاستحواذ، وهيكلة الصفقات في أكثر من 40 ولاية قضائية. نهج استشاري أولاً. متوافق مع النجاح.", whatEye:"ما نقدّمه", whatH:"استشارة كبار المستشارين في كل معاملة", whatP1:"تقدّم ممارسة استشارات المعاملات في ARM Management توجيهاً رفيع المستوى عبر الدورة الكاملة للمعاملات العابرة للحدود — من تقييم المشروع الأولي وهيكلة الصفقة وصولاً إلى التنفيذ والإغلاق والامتثال بعد المعاملة. كل مشروع تديره مستشار كبير ذو خبرة مباشرة في الولاية القضائية ونوع المعاملة ذات الصلة.", whatP2:"نقدّم المشورة في المعاملات عبر الاتحاد الأوروبي ودول الخليج وآسيا والمحيط الهادئ وأمريكا اللاتينية. يشمل عملاؤنا صناديق الأسهم الخاصة التي تنشر رأس المال في أسواق جديدة، ومكاتب العائلة التي تستحوذ على شركات تشغيلية، والمؤسسين الباحثين عن مستثمرين استراتيجيين، والشركات متعددة الجنسيات التي تتوسع عبر الاستحواذ.", svcEye:"خدماتنا", svcH:"ما نستشير فيه", svcs:[["استشارات الاستثمار الخاص","هيكلة الاستثمارات الخاصة الواردة والصادرة بين الولايات القضائية. اختيار الكيان القانوني، وتحسين مركبة الاستثمار، والامتثال التنظيمي، وتنسيق التقارير للمستثمرين."],["الاندماجات والاستحواذات","استشارات اندماجات واستحواذات من جانب المشتري والبائع تشمل تحديد الأهداف، وتنسيق العناية الواجبة، ودعم التقييم، وهيكلة الصفقات، والمساعدة في التفاوض عبر 40+ ولاية قضائية."],["دعم الاستحواذ","دعم شامل للاستحواذات العابرة للحدود — من التقييم الأولي لدخول السوق وفحص الأهداف وصولاً إلى التقديمات التنظيمية وآليات الإغلاق والتكامل بعد الاستحواذ."],["هيكلة الصفقات","هياكل معاملات فعّالة ضريبياً ومُحسَّنة تجارياً عبر ولايات قضائية متعددة. تنسيق المتطلبات القانونية والضريبية والتنظيمية لحماية القيمة وتقليل الاحتكاك."],["المشاريع المشتركة والشراكات","هيكلة وتفاوض وتوثيق المشاريع المشتركة والشراكات الاستراتيجية عبر الأسواق الدولية، بما في ذلك أطر الحوكمة وآليات الخروج."],["التنقل التنظيمي والامتثال","التنقل في لوائح الاستثمار الأجنبي والموافقات القطاعية والمتطلبات الخاصة بالولايات القضائية التي تؤثر على المعاملات العابرة للحدود."]], apprEye:"نهج ARM", apprH:"الاستشارة أولاً. لا العمليات.", apprP:"معظم شركات استشارات المعاملات مهيكلة حول العمليات — تفرض رسوماً على الخطوات لا على النتائج. ARM Management تعمل بشكل مختلف. نقيّم كل مشروع بصدق قبل قبوله. نُخبر العملاء مباشرةً عندما لا تنجح هيكلة المعاملة، أو عندما تكون الطرف الآخر غير موثوق، أو عندما تقدّم ولاية قضائية مخاطر تفوق الفائدة التجارية.", principles:[["تقييم صادق للمشروع","قبل أي التزام، نقيّم ما إذا كانت المعاملة قابلة للتحقيق، وبأي تكلفة، وفي أي إطار زمني. لا نقبل مشاريع لا نستطيع تنفيذها."],["استمرارية المستشار الكبير","المستشار الذي يقيّم معاملتك هو من يديرها. لا إحالات لمساعدين مبتدئين بعد التوقيع على المشروع."],["خبرة بالولايات القضائية","نحافظ على علاقات نشطة مع متخصصين قانونيين وضريبيين وتنظيميين موثوقين في كل ولاية قضائية نستشير فيها — مختارين بناءً على بيانات الأداء، لا على الملاءمة التجارية."],["هيكل رسوم شفاف","تُتفق على الرسوم قبل بدء العمل. لاستشارات المعاملات، نهيكل عادةً الرسوم حول معالم الصفقة بدلاً من الفوترة بالساعة."]], jurEye:"الولايات القضائية", jurH:"أين نستشير", regions:[["الاتحاد الأوروبي","جميع الدول الأعضاء الـ27 إضافةً إلى المملكة المتحدة وسويسرا. اندماجات واستحواذات عابرة للحدود، أسهم خاصة، مشاريع مشتركة."],["دول الخليج والشرق الأوسط","الإمارات (البر الرئيسي، المناطق الحرة، DIFC، ADGM)، السعودية، قطر، البحرين، الكويت، عُمان."],["آسيا والمحيط الهادئ","سنغافورة، هونغ كونغ، ماليزيا، الهند، فيتنام، تايلاند، إندونيسيا، اليابان."],["أمريكا اللاتينية","المكسيك، كولومبيا، البرازيل، تشيلي، بنما، الأوروغواي."]], ctaH:"ناقش معاملتك", ctaP:"كل مشروع استشارات معاملات في ARM يبدأ بتقييم سري. سنُخبرك بصدق بما هو قابل للتحقيق، وفي أي إطار زمني، وبأي تكلفة — قبل بدء أي عمل.", ctaBtn:"جدوِّل استشارة سرية ←", btn2:"خدماتنا" },
  ru: { title:"Транзакционный консалтинг | ARM Management", desc:"Транзакционный консалтинг высокого уровня — частные инвестиции, M&A и структурирование сделок в 40+ юрисдикциях.", eye:"Транзакционный консалтинг", h1:"Транзакционный консалтинг", hero:"Частные инвестиции, сделки M&A, поддержка сделок и структурирование в 40+ юрисдикциях. Принцип advisory-first. Ориентация на результат.", whatEye:"Что мы делаем", whatH:"Старший консультант на каждой сделке", whatP1:"Практика транзакционного консалтинга ARM Management обеспечивает руководство высокого уровня на протяжении всего жизненного цикла трансграничных сделок — от первоначальной оценки мандата и структурирования до исполнения, закрытия и пост-транзакционного комплаенс. Каждый проект ведёт старший консультант с прямым опытом работы в соответствующей юрисдикции и типе сделки.", whatP2:"Мы консультируем по сделкам в ЕС, Заливе, Азиатско-Тихоокеанском регионе и Латинской Америке. Среди наших клиентов — фонды прямых инвестиций, размещающие капитал на новых рынках, семейные офисы, приобретающие операционные бизнесы, основатели в поиске стратегических инвесторов, и транснациональные корпорации, расширяющиеся через приобретения.", svcEye:"Наши услуги", svcH:"Что мы делаем", svcs:[["Консалтинг по частным инвестициям","Структурирование входящих и исходящих частных инвестиций между юрисдикциями. Выбор юридической структуры, оптимизация инвестиционного инструмента, регуляторный комплаенс и координация инвесторской отчётности."],["Слияния и поглощения","Консалтинг по M&A на стороне покупателя и продавца: поиск объектов, координация due diligence, поддержка оценки, структурирование сделки и помощь в переговорах в 40+ юрисдикциях."],["Поддержка при поглощениях","Комплексная поддержка трансграничных поглощений — от первоначальной оценки входа на рынок до регуляторных подач, механизмов закрытия и пост-приобретационной интеграции."],["Структурирование сделок","Налогово-эффективные и коммерчески оптимизированные структуры транзакций в нескольких юрисдикциях. Координация правовых, налоговых и регуляторных требований для защиты стоимости."],["Совместные предприятия и партнёрства","Структурирование, согласование и документирование СП и стратегических партнёрств на международных рынках, включая механизмы корпоративного управления и выхода."],["Регуляторная навигация и комплаенс","Навигация в регулировании иностранных инвестиций, секторальных согласованиях и юрисдикционных требованиях, влияющих на трансграничные сделки."]], apprEye:"Подход ARM", apprH:"Advisory-first. Не process-first.", apprP:"Большинство транзакционных консалтинговых фирм ориентированы на процесс — они берут плату за шаги, а не за результат. ARM Management работает иначе. Мы честно оцениваем каждый мандат перед его принятием. Мы напрямую говорим клиентам, когда структура сделки не сработает, когда контрагент не является надёжным, или когда юрисдикция несёт риски, перевешивающие коммерческую выгоду.", principles:[["Честная оценка мандата","До начала любого проекта мы оцениваем, достижима ли сделка, по какой цене и в какие сроки. Мы не берёмся за мандаты, которые не можем исполнить."],["Преемственность старшего консультанта","Консультант, который оценивает вашу сделку, тот же, кто её ведёт. Никаких передач младшим сотрудникам после подписания мандата."],["Юрисдикционная экспертиза","Мы поддерживаем активные отношения с проверенными юридическими, налоговыми и регуляторными специалистами в каждой юрисдикции — отобранными по репутации, а не коммерческим соображениям."],["Прозрачная структура гонораров","Гонорары согласуются до начала работы. Для транзакционного консалтинга мы, как правило, структурируем гонорары вокруг вех сделки, а не почасовой оплаты."]], jurEye:"Юрисдикции", jurH:"Где мы консультируем", regions:[["Европейский союз","Все 27 государств-членов плюс Великобритания и Швейцария. Трансграничные M&A, прямые инвестиции, СП."],["Залив и Ближний Восток","ОАЭ (материк, свободные зоны, DIFC, ADGM), Саудовская Аравия, Катар, Бахрейн, Кувейт, Оман."],["Азиатско-Тихоокеанский регион","Сингапур, Гонконг, Малайзия, Индия, Вьетнам, Таиланд, Индонезия, Япония."],["Латинская Америка","Мексика, Колумбия, Бразилия, Чили, Панама, Уругвай."]], ctaH:"Обсудите вашу сделку", ctaP:"Каждый проект транзакционного консалтинга ARM начинается с конфиденциальной оценки. Мы честно скажем вам, что достижимо, в какие сроки и по какой цене — до начала работы.", ctaBtn:"Записаться на конфиденциальную консультацию →", btn2:"Наши услуги" },
  zh: { title:"交易咨询 | ARM Management", desc:"资深主导的跨境交易咨询——私人投资、并购、40+司法管辖区交易架构。", eye:"交易咨询", h1:"跨境交易咨询", hero:"在40余个司法管辖区提供私人投资、并购、收购支持和交易架构服务。以顾问视角优先，与成果深度绑定。", whatEye:"我们的服务内容", whatH:"每笔交易均由资深顾问主导", whatP1:"ARM Management的交易咨询业务在跨境交易的整个生命周期提供高级指导——从初始委托评估和交易架构，到执行、交割和交易后合规。每个项目均由在相关司法管辖区和交易类型具有直接经验的资深顾问负责。", whatP2:"我们在欧盟、海湾、亚太和拉丁美洲提供交易咨询。客户包括在新市场配置资本的私募基金、收购运营企业的家族办公室、寻求战略投资者的创始人，以及通过收购扩张的跨国公司。", svcEye:"我们的服务", svcH:"咨询范围", svcs:[["私人投资咨询","跨司法管辖区的境内外私人投资架构。法律实体选择、投资工具优化、监管合规及投资者报告协调。"],["并购","买方和卖方并购咨询，包括目标识别、尽职调查协调、估值支持、交易架构及40+司法管辖区谈判协助。"],["收购支持","跨境收购的端到端支持——从初始市场进入评估和目标筛选，到监管申报、交割机制和收购后整合。"],["交易架构","跨多个司法管辖区的税务高效、商业优化交易结构。协调法律、税务和监管要求以保护价值、减少摩擦。"],["合资与合作","在国际市场构建、谈判和记录合资企业及战略合作，包括治理框架和退出机制。"],["监管合规导航","在欧盟、海湾、亚洲和拉丁美洲影响跨境交易的外资法规、行业审批和司法管辖区特定要求中导航。"]], apprEye:"ARM方法", apprH:"顾问优先，而非流程优先。", apprP:"大多数交易咨询公司以流程为中心——按步骤收费，而非按结果收费。ARM Management的运作方式不同。我们在接受每个委托之前诚实地进行评估。我们直接告知客户交易结构何时行不通、交易对手何时不可信，或某司法管辖区的风险何时超过商业收益。", principles:[["诚实的委托评估","在任何项目开始之前，我们评估交易是否可实现、成本多少、时间线如何。我们不接受无法执行的委托。"],["资深顾问连续性","评估您交易的顾问就是管理它的人。委托签署后不会移交给初级员工。"],["司法管辖区专业知识","我们在每个咨询的司法管辖区与经过核验的法律、税务和监管专业人士保持活跃关系——依据业绩记录而非商业便利性筛选。"],["透明的费用结构","费用在工作开始前商定。对于交易咨询，我们通常围绕交易里程碑而非按小时计费来构建费用结构。"]], jurEye:"司法管辖区", jurH:"我们的咨询覆盖", regions:[["欧盟","全部27个成员国及英国、瑞士。跨境并购、私募股权、合资企业。"],["海湾及中东","阿联酋（大陆、自由区、DIFC、ADGM）、沙特阿拉伯、卡塔尔、巴林、科威特、阿曼。"],["亚太地区","新加坡、香港、马来西亚、印度、越南、泰国、印度尼西亚、日本。"],["拉丁美洲","墨西哥、哥伦比亚、巴西、智利、巴拿马、乌拉圭。"]], ctaH:"讨论您的交易", ctaP:"每个ARM交易咨询项目都从保密评估开始。我们将坦诚告知什么是可实现的、时间线和成本——在任何工作开始之前。", ctaBtn:"预约保密咨询 →", btn2:"我们的服务" },
};
const c = d[lang];
---
<PageWrapper lang={lang} title={c.title} description={c.desc} canonicalPath="/services/transaction-advisory">
<main dir={isRTL ? 'rtl' : 'ltr'}>
  <section class="page-hero">
    <div class="page-hero__bg" style="background-image:url('https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=1600&q=80&auto=format&fit=crop')"></div>
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content container">
      <span class="eyebrow">{c.eye}</span>
      <h1>{c.h1}</h1>
      <p>{c.hero}</p>
      <div class="btn-row" style="justify-content:flex-start;margin-top:30px">
        <a href={lp('/contact')} class="btn-primary">{c.ctaBtn}</a>
        <a href={lp('/services')} class="btn-secondary">{c.btn2}</a>
      </div>
    </div>
  </section>

  <section class="section section--cream">
    <div class="container--narrow">
      <span class="eyebrow reveal">{c.whatEye}</span>
      <h2 class="reveal">{c.whatH}</h2>
      <div class="gold-rule reveal"></div>
      <p class="reveal">{c.whatP1}</p>
      <p class="reveal" style="margin-top:20px">{c.whatP2}</p>
    </div>
  </section>

  <section class="section section--warm" style="border-top:1px solid #E2DDD6">
    <div class="container">
      <span class="eyebrow reveal">{c.svcEye}</span>
      <h2 class="reveal">{c.svcH}</h2>
      <div class="gold-rule reveal"></div>
      <div class="grid-3" style="margin-top:40px">
        {c.svcs.map(([h, p]: [string,string], i: number) => (
          <div class={`card reveal reveal-delay-${(i%3)+1}`}><h3>{h}</h3><p>{p}</p></div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--navy">
    <div class="container--narrow">
      <span class="eyebrow reveal" style="color:#B8960C">{c.apprEye}</span>
      <h2 class="reveal" style="color:#F7F3EC">{c.apprH}</h2>
      <div class="gold-rule reveal"></div>
      <p class="reveal" style="color:rgba(247,243,236,.78)">{c.apprP}</p>
      <div style="margin-top:48px;display:grid;grid-template-columns:repeat(2,1fr);gap:32px">
        {c.principles.map(([h, p]: [string,string], i: number) => (
          <div class={`reveal reveal-delay-${(i%2)+1}`} style="border-top:1px solid rgba(184,150,12,.3);padding-top:20px">
            <h4 style="font-family:'Inter',sans-serif;font-size:12px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:#B8960C;margin-bottom:10px">{h}</h4>
            <p style="color:rgba(247,243,236,.65);font-size:15px;line-height:1.75">{p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--cream" style="border-top:1px solid #E2DDD6">
    <div class="container--narrow">
      <span class="eyebrow reveal">{c.jurEye}</span>
      <h2 class="reveal">{c.jurH}</h2>
      <div class="gold-rule reveal"></div>
      <div class="reveal" style="display:grid;grid-template-columns:repeat(2,1fr);gap:24px;margin-top:32px">
        {c.regions.map(([h, p]: [string,string]) => (
          <div style="padding:24px;background:#FDFAF6;border:1px solid #E2DDD6;border-radius:2px">
            <h4 style="font-size:16px;margin-bottom:8px">{h}</h4>
            <p style="font-size:14px;color:#6B7280;line-height:1.65">{p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <h2 class="reveal">{c.ctaH}</h2>
    <p class="reveal reveal-delay-1">{c.ctaP}</p>
    <div class="btn-row reveal reveal-delay-2">
      <a href={lp('/contact')} class="btn-primary">{c.ctaBtn}</a>
      <a href={lp('/services')} class="btn-secondary">{c.btn2}</a>
    </div>
  </section>
</main>
</PageWrapper>
