---
import PageWrapper from './PageWrapper.astro';
import { localePath } from '../i18n/translations';
import type { Locale } from '../i18n/translations';
interface Props { lang: Locale; }
const { lang } = Astro.props;
const lp = (p: string) => localePath(lang, p);
const isRTL = lang === 'ar';

const L: Record<string, any> = {
  en: { title:"Leadership — Jakub Zientala, Vice President | ARM Management", desc:"Jakub Zientala is Vice President of ARM Management, leading client engagement and the firm's regulatory and market-access work across its international markets.", eyebrow:"Leadership", role:"Vice President", pos:"Leads client engagement and ARM Management's regulatory and market-access proposition across the firm's international markets.", btn1:"Request an Introduction →", btn2:"Explore Our Services", profileH:"Profile", lede:"Jakub Zientala is Vice President of ARM Management, where he leads client engagement and the firm's regulatory and market-access proposition across its international markets. He advises the senior leadership of international companies, investors and institutions — at home in the boardroom, the ministry and the EU institutions alike.", p2:"He has built his career at the intersection of European regulation, government affairs and market access. As Director of European and Governmental Affairs for a cross-border industry alliance, he led a multi-year campaign that helped protect an estimated €40 million European market from adverse international regulation, carrying the case to UN level.", p3:"He went on to found his own advisory practice, guiding corporates, founders and public institutions on European market entry, regulatory positioning and stakeholder strategy. Earlier, he worked across the European institutional landscape — as a European Climate Pact Ambassador for the European Commission, a Youth Delegate of the Netherlands to the Council of Europe, and a research assistant at EIPA.", p4:"Equally at ease with a chief executive, a minister or a regulator, Jakub is the adviser senior leaders turn to when an outcome depends on politics and regulation as much as on commercial strategy. He holds a Master's in Public Policy from UNU-MERIT / Maastricht University and an LL.B. in European Law, advises in English, Polish, Czech and Russian, and is based in Brussels.", focusH:"Areas of Focus", chips:["Market entry & regulatory strategy","Board & C-suite advisory","Government relations & public affairs","Strategy through to execution","Institutional positioning & legitimacy","Cross-border stakeholder coalitions","Political & regulatory risk","Emerging-sector regulation (MiCA / VARA)"], credH:"Credentials & Background", edu:"LL.B. European Law — Maastricht University · MA Public Policy — UNU-MERIT / Maastricht", langs:"English · Polish · Czech · Russian", focus:"Regulatory strategy · Government affairs · Market access", eu:"European Commission (DG Clima) · EEAS · Council of Europe · EIPA", based:"Brussels", ctaEye:"Private & Confidential", ctaH:"Speak with our team directly.", ctaP:"Engagements begin with a confidential conversation. ARM Management works with a limited number of clients at a time.", ctaBtn:"Request an Introduction →" },
  fr: { title:"Direction — Jakub Zientala, Vice-Président | ARM Management", desc:"Jakub Zientala est Vice-Président d'ARM Management, responsable de l'engagement client et du travail réglementaire et d'accès au marché de la firme.", eyebrow:"Direction", role:"Vice-Président", pos:"Dirige l'engagement client et la proposition réglementaire et d'accès au marché d'ARM Management sur ses marchés internationaux.", btn1:"Demander une introduction →", btn2:"Découvrir nos services", profileH:"Profil", lede:"Jakub Zientala est Vice-Président d'ARM Management, où il dirige l'engagement client et la proposition réglementaire et d'accès au marché de la firme sur ses marchés internationaux. Il conseille les dirigeants d'entreprises internationales, d'investisseurs et d'institutions — à l'aise aussi bien dans la salle du conseil que dans les ministères et les institutions européennes.", p2:"Il a construit sa carrière à l'intersection de la réglementation européenne, des affaires gouvernementales et de l'accès au marché. En tant que Directeur des Affaires Européennes et Gouvernementales d'une alliance industrielle transfrontalière, il a mené une campagne pluriannuelle qui a contribué à protéger un marché européen estimé à 40 millions d'euros contre une réglementation internationale défavorable, portant le cas jusqu'au niveau de l'ONU.", p3:"Il a ensuite fondé son propre cabinet de conseil, guidant des entreprises, des fondateurs et des institutions publiques sur l'entrée sur le marché européen, le positionnement réglementaire et la stratégie des parties prenantes. Auparavant, il a travaillé dans le paysage institutionnel européen — en tant qu'Ambassadeur du Pacte européen pour le climat pour la Commission européenne, Délégué Jeunesse des Pays-Bas au Conseil de l'Europe, et assistant de recherche à l'EIPA.", p4:"Aussi à l'aise avec un PDG, un ministre ou un régulateur, Jakub est le conseiller vers lequel les dirigeants seniors se tournent lorsqu'un résultat dépend autant de la politique et de la réglementation que de la stratégie commerciale. Il conseille en anglais, polonais, tchèque et russe, et est basé à Bruxelles.", focusH:"Domaines d'intervention", chips:["Stratégie d'entrée sur le marché & réglementaire","Conseil Conseil d'administration & Comité de direction","Relations gouvernementales & affaires publiques","De la stratégie à l'exécution","Positionnement institutionnel & légitimité","Coalitions transfrontalières de parties prenantes","Risque politique & réglementaire","Réglementation des secteurs émergents (MiCA / VARA)"], credH:"Formation & Parcours", edu:"LL.B. Droit européen — Université de Maastricht · MA Politiques publiques — UNU-MERIT / Maastricht", langs:"Anglais · Polonais · Tchèque · Russe", focus:"Stratégie réglementaire · Affaires gouvernementales · Accès au marché", eu:"Commission européenne (DG Clima) · SEAE · Conseil de l'Europe · EIPA", based:"Bruxelles", ctaEye:"Privé & Confidentiel", ctaH:"Parlez directement à notre équipe.", ctaP:"Les missions commencent par une conversation confidentielle. ARM Management travaille avec un nombre limité de clients à la fois.", ctaBtn:"Demander une introduction →" },
  es: { title:"Dirección — Jakub Zientala, Vicepresidente | ARM Management", desc:"Jakub Zientala es Vicepresidente de ARM Management, liderando el compromiso con los clientes y el trabajo regulatorio de la firma en sus mercados internacionales.", eyebrow:"Dirección", role:"Vicepresidente", pos:"Dirige el compromiso con los clientes y la propuesta regulatoria y de acceso al mercado de ARM Management en sus mercados internacionales.", btn1:"Solicitar una introducción →", btn2:"Explorar nuestros servicios", profileH:"Perfil", lede:"Jakub Zientala es Vicepresidente de ARM Management, donde lidera el compromiso con los clientes y la propuesta regulatoria y de acceso al mercado de la firma en sus mercados internacionales. Asesora a la alta dirección de empresas internacionales, inversores e instituciones.", p2:"Ha construido su carrera en la intersección de la regulación europea, los asuntos gubernamentales y el acceso al mercado. Como Director de Asuntos Europeos y Gubernamentales de una alianza industrial transfronteriza, lideró una campaña plurianual que ayudó a proteger un mercado europeo estimado en 40 millones de euros de una regulación internacional adversa, llevando el caso hasta el nivel de la ONU.", p3:"Posteriormente fundó su propia práctica de asesoría, orientando a empresas, fundadores e instituciones públicas sobre la entrada al mercado europeo, el posicionamiento regulatorio y la estrategia de partes interesadas.", p4:"Igualmente cómodo con un director ejecutivo, un ministro o un regulador, Jakub es el asesor al que recurren los líderes senior cuando un resultado depende tanto de la política y la regulación como de la estrategia comercial. Asesora en inglés, polaco, checo y ruso, y está basado en Bruselas.", focusH:"Áreas de enfoque", chips:["Estrategia de entrada al mercado y regulatoria","Asesoría a Consejo y C-suite","Relaciones gubernamentales y asuntos públicos","De la estrategia a la ejecución","Posicionamiento institucional y legitimidad","Coaliciones transfronterizas de partes interesadas","Riesgo político y regulatorio","Regulación de sectores emergentes (MiCA / VARA)"], credH:"Formación & Trayectoria", edu:"LL.B. Derecho europeo — Universidad de Maastricht · MA Políticas Públicas — UNU-MERIT / Maastricht", langs:"Inglés · Polaco · Checo · Ruso", focus:"Estrategia regulatoria · Asuntos gubernamentales · Acceso al mercado", eu:"Comisión Europea (DG Clima) · SEAE · Consejo de Europa · EIPA", based:"Bruselas", ctaEye:"Privado & Confidencial", ctaH:"Hable directamente con nuestro equipo.", ctaP:"Los proyectos comienzan con una conversación confidencial. ARM Management trabaja con un número limitado de clientes a la vez.", ctaBtn:"Solicitar una introducción →" },
  ar: { title:"القيادة — ياكوب زيينتالا، نائب الرئيس | ARM Management", desc:"ياكوب زيينتالا هو نائب رئيس ARM Management، يقود التواصل مع العملاء والعمل التنظيمي للشركة في أسواقها الدولية.", eyebrow:"القيادة", role:"نائب الرئيس", pos:"يقود التواصل مع العملاء وعرض ARM Management التنظيمي وصلاحيات الوصول إلى السوق عبر أسواقها الدولية.", btn1:"طلب تعريف ←", btn2:"اكتشف خدماتنا", profileH:"الملف الشخصي", lede:"ياكوب زيينتالا هو نائب رئيس ARM Management، حيث يقود التواصل مع العملاء وعرض الشركة التنظيمي وصلاحيات الوصول إلى السوق. يقدّم المشورة لقيادات الشركات الدولية والمستثمرين والمؤسسات.", p2:"بنى مسيرته المهنية عند تقاطع اللوائح الأوروبية والشؤون الحكومية والوصول إلى السوق. بصفته مديراً للشؤون الأوروبية والحكومية لتحالف صناعي عابر للحدود، قاد حملة متعددة السنوات ساعدت في حماية سوق أوروبية تُقدَّر بـ40 مليون يورو من اللوائح الدولية الضارة.", p3:"أسّس بعد ذلك مكتب استشاري خاصاً به، يرشد الشركات والمؤسسين والمؤسسات العامة في الدخول إلى السوق الأوروبية والتموضع التنظيمي واستراتيجية أصحاب المصلحة.", p4:"مرتاح بالقدر نفسه مع مدير تنفيذي أو وزير أو جهة تنظيمية، يُعدّ ياكوب المستشار الذي يلجأ إليه القادة الكبار عندما تعتمد النتيجة على السياسة واللوائح بقدر ما تعتمد على الاستراتيجية التجارية. يقدّم المشورة بالإنجليزية والبولندية والتشيكية والروسية، ومقره بروكسل.", focusH:"مجالات التركيز", chips:["استراتيجية الدخول إلى السوق والتنظيم","استشارات مجلس الإدارة والإدارة العليا","العلاقات الحكومية والشؤون العامة","من الاستراتيجية إلى التنفيذ","التموضع المؤسسي والشرعية","تحالفات أصحاب المصلحة عبر الحدود","المخاطر السياسية والتنظيمية","تنظيم القطاعات الناشئة (MiCA / VARA)"], credH:"المؤهلات والخلفية", edu:"LL.B. القانون الأوروبي — جامعة ماستريخت · ماجستير السياسات العامة — UNU-MERIT / ماستريخت", langs:"الإنجليزية · البولندية · التشيكية · الروسية", focus:"الاستراتيجية التنظيمية · الشؤون الحكومية · الوصول إلى السوق", eu:"المفوضية الأوروبية (المديرية العامة للمناخ) · EEAS · مجلس أوروبا · EIPA", based:"بروكسل", ctaEye:"خاص وسري", ctaH:"تحدّث مباشرة مع فريقنا.", ctaP:"تبدأ المشاريع بمحادثة سرية. ARM Management تعمل مع عدد محدود من العملاء في كل مرة.", ctaBtn:"طلب تعريف ←" },
  ru: { title:"Руководство — Якуб Зиенталя, Вице-президент | ARM Management", desc:"Якуб Зиенталя — вице-президент ARM Management, руководящий работой с клиентами и регуляторным направлением компании на международных рынках.", eyebrow:"Руководство", role:"Вице-президент", pos:"Руководит работой с клиентами и регуляторным предложением ARM Management на международных рынках компании.", btn1:"Запросить введение →", btn2:"Наши услуги", profileH:"Профиль", lede:"Якуб Зиенталя — вице-президент ARM Management, где он руководит работой с клиентами и регуляторным предложением компании на международных рынках. Он консультирует топ-менеджмент международных компаний, инвесторов и институтов.", p2:"Он построил карьеру на пересечении европейского регулирования, государственных отношений и доступа на рынок. В качестве директора по европейским и государственным делам трансграничного отраслевого альянса он руководил многолетней кампанией, которая помогла защитить европейский рынок объёмом около €40 млн от неблагоприятного международного регулирования.", p3:"Затем он основал собственную консалтинговую практику, помогая корпорациям, основателям и государственным институтам в выходе на европейский рынок, регуляторном позиционировании и стратегии работы со стейкхолдерами.", p4:"Одинаково комфортно чувствуя себя с генеральным директором, министром или регулятором, Якуб — это советник, к которому обращаются топ-руководители, когда результат зависит от политики и регулирования не меньше, чем от коммерческой стратегии. Консультирует на английском, польском, чешском и русском языках, базируется в Брюсселе.", focusH:"Направления работы", chips:["Стратегия выхода на рынок и регуляторная стратегия","Консультирование совета директоров и C-suite","GR и работа с государственными органами","От стратегии до исполнения","Институциональное позиционирование и легитимность","Трансграничные коалиции стейкхолдеров","Политические и регуляторные риски","Регулирование новых секторов (MiCA / VARA)"], credH:"Образование и опыт", edu:"LL.B. Европейское право — Маастрихтский университет · MA Государственная политика — UNU-MERIT / Маастрихт", langs:"Английский · Польский · Чешский · Русский", focus:"Регуляторная стратегия · Государственные отношения · Доступ на рынок", eu:"Европейская комиссия (DG Clima) · EEAS · Совет Европы · EIPA", based:"Брюссель", ctaEye:"Конфиденциально", ctaH:"Поговорите с нашей командой напрямую.", ctaP:"Проекты начинаются с конфиденциального разговора. ARM Management работает с ограниченным числом клиентов одновременно.", ctaBtn:"Запросить введение →" },
  zh: { title:"领导团队 — 雅库布·任塔拉，副总裁 | ARM Management", desc:"雅库布·任塔拉是ARM Management副总裁，负责领导客户关系及公司在国际市场的监管和市场准入工作。", eyebrow:"领导团队", role:"副总裁", pos:"负责领导ARM Management的客户关系及其在国际市场的监管与市场准入业务。", btn1:"申请介绍 →", btn2:"探索我们的服务", profileH:"个人简介", lede:"雅库布·任塔拉是ARM Management副总裁，负责领导客户关系及公司的监管和市场准入业务。他为国际公司、投资者和机构的高层管理人员提供咨询，在董事会、政府部门和欧盟机构中均游刃有余。", p2:"他的职业生涯建立在欧洲监管、政府事务和市场准入的交叉领域。作为一个跨境行业联盟的欧洲和政府事务总监，他领导了一场历时数年的行动，帮助保护了约4000万欧元的欧洲市场免受不利国际监管的影响，并将此案推进至联合国层面。", p3:"此后，他创立了自己的咨询实践，指导企业、创始人和公共机构开展欧洲市场进入、监管定位和利益相关方战略工作。", p4:"无论面对首席执行官、部长还是监管机构，雅库布都同样得心应手。他是高级管理人员在结果同时取决于政治监管与商业战略时所求助的顾问。他以英语、波兰语、捷克语和俄语提供咨询，常驻布鲁塞尔。", focusH:"专注领域", chips:["市场进入与监管战略","董事会与C级高管咨询","政府关系与公共事务","从战略到执行","机构定位与公信力","跨境利益相关方联盟","政治与监管风险","新兴行业监管（MiCA / VARA）"], credH:"资历与背景", edu:"欧洲法律法学士 — 马斯特里赫特大学 · 公共政策硕士 — UNU-MERIT / 马斯特里赫特", langs:"英语 · 波兰语 · 捷克语 · 俄语", focus:"监管战略 · 政府事务 · 市场准入", eu:"欧洲委员会（气候总司）· EEAS · 欧洲委员会 · EIPA", based:"布鲁塞尔", ctaEye:"私密与保密", ctaH:"直接与我们的团队交流。", ctaP:"项目始于一次保密对话。ARM Management每次只与有限数量的客户合作。", ctaBtn:"申请介绍 →" },
};
const c = L[lang];
---
<PageWrapper lang={lang} title={c.title} description={c.desc} canonicalPath="/leadership">
  <main class="ld">
    <section class="ld-hero" dir={isRTL ? 'rtl' : 'ltr'}>
      <div class="container">
        <span class="eyebrow">{c.eyebrow}</span>
        <h1>Jakub Zientala</h1>
        <div class="ld-role">{c.role}</div>
        <p class="ld-pos">{c.pos}</p>
        <div class="ld-cta">
          <a href={lp('/contact')} class="btn-primary">{c.btn1}</a>
          <a href={lp('/services')} class="btn-secondary">{c.btn2}</a>
        </div>
      </div>
    </section>

    <section class="ld-profile" dir={isRTL ? 'rtl' : 'ltr'}>
      <div class="container ld-grid">
        <div class="ld-portrait">
          <div class="ld-frame"><img src="/images/jakub-zientala.jpg" alt="Jakub Zientala, Vice President of ARM Management" width="900" height="1124" /></div>
          <div class="ld-nameplate"><div class="ld-n">Jakub Zientala</div><div class="ld-t">{c.role}</div></div>
        </div>
        <div class="ld-bio">
          <h2>{c.profileH}</h2><div class="ld-rule"></div>
          <p class="ld-lede">{c.lede}</p>
          <p>{c.p2}</p>
          <p>{c.p3}</p>
          <p>{c.p4}</p>
        </div>
      </div>
    </section>

    <section class="ld-band" dir={isRTL ? 'rtl' : 'ltr'}>
      <div class="container">
        <h3 class="ld-h3">{c.focusH}</h3>
        <div class="ld-focus">
          {c.chips.map((chip: string) => <span class="ld-chip">{chip}</span>)}
        </div>
      </div>
    </section>

    <section class="ld-cred-wrap" dir={isRTL ? 'rtl' : 'ltr'}>
      <div class="container">
        <h3 class="ld-h3">{c.credH}</h3>
        <div class="ld-cred">
          <div class="ld-item"><div class="ld-k">{lang === 'ar' ? 'التعليم' : lang === 'fr' ? 'Formation' : lang === 'es' ? 'Educación' : lang === 'ru' ? 'Образование' : lang === 'zh' ? '教育' : 'Education'}</div><div class="ld-v">{c.edu}</div></div>
          <div class="ld-item"><div class="ld-k">{lang === 'ar' ? 'اللغات' : lang === 'fr' ? 'Langues' : lang === 'es' ? 'Idiomas' : lang === 'ru' ? 'Языки' : lang === 'zh' ? '语言' : 'Languages'}</div><div class="ld-v">{c.langs}</div></div>
          <div class="ld-item"><div class="ld-k">{lang === 'ar' ? 'التركيز' : lang === 'fr' ? 'Spécialisation' : lang === 'es' ? 'Enfoque' : lang === 'ru' ? 'Направление' : lang === 'zh' ? '专注领域' : 'Focus'}</div><div class="ld-v">{c.focus}</div></div>
          <div class="ld-item"><div class="ld-k">{lang === 'ar' ? 'المؤسسات الأوروبية' : lang === 'fr' ? 'Institutions UE' : lang === 'es' ? 'Instituciones UE' : lang === 'ru' ? 'Институты ЕС' : lang === 'zh' ? '欧盟机构' : 'EU institutions'}</div><div class="ld-v">{c.eu}</div></div>
          <div class="ld-item"><div class="ld-k">{lang === 'ar' ? 'المقر' : lang === 'fr' ? 'Basé à' : lang === 'es' ? 'Basado en' : lang === 'ru' ? 'Офис' : lang === 'zh' ? '常驻地' : 'Based'}</div><div class="ld-v">{c.based}</div></div>
        </div>
      </div>
    </section>

    <section class="cta-section" dir={isRTL ? 'rtl' : 'ltr'}>
      <span class="eyebrow is-center" style="justify-content:center">{c.ctaEye}</span>
      <h2>{c.ctaH}</h2>
      <p>{c.ctaP}</p>
      <div class="btn-row">
        <a href={lp('/contact')} class="btn-primary">{c.ctaBtn}</a>
      </div>
    </section>
  </main>
</PageWrapper>
