---
import PageWrapper from './PageWrapper.astro';
import { localePath } from '../i18n/translations';
import type { Locale } from '../i18n/translations';
interface Props { lang: Locale; }
const { lang } = Astro.props;
const lp = (p: string) => localePath(lang, p);
const isRTL = lang === 'ar';
const DATA: Record<string, any> = {"en": {"title": "International Company Formation | ARM Management", "desc": "Incorporate in 40+ jurisdictions across the EU, GCC, Asia, and Latin America.", "eye": "Company Formation", "h1": "International Company\nFormation", "hero": "Incorporate in 40+ jurisdictions. From legal entity selection to VAT registration — fully coordinated.", "whatEye": "What We Do", "whatH": "One Relationship. Every Jurisdiction.", "whatP1": "Setting up a legal entity in a foreign jurisdiction involves far more than filing incorporation documents. It requires selecting the right legal structure, understanding local ownership rules, appointing appropriate directors, registering for tax, opening banking facilities, and ensuring ongoing compliance.", "whatP2": "ARM Management coordinates the entire company formation process across 40+ jurisdictions through a single point of contact. We manage local lawyers, notaries, and incorporation agents on your behalf, and ensure every step is completed correctly and on time.", "svcEye": "Services", "svcH": "The Full Formation Lifecycle", "svcs": [["Legal Entity Selection", "Advising on the optimal legal structure for your jurisdiction, ownership profile, and business purpose — LLC, branch office, holding company, free zone entity, or other structures."], ["Incorporation & Registration", "Managing the full incorporation process including preparation and filing of constitutional documents, shareholder agreements, and all regulatory registrations."], ["VAT & Tax Registration", "Registering for VAT, GST, corporate tax, and other applicable taxes, including obtaining relevant tax identification numbers."], ["Director & Secretary Services", "Providing nominee director and company secretary services where local presence requirements apply, including registered office addresses."], ["Bank Account Opening", "Coordinating corporate bank account opening in the jurisdiction of incorporation, leveraging our relationships with local and international banking institutions."], ["Ongoing Compliance", "Annual filings, director changes, share transfers, and all ongoing statutory requirements managed on your behalf."]], "ctaH": "Ready to Incorporate?", "ctaP": "Tell us where you need to be established and we will give you a clear assessment of the optimal structure, timeline, and cost — before any work begins.", "ctaBtn": "Schedule a Consultation →", "btn2": "View Jurisdiction Guides"}, "fr": {"title": "Création de sociétés à l'international | ARM Management", "desc": "Immatriculation dans 40+ juridictions à travers l'UE, le CCG, l'Asie et l'Amérique latine.", "eye": "Création de sociétés", "h1": "Création de sociétés\nà l'international", "hero": "Immatriculation dans plus de 40 juridictions. Du choix de la structure à l'enregistrement TVA — entièrement coordonné.", "whatEye": "Ce que nous faisons", "whatH": "Une relation. Chaque juridiction.", "whatP1": "La création d'une entité juridique dans une juridiction étrangère implique bien plus que le simple dépôt de documents d'immatriculation. Elle nécessite de choisir la bonne structure juridique, comprendre les règles locales de propriété, nommer des dirigeants appropriés, s'enregistrer aux impôts, ouvrir des facilités bancaires et assurer la conformité continue.", "whatP2": "ARM Management coordonne l'ensemble du processus de création de sociétés dans plus de 40 juridictions via un seul point de contact. Nous gérons les avocats locaux, notaires et agents d'incorporation en votre nom.", "svcEye": "Services", "svcH": "Le cycle complet de création", "svcs": [["Sélection de la structure juridique", "Conseil sur la structure légale optimale pour votre juridiction, votre profil d'actionnariat et votre objet social — SARL, succursale, holding, entité en zone franche ou autres structures."], ["Immatriculation & Enregistrement", "Gestion du processus complet d'immatriculation incluant la préparation et le dépôt des documents constitutifs, des pactes d'actionnaires et de toutes les inscriptions réglementaires."], ["Enregistrement TVA & Fiscal", "Enregistrement à la TVA, à l'impôt sur les sociétés et aux autres taxes applicables, incluant l'obtention des numéros d'identification fiscale."], ["Services de Dirigeant & Secrétaire", "Fourniture de services de dirigeant mandataire et de secrétaire d'entreprise lorsque des exigences de présence locale s'appliquent."], ["Ouverture de compte bancaire", "Coordination de l'ouverture de comptes bancaires d'entreprise dans la juridiction d'immatriculation, en tirant parti de nos relations avec les établissements bancaires locaux et internationaux."], ["Conformité continue", "Dépôts annuels, changements de dirigeants, cessions de parts et toutes les obligations statutaires continues gérées en votre nom."]], "ctaH": "Prêt à vous immatriculer ?", "ctaP": "Dites-nous où vous devez être établi et nous vous fournirons une évaluation claire de la structure optimale, du calendrier et du coût — avant tout début de travaux.", "ctaBtn": "Planifier une consultation →", "btn2": "Guides juridictionnels"}, "es": {"title": "Constitución Internacional de Sociedades | ARM Management", "desc": "Incorporación en 40+ jurisdicciones en la UE, CCG, Asia y América Latina.", "eye": "Constitución de Sociedades", "h1": "Constitución Internacional\nde Sociedades", "hero": "Incorporación en más de 40 jurisdicciones. Desde la selección de entidad hasta el registro de IVA — totalmente coordinado.", "whatEye": "Lo que hacemos", "whatH": "Una relación. Cada jurisdicción.", "whatP1": "Establecer una entidad legal en una jurisdicción extranjera implica mucho más que presentar documentos de incorporación. Requiere seleccionar la estructura legal adecuada, entender las reglas de propiedad locales, nombrar directores apropiados, registrarse para impuestos, abrir facilidades bancarias y garantizar el cumplimiento continuo.", "whatP2": "ARM Management coordina todo el proceso de constitución de sociedades en más de 40 jurisdicciones a través de un único punto de contacto. Gestionamos abogados locales, notarios y agentes de incorporación en su nombre.", "svcEye": "Servicios", "svcH": "El ciclo completo de constitución", "svcs": [["Selección de Entidad Legal", "Asesoría sobre la estructura legal óptima para su jurisdicción, perfil de propiedad y propósito comercial — LLC, sucursal, holding, entidad de zona franca u otras estructuras."], ["Incorporación y Registro", "Gestión del proceso completo de incorporación incluyendo preparación y presentación de documentos constitutivos, acuerdos de accionistas y todos los registros regulatorios."], ["Registro de IVA e Impuestos", "Registro para IVA, impuesto de sociedades y otros impuestos aplicables, incluyendo la obtención de números de identificación fiscal."], ["Servicios de Director y Secretario", "Provisión de servicios de director designado y secretario de empresa donde se aplican requisitos de presencia local."], ["Apertura de Cuenta Bancaria", "Coordinación de apertura de cuentas bancarias corporativas, aprovechando nuestras relaciones con instituciones bancarias locales e internacionales."], ["Cumplimiento Continuo", "Presentaciones anuales, cambios de directores, transferencias de acciones y todos los requisitos estatutarios continuos gestionados en su nombre."]], "ctaH": "¿Listo para incorporarse?", "ctaP": "Díganos dónde necesita estar establecido y le daremos una evaluación clara de la estructura óptima, el plazo y el costo — antes de que comience cualquier trabajo.", "ctaBtn": "Programar una consulta →", "btn2": "Guías jurisdiccionales"}, "ar": {"title": "تأسيس الشركات الدولية | ARM Management", "desc": "التأسيس في 40+ ولاية قضائية عبر الاتحاد الأوروبي ودول الخليج وآسيا وأمريكا اللاتينية.", "eye": "تأسيس الشركات", "h1": "تأسيس الشركات\nالدولية", "hero": "التأسيس في أكثر من 40 ولاية قضائية. من اختيار الكيان القانوني إلى التسجيل الضريبي — منسّق بالكامل.", "whatEye": "ما نقدّمه", "whatH": "علاقة واحدة. كل الولايات القضائية.", "whatP1": "يتضمّن إنشاء كيان قانوني في ولاية قضائية أجنبية ما هو أكثر بكثير من مجرد تقديم وثائق التأسيس. يتطلب اختيار الهيكل القانوني الصحيح، وفهم قواعد الملكية المحلية، وتعيين المديرين المناسبين، والتسجيل الضريبي، وفتح التسهيلات المصرفية، وضمان الامتثال المستمر.", "whatP2": "تنسّق ARM Management عملية تأسيس الشركات بالكامل في أكثر من 40 ولاية قضائية من خلال نقطة تواصل واحدة. ندير المحامين المحليين والموثّقين ووكلاء التأسيس نيابةً عنك.", "svcEye": "الخدمات", "svcH": "دورة التأسيس الكاملة", "svcs": [["اختيار الكيان القانوني", "المشورة بشأن الهيكل القانوني الأمثل لولايتك القضائية وملف الملكية والغرض التجاري — شركة ذات مسؤولية محدودة أو فرع أو شركة قابضة أو كيان في منطقة حرة أو هياكل أخرى."], ["التأسيس والتسجيل", "إدارة عملية التأسيس الكاملة بما في ذلك إعداد وتقديم الوثائق التأسيسية واتفاقيات المساهمين وجميع التسجيلات التنظيمية."], ["التسجيل الضريبي وضريبة القيمة المضافة", "التسجيل لضريبة القيمة المضافة وضريبة الشركات والضرائب الأخرى المطبّقة، بما في ذلك الحصول على أرقام التعريف الضريبية ذات الصلة."], ["خدمات المدير والأمين", "توفير خدمات المدير الاسمي وأمين الشركة حيثما تنطبق متطلبات الحضور المحلي."], ["فتح الحسابات المصرفية", "تنسيق فتح الحسابات المصرفية للشركات بالاستفادة من علاقاتنا مع المؤسسات المصرفية المحلية والدولية."], ["الامتثال المستمر", "الإيداعات السنوية وتغييرات المديرين وتحويلات الأسهم وجميع المتطلبات القانونية المستمرة التي تتم إدارتها نيابةً عنك."]], "ctaH": "هل أنت مستعد للتأسيس؟", "ctaP": "أخبرنا أين تحتاج إلى التأسيس وسنمنحك تقييماً واضحاً للهيكل الأمثل والجدول الزمني والتكلفة — قبل بدء أي عمل.", "ctaBtn": "جدوِّل استشارة ←", "btn2": "أدلة الولايات القضائية"}, "ru": {"title": "Международная регистрация компаний | ARM Management", "desc": "Инкорпорация в 40+ юрисдикциях в ЕС, Заливе, Азии и Латинской Америке.", "eye": "Регистрация компаний", "h1": "Международная\nрегистрация компаний", "hero": "Инкорпорация в 40+ юрисдикциях. От выбора юридической структуры до регистрации НДС — полная координация.", "whatEye": "Что мы делаем", "whatH": "Один контакт. Любая юрисдикция.", "whatP1": "Регистрация юридического лица в иностранной юрисдикции — это гораздо больше, чем подача документов. Требует выбора правильной структуры, понимания местных правил владения, назначения директоров, налоговой регистрации, открытия банковских счетов и обеспечения постоянного комплаенс.", "whatP2": "ARM Management координирует весь процесс регистрации компаний в 40+ юрисдикциях через единый контакт. Мы управляем местными юристами, нотариусами и регистрационными агентами от вашего имени.", "svcEye": "Услуги", "svcH": "Полный цикл регистрации", "svcs": [["Выбор юридической структуры", "Консультирование по оптимальной правовой структуре — ООО, филиал, холдинг, свободная зона и другие."], ["Инкорпорация и регистрация", "Управление полным процессом регистрации, включая подготовку и подачу учредительных документов и всех регуляторных регистраций."], ["Регистрация НДС и налогов", "Регистрация для НДС, корпоративного налога и других применимых налогов, включая получение ИНН."], ["Услуги директора и секретаря", "Предоставление услуг номинального директора и корпоративного секретаря при наличии требований местного присутствия."], ["Открытие банковских счетов", "Координация открытия корпоративных банковских счетов с использованием наших отношений с местными и международными банками."], ["Текущий комплаенс", "Ежегодные подачи, смены директоров, передача акций и все текущие уставные требования."]], "ctaH": "Готовы к инкорпорации?", "ctaP": "Расскажите нам, где вам нужно быть зарегистрированными, и мы дадим чёткую оценку оптимальной структуры, сроков и стоимости — до начала работы.", "ctaBtn": "Записаться на консультацию →", "btn2": "Юрисдикционные гиды"}, "zh": {"title": "国际公司注册 | ARM Management", "desc": "在欧盟、海湾、亚洲和拉丁美洲40+司法管辖区注册公司。", "eye": "公司注册", "h1": "国际公司\n注册", "hero": "在欧盟、海湾、亚洲和拉丁美洲40余个司法管辖区注册公司。从法律实体选择到增值税注册——全程协调。", "whatEye": "我们的服务内容", "whatH": "一个关系。覆盖每个司法管辖区。", "whatP1": "在境外司法管辖区设立法律实体远不止于提交注册文件。需要选择正确的法律结构、了解当地所有权规则、任命适当的董事、进行税务登记、开设银行账户并确保持续合规。", "whatP2": "ARM Management通过单一联络点协调40余个司法管辖区的整个公司注册流程。我们代表您管理当地律师、公证人和注册代理。", "svcEye": "服务", "svcH": "完整的注册生命周期", "svcs": [["法律实体选择", "就司法管辖区、所有权结构和业务目的的最优法律结构提供建议——有限责任公司、分支机构、控股公司、自由区实体或其他结构。"], ["注册成立", "管理完整注册流程，包括准备和提交组织文件、股东协议及所有监管注册。"], ["增值税和税务注册", "注册增值税、企业所得税及其他适用税种，包括获取相关税务识别号码。"], ["董事和秘书服务", "在适用当地存在要求时提供名义董事和公司秘书服务，包括注册办公地址。"], ["银行账户开设", "协调开设公司银行账户，利用我们与当地和国际银行机构的关系。"], ["持续合规", "代表您管理年度申报、董事变更、股权转让及所有持续法定要求。"]], "ctaH": "准备好注册公司了吗？", "ctaP": "告诉我们您需要在哪里成立，我们将提供关于最优结构、时间线和成本的清晰评估——在任何工作开始之前。", "ctaBtn": "预约咨询 →", "btn2": "司法管辖区指南"}};
const c = DATA[lang];
---
<PageWrapper lang={lang} title={c.title} description={c.desc} canonicalPath="/services/company-formation">
<main dir={isRTL ? 'rtl' : 'ltr'}>
  <section class="page-hero">
    <div class="page-hero__bg" style="background-image:url('https://images.unsplash.com/photo-1507679799987-c73779587ccf?w=1600&q=80&auto=format&fit=crop')"></div>
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content container">
      <span class="eyebrow">{c.eye}</span>
      <h1 set:html={c.h1.replace('\n','<br>')}></h1>
      <p>{c.hero}</p>
      <div class="btn-row" style="justify-content:flex-start;margin-top:30px">
        <a href={lp('/contact')} class="btn-primary">{c.ctaBtn}</a>
        <a href={lp('/services')} class="btn-secondary">{c.btn2}</a>
      </div>
    </div>
  </section>
  <section class="section section--cream">
    <div class="container--narrow">
      <span class="eyebrow reveal">{c.whatEye}</span>
      <h2 class="reveal">{c.whatH}</h2>
      <div class="gold-rule reveal"></div>
      <p class="reveal">{c.whatP1}</p>
      <p class="reveal" style="margin-top:20px">{c.whatP2}</p>
    </div>
  </section>
  <section class="section section--warm" style="border-top:1px solid #E2DDD6">
    <div class="container">
      <span class="eyebrow reveal">{c.svcEye}</span>
      <h2 class="reveal">{c.svcH}</h2>
      <div class="gold-rule reveal"></div>
      <div class="grid-3" style="margin-top:40px">
        {c.svcs.map(([h, p]: [string,string], i: number) => (
          <div class={`card reveal reveal-delay-${(i%3)+1}`}><h3>{h}</h3><p>{p}</p></div>
        ))}
      </div>
    </div>
  </section>
  <section class="cta-section">
    <h2 class="reveal">{c.ctaH}</h2>
    <p class="reveal reveal-delay-1">{c.ctaP}</p>
    <div class="btn-row reveal reveal-delay-2">
      <a href={lp('/contact')} class="btn-primary">{c.ctaBtn}</a>
    </div>
  </section>
</main>
</PageWrapper>
