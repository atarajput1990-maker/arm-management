---
import PageWrapper from './PageWrapper.astro';
import { localePath } from '../i18n/translations';
import type { Locale } from '../i18n/translations';
interface Props { lang: Locale; }
const { lang } = Astro.props;
const lp = (p: string) => localePath(lang, p);
const isRTL = lang === 'ar';
const DATA: Record<string, any> = {"en": {"title": "Crypto & Web3 Advisory | ARM Management", "desc": "VARA licence advisory, MiCA CASP authorisation, token structuring, DAO legal frameworks, and crypto company formation.", "eye": "Crypto & Web3", "h1": "Crypto & Web3 Advisory", "hero": "VARA · MiCA · MAS · SFC · VASP licensing and regulatory strategy across major crypto jurisdictions.", "whatEye": "What We Do", "whatH": "Regulated Crypto Operations, Built Correctly.", "whatP1": "The regulatory environment for virtual assets and Web3 businesses has changed dramatically. The UAE's VARA framework, the EU's MiCA regulation, and licensing regimes in Singapore, Hong Kong, and other major jurisdictions have created clear pathways for compliant crypto operations — and equally clear consequences for those who operate without the correct licences.", "whatP2": "ARM Management advises exchanges, DeFi protocols, NFT platforms, token issuers, DAOs, and Web3 infrastructure businesses on regulatory strategy across major crypto jurisdictions. We combine legal structuring, regulatory advisory, and AML programme design into a single coordinated engagement.", "svcEye": "Our Services", "svcH": "What We Advise On", "svcs": [["VARA Licence Advisory (Dubai)", "Full advisory on the VARA licensing process in Dubai — from initial eligibility assessment and category selection through to application preparation, regulatory engagement, and post-licence compliance."], ["MiCA Compliance (EU)", "Advising crypto-asset service providers on MiCA authorisation in EU member states — regulatory readiness assessments, application strategy, and ongoing CASP compliance."], ["Token Structuring & Legal Analysis", "Legal analysis of token structures to determine regulatory classification — utility, security, e-money, or hybrid — and advising on the appropriate issuance jurisdiction and structure."], ["DAO Legal Frameworks", "Advising on the legal structuring of DAOs — foundation models, Swiss associations, Marshall Islands LLCs, and other frameworks that provide legal personality to decentralised organisations."], ["Crypto Company Formation", "Establishing crypto and Web3 businesses in VARA (Dubai), ADGM, DIFC, Cayman, BVI, Malta (MiCA), Singapore, and other major crypto jurisdictions."], ["AML/CFT Programme Design", "Designing AML/CFT programmes that meet the specific requirements of virtual asset service providers under FATF guidance, VARA rules, MiCA, and local regulations."]], "ctaH": "Discuss Your Regulatory Strategy", "ctaP": "Whether you are applying for a VARA licence, structuring for MiCA, or building a compliant Web3 business from scratch, the right regulatory strategy is the foundation. Begin with a confidential assessment.", "ctaBtn": "Schedule a Consultation →", "btn2": "Our Services", "apprEye": "The ARM Approach", "apprH": "Regulation as a Competitive Advantage.", "apprP": "Most crypto businesses treat regulation as a constraint to be minimised. The businesses that will lead the next cycle treat it as a structural advantage — they are licensed, audited, and operating with institutional-grade compliance while competitors are still figuring out their structure. ARM Management advises clients who want to be in the first group.", "principles": [["Jurisdiction Selection", "Selecting the right jurisdiction is the first and most consequential decision — VARA, MiCA, MAS, SFC, and other frameworks each have different capital requirements, timelines, and operational restrictions."], ["Regulatory Engagement Strategy", "How you engage with the regulator during the application process affects approval probability and ongoing supervisory relationship. ARM advises on positioning, communication, and expectation management."], ["AML/CFT Programme Design", "Virtual asset regulators scrutinise AML programmes closely. ARM designs programmes that meet the specific requirements of FATF guidance, VARA rules, MiCA, and local regulations."], ["Post-Licence Compliance", "Getting the licence is step one. ARM supports ongoing compliance obligations — regulatory reporting, policy updates, training, and responding to supervisory queries."]], "jurEye": "Jurisdictions", "jurH": "Where We Advise", "regions": [["Dubai (VARA)", "The UAE's Virtual Assets Regulatory Authority. VARA licences cover exchanges, brokers, advisors, custodians, and transfer and settlement services."], ["EU (MiCA)", "Markets in Crypto-Assets Regulation. CASP authorisation across all 27 EU member states. Passporting to operate EU-wide from a single member state."], ["Singapore (MAS)", "Monetary Authority of Singapore. Major Payment Institution licence for digital payment token services. Variable Capital Company structures."], ["Hong Kong (SFC)", "Securities and Futures Commission. Type 1 and Type 7 licences for virtual asset trading platforms. VASP licence under AMLO."]]}, "fr": {"title": "Conseil Crypto & Web3 | ARM Management", "desc": "Conseil en licence VARA, autorisation CASP MiCA, structuration de tokens, cadres juridiques DAO et création d'entités crypto.", "eye": "Crypto & Web3", "h1": "Conseil Crypto\net Web3", "hero": "VARA · MiCA · MAS · SFC · Licences VASP et stratégie réglementaire dans les principales juridictions crypto.", "whatEye": "Ce que nous faisons", "whatH": "Des opérations crypto régulées, construites correctement.", "whatP1": "L'environnement réglementaire pour les actifs virtuels et les entreprises Web3 a radicalement évolué. Le cadre VARA des EAU, le règlement MiCA de l'UE et les régimes de licence à Singapour, Hong Kong et d'autres grandes juridictions ont créé des voies claires pour des opérations crypto conformes.", "whatP2": "ARM Management conseille les exchanges, protocoles DeFi, plateformes NFT, émetteurs de tokens, DAOs et entreprises d'infrastructure Web3 sur la stratégie réglementaire dans les principales juridictions crypto.", "svcEye": "Nos services", "svcH": "Ce sur quoi nous conseillons", "svcs": [["Conseil en licence VARA (Dubaï)", "Conseil complet sur le processus de licence VARA à Dubaï — de l'évaluation d'éligibilité initiale à la préparation de la demande et à la conformité post-licence."], ["Conformité MiCA (UE)", "Conseil aux prestataires de services sur actifs cryptographiques pour l'autorisation MiCA — évaluations de la préparation réglementaire et stratégie de demande."], ["Structuration de tokens & analyse juridique", "Analyse juridique des structures de tokens pour déterminer la classification réglementaire — utilitaire, valeur mobilière, monnaie électronique ou hybride."], ["Cadres juridiques DAO", "Conseil sur la structuration juridique des DAOs — modèles de fondation, associations suisses, LLC des Îles Marshall et autres cadres."], ["Création d'entités crypto", "Établissement d'entreprises crypto et Web3 à VARA (Dubaï), ADGM, DIFC, Caïmans, BVI, Malte (MiCA), Singapour et autres."], ["Conception de programme LBC/FT", "Conception de programmes LBC/FT répondant aux exigences spécifiques des prestataires de services sur actifs virtuels."]], "ctaH": "Discutez de votre stratégie réglementaire", "ctaP": "Que vous demandiez une licence VARA, structuriez pour MiCA ou construisiez une entreprise Web3 conforme depuis le début, la bonne stratégie réglementaire est le fondement.", "ctaBtn": "Planifier une consultation →", "btn2": "Nos services", "apprEye": "L'approche ARM", "apprH": "La réglementation comme avantage concurrentiel.", "apprP": "La plupart des entreprises crypto traitent la réglementation comme une contrainte à minimiser. Les entreprises qui mèneront le prochain cycle la traitent comme un avantage structurel — elles sont licenciées, auditées et opèrent avec une conformité de qualité institutionnelle. ARM Management conseille les clients qui veulent être dans ce premier groupe.", "principles": [["Sélection de la juridiction", "Choisir la bonne juridiction est la première décision et la plus importante — VARA, MiCA, MAS, SFC et autres cadres ont des exigences de capital, des délais et des restrictions opérationnelles différents."], ["Stratégie d'engagement réglementaire", "La façon dont vous engagez le régulateur pendant le processus de demande affecte la probabilité d'approbation et la relation de supervision continue."], ["Conception du programme LBC/FT", "Les régulateurs d'actifs virtuels scrutent attentivement les programmes LBC. ARM conçoit des programmes répondant aux exigences GAFI, règles VARA, MiCA et réglementations locales."], ["Conformité post-licence", "Obtenir la licence est la première étape. ARM soutient les obligations de conformité continues — reporting réglementaire, mises à jour des politiques, formation et réponse aux questions de supervision."]], "jurEye": "Juridictions", "jurH": "Où nous conseillons", "regions": [["Dubaï (VARA)", "L'Autorité de Réglementation des Actifs Virtuels des EAU. Les licences VARA couvrent les exchanges, courtiers, conseillers, dépositaires et services de transfert et règlement."], ["UE (MiCA)", "Règlement sur les Marchés de Crypto-Actifs. Autorisation CASP dans les 27 États membres. Passeportisation pour opérer dans toute l'UE depuis un seul État membre."], ["Singapour (MAS)", "Autorité Monétaire de Singapour. Licence d'Institution de Paiement Majeure pour les services de jetons de paiement numériques. Structures VCC."], ["Hong Kong (SFC)", "Commission des Valeurs Mobilières et des Contrats à Terme. Licences de type 1 et 7 pour les plateformes de trading d'actifs virtuels. Licence VASP."]]}, "es": {"title": "Asesoría Crypto y Web3 | ARM Management", "desc": "Asesoría de licencia VARA, autorización CASP MiCA, estructuración de tokens, marcos legales DAO y constitución de entidades crypto.", "eye": "Crypto & Web3", "h1": "Asesoría Crypto\ny Web3", "hero": "VARA · MiCA · MAS · SFC · Licencias VASP y estrategia regulatoria en las principales jurisdicciones crypto.", "whatEye": "Lo que hacemos", "whatH": "Operaciones crypto reguladas, construidas correctamente.", "whatP1": "El entorno regulatorio para los activos virtuales y los negocios Web3 ha cambiado drásticamente. El marco VARA de los EAU, el reglamento MiCA de la UE y los regímenes de licencias en Singapur, Hong Kong y otras jurisdicciones principales han creado vías claras para operaciones crypto conformes.", "whatP2": "ARM Management asesora a exchanges, protocolos DeFi, plataformas NFT, emisores de tokens, DAOs y empresas de infraestructura Web3 sobre estrategia regulatoria.", "svcEye": "Nuestros servicios", "svcH": "En qué asesoramos", "svcs": [["Asesoría de Licencia VARA (Dubai)", "Asesoría completa sobre el proceso de licencia VARA en Dubai — desde la evaluación de elegibilidad hasta la preparación de la solicitud y el cumplimiento post-licencia."], ["Cumplimiento MiCA (UE)", "Asesoría a proveedores de servicios de criptoactivos sobre la autorización MiCA — evaluaciones de preparación regulatoria y estrategia de solicitud."], ["Estructuración de Tokens & Análisis Legal", "Análisis legal de estructuras de tokens para determinar la clasificación regulatoria — utilidad, valor mobiliario, dinero electrónico o híbrido."], ["Marcos Legales DAO", "Asesoría sobre la estructuración legal de DAOs — modelos de fundación, asociaciones suizas, LLC de Islas Marshall y otros marcos."], ["Constitución de Empresas Crypto", "Establecimiento de empresas crypto y Web3 en VARA (Dubai), ADGM, DIFC, Caimán, BVI, Malta (MiCA), Singapur y otros."], ["Diseño de Programa AML/CFT", "Diseño de programas AML/CFT que cumplen con los requisitos específicos de los proveedores de servicios de activos virtuales."]], "ctaH": "Discuta su estrategia regulatoria", "ctaP": "Ya sea que esté solicitando una licencia VARA, estructurando para MiCA o construyendo un negocio Web3 conforme desde cero, la estrategia regulatoria correcta es el fundamento.", "ctaBtn": "Programar una consulta →", "btn2": "Nuestros servicios", "apprEye": "El enfoque ARM", "apprH": "La regulación como ventaja competitiva.", "apprP": "La mayoría de las empresas crypto tratan la regulación como una restricción a minimizar. Las empresas que liderarán el próximo ciclo la tratan como una ventaja estructural — están licenciadas, auditadas y operando con cumplimiento de grado institucional. ARM Management asesora a clientes que quieren estar en ese primer grupo.", "principles": [["Selección de jurisdicción", "Seleccionar la jurisdicción correcta es la primera y más importante decisión — VARA, MiCA, MAS, SFC y otros marcos tienen diferentes requisitos de capital, plazos y restricciones operativas."], ["Estrategia de compromiso regulatorio", "Cómo se involucra con el regulador durante el proceso de solicitud afecta la probabilidad de aprobación y la relación de supervisión continua."], ["Diseño de programa AML/CFT", "Los reguladores de activos virtuales examinan de cerca los programas AML. ARM diseña programas que cumplen con los requisitos específicos de la guía GAFI, reglas VARA, MiCA y regulaciones locales."], ["Cumplimiento post-licencia", "Obtener la licencia es el primer paso. ARM apoya las obligaciones de cumplimiento continuas — informes regulatorios, actualizaciones de políticas, capacitación y respuesta a consultas supervisoras."]], "jurEye": "Jurisdicciones", "jurH": "Dónde asesoramos", "regions": [["Dubái (VARA)", "La Autoridad Reguladora de Activos Virtuales de los EAU. Las licencias VARA cubren exchanges, corredores, asesores, custodios y servicios de transferencia y liquidación."], ["UE (MiCA)", "Regulación de Mercados en Criptoactivos. Autorización CASP en los 27 Estados miembros. Pasaportización para operar en toda la UE desde un único Estado miembro."], ["Singapur (MAS)", "Autoridad Monetaria de Singapur. Licencia de Institución de Pago Principal para servicios de tokens de pago digital. Estructuras VCC."], ["Hong Kong (SFC)", "Comisión de Valores y Futuros. Licencias tipo 1 y 7 para plataformas de trading de activos virtuales. Licencia VASP bajo AMLO."]]}, "ar": {"title": "استشارات العملات الرقمية وWeb3 | ARM Management", "desc": "استشارات ترخيص VARA، وترخيص CASP وفق MiCA، وهيكلة الرموز، والأطر القانونية لـ DAO، وتأسيس شركات العملات الرقمية.", "eye": "العملات الرقمية وWeb3", "h1": "استشارات العملات\nالرقمية وWeb3", "hero": "VARA · MiCA · MAS · SFC · تراخيص VASP والاستراتيجية التنظيمية عبر الولايات القضائية الرئيسية للعملات الرقمية.", "whatEye": "ما نقدّمه", "whatH": "عمليات مشفّرة منظّمة، مبنية بشكل صحيح.", "whatP1": "تغيّر البيئة التنظيمية للأصول الافتراضية وأعمال Web3 بشكل جذري. أنشأ إطار VARA الإماراتي ولوائح MiCA الأوروبية وأنظمة الترخيص في سنغافورة وهونغ كونغ مسارات واضحة للعمليات المشفّرة المتوافقة.", "whatP2": "تقدّم ARM Management الاستشارات للبورصات وبروتوكولات DeFi ومنصات NFT ومُصدري الرموز وـ DAOs وشركات البنية التحتية لـ Web3 حول الاستراتيجية التنظيمية.", "svcEye": "خدماتنا", "svcH": "ما نستشير فيه", "svcs": [["استشارات ترخيص VARA (دبي)", "استشارات شاملة حول عملية ترخيص VARA في دبي — من تقييم الأهلية الأولي واختيار الفئة إلى إعداد الطلب والامتثال بعد الترخيص."], ["الامتثال لـ MiCA (الاتحاد الأوروبي)", "المشورة لمقدمي خدمات الأصول المشفّرة بشأن الترخيص وفق MiCA في الدول الأعضاء في الاتحاد الأوروبي."], ["هيكلة الرموز والتحليل القانوني", "التحليل القانوني لهياكل الرموز لتحديد التصنيف التنظيمي — فائدة أو أوراق مالية أو نقود إلكترونية أو هجينة."], ["الأطر القانونية لـ DAO", "المشورة بشأن الهيكلة القانونية لـ DAOs — نماذج المؤسسات والجمعيات السويسرية وشركات جزر مارشال والأطر الأخرى."], ["تأسيس شركات العملات الرقمية", "إنشاء أعمال العملات الرقمية وWeb3 في VARA (دبي) وADGM وDIFC وجزر كايمان وجزر العذراء البريطانية ومالطا (MiCA) وسنغافورة وغيرها."], ["تصميم برامج مكافحة غسل الأموال", "تصميم برامج مكافحة غسل الأموال التي تلبّي المتطلبات المحددة لمقدمي خدمات الأصول الافتراضية."]], "ctaH": "ناقش استراتيجيتك التنظيمية", "ctaP": "سواء كنت تتقدم للحصول على ترخيص VARA أو تُهيكل لـ MiCA أو تبني عمل Web3 متوافق من الصفر، فإن الاستراتيجية التنظيمية الصحيحة هي الأساس.", "ctaBtn": "جدوِّل استشارة ←", "btn2": "خدماتنا", "apprEye": "نهج ARM", "apprH": "التنظيم كميزة تنافسية.", "apprP": "معظم الشركات المشفّرة تتعامل مع التنظيم باعتباره قيداً يجب تقليصه. الشركات التي ستقود الدورة القادمة تتعامل معه كميزة هيكلية — مرخّصة ومراجَعة وتعمل بامتثال على مستوى المؤسسات. ARM Management تستشير العملاء الراغبين في الانضمام إلى هذه المجموعة الأولى.", "principles": [["اختيار الولاية القضائية", "اختيار الولاية القضائية الصحيحة هو القرار الأول والأكثر أهمية — لـ VARA وMiCA وMAS وSFC وأطر أخرى متطلبات رأس مال ومواعيد وقيود تشغيلية مختلفة."], ["استراتيجية التعامل التنظيمي", "طريقة تعاملك مع الجهة التنظيمية خلال عملية التقديم تؤثر على احتمالية الموافقة والعلاقة الإشرافية المستمرة."], ["تصميم برنامج مكافحة غسل الأموال", "تُدقّق جهات تنظيم الأصول الافتراضية في برامج مكافحة غسل الأموال. ARM تصمم برامج تلبّي المتطلبات المحددة لإرشادات FATF وقواعد VARA وMiCA واللوائح المحلية."], ["الامتثال ما بعد الترخيص", "الحصول على الترخيص هو الخطوة الأولى. ARM تدعم التزامات الامتثال المستمرة — التقارير التنظيمية وتحديثات السياسات والتدريب والردود على الاستفسارات الإشرافية."]], "jurEye": "الولايات القضائية", "jurH": "أين نستشير", "regions": [["دبي (VARA)", "هيئة تنظيم الأصول الافتراضية في الإمارات. تغطي تراخيص VARA البورصات والوسطاء والمستشارين وأمناء الحفظ وخدمات التحويل والتسوية."], ["الاتحاد الأوروبي (MiCA)", "لائحة أسواق الأصول المشفّرة. ترخيص CASP في الدول الأعضاء الـ27. التجوازية للعمل في جميع أنحاء الاتحاد الأوروبي من دولة عضو واحدة."], ["سنغافورة (MAS)", "هيئة النقد في سنغافورة. ترخيص مؤسسة الدفع الرئيسية لخدمات رموز الدفع الرقمي. هياكل VCC."], ["هونغ كونغ (SFC)", "هيئة الأوراق المالية والعقود الآجلة. تراخيص النوع 1 و7 لمنصات تداول الأصول الافتراضية. ترخيص VASP."]]}, "ru": {"title": "Крипто и Web3-консалтинг | ARM Management", "desc": "Консалтинг по лицензии VARA, авторизация CASP по MiCA, структурирование токенов, юридические рамки DAO и регистрация крипто-компаний.", "eye": "Крипто и Web3", "h1": "Крипто и Web3\nконсалтинг", "hero": "VARA · MiCA · MAS · SFC · Лицензирование VASP и регуляторная стратегия в ведущих крипто-юрисдикциях.", "whatEye": "Что мы делаем", "whatH": "Регулируемые крипто-операции, выстроенные правильно.", "whatP1": "Регуляторная среда для виртуальных активов и Web3-бизнесов кардинально изменилась. Фреймворк VARA ОАЭ, регламент MiCA ЕС и режимы лицензирования в Сингапуре и Гонконге создали чёткие пути для соответствующих крипто-операций.", "whatP2": "ARM Management консультирует биржи, DeFi-протоколы, NFT-платформы, эмитентов токенов, DAO и инфраструктурные Web3-компании по регуляторной стратегии.", "svcEye": "Услуги", "svcH": "Что мы делаем", "svcs": [["Консалтинг по лицензии VARA (Дубай)", "Полный консалтинг по процессу лицензирования VARA в Дубае — от оценки приемлемости до подачи заявки и пост-лицензионного комплаенс."], ["Комплаенс MiCA (ЕС)", "Консультирование поставщиков услуг криптоактивов по авторизации MiCA в государствах-членах ЕС."], ["Структурирование токенов и юридический анализ", "Юридический анализ структур токенов для определения регуляторной классификации — утилитарные, ценные бумаги, электронные деньги или гибридные."], ["Юридические рамки DAO", "Консультирование по юридическому структурированию DAO — модели фондов, швейцарские ассоциации, LLC Маршалловых островов."], ["Регистрация крипто-компаний", "Создание крипто и Web3-бизнесов в VARA (Дубай), ADGM, DIFC, Каймановых островах, BVI, Мальте (MiCA), Сингапуре и других."], ["Разработка программ ПОД/ФТ", "Разработка программ ПОД/ФТ, соответствующих требованиям поставщиков услуг виртуальных активов."]], "ctaH": "Обсудите регуляторную стратегию", "ctaP": "Будь то получение лицензии VARA, структурирование под MiCA или создание комплаентного Web3-бизнеса с нуля — правильная регуляторная стратегия является основой.", "ctaBtn": "Записаться на консультацию →", "btn2": "Наши услуги", "apprEye": "Подход ARM", "apprH": "Регулирование как конкурентное преимущество.", "apprP": "Большинство крипто-бизнесов относятся к регулированию как к ограничению. Компании, которые возглавят следующий цикл, рассматривают его как структурное преимущество — они лицензированы, проходят аудит и работают с комплаенс институционального уровня. ARM Management консультирует клиентов, желающих войти в эту первую группу.", "principles": [["Выбор юрисдикции", "Выбор правильной юрисдикции — первое и наиболее значимое решение. VARA, MiCA, MAS, SFC и другие фреймворки имеют разные требования к капиталу, сроки и операционные ограничения."], ["Стратегия взаимодействия с регулятором", "То, как вы взаимодействуете с регулятором в процессе подачи заявки, влияет на вероятность одобрения и последующие надзорные отношения."], ["Разработка программы ПОД/ФТ", "Регуляторы виртуальных активов тщательно проверяют программы ПОД. ARM разрабатывает программы, соответствующие требованиям FATF, правилам VARA, MiCA и местным нормам."], ["Пост-лицензионный комплаенс", "Получение лицензии — это первый шаг. ARM поддерживает текущие обязательства по комплаенс — регуляторная отчётность, обновление политик, обучение и ответы на надзорные запросы."]], "jurEye": "Юрисдикции", "jurH": "Где мы консультируем", "regions": [["Дубай (VARA)", "Регулятор виртуальных активов ОАЭ. Лицензии VARA охватывают биржи, брокеров, советников, кастодиев и услуги перевода и расчётов."], ["ЕС (MiCA)", "Регламент о рынках криптоактивов. Авторизация CASP во всех 27 государствах-членах. Паспортизация для работы по всему ЕС из одного государства."], ["Сингапур (MAS)", "Монетарное управление Сингапура. Лицензия Major Payment Institution для услуг цифровых платёжных токенов. Структуры VCC."], ["Гонконг (SFC)", "Комиссия по ценным бумагам и фьючерсам. Лицензии Type 1 и Type 7 для платформ торговли виртуальными активами. Лицензия VASP."]]}, "zh": {"title": "加密货币与Web3咨询 | ARM Management", "desc": "VARA牌照咨询、MiCA CASP授权、代币架构、DAO法律框架及加密货币公司注册。", "eye": "加密货币与Web3", "h1": "加密货币与\nWeb3咨询", "hero": "VARA · MiCA · MAS · SFC · 主要加密货币司法管辖区的VASP许可及监管战略。", "whatEye": "我们的服务内容", "whatH": "合规的加密货币运营，从正确的架构开始。", "whatP1": "虚拟资产和Web3业务的监管环境已发生根本性变化。阿联酋VARA框架、欧盟MiCA法规以及新加坡、香港等主要司法管辖区的许可制度，为合规的加密货币运营创造了清晰的路径。", "whatP2": "ARM Management为交易所、DeFi协议、NFT平台、代币发行方、DAO和Web3基础设施企业提供主要加密货币司法管辖区的监管战略咨询。", "svcEye": "服务", "svcH": "咨询范围", "svcs": [["VARA牌照咨询（迪拜）", "关于迪拜VARA许可流程的全面咨询——从初始资格评估和类别选择到申请准备、监管沟通和许可后合规。"], ["MiCA合规（欧盟）", "就欧盟成员国MiCA授权为加密资产服务提供商提供咨询——监管准备评估、申请策略和持续CASP合规。"], ["代币架构与法律分析", "对代币结构进行法律分析以确定监管分类——效用代币、证券代币、电子货币代币或混合代币。"], ["DAO法律框架", "就DAO的法律架构提供咨询——基金会模式、瑞士协会、马绍尔群岛LLC及其他框架。"], ["加密货币公司注册", "在VARA（迪拜）、ADGM、DIFC、开曼群岛、英属维尔京群岛、马耳他（MiCA）、新加坡等主要加密货币司法管辖区建立加密货币和Web3企业。"], ["反洗钱/打击恐怖主义融资计划设计", "设计满足FATF指南、VARA规则、MiCA及当地法规规定的虚拟资产服务提供商特定要求的AML/CFT计划。"]], "ctaH": "讨论您的监管战略", "ctaP": "无论您是在申请VARA牌照、为MiCA进行架构，还是从零开始构建合规的Web3业务，正确的监管战略都是基础。", "ctaBtn": "预约咨询 →", "btn2": "我们的服务", "apprEye": "ARM方法", "apprH": "将监管转化为竞争优势。", "apprP": "大多数加密货币企业将监管视为需要最小化的约束。将引领下一个周期的企业将其视为结构性优势——他们已获许可、接受审计，以机构级合规运营。ARM Management为希望属于第一类的客户提供咨询。", "principles": [["司法管辖区选择", "选择正确的司法管辖区是第一个也是最关键的决定——VARA、MiCA、MAS、SFC及其他框架各有不同的资本要求、时间表和运营限制。"], ["监管参与策略", "在申请过程中与监管机构的沟通方式影响审批概率和持续的监管关系。"], ["AML/CFT计划设计", "虚拟资产监管机构密切审查AML计划。ARM设计符合FATF指南、VARA规则、MiCA及当地法规特定要求的计划。"], ["许可后合规", "获得许可证是第一步。ARM支持持续合规义务——监管报告、政策更新、培训及回应监管问询。"]], "jurEye": "司法管辖区", "jurH": "咨询覆盖范围", "regions": [["迪拜（VARA）", "阿联酋虚拟资产监管局。VARA许可证覆盖交易所、经纪商、顾问、托管人及转账和结算服务。"], ["欧盟（MiCA）", "加密资产市场法规。在全部27个成员国的CASP授权。从单一成员国获得在全欧盟运营的通行权。"], ["新加坡（MAS）", "新加坡金融管理局。数字支付代币服务的主要支付机构牌照。可变资本公司架构。"], ["香港（SFC）", "证券及期货事务监察委员会。虚拟资产交易平台的1类和7类牌照。AMLO下的VASP牌照。"]]}};
const c = DATA[lang];
---
<PageWrapper lang={lang} title={c.title} description={c.desc} canonicalPath="/services/crypto-web3">
<main dir={isRTL ? 'rtl' : 'ltr'}>
  <section class="page-hero">
    <div class="page-hero__bg" style="background-image:url('https://images.unsplash.com/photo-1639762681485-074b7f938ba0?w=1600&q=80&auto=format&fit=crop')"></div>
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content container">
      <span class="eyebrow">{c.eye}</span>
      <h1 set:html={c.h1.replace('\n','<br>')}></h1>
      <p>{c.hero}</p>
      <div class="btn-row" style="justify-content:flex-start;margin-top:30px">
        <a href={lp('/contact')} class="btn-primary">{c.ctaBtn}</a>
        <a href={lp('/services')} class="btn-secondary">{c.btn2}</a>
      </div>
    </div>
  </section>
  <section class="section section--cream">
    <div class="container--narrow">
      <span class="eyebrow reveal">{c.whatEye}</span>
      <h2 class="reveal">{c.whatH}</h2>
      <div class="gold-rule reveal"></div>
      <p class="reveal">{c.whatP1}</p>
      <p class="reveal" style="margin-top:20px">{c.whatP2}</p>
    </div>
  </section>
  <section class="section section--warm" style="border-top:1px solid #E2DDD6">
    <div class="container">
      <span class="eyebrow reveal">{c.svcEye}</span>
      <h2 class="reveal">{c.svcH}</h2>
      <div class="gold-rule reveal"></div>
      <div class="grid-3" style="margin-top:40px">
        {c.svcs.map(([h, p]: [string,string], i: number) => (
          <div class={`card reveal reveal-delay-${(i%3)+1}`}><h3>{h}</h3><p>{p}</p></div>
        ))}
      </div>
    </div>
  </section>
  <section class="section section--navy">
    <div class="container--narrow">
      <span class="eyebrow reveal" style="color:#B8960C">{c.apprEye}</span>
      <h2 class="reveal" style="color:#F7F3EC">{c.apprH}</h2>
      <div class="gold-rule reveal"></div>
      <p class="reveal" style="color:rgba(247,243,236,.78)">{c.apprP}</p>
      <div style="margin-top:48px;display:grid;grid-template-columns:repeat(2,1fr);gap:32px">
        {c.principles.map(([h, p]: [string,string], i: number) => (
          <div class={`reveal reveal-delay-${(i%2)+1}`} style="border-top:1px solid rgba(184,150,12,.3);padding-top:20px">
            <h4 style="font-family:'Inter',sans-serif;font-size:12px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:#B8960C;margin-bottom:10px">{h}</h4>
            <p style="color:rgba(247,243,236,.65);font-size:15px;line-height:1.75">{p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  <section class="section section--cream" style="border-top:1px solid #E2DDD6">
    <div class="container--narrow">
      <span class="eyebrow reveal">{c.jurEye}</span>
      <h2 class="reveal">{c.jurH}</h2>
      <div class="gold-rule reveal"></div>
      <div class="reveal" style="display:grid;grid-template-columns:repeat(2,1fr);gap:24px;margin-top:32px">
        {c.regions.map(([h, p]: [string,string]) => (
          <div style="padding:24px;background:#FDFAF6;border:1px solid #E2DDD6;border-radius:2px">
            <h4 style="font-size:16px;margin-bottom:8px">{h}</h4>
            <p style="font-size:14px;color:#6B7280;line-height:1.65">{p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  <section class="cta-section">
    <h2 class="reveal">{c.ctaH}</h2>
    <p class="reveal reveal-delay-1">{c.ctaP}</p>
    <div class="btn-row reveal reveal-delay-2">
      <a href={lp('/contact')} class="btn-primary">{c.ctaBtn}</a>
    </div>
  </section>
</main>
</PageWrapper>
