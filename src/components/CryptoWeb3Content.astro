---
import PageWrapper from './PageWrapper.astro';
import { localePath } from '../i18n/translations';
import type { Locale } from '../i18n/translations';
interface Props { lang: Locale; }
const { lang } = Astro.props;
const lp = (p: string) => localePath(lang, p);
const isRTL = lang === 'ar';
const DATA: Record<string, any> = {"en": {"title": "Crypto & Web3 Advisory | ARM Management", "desc": "VARA licence advisory, MiCA CASP authorisation, token structuring, DAO legal frameworks, and crypto company formation.", "eye": "Crypto & Web3", "h1": "Crypto & Web3 Advisory", "hero": "VARA · MiCA · MAS · SFC · VASP licensing and regulatory strategy across major crypto jurisdictions.", "whatEye": "What We Do", "whatH": "Regulated Crypto Operations, Built Correctly.", "whatP1": "The regulatory environment for virtual assets and Web3 businesses has changed dramatically. The UAE's VARA framework, the EU's MiCA regulation, and licensing regimes in Singapore, Hong Kong, and other major jurisdictions have created clear pathways for compliant crypto operations — and equally clear consequences for those who operate without the correct licences.", "whatP2": "ARM Management advises exchanges, DeFi protocols, NFT platforms, token issuers, DAOs, and Web3 infrastructure businesses on regulatory strategy across major crypto jurisdictions. We combine legal structuring, regulatory advisory, and AML programme design into a single coordinated engagement.", "svcEye": "Our Services", "svcH": "What We Advise On", "svcs": [["VARA Licence Advisory (Dubai)", "Full advisory on the VARA licensing process in Dubai — from initial eligibility assessment and category selection through to application preparation, regulatory engagement, and post-licence compliance."], ["MiCA Compliance (EU)", "Advising crypto-asset service providers on MiCA authorisation in EU member states — regulatory readiness assessments, application strategy, and ongoing CASP compliance."], ["Token Structuring & Legal Analysis", "Legal analysis of token structures to determine regulatory classification — utility, security, e-money, or hybrid — and advising on the appropriate issuance jurisdiction and structure."], ["DAO Legal Frameworks", "Advising on the legal structuring of DAOs — foundation models, Swiss associations, Marshall Islands LLCs, and other frameworks that provide legal personality to decentralised organisations."], ["Crypto Company Formation", "Establishing crypto and Web3 businesses in VARA (Dubai), ADGM, DIFC, Cayman, BVI, Malta (MiCA), Singapore, and other major crypto jurisdictions."], ["AML/CFT Programme Design", "Designing AML/CFT programmes that meet the specific requirements of virtual asset service providers under FATF guidance, VARA rules, MiCA, and local regulations."]], "ctaH": "Discuss Your Regulatory Strategy", "ctaP": "Whether you are applying for a VARA licence, structuring for MiCA, or building a compliant Web3 business from scratch, the right regulatory strategy is the foundation. Begin with a confidential assessment.", "ctaBtn": "Schedule a Consultation →", "btn2": "Our Services"}, "fr": {"title": "Conseil Crypto & Web3 | ARM Management", "desc": "Conseil en licence VARA, autorisation CASP MiCA, structuration de tokens, cadres juridiques DAO et création d'entités crypto.", "eye": "Crypto & Web3", "h1": "Conseil Crypto\net Web3", "hero": "VARA · MiCA · MAS · SFC · Licences VASP et stratégie réglementaire dans les principales juridictions crypto.", "whatEye": "Ce que nous faisons", "whatH": "Des opérations crypto régulées, construites correctement.", "whatP1": "L'environnement réglementaire pour les actifs virtuels et les entreprises Web3 a radicalement évolué. Le cadre VARA des EAU, le règlement MiCA de l'UE et les régimes de licence à Singapour, Hong Kong et d'autres grandes juridictions ont créé des voies claires pour des opérations crypto conformes.", "whatP2": "ARM Management conseille les exchanges, protocoles DeFi, plateformes NFT, émetteurs de tokens, DAOs et entreprises d'infrastructure Web3 sur la stratégie réglementaire dans les principales juridictions crypto.", "svcEye": "Nos services", "svcH": "Ce sur quoi nous conseillons", "svcs": [["Conseil en licence VARA (Dubaï)", "Conseil complet sur le processus de licence VARA à Dubaï — de l'évaluation d'éligibilité initiale à la préparation de la demande et à la conformité post-licence."], ["Conformité MiCA (UE)", "Conseil aux prestataires de services sur actifs cryptographiques pour l'autorisation MiCA — évaluations de la préparation réglementaire et stratégie de demande."], ["Structuration de tokens & analyse juridique", "Analyse juridique des structures de tokens pour déterminer la classification réglementaire — utilitaire, valeur mobilière, monnaie électronique ou hybride."], ["Cadres juridiques DAO", "Conseil sur la structuration juridique des DAOs — modèles de fondation, associations suisses, LLC des Îles Marshall et autres cadres."], ["Création d'entités crypto", "Établissement d'entreprises crypto et Web3 à VARA (Dubaï), ADGM, DIFC, Caïmans, BVI, Malte (MiCA), Singapour et autres."], ["Conception de programme LBC/FT", "Conception de programmes LBC/FT répondant aux exigences spécifiques des prestataires de services sur actifs virtuels."]], "ctaH": "Discutez de votre stratégie réglementaire", "ctaP": "Que vous demandiez une licence VARA, structuriez pour MiCA ou construisiez une entreprise Web3 conforme depuis le début, la bonne stratégie réglementaire est le fondement.", "ctaBtn": "Planifier une consultation →", "btn2": "Nos services"}, "es": {"title": "Asesoría Crypto y Web3 | ARM Management", "desc": "Asesoría de licencia VARA, autorización CASP MiCA, estructuración de tokens, marcos legales DAO y constitución de entidades crypto.", "eye": "Crypto & Web3", "h1": "Asesoría Crypto\ny Web3", "hero": "VARA · MiCA · MAS · SFC · Licencias VASP y estrategia regulatoria en las principales jurisdicciones crypto.", "whatEye": "Lo que hacemos", "whatH": "Operaciones crypto reguladas, construidas correctamente.", "whatP1": "El entorno regulatorio para los activos virtuales y los negocios Web3 ha cambiado drásticamente. El marco VARA de los EAU, el reglamento MiCA de la UE y los regímenes de licencias en Singapur, Hong Kong y otras jurisdicciones principales han creado vías claras para operaciones crypto conformes.", "whatP2": "ARM Management asesora a exchanges, protocolos DeFi, plataformas NFT, emisores de tokens, DAOs y empresas de infraestructura Web3 sobre estrategia regulatoria.", "svcEye": "Nuestros servicios", "svcH": "En qué asesoramos", "svcs": [["Asesoría de Licencia VARA (Dubai)", "Asesoría completa sobre el proceso de licencia VARA en Dubai — desde la evaluación de elegibilidad hasta la preparación de la solicitud y el cumplimiento post-licencia."], ["Cumplimiento MiCA (UE)", "Asesoría a proveedores de servicios de criptoactivos sobre la autorización MiCA — evaluaciones de preparación regulatoria y estrategia de solicitud."], ["Estructuración de Tokens & Análisis Legal", "Análisis legal de estructuras de tokens para determinar la clasificación regulatoria — utilidad, valor mobiliario, dinero electrónico o híbrido."], ["Marcos Legales DAO", "Asesoría sobre la estructuración legal de DAOs — modelos de fundación, asociaciones suizas, LLC de Islas Marshall y otros marcos."], ["Constitución de Empresas Crypto", "Establecimiento de empresas crypto y Web3 en VARA (Dubai), ADGM, DIFC, Caimán, BVI, Malta (MiCA), Singapur y otros."], ["Diseño de Programa AML/CFT", "Diseño de programas AML/CFT que cumplen con los requisitos específicos de los proveedores de servicios de activos virtuales."]], "ctaH": "Discuta su estrategia regulatoria", "ctaP": "Ya sea que esté solicitando una licencia VARA, estructurando para MiCA o construyendo un negocio Web3 conforme desde cero, la estrategia regulatoria correcta es el fundamento.", "ctaBtn": "Programar una consulta →", "btn2": "Nuestros servicios"}, "ar": {"title": "استشارات العملات الرقمية وWeb3 | ARM Management", "desc": "استشارات ترخيص VARA، وترخيص CASP وفق MiCA، وهيكلة الرموز، والأطر القانونية لـ DAO، وتأسيس شركات العملات الرقمية.", "eye": "العملات الرقمية وWeb3", "h1": "استشارات العملات\nالرقمية وWeb3", "hero": "VARA · MiCA · MAS · SFC · تراخيص VASP والاستراتيجية التنظيمية عبر الولايات القضائية الرئيسية للعملات الرقمية.", "whatEye": "ما نقدّمه", "whatH": "عمليات مشفّرة منظّمة، مبنية بشكل صحيح.", "whatP1": "تغيّر البيئة التنظيمية للأصول الافتراضية وأعمال Web3 بشكل جذري. أنشأ إطار VARA الإماراتي ولوائح MiCA الأوروبية وأنظمة الترخيص في سنغافورة وهونغ كونغ مسارات واضحة للعمليات المشفّرة المتوافقة.", "whatP2": "تقدّم ARM Management الاستشارات للبورصات وبروتوكولات DeFi ومنصات NFT ومُصدري الرموز وـ DAOs وشركات البنية التحتية لـ Web3 حول الاستراتيجية التنظيمية.", "svcEye": "خدماتنا", "svcH": "ما نستشير فيه", "svcs": [["استشارات ترخيص VARA (دبي)", "استشارات شاملة حول عملية ترخيص VARA في دبي — من تقييم الأهلية الأولي واختيار الفئة إلى إعداد الطلب والامتثال بعد الترخيص."], ["الامتثال لـ MiCA (الاتحاد الأوروبي)", "المشورة لمقدمي خدمات الأصول المشفّرة بشأن الترخيص وفق MiCA في الدول الأعضاء في الاتحاد الأوروبي."], ["هيكلة الرموز والتحليل القانوني", "التحليل القانوني لهياكل الرموز لتحديد التصنيف التنظيمي — فائدة أو أوراق مالية أو نقود إلكترونية أو هجينة."], ["الأطر القانونية لـ DAO", "المشورة بشأن الهيكلة القانونية لـ DAOs — نماذج المؤسسات والجمعيات السويسرية وشركات جزر مارشال والأطر الأخرى."], ["تأسيس شركات العملات الرقمية", "إنشاء أعمال العملات الرقمية وWeb3 في VARA (دبي) وADGM وDIFC وجزر كايمان وجزر العذراء البريطانية ومالطا (MiCA) وسنغافورة وغيرها."], ["تصميم برامج مكافحة غسل الأموال", "تصميم برامج مكافحة غسل الأموال التي تلبّي المتطلبات المحددة لمقدمي خدمات الأصول الافتراضية."]], "ctaH": "ناقش استراتيجيتك التنظيمية", "ctaP": "سواء كنت تتقدم للحصول على ترخيص VARA أو تُهيكل لـ MiCA أو تبني عمل Web3 متوافق من الصفر، فإن الاستراتيجية التنظيمية الصحيحة هي الأساس.", "ctaBtn": "جدوِّل استشارة ←", "btn2": "خدماتنا"}, "ru": {"title": "Крипто и Web3-консалтинг | ARM Management", "desc": "Консалтинг по лицензии VARA, авторизация CASP по MiCA, структурирование токенов, юридические рамки DAO и регистрация крипто-компаний.", "eye": "Крипто и Web3", "h1": "Крипто и Web3\nконсалтинг", "hero": "VARA · MiCA · MAS · SFC · Лицензирование VASP и регуляторная стратегия в ведущих крипто-юрисдикциях.", "whatEye": "Что мы делаем", "whatH": "Регулируемые крипто-операции, выстроенные правильно.", "whatP1": "Регуляторная среда для виртуальных активов и Web3-бизнесов кардинально изменилась. Фреймворк VARA ОАЭ, регламент MiCA ЕС и режимы лицензирования в Сингапуре и Гонконге создали чёткие пути для соответствующих крипто-операций.", "whatP2": "ARM Management консультирует биржи, DeFi-протоколы, NFT-платформы, эмитентов токенов, DAO и инфраструктурные Web3-компании по регуляторной стратегии.", "svcEye": "Услуги", "svcH": "Что мы делаем", "svcs": [["Консалтинг по лицензии VARA (Дубай)", "Полный консалтинг по процессу лицензирования VARA в Дубае — от оценки приемлемости до подачи заявки и пост-лицензионного комплаенс."], ["Комплаенс MiCA (ЕС)", "Консультирование поставщиков услуг криптоактивов по авторизации MiCA в государствах-членах ЕС."], ["Структурирование токенов и юридический анализ", "Юридический анализ структур токенов для определения регуляторной классификации — утилитарные, ценные бумаги, электронные деньги или гибридные."], ["Юридические рамки DAO", "Консультирование по юридическому структурированию DAO — модели фондов, швейцарские ассоциации, LLC Маршалловых островов."], ["Регистрация крипто-компаний", "Создание крипто и Web3-бизнесов в VARA (Дубай), ADGM, DIFC, Каймановых островах, BVI, Мальте (MiCA), Сингапуре и других."], ["Разработка программ ПОД/ФТ", "Разработка программ ПОД/ФТ, соответствующих требованиям поставщиков услуг виртуальных активов."]], "ctaH": "Обсудите регуляторную стратегию", "ctaP": "Будь то получение лицензии VARA, структурирование под MiCA или создание комплаентного Web3-бизнеса с нуля — правильная регуляторная стратегия является основой.", "ctaBtn": "Записаться на консультацию →", "btn2": "Наши услуги"}, "zh": {"title": "加密货币与Web3咨询 | ARM Management", "desc": "VARA牌照咨询、MiCA CASP授权、代币架构、DAO法律框架及加密货币公司注册。", "eye": "加密货币与Web3", "h1": "加密货币与\nWeb3咨询", "hero": "VARA · MiCA · MAS · SFC · 主要加密货币司法管辖区的VASP许可及监管战略。", "whatEye": "我们的服务内容", "whatH": "合规的加密货币运营，从正确的架构开始。", "whatP1": "虚拟资产和Web3业务的监管环境已发生根本性变化。阿联酋VARA框架、欧盟MiCA法规以及新加坡、香港等主要司法管辖区的许可制度，为合规的加密货币运营创造了清晰的路径。", "whatP2": "ARM Management为交易所、DeFi协议、NFT平台、代币发行方、DAO和Web3基础设施企业提供主要加密货币司法管辖区的监管战略咨询。", "svcEye": "服务", "svcH": "咨询范围", "svcs": [["VARA牌照咨询（迪拜）", "关于迪拜VARA许可流程的全面咨询——从初始资格评估和类别选择到申请准备、监管沟通和许可后合规。"], ["MiCA合规（欧盟）", "就欧盟成员国MiCA授权为加密资产服务提供商提供咨询——监管准备评估、申请策略和持续CASP合规。"], ["代币架构与法律分析", "对代币结构进行法律分析以确定监管分类——效用代币、证券代币、电子货币代币或混合代币。"], ["DAO法律框架", "就DAO的法律架构提供咨询——基金会模式、瑞士协会、马绍尔群岛LLC及其他框架。"], ["加密货币公司注册", "在VARA（迪拜）、ADGM、DIFC、开曼群岛、英属维尔京群岛、马耳他（MiCA）、新加坡等主要加密货币司法管辖区建立加密货币和Web3企业。"], ["反洗钱/打击恐怖主义融资计划设计", "设计满足FATF指南、VARA规则、MiCA及当地法规规定的虚拟资产服务提供商特定要求的AML/CFT计划。"]], "ctaH": "讨论您的监管战略", "ctaP": "无论您是在申请VARA牌照、为MiCA进行架构，还是从零开始构建合规的Web3业务，正确的监管战略都是基础。", "ctaBtn": "预约咨询 →", "btn2": "我们的服务"}};
const c = DATA[lang];
---
<PageWrapper lang={lang} title={c.title} description={c.desc} canonicalPath="/services/crypto-web3">
<main dir={isRTL ? 'rtl' : 'ltr'}>
  <section class="page-hero">
    <div class="page-hero__bg" style="background-image:url('https://images.unsplash.com/photo-1639762681485-074b7f938ba0?w=1600&q=80&auto=format&fit=crop')"></div>
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content container">
      <span class="eyebrow">{c.eye}</span>
      <h1 set:html={c.h1.replace('\n','<br>')}></h1>
      <p>{c.hero}</p>
      <div class="btn-row" style="justify-content:flex-start;margin-top:30px">
        <a href={lp('/contact')} class="btn-primary">{c.ctaBtn}</a>
        <a href={lp('/services')} class="btn-secondary">{c.btn2}</a>
      </div>
    </div>
  </section>
  <section class="section section--cream">
    <div class="container--narrow">
      <span class="eyebrow reveal">{c.whatEye}</span>
      <h2 class="reveal">{c.whatH}</h2>
      <div class="gold-rule reveal"></div>
      <p class="reveal">{c.whatP1}</p>
      <p class="reveal" style="margin-top:20px">{c.whatP2}</p>
    </div>
  </section>
  <section class="section section--warm" style="border-top:1px solid #E2DDD6">
    <div class="container">
      <span class="eyebrow reveal">{c.svcEye}</span>
      <h2 class="reveal">{c.svcH}</h2>
      <div class="gold-rule reveal"></div>
      <div class="grid-3" style="margin-top:40px">
        {c.svcs.map(([h, p]: [string,string], i: number) => (
          <div class={`card reveal reveal-delay-${(i%3)+1}`}><h3>{h}</h3><p>{p}</p></div>
        ))}
      </div>
    </div>
  </section>
  <section class="cta-section">
    <h2 class="reveal">{c.ctaH}</h2>
    <p class="reveal reveal-delay-1">{c.ctaP}</p>
    <div class="btn-row reveal reveal-delay-2">
      <a href={lp('/contact')} class="btn-primary">{c.ctaBtn}</a>
    </div>
  </section>
</main>
</PageWrapper>
