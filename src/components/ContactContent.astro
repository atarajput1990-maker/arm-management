    fCompany: "Компания / Организация", fCompanyPh: "Название вашей компании", fCountry: "Страна проживания", fCountryPh: "напр. Объединённые Арабские Эмираты",
    fService: "Направление услуг", fServicePh: "Выберите направление",
    fServices: ["Транзакционный консалтинг","Регистрация компаний","Бухучёт и налоги","Расчёт зарплат и HR","Международная мобильность и резидентство","Крипто и Web3","Другое"],
    fMessage: "Краткое описание *", fMessagePh: "Пожалуйста, кратко опишите вашу ситуацию и с чем вам нужна помощь...",
