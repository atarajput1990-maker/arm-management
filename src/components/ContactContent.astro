    fService: "مجال الخدمة", fServicePh: "اختر مجال الخدمة",
    fServices: ["استشارات المعاملات","تأسيس الشركات","المحاسبة والضرائب","الرواتب والموارد البشرية","التنقل الدولي والإقامة","العملات الرقمية وWeb3","أخرى"],
    fMessage: "وصف موجز *", fMessagePh: "يرجى وصف وضعك بإيجاز وما تحتاج المساعدة فيه...",
