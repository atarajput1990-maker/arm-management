const c = copy[lang];
---
<PageWrapper lang={lang} title={c.title} description={c.desc} canonicalPath="/contact">
<main>
  <section class="page-hero">
    <div class="page-hero__bg" style="background-image:url('https://images.unsplash.com/photo-1497366216548-37526070297c?w=1600&q=80&auto=format&fit=crop')"></div>
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content container" dir={isRTL ? 'rtl' : 'ltr'}>
      <span class="eyebrow">{c.eyebrow}</span>
      <h1>{c.h1a}<br>{c.h1b}</h1>
      <p>{c.hero}</p>
    </div>
  </section>

  <section class="section section--cream" dir={isRTL ? 'rtl' : 'ltr'}>
    <div class="container">
      <div class="contact-grid reveal">
        <div class="contact-card">
          <span class="eyebrow">{c.emailEye}</span>
          <h3>{c.emailH3}</h3>
          <p>{c.emailP}</p>
          <a href="mailto:info@arm-management.com" class="btn-navy">{c.emailBtn}</a>
        </div>
        <div class="contact-card">
          <span class="eyebrow">{c.schedEye}</span>
          <h3>{c.schedH3}</h3>
          <p>{c.schedP}</p>
          <a href="mailto:info@arm-management.com?subject=Consultation Request" class="btn-navy">{c.schedBtn}</a>
        </div>
        <div class="contact-card">
          <span class="eyebrow">{c.confEye}</span>
          <h3>{c.confH3}</h3>
          <p>{c.confP}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--warm" style="border-top:1px solid #E2DDD6" dir={isRTL ? 'rtl' : 'ltr'}>
    <div class="container--narrow">
      <h2 class="reveal">{c.formH2}</h2>
      <div class="gold-rule reveal"></div>
      <p class="reveal" style="color:#6B7280;margin-bottom:40px">{c.formP}</p>
      <form class="contact-form reveal" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" action={lp('/thank-you')}>
        <input type="hidden" name="form-name" value="contact">
        <p style="display:none"><input name="bot-field"></p>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for={`name-${lang}`}>{c.fName}</label>
            <input class="form-input" type="text" id={`name-${lang}`} name="name" required placeholder={c.fNamePh}>
          </div>
          <div class="form-group">
            <label class="form-label" for={`email-${lang}`}>{c.fEmail}</label>
            <input class="form-input" type="email" id={`email-${lang}`} name="email" required placeholder={c.fEmailPh}>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for={`company-${lang}`}>{c.fCompany}</label>
            <input class="form-input" type="text" id={`company-${lang}`} name="company" placeholder={c.fCompanyPh}>
          </div>
          <div class="form-group">
            <label class="form-label" for={`country-${lang}`}>{c.fCountry}</label>
            <input class="form-input" type="text" id={`country-${lang}`} name="country" placeholder={c.fCountryPh}>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label" for={`service-${lang}`}>{c.fService}</label>
          <select class="form-select" id={`service-${lang}`} name="service">
            <option value="">{c.fServicePh}</option>
            {c.fServices.map(s => <option>{s}</option>)}
          </select>
        </div>
        <div class="form-group">
          <label class="form-label" for={`message-${lang}`}>{c.fMessage}</label>
          <textarea class="form-textarea" id={`message-${lang}`} name="message" required placeholder={c.fMessagePh}></textarea>
        </div>
        <div class="form-group">
          <label class="form-label" for={`source-${lang}`}>{c.fSource}</label>
          <select class="form-select" id={`source-${lang}`} name="source">
            <option value="">{c.fSourcePh}</option>
            {c.fSources.map(s => <option>{s}</option>)}
          </select>
        </div>
        <button type="submit" class="btn-primary" style="border:none;cursor:pointer;font-size:12px">{c.fSubmit}</button>
      </form>
    </div>
  </section>
</main>
</PageWrapper>
