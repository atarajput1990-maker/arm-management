---
import PageWrapper from './PageWrapper.astro';
import { localePath } from '../i18n/translations';
import type { Locale } from '../i18n/translations';
interface Props { lang: Locale; }
const { lang } = Astro.props;
const lp = (p: string) => localePath(lang, p);
const isRTL = lang === 'ar';
const DATA: Record<string, any> = {"en": {"title": "Asia Pacific | ARM Management", "desc": "ARM Management advises on company formation, accounting, payroll, and transaction advisory across Singapore, Hong Kong, Malaysia, India, Vietnam, and Japan.", "eyebrow": "Asia Pacific", "h1": "Asia Pacific", "hero": "Singapore, Hong Kong, Malaysia, India, Vietnam, Thailand, Indonesia, and Japan.", "s2h": "ARM Management in Asia Pacific", "s2p1": "Asia Pacific represents some of the world's most dynamic and commercially significant markets. Singapore and Hong Kong serve as the region's primary entry points for international businesses — offering common law legal systems, strong financial infrastructure, and favourable tax regimes. ARM Management advises clients expanding into these and the wider APAC region from initial market assessment through to ongoing compliance.", "s2p2": "Our Shenzhen office serves our China and wider North Asia practice, advising on market entry, entity formation, and cross-border structuring for businesses with interests in China, Japan, and Korea.", "svcsEye": "Services in Asia Pacific", "svcsH": "What ARM Management Does Here", "svcs": [["Company Formation", "Singapore, Hong Kong, Malaysia, India, Vietnam, Thailand, Indonesia. Free trade zone entities."], ["Crypto & Web3", "Singapore MAS MPI licensing. Hong Kong SFC Type 1 and 7. VASP licensing and regional regulatory advisory."], ["Accounting & Tax", "Singapore GST, Hong Kong profits tax, Malaysia income tax, India GST, Vietnam tax compliance."], ["Transaction Advisory", "Regional M&A and private equity. Singapore and Hong Kong deal structuring across APAC."], ["Global Mobility", "Singapore EP, EntrePass, Tech.Pass. Hong Kong IANG. Malaysia MM2H. Thailand LTR visa."], ["Payroll & HR", "Singapore CPF, Hong Kong MPF, Malaysia EPF/SOCSO, India PF/ESIC employment compliance."]], "navyEye": "Key Jurisdictions", "navyH": "Where We Operate", "offices": [["Singapore", "Primary APAC hub. MAS licensing, company incorporation, Employment Pass, cross-border structuring."], ["Hong Kong", "Company incorporation, SFC crypto licensing, profits tax, MPF payroll, IANG visa advisory."], ["China (Shenzhen)", "ARM's China hub. WFOE formation, VAT and corporate tax, China-UAE and China-EU cross-border structuring."], ["Southeast Asia", "Malaysia, Vietnam, Thailand, Indonesia — company formation, employment law, and tax compliance."]]}, "fr": {"title": "Asie-Pacifique | ARM Management", "desc": "ARM Management conseille sur la création de sociétés, la comptabilité, la paie et les transactions à Singapour, Hong Kong, Malaisie, Inde, Vietnam et Japon.", "eyebrow": "Asie-Pacifique", "h1": "Asie-Pacifique", "hero": "Singapour, Hong Kong, Malaisie, Inde, Vietnam, Thaïlande, Indonésie et Japon.", "s2h": "ARM Management en Asie-Pacifique", "s2p1": "L'Asie-Pacifique représente certains des marchés les plus dynamiques et commercialement significatifs au monde. Singapour et Hong Kong servent de points d'entrée principaux pour les entreprises internationales dans la région.", "s2p2": "Notre bureau de Shenzhen sert notre pratique Chine et Asie du Nord, conseillant sur l'entrée sur le marché, la création d'entités et la structuration transfrontalière.", "svcsEye": "Services en Asie-Pacifique", "svcsH": "Ce qu'ARM Management fait ici", "svcs": [["Création de sociétés", "Singapour, Hong Kong, Malaisie, Inde, Vietnam, Thaïlande, Indonésie. Entités en zones de libre-échange."], ["Crypto & Web3", "Licences MPI MAS Singapour. SFC type 1 et 7 Hong Kong. VASP et conseil réglementaire régional."], ["Comptabilité & Fiscalité", "TPS Singapour, taxe bénéfices Hong Kong, impôt Malaisie, TPS Inde, conformité fiscale Vietnam."], ["Conseil en transactions", "M&A et private equity régionaux. Singapour et Hong Kong pour la structuration APAC."], ["Mobilité internationale", "EP, EntrePass, Tech.Pass Singapour. IANG Hong Kong. MM2H Malaisie. Visa LTR Thaïlande."], ["Paie & RH", "CPF Singapour, MPF Hong Kong, EPF/SOCSO Malaisie, PF/ESIC Inde."]], "navyEye": "Juridictions clés", "navyH": "Où nous opérons", "offices": [["Singapour", "Hub APAC principal. Licences MAS, constitution, Employment Pass, structuration transfrontalière."], ["Hong Kong", "Constitution, licences SFC crypto, taxe bénéfices, paie MPF, visa IANG."], ["Chine (Shenzhen)", "Hub Chine d'ARM. Formation WFOE, TVA, impôt sur les sociétés, structuration transfrontalière."], ["Asie du Sud-Est", "Malaisie, Vietnam, Thaïlande, Indonésie — création de sociétés, droit du travail, fiscalité."]]}, "es": {"title": "Asia-Pacífico | ARM Management", "desc": "ARM Management asesora en constitución de sociedades, contabilidad, nómina y transacciones en Singapur, Hong Kong, Malasia, India, Vietnam y Japón.", "eyebrow": "Asia-Pacífico", "h1": "Asia-Pacífico", "hero": "Singapur, Hong Kong, Malasia, India, Vietnam, Tailandia, Indonesia y Japón.", "s2h": "ARM Management en Asia-Pacífico", "s2p1": "Asia-Pacífico representa algunos de los mercados más dinámicos y comercialmente significativos del mundo. Singapur y Hong Kong sirven como los principales puntos de entrada para las empresas internacionales en la región.", "s2p2": "Nuestra oficina en Shenzhen atiende nuestra práctica en China y Asia del Norte, asesorando en entrada al mercado, constitución de entidades y estructuración transfronteriza.", "svcsEye": "Servicios en Asia-Pacífico", "svcsH": "Lo que hace ARM Management aquí", "svcs": [["Constitución de sociedades", "Singapur, Hong Kong, Malasia, India, Vietnam, Tailandia, Indonesia. Zonas de libre comercio."], ["Crypto & Web3", "Licencias MPI MAS Singapur. SFC tipo 1 y 7 Hong Kong. VASP y asesoría regulatoria regional."], ["Contabilidad & Impuestos", "GST Singapur, impuesto beneficios Hong Kong, impuesto Malasia, GST India, cumplimiento Vietnam."], ["Asesoría en Transacciones", "M&A y private equity regional. Singapur y Hong Kong para estructuración APAC."], ["Movilidad Global", "EP, EntrePass, Tech.Pass Singapur. IANG Hong Kong. MM2H Malasia. Visa LTR Tailandia."], ["Nómina & RRHH", "CPF Singapur, MPF Hong Kong, EPF/SOCSO Malasia, PF/ESIC India."]], "navyEye": "Jurisdicciones clave", "navyH": "Dónde operamos", "offices": [["Singapur", "Hub APAC principal. Licencias MAS, constitución, Employment Pass, estructuración transfronteriza."], ["Hong Kong", "Constitución, licencias SFC crypto, impuesto beneficios, nómina MPF, visa IANG."], ["China (Shenzhen)", "Hub China de ARM. WFOE, IVA, impuesto de sociedades, estructuración China-EAU y China-UE."], ["Sudeste Asiático", "Malasia, Vietnam, Tailandia, Indonesia — constitución, derecho laboral, cumplimiento fiscal."]]}, "ar": {"title": "آسيا والمحيط الهادئ | ARM Management", "desc": "تقدّم ARM Management المشورة في تأسيس الشركات والمحاسبة والرواتب والمعاملات في سنغافورة وهونغ كونغ وماليزيا والهند وفيتنام واليابان.", "eyebrow": "آسيا والمحيط الهادئ", "h1": "آسيا والمحيط الهادئ", "hero": "سنغافورة، وهونغ كونغ، وماليزيا، والهند، وفيتنام، وتايلاند، وإندونيسيا، واليابان.", "s2h": "ARM Management في آسيا والمحيط الهادئ", "s2p1": "تُمثّل منطقة آسيا والمحيط الهادئ بعضاً من أكثر الأسواق ديناميكيةً وأهميةً تجاريةً في العالم. تُعدّ سنغافورة وهونغ كونغ نقاط الدخول الرئيسية في المنطقة للشركات الدولية.", "s2p2": "يخدم مكتبنا في شنجن ممارستنا في الصين وشمال آسيا، مقدّماً المشورة في دخول السوق وتأسيس الكيانات والهيكلة العابرة للحدود.", "svcsEye": "الخدمات في آسيا والمحيط الهادئ", "svcsH": "ما تفعله ARM Management هنا", "svcs": [["تأسيس الشركات", "سنغافورة وهونغ كونغ وماليزيا والهند وفيتنام وتايلاند وإندونيسيا. كيانات في مناطق التجارة الحرة."], ["العملات الرقمية وWeb3", "تراخيص MAS MPI في سنغافورة. SFC النوع 1 و7 في هونغ كونغ. VASP والاستشارات التنظيمية."], ["المحاسبة والضرائب", "GST سنغافورة وضريبة الأرباح في هونغ كونغ وضريبة ماليزيا وGST الهند وفيتنام."], ["استشارات المعاملات", "الاندماجات والاستحواذات والأسهم الخاصة الإقليمية. هيكلة الصفقات في سنغافورة وهونغ كونغ."], ["التنقل الدولي", "EP وEntrePass وTech.Pass في سنغافورة. IANG في هونغ كونغ. MM2H في ماليزيا. LTR في تايلاند."], ["الرواتب والموارد البشرية", "CPF سنغافورة وMPF هونغ كونغ وEPF/SOCSO ماليزيا وPF/ESIC الهند."]], "navyEye": "الولايات القضائية الرئيسية", "navyH": "أين نعمل", "offices": [["سنغافورة", "المحور الرئيسي في آسيا والمحيط الهادئ. تراخيص MAS وتأسيس الشركات وتصريح العمل والهيكلة العابرة للحدود."], ["هونغ كونغ", "تأسيس الشركات وتراخيص SFC للعملات الرقمية وضريبة الأرباح ورواتب MPF وتأشيرة IANG."], ["الصين (شنجن)", "محور الصين لـ ARM. تأسيس WFOE وضريبة القيمة المضافة وضريبة الشركات والهيكلة العابرة للحدود."], ["جنوب شرق آسيا", "ماليزيا وفيتنام وتايلاند وإندونيسيا — تأسيس الشركات وقانون العمل والامتثال الضريبي."]]}, "ru": {"title": "Азиатско-Тихоокеанский регион | ARM Management", "desc": "ARM Management консультирует по регистрации компаний, бухучёту, зарплатам и сделкам в Сингапуре, Гонконге, Малайзии, Индии, Вьетнаме и Японии.", "eyebrow": "АТР", "h1": "Азиатско-Тихоокеанский регион", "hero": "Сингапур, Гонконг, Малайзия, Индия, Вьетнам, Таиланд, Индонезия и Япония.", "s2h": "ARM Management в Азиатско-Тихоокеанском регионе", "s2p1": "Азиатско-Тихоокеанский регион представляет одни из наиболее динамичных и коммерчески значимых рынков мира. Сингапур и Гонконг служат основными точками входа для международных компаний в регион.", "s2p2": "Наш офис в Шэньчжэне обслуживает практику по Китаю и Северной Азии, консультируя по выходу на рынок, регистрации структур и трансграничному структурированию.", "svcsEye": "Услуги в АТР", "svcsH": "Что ARM Management делает здесь", "svcs": [["Регистрация компаний", "Сингапур, Гонконг, Малайзия, Индия, Вьетнам, Таиланд, Индонезия. Структуры в свободных зонах."], ["Крипто и Web3", "MAS MPI Сингапур. SFC Type 1 и 7 Гонконг. VASP и региональный регуляторный консалтинг."], ["Учёт и налоги", "GST Сингапура, налог на прибыль Гонконга, налог Малайзии, GST Индии, комплаенс Вьетнама."], ["Транзакционный консалтинг", "Региональные M&A и прямые инвестиции. Сингапур и Гонконг для структурирования в АТР."], ["Международная мобильность", "EP, EntrePass, Tech.Pass Сингапура. IANG Гонконга. MM2H Малайзии. LTR Таиланда."], ["Расчёт зарплат и HR", "CPF Сингапура, MPF Гонконга, EPF/SOCSO Малайзии, PF/ESIC Индии."]], "navyEye": "Ключевые юрисдикции", "navyH": "Где мы работаем", "offices": [["Сингапур", "Основной APAC-хаб. Лицензирование MAS, регистрация, Employment Pass, трансграничное структурирование."], ["Гонконг", "Регистрация, крипто-лицензирование SFC, налог на прибыль, расчёт зарплат MPF, виза IANG."], ["Китай (Шэньчжэнь)", "Китайский хаб ARM. WFOE, НДС, корпоративный налог, трансграничное структурирование."], ["Юго-Восточная Азия", "Малайзия, Вьетнам, Таиланд, Индонезия — регистрация, трудовое право, налоговый комплаенс."]]}, "zh": {"title": "亚太地区 | ARM Management", "desc": "ARM Management在新加坡、香港、马来西亚、印度、越南和日本提供公司注册、会计、薪酬及交易咨询服务。", "eyebrow": "亚太地区", "h1": "亚太地区", "hero": "新加坡、香港、马来西亚、印度、越南、泰国、印度尼西亚及日本。", "s2h": "ARM Management在亚太地区", "s2p1": "亚太地区拥有世界上一些最具活力和商业价值的市场。新加坡和香港是国际企业进入该地区的主要门户——提供普通法法律体系、强大的金融基础设施和优惠的税收制度。", "s2p2": "我们的深圳办公室服务于中国和北亚业务，为在中国、日本和韩国有业务的企业提供市场进入、实体设立和跨境架构咨询。", "svcsEye": "亚太地区服务", "svcsH": "ARM Management在此的服务", "svcs": [["公司注册", "新加坡、香港、马来西亚、印度、越南、泰国、印度尼西亚。自由贸易区实体。"], ["加密货币与Web3", "新加坡MAS MPI许可证。香港SFC 1类和7类牌照。VASP许可及地区监管咨询。"], ["会计与税务", "新加坡商品及服务税、香港利得税、马来西亚所得税、印度商品及服务税、越南税务合规。"], ["交易咨询", "地区并购和私募股权。新加坡和香港面向亚太地区的交易架构。"], ["全球移民", "新加坡EP、EntrePass、Tech.Pass。香港IANG。马来西亚MM2H。泰国LTR签证。"], ["薪酬与人力资源", "新加坡CPF、香港MPF、马来西亚EPF/SOCSO、印度PF/ESIC合规。"]], "navyEye": "主要司法管辖区", "navyH": "我们的运营区域", "offices": [["新加坡", "亚太主要枢纽。MAS许可证、公司注册、就业准证及跨境架构。"], ["香港", "公司注册、SFC加密货币许可证、利得税、MPF薪酬、IANG签证咨询。"], ["中国（深圳）", "ARM中国枢纽。外商独资企业设立、增值税和企业税、中国-阿联酋及中国-欧盟跨境架构。"], ["东南亚", "马来西亚、越南、泰国、印度尼西亚——公司注册、劳动法及税务合规。"]]}};
const c = DATA[lang];
---
<PageWrapper lang={lang} title={c.title} description={c.desc} canonicalPath="/regions/asia-pacific">
<main dir={isRTL ? 'rtl' : 'ltr'}>
  <section class="page-hero">
    <div class="page-hero__bg" style="background-image:url('https://images.unsplash.com/photo-1525625293386-3f8f99389edd?w=1600&q=80&auto=format&fit=crop')"></div>
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content container">
      <span class="eyebrow">{c.eyebrow}</span>
      <h1>{c.h1}</h1>
      <p>{c.hero}</p>
    </div>
  </section>
  <section class="section section--cream">
    <div class="container--narrow">
      <h2 class="reveal">{c.s2h}</h2>
      <div class="gold-rule reveal"></div>
      <p class="reveal">{c.s2p1}</p>
      <p class="reveal" style="margin-top:20px">{c.s2p2}</p>
    </div>
  </section>
  <section class="section section--warm" style="border-top:1px solid #E2DDD6">
    <div class="container">
      <span class="eyebrow reveal">{c.svcsEye}</span>
      <h2 class="reveal">{c.svcsH}</h2>
      <div class="gold-rule reveal"></div>
      <div class="grid-3" style="margin-top:40px">
        {c.svcs.map(([sh, sp]: [string,string], i: number) => (
          <div class={`card reveal reveal-delay-${(i%3)+1}`}><h3>{sh}</h3><p>{sp}</p></div>
        ))}
      </div>
    </div>
  </section>
  <section class="section section--navy">
    <div class="container--narrow">
      <span class="eyebrow reveal" style="color:#B8960C">{c.navyEye}</span>
      <h2 class="reveal" style="color:#F7F3EC">{c.navyH}</h2>
      <div class="gold-rule reveal"></div>
      <div style="margin-top:40px;display:grid;grid-template-columns:repeat(2,1fr);gap:24px">
        {c.offices.map(([oh, op]: [string,string], i: number) => (
          <div class={`reveal reveal-delay-${(i%2)+1}`} style="background:rgba(247,243,236,.04);border:1px solid rgba(184,150,12,.2);padding:24px;border-radius:2px">
            <h4 style="color:#C9A227;font-family:'Inter',sans-serif;font-size:13px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;margin-bottom:10px">{oh}</h4>
            <p style="color:rgba(247,243,236,.65);font-size:14px;line-height:1.7">{op}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  <section class="cta-section">
    <h2 class="reveal">{c.ctaH}</h2>
    <p class="reveal reveal-delay-1">{c.ctaP}</p>
    <div class="btn-row reveal reveal-delay-2">
      <a href={lp('/contact')} class="btn-primary">{c.ctaBtn}</a>
      <a href={lp('/services')} class="btn-secondary">{c.btn2}</a>
    </div>
  </section>
</main>
</PageWrapper>
