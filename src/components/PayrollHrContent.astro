---
import PageWrapper from './PageWrapper.astro';
import { localePath } from '../i18n/translations';
import type { Locale } from '../i18n/translations';
interface Props { lang: Locale; }
const { lang } = Astro.props;
const lp = (p: string) => localePath(lang, p);
const isRTL = lang === 'ar';
const DATA: Record<string, any> = {"en": {"title": "Payroll & HR Advisory | ARM Management", "desc": "Global payroll strategy, multi-country payroll compliance, international assignment planning, and HR advisory.", "eye": "Payroll & HR", "h1": "Payroll & HR Advisory", "hero": "Multi-country payroll compliance and workforce strategy across every jurisdiction you employ in.", "whatEye": "What We Do", "whatH": "International Payroll Without the Exposure", "whatP1": "Running payroll across multiple countries is one of the most compliance-intensive activities an international business undertakes. Employment law, social security contributions, income tax withholding, benefits requirements, and termination rules vary dramatically by jurisdiction — and non-compliance exposes both the business and its directors to significant legal and financial risk.", "whatP2": "ARM Management provides strategic advisory on global payroll structure, multi-country payroll compliance, international assignment planning, and workforce strategy — coordinated across all your operating jurisdictions through a single senior relationship.", "svcEye": "Our Services", "svcH": "What We Advise On", "svcs": [["Global Payroll Strategy", "Advising on the optimal payroll structure for your international workforce — employer of record, local entity payroll, PEO arrangements, or hybrid approaches."], ["Multi-Country Payroll Compliance", "Ensuring payroll calculations, tax withholding, social security contributions, and payslip requirements are met correctly in each jurisdiction."], ["International Assignment Planning", "Structuring international assignments to manage tax exposure, social security obligations, and employment law compliance across home and host countries."], ["Shadow Payroll", "Managing shadow payroll for internationally mobile employees to ensure correct tax reporting in all relevant jurisdictions."], ["Employment Contract Review", "Reviewing and advising on employment contracts to ensure compliance with local law and alignment with the overall group employment framework."], ["HR Compliance Advisory", "Advising on local HR compliance requirements including working time regulations, leave entitlements, termination procedures, and data protection obligations."]], "ctaH": "Discuss Your Payroll Requirements", "ctaP": "Tell us where you employ and we will give you a clear picture of your compliance obligations and how ARM can help you meet them efficiently.", "ctaBtn": "Schedule a Consultation →", "btn2": "Our Services", "apprEye": "The ARM Approach", "apprH": "Strategy Before Compliance.", "apprP": "Most payroll providers are compliance engines — they process what you give them and file what they must. ARM Management's role is different: we advise on the structure before the payroll runs, identifying exposures before they become liabilities.", "principles": [["Employer of Record vs Local Entity", "Advising on the right employment model for each jurisdiction — when a local entity is necessary and when an employer of record approach is more efficient."], ["Tax Efficiency", "Structuring compensation packages across jurisdictions to manage income tax, social security, and benefit obligations efficiently."], ["Assignment Planning", "Pre-assignment tax planning to manage permanent establishment risk and employee tax exposure in both home and host countries."], ["Termination Risk Management", "Advising on termination procedures and severance obligations across jurisdictions before employment contracts are signed, not after disputes arise."]], "jurEye": "Jurisdictions", "jurH": "Where We Advise", "regions": [["European Union", "Employment law compliance across all 27 member states. Social security coordination under EU regulations. Posted workers, cross-border commuters."], ["GCC & Middle East", "UAE WPS payroll compliance, DIFC and ADGM employment frameworks, Saudi GOSI, Qatar and Bahrain payroll."], ["Asia Pacific", "Singapore CPF, Hong Kong MPF, Malaysia EPF and SOCSO, India PF and ESIC, Vietnam social insurance."], ["Latin America", "Mexico IMSS and INFONAVIT, Colombia pension and health contributions, Brazil CLT, Chile AFP."]]}, "fr": {"title": "Paie & Conseil RH | ARM Management", "desc": "Stratégie de paie internationale, conformité multi-pays, planification des missions et conseil RH.", "eye": "Paie & RH", "h1": "Paie & Conseil RH", "hero": "Conformité de la paie multi-pays et stratégie de workforce dans chaque juridiction où vous employez.", "whatEye": "Ce que nous faisons", "whatH": "La paie internationale sans les risques", "whatP1": "Gérer la paie dans plusieurs pays est l'une des activités les plus intensives en conformité qu'une entreprise internationale entreprend. Le droit du travail, les cotisations sociales, la retenue à la source et les règles de licenciement varient considérablement selon les juridictions.", "whatP2": "ARM Management fournit des conseils stratégiques sur la structure de paie globale, la conformité de la paie multi-pays, la planification des missions internationales et la stratégie de workforce.", "svcEye": "Nos services", "svcH": "Ce sur quoi nous conseillons", "svcs": [["Stratégie de paie globale", "Conseil sur la structure de paie optimale pour votre workforce internationale — employeur de référence, paie via entité locale, arrangements PEO ou approches hybrides."], ["Conformité de la paie multi-pays", "Assurer que les calculs de paie, les retenues fiscales, les cotisations sociales et les exigences de bulletins de salaire sont correctement respectés dans chaque juridiction."], ["Planification des missions internationales", "Structuration des missions internationales pour gérer l'exposition fiscale, les obligations de sécurité sociale et la conformité du droit du travail."], ["Shadow payroll", "Gestion du shadow payroll pour les employés mobiles à l'international pour assurer le reporting fiscal correct dans toutes les juridictions pertinentes."], ["Revue des contrats de travail", "Revue et conseil sur les contrats de travail pour assurer la conformité avec le droit local et l'alignement avec le cadre d'emploi du groupe."], ["Conseil conformité RH", "Conseil sur les exigences locales de conformité RH incluant le temps de travail, les congés, les procédures de licenciement et les obligations de protection des données."]], "ctaH": "Discutez de vos besoins en paie", "ctaP": "Dites-nous où vous employez et nous vous donnerons une image claire de vos obligations de conformité et comment ARM peut vous aider à les respecter efficacement.", "ctaBtn": "Planifier une consultation →", "btn2": "Nos services", "apprEye": "L'approche ARM", "apprH": "La stratégie avant la conformité.", "apprP": "La plupart des prestataires de paie sont des moteurs de conformité — ils traitent ce que vous leur donnez. ARM Management joue un rôle différent : nous conseillons sur la structure avant l'exécution de la paie, en identifiant les expositions avant qu'elles ne deviennent des passifs.", "principles": [["Employeur de référence vs entité locale", "Conseil sur le bon modèle d'emploi pour chaque juridiction — quand une entité locale est nécessaire et quand l'approche employeur de référence est plus efficace."], ["Efficacité fiscale", "Structuration des packages de rémunération pour gérer l'impôt sur le revenu, la sécurité sociale et les obligations d'avantages sociaux."], ["Planification des missions", "Planification fiscale pré-mission pour gérer le risque d'établissement stable et l'exposition fiscale des employés."], ["Gestion du risque de licenciement", "Conseil sur les procédures de licenciement et les obligations d'indemnisation avant la signature des contrats de travail."]], "jurEye": "Juridictions", "jurH": "Où nous conseillons", "regions": [["Union européenne", "Conformité du droit du travail dans les 27 États membres. Coordination de la sécurité sociale selon les règlements UE. Travailleurs détachés, frontaliers."], ["CCG & Moyen-Orient", "Conformité WPS des EAU, cadres d'emploi DIFC et ADGM, GOSI saoudien, paie au Qatar et Bahreïn."], ["Asie-Pacifique", "CPF de Singapour, MPF de Hong Kong, EPF et SOCSO de Malaisie, PF et ESIC en Inde, assurance sociale au Vietnam."], ["Amérique latine", "IMSS et INFONAVIT au Mexique, cotisations pension et santé en Colombie, CLT au Brésil, AFP au Chili."]]}, "es": {"title": "Nómina y Asesoría de RRHH | ARM Management", "desc": "Estrategia global de nómina, cumplimiento de nómina multi-país, planificación de asignaciones internacionales y asesoría de RRHH.", "eye": "Nómina & RRHH", "h1": "Nómina y Asesoría\nde RRHH", "hero": "Cumplimiento de nómina multi-país y estrategia de plantilla en cada jurisdicción donde emplea.", "whatEye": "Lo que hacemos", "whatH": "Nómina internacional sin la exposición", "whatP1": "Gestionar la nómina en múltiples países es una de las actividades más intensivas en cumplimiento que realiza una empresa internacional. El derecho laboral, las contribuciones a la seguridad social, la retención de impuestos y las reglas de despido varían enormemente por jurisdicción.", "whatP2": "ARM Management proporciona asesoría estratégica sobre estructura de nómina global, cumplimiento de nómina multi-país, planificación de asignaciones internacionales y estrategia de plantilla.", "svcEye": "Nuestros servicios", "svcH": "En qué asesoramos", "svcs": [["Estrategia de nómina global", "Asesoría sobre la estructura de nómina óptima para su plantilla internacional — empleador de registro, nómina de entidad local, acuerdos PEO o enfoques híbridos."], ["Cumplimiento de nómina multi-país", "Asegurar que los cálculos de nómina, retenciones fiscales, contribuciones a la seguridad social y requisitos de recibos de pago se cumplan correctamente en cada jurisdicción."], ["Planificación de asignaciones internacionales", "Estructurar asignaciones internacionales para gestionar la exposición fiscal, obligaciones de seguridad social y cumplimiento del derecho laboral."], ["Shadow payroll", "Gestión del shadow payroll para empleados con movilidad internacional para asegurar el reporte fiscal correcto en todas las jurisdicciones relevantes."], ["Revisión de contratos laborales", "Revisión y asesoría sobre contratos laborales para asegurar el cumplimiento con la ley local y la alineación con el marco de empleo del grupo."], ["Asesoría de cumplimiento de RRHH", "Asesoría sobre requisitos locales de cumplimiento de RRHH incluyendo tiempo de trabajo, derechos de licencia, procedimientos de despido y obligaciones de protección de datos."]], "ctaH": "Discuta sus requisitos de nómina", "ctaP": "Díganos dónde emplea y le daremos una imagen clara de sus obligaciones de cumplimiento y cómo ARM puede ayudarle a cumplirlas eficientemente.", "ctaBtn": "Programar una consulta →", "btn2": "Nuestros servicios", "apprEye": "El enfoque ARM", "apprH": "Estrategia antes que cumplimiento.", "apprP": "La mayoría de los proveedores de nómina son motores de cumplimiento. El papel de ARM Management es diferente: asesoramos sobre la estructura antes de ejecutar la nómina, identificando exposiciones antes de que se conviertan en pasivos.", "principles": [["Empleador de registro vs entidad local", "Asesoría sobre el modelo de empleo correcto para cada jurisdicción — cuándo es necesaria una entidad local y cuándo el enfoque de empleador de registro es más eficiente."], ["Eficiencia fiscal", "Estructuración de paquetes de compensación para gestionar eficientemente el impuesto sobre la renta, la seguridad social y las obligaciones de beneficios."], ["Planificación de asignaciones", "Planificación fiscal previa a la asignación para gestionar el riesgo de establecimiento permanente y la exposición fiscal de los empleados."], ["Gestión del riesgo de despido", "Asesoría sobre procedimientos de despido y obligaciones de indemnización antes de que se firmen los contratos laborales."]], "jurEye": "Jurisdicciones", "jurH": "Dónde asesoramos", "regions": [["Unión Europea", "Cumplimiento del derecho laboral en los 27 Estados miembros. Coordinación de seguridad social bajo reglamentos UE. Trabajadores desplazados, fronterizos."], ["CCG & Oriente Medio", "Cumplimiento WPS de los EAU, marcos laborales DIFC y ADGM, GOSI saudita, nómina en Qatar y Bahréin."], ["Asia-Pacífico", "CPF de Singapur, MPF de Hong Kong, EPF y SOCSO de Malasia, PF y ESIC en India, seguro social en Vietnam."], ["América Latina", "IMSS e INFONAVIT en México, cotizaciones de pensión y salud en Colombia, CLT en Brasil, AFP en Chile."]]}, "ar": {"title": "الرواتب والاستشارات في الموارد البشرية | ARM Management", "desc": "استراتيجية الرواتب العالمية، والامتثال متعدد الدول، وتخطيط المهمات الدولية، واستشارات الموارد البشرية.", "eye": "الرواتب والموارد البشرية", "h1": "الرواتب والاستشارات\nفي الموارد البشرية", "hero": "الامتثال في الرواتب متعدد الدول واستراتيجية القوى العاملة في كل ولاية قضائية تعمل بها.", "whatEye": "ما نقدّمه", "whatH": "الرواتب الدولية بلا مخاطر", "whatP1": "إدارة الرواتب عبر دول متعددة هي من أكثر الأنشطة التي تتطلب الامتثال في المؤسسات الدولية. يتباين قانون العمل والاشتراكات الاجتماعية وحجب الضرائب وقواعد إنهاء الخدمة بشكل كبير بين الولايات القضائية.", "whatP2": "توفّر ARM Management استشارة استراتيجية حول هيكل الرواتب العالمية، والامتثال متعدد الدول، وتخطيط المهمات الدولية، واستراتيجية القوى العاملة.", "svcEye": "خدماتنا", "svcH": "ما نستشير فيه", "svcs": [["استراتيجية الرواتب العالمية", "المشورة بشأن الهيكل الأمثل للرواتب لقوتك العاملة الدولية — صاحب عمل مسجّل أو رواتب عبر كيان محلي أو ترتيبات PEO أو مناهج هجينة."], ["الامتثال في الرواتب متعدد الدول", "ضمان حسابات الرواتب وحجب الضرائب واشتراكات الضمان الاجتماعي ومتطلبات كشوف الرواتب في كل ولاية قضائية."], ["تخطيط المهمات الدولية", "هيكلة المهمات الدولية لإدارة التعرض الضريبي والتزامات الضمان الاجتماعي وامتثال قانون العمل."], ["الرواتب الظل (Shadow Payroll)", "إدارة الرواتب الظل للموظفين المتنقلين دولياً لضمان التقارير الضريبية الصحيحة في جميع الولايات القضائية ذات الصلة."], ["مراجعة عقود العمل", "مراجعة عقود العمل والمشورة بشأنها لضمان الامتثال للقانون المحلي والتوافق مع إطار التوظيف الجماعي."], ["استشارات امتثال الموارد البشرية", "المشورة بشأن متطلبات امتثال الموارد البشرية المحلية بما في ذلك ساعات العمل وحقوق الإجازة وإجراءات إنهاء الخدمة."]], "ctaH": "ناقش متطلبات رواتبك", "ctaP": "أخبرنا أين توظّف وسنمنحك صورة واضحة عن التزامات الامتثال الخاصة بك وكيف يمكن لـ ARM مساعدتك في الوفاء بها.", "ctaBtn": "جدوِّل استشارة ←", "btn2": "خدماتنا", "apprEye": "نهج ARM", "apprH": "الاستراتيجية قبل الامتثال.", "apprP": "معظم مزودي الرواتب هم محركات امتثال. دور ARM Management مختلف: نستشير حول الهيكل قبل تشغيل الرواتب، ونحدد المخاطر قبل أن تتحوّل إلى التزامات.", "principles": [["صاحب العمل المسجّل مقابل الكيان المحلي", "المشورة حول نموذج التوظيف الصحيح لكل ولاية قضائية — متى يكون الكيان المحلي ضرورياً ومتى يكون نهج صاحب العمل المسجّل أكثر كفاءة."], ["الكفاءة الضريبية", "هيكلة حزم التعويضات لإدارة ضريبة الدخل والضمان الاجتماعي والتزامات المزايا بكفاءة."], ["تخطيط المهمات", "التخطيط الضريبي قبل المهمة لإدارة مخاطر المنشأة الدائمة والتعرض الضريبي للموظفين."], ["إدارة مخاطر إنهاء الخدمة", "المشورة بشأن إجراءات إنهاء الخدمة والتزامات التعويض قبل توقيع عقود العمل."]], "jurEye": "الولايات القضائية", "jurH": "أين نستشير", "regions": [["الاتحاد الأوروبي", "امتثال قانون العمل في الدول الأعضاء الـ27. تنسيق الضمان الاجتماعي وفق لوائح الاتحاد الأوروبي. العمال المنقولون والعابرون للحدود."], ["دول الخليج والشرق الأوسط", "امتثال الرواتب WPS الإماراتية، وأطر عمل DIFC وADGM، وGOSI السعودي، والرواتب في قطر والبحرين."], ["آسيا والمحيط الهادئ", "CPF في سنغافورة، وMPF في هونغ كونغ، وEPF وSOCSO في ماليزيا، وPF وESIC في الهند، والتأمين الاجتماعي في فيتنام."], ["أمريكا اللاتينية", "IMSS وINFONAVIT في المكسيك، واشتراكات التقاعد والصحة في كولومبيا، وCLT في البرازيل، وAFP في تشيلي."]]}, "ru": {"title": "Расчёт зарплат и HR | ARM Management", "desc": "Глобальная стратегия расчёта зарплат, многострановой комплаенс, планирование командировок и HR-консалтинг.", "eye": "Зарплаты и HR", "h1": "Расчёт зарплат\nи HR-консалтинг", "hero": "Многострановой комплаенс зарплат и стратегия персонала в каждой юрисдикции, где вы работаете.", "whatEye": "Что мы делаем", "whatH": "Международный расчёт зарплат без рисков", "whatP1": "Расчёт зарплат в нескольких странах — одна из наиболее требовательных с точки зрения комплаенс задач международного бизнеса. Трудовое законодательство, социальные взносы, налогообложение и правила увольнения существенно различаются по юрисдикциям.", "whatP2": "ARM Management предоставляет стратегические консультации по глобальной структуре расчёта зарплат, многострановому комплаенс, планированию международных командировок и стратегии персонала.", "svcEye": "Услуги", "svcH": "Что мы делаем", "svcs": [["Глобальная стратегия расчёта зарплат", "Консультирование по оптимальной структуре расчёта зарплат — работодатель по записи, местная компания, PEO или гибридные подходы."], ["Многострановой комплаенс зарплат", "Обеспечение корректности расчётов зарплат, налоговых удержаний, социальных взносов и требований к расчётным листкам в каждой юрисдикции."], ["Планирование международных командировок", "Структурирование международных командировок для управления налоговыми рисками, обязательствами по социальному страхованию и трудовым комплаенс."], ["Теневой расчёт зарплат", "Управление теневым расчётом зарплат для международно мобильных сотрудников для обеспечения корректной налоговой отчётности."], ["Проверка трудовых договоров", "Проверка трудовых договоров и консультации по ним для соответствия местному законодательству и групповой политике."], ["Консультирование по HR-комплаенс", "Консультирование по местным требованиям HR-комплаенс, включая режим рабочего времени, отпускные права, порядок увольнения и защиту данных."]], "ctaH": "Обсудите требования к расчёту зарплат", "ctaP": "Расскажите нам, где вы нанимаете сотрудников, и мы дадим чёткую картину ваших обязательств по комплаенс.", "ctaBtn": "Записаться на консультацию →", "btn2": "Наши услуги", "apprEye": "Подход ARM", "apprH": "Стратегия прежде комплаенс.", "apprP": "Большинство провайдеров расчёта зарплат — это движки комплаенс. Роль ARM Management иная: мы консультируем по структуре до запуска расчёта зарплат, выявляя риски до того, как они превращаются в обязательства.", "principles": [["Работодатель по записи vs местное юридическое лицо", "Консультирование по правильной модели трудоустройства для каждой юрисдикции — когда необходимо местное юрлицо, а когда эффективнее работодатель по записи."], ["Налоговая эффективность", "Структурирование компенсационных пакетов для эффективного управления подоходным налогом, социальными взносами и льготами."], ["Планирование командировок", "Налоговое планирование до командировки для управления риском постоянного представительства и налоговой нагрузкой сотрудников."], ["Управление риском увольнения", "Консультирование по процедурам увольнения и выходным пособиям до подписания трудовых договоров."]], "jurEye": "Юрисдикции", "jurH": "Где мы консультируем", "regions": [["Европейский союз", "Комплаенс трудового законодательства во всех 27 государствах-членах. Координация социального обеспечения по нормам ЕС. Командированные работники, трансграничные сотрудники."], ["Залив и Ближний Восток", "Комплаенс WPS ОАЭ, трудовые рамки DIFC и ADGM, Saudi GOSI, расчёт зарплат в Катаре и Бахрейне."], ["Азиатско-Тихоокеанский регион", "CPF Сингапура, MPF Гонконга, EPF и SOCSO Малайзии, PF и ESIC Индии, социальное страхование Вьетнама."], ["Латинская Америка", "IMSS и INFONAVIT Мексики, пенсионные и медицинские взносы Колумбии, CLT Бразилии, AFP Чили."]]}, "zh": {"title": "薪酬与人力资源咨询 | ARM Management", "desc": "全球薪酬战略、多国薪酬合规、国际外派规划及人力资源咨询。", "eye": "薪酬与人力资源", "h1": "薪酬与人力\n资源咨询", "hero": "覆盖您雇员所在每个司法管辖区的多国薪酬合规与劳动力战略。", "whatEye": "我们的服务内容", "whatH": "国际薪酬，零风险敞口", "whatP1": "跨多国运营薪酬是国际企业最具合规要求的活动之一。劳动法、社会保险缴纳、所得税预扣、福利要求和终止规则因司法管辖区而差异巨大。", "whatP2": "ARM Management就全球薪酬架构、多国薪酬合规、国际外派规划和劳动力战略提供战略咨询——通过单一资深关系进行协调。", "svcEye": "服务", "svcH": "咨询范围", "svcs": [["全球薪酬战略", "就国际劳动力的最优薪酬架构提供建议——雇主记录、当地实体薪酬、PEO安排或混合方式。"], ["多国薪酬合规", "确保每个司法管辖区的薪酬计算、税务预扣、社会保险缴纳和工资单要求均正确满足。"], ["国际外派规划", "架构国际外派以管理税务敞口、社会保障义务及母国与东道国的劳动法合规。"], ["影子薪酬", "为国际移动员工管理影子薪酬，确保在所有相关司法管辖区进行正确的税务申报。"], ["劳动合同审查", "审查劳动合同并提供建议，确保符合当地法律并与集团整体用工框架一致。"], ["人力资源合规咨询", "就当地人力资源合规要求提供建议，包括工作时间规定、休假权利、终止程序和数据保护义务。"]], "ctaH": "讨论您的薪酬要求", "ctaP": "告诉我们您在哪里雇用人员，我们将提供关于您的合规义务及ARM如何帮助您高效满足的清晰说明。", "ctaBtn": "预约咨询 →", "btn2": "我们的服务", "apprEye": "ARM方法", "apprH": "战略先于合规。", "apprP": "大多数薪酬服务提供商是合规引擎。ARM Management的角色不同：我们在薪酬运行之前就结构提供建议，在风险成为负债之前识别风险。", "principles": [["雇主记录与本地实体", "就每个司法管辖区的正确用工模式提供建议——何时需要本地实体，何时雇主记录方式更为高效。"], ["税务效率", "跨司法管辖区构建薪酬方案，高效管理所得税、社会保险和福利义务。"], ["外派规划", "外派前税务规划，管理常设机构风险和员工在母国及东道国的税务敞口。"], ["终止风险管理", "在签署劳动合同之前（而非在争议出现之后），就终止程序和遣散费义务提供建议。"]], "jurEye": "司法管辖区", "jurH": "咨询覆盖范围", "regions": [["欧盟", "全部27个成员国的劳动法合规。欧盟法规下的社会保障协调。外派工人、跨境通勤者。"], ["海湾及中东", "阿联酋WPS薪酬合规、DIFC和ADGM用工框架、沙特GOSI、卡塔尔和巴林薪酬。"], ["亚太地区", "新加坡CPF、香港MPF、马来西亚EPF和SOCSO、印度PF和ESIC、越南社会保险。"], ["拉丁美洲", "墨西哥IMSS和INFONAVIT、哥伦比亚养老和医疗缴款、巴西CLT、智利AFP。"]]}};
const c = DATA[lang];
---
<PageWrapper lang={lang} title={c.title} description={c.desc} canonicalPath="/services/payroll-hr">
<main dir={isRTL ? 'rtl' : 'ltr'}>
  <section class="page-hero">
    <div class="page-hero__bg" style="background-image:url('https://images.unsplash.com/photo-1521791136064-7986c2920216?w=1600&q=80&auto=format&fit=crop')"></div>
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content container">
      <span class="eyebrow">{c.eye}</span>
      <h1 set:html={c.h1.replace('\n','<br>')}></h1>
      <p>{c.hero}</p>
      <div class="btn-row" style="justify-content:flex-start;margin-top:30px">
        <a href={lp('/contact')} class="btn-primary">{c.ctaBtn}</a>
        <a href={lp('/services')} class="btn-secondary">{c.btn2}</a>
      </div>
    </div>
  </section>
  <section class="section section--cream">
    <div class="container--narrow">
      <span class="eyebrow reveal">{c.whatEye}</span>
      <h2 class="reveal">{c.whatH}</h2>
      <div class="gold-rule reveal"></div>
      <p class="reveal">{c.whatP1}</p>
      <p class="reveal" style="margin-top:20px">{c.whatP2}</p>
    </div>
  </section>
  <section class="section section--warm" style="border-top:1px solid #E2DDD6">
    <div class="container">
      <span class="eyebrow reveal">{c.svcEye}</span>
      <h2 class="reveal">{c.svcH}</h2>
      <div class="gold-rule reveal"></div>
      <div class="grid-3" style="margin-top:40px">
        {c.svcs.map(([h, p]: [string,string], i: number) => (
          <div class={`card reveal reveal-delay-${(i%3)+1}`}><h3>{h}</h3><p>{p}</p></div>
        ))}
      </div>
    </div>
  </section>
  <section class="section section--navy">
    <div class="container--narrow">
      <span class="eyebrow reveal" style="color:#B8960C">{c.apprEye}</span>
      <h2 class="reveal" style="color:#F7F3EC">{c.apprH}</h2>
      <div class="gold-rule reveal"></div>
      <p class="reveal" style="color:rgba(247,243,236,.78)">{c.apprP}</p>
      <div style="margin-top:48px;display:grid;grid-template-columns:repeat(2,1fr);gap:32px">
        {c.principles.map(([h, p]: [string,string], i: number) => (
          <div class={`reveal reveal-delay-${(i%2)+1}`} style="border-top:1px solid rgba(184,150,12,.3);padding-top:20px">
            <h4 style="font-family:'Inter',sans-serif;font-size:12px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:#B8960C;margin-bottom:10px">{h}</h4>
            <p style="color:rgba(247,243,236,.65);font-size:15px;line-height:1.75">{p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  <section class="section section--cream" style="border-top:1px solid #E2DDD6">
    <div class="container--narrow">
      <span class="eyebrow reveal">{c.jurEye}</span>
      <h2 class="reveal">{c.jurH}</h2>
      <div class="gold-rule reveal"></div>
      <div class="reveal" style="display:grid;grid-template-columns:repeat(2,1fr);gap:24px;margin-top:32px">
        {c.regions.map(([h, p]: [string,string]) => (
          <div style="padding:24px;background:#FDFAF6;border:1px solid #E2DDD6;border-radius:2px">
            <h4 style="font-size:16px;margin-bottom:8px">{h}</h4>
            <p style="font-size:14px;color:#6B7280;line-height:1.65">{p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  <section class="cta-section">
    <h2 class="reveal">{c.ctaH}</h2>
    <p class="reveal reveal-delay-1">{c.ctaP}</p>
    <div class="btn-row reveal reveal-delay-2">
      <a href={lp('/contact')} class="btn-primary">{c.ctaBtn}</a>
    </div>
  </section>
</main>
</PageWrapper>
