  {n:"Bangladesh", r:"South Asia", lat:23.7, lng:90.4, ct:"27.5%", vat:"15%", s:"bangladesh"},
  {n:"Pakistan", r:"South Asia", lat:30.4, lng:69.3, ct:"29%", vat:"18%", s:"pakistan"},
  {n:"Sri Lanka", r:"South Asia", lat:7.9, lng:80.7, ct:"30% / 14% export", vat:"18%", s:"sri-lanka"},
