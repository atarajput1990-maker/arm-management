---
import PageWrapper from './PageWrapper.astro';
import { localePath } from '../i18n/translations';
import type { Locale } from '../i18n/translations';
interface Props { lang: Locale; }
const { lang } = Astro.props;
const lp = (p: string) => localePath(lang, p);
const isRTL = lang === 'ar';

const L: Record<string, any> = {
  en: { title:"Who We Work With | ARM Management", desc:"ARM Management works with sophisticated individuals and organisations operating across borders.", eyebrow:"Clients", h1:"Who We Work With", hero:"Sophisticated clients who operate across borders.", btn1:"Discuss Your Mandate →", btn2:"Explore Our Services", s2eye:"The Clients We Serve", s2h:"Not Every Client. The Right Clients.", s2p1:"ARM Management does not serve every type of client. We work with a defined group of sophisticated individuals and organisations who share a common characteristic: they operate across borders and require an advisor who understands the full picture of their international business — not just a single jurisdiction or a single service line.", s2p2:"We are selective about the mandates we accept. Before any engagement begins, we assess honestly whether we can add meaningful value. If we cannot, we say so.", s3eye:"Who We Advise", s3h:"The Profiles We Work With", profiles:[["International Entrepreneurs","Founders building businesses across multiple jurisdictions — from initial market entry and entity formation through to complex multi-entity group structures, payroll, and ongoing compliance."],["Private Investors & Family Offices","Private capital deploying across international markets — structuring investment vehicles, managing cross-border tax efficiency, and navigating regulatory requirements in target jurisdictions."],["Multinational Corporations","Established businesses expanding into new markets or rationalising complex international structures — requiring experienced advisory that coordinates legal, tax, and regulatory requirements."],["High-Net-Worth Individuals","Internationally mobile individuals requiring residence planning, UAE Golden Visa and EU residency programmes, citizenship advisory, and coordination of cross-border personal tax obligations."],["Web3 & Crypto Businesses","Exchanges, protocols, token issuers, and Web3 infrastructure businesses requiring VARA, MiCA, and other regulatory licensing, plus entity formation and AML programme design."],["Professional Service Firms","Law firms, accounting practices, and consultancies seeking to extend their international offering through a coordinated referral relationship with an established cross-border advisory."]], s4eye:"Our Standard", s4h:"What Our Clients Expect From Us.", s4p:"Every ARM Management client receives the same standard of service regardless of mandate size: a named senior advisor who knows their business, honest assessments before work begins, fixed and transparent fees, and complete confidentiality.", standards:[["Complete Confidentiality","All client information is handled with absolute discretion. We do not publish client names, case studies, or transaction details without explicit written permission."],["Senior Continuity","The advisor who assesses your situation is the advisor who manages it. No handoffs, no account managers, no junior associates handling your most important matters."],["Honest Assessments","We tell clients honestly when something will not work, when a timeline is unrealistic, or when a jurisdiction presents risks that outweigh the commercial benefit."],["Transparent Fees","Every engagement is scoped and priced before work begins. No hourly billing surprises. Fees reflect value delivered, not time spent."]], ctaH:"Schedule a Consultation", ctaP:"Every new client engagement begins with a confidential introductory conversation. Tell us about your situation and what you are trying to achieve.", ctaBtn:"Schedule a Consultation →" },
  fr: { title:"Nos clients | ARM Management", desc:"ARM Management travaille avec des individus et organisations sophistiqués opérant à l'échelle internationale.", eyebrow:"Clients", h1:"Nos clients", hero:"Des clients avertis qui opèrent à l'international.", btn1:"Discuter de votre mandat →", btn2:"Découvrir nos services", s2eye:"Les clients que nous servons", s2h:"Pas tous les clients. Les bons clients.", s2p1:"ARM Management ne sert pas tous les types de clients. Nous travaillons avec un groupe défini d'individus et d'organisations sophistiqués qui partagent une caractéristique commune : ils opèrent à l'échelle internationale et ont besoin d'un conseiller qui comprend l'ensemble de leur activité.", s2p2:"Nous sommes sélectifs quant aux mandats que nous acceptons. Avant tout engagement, nous évaluons honnêtement si nous pouvons apporter une valeur réelle. Si ce n'est pas le cas, nous le disons.", s3eye:"Qui nous conseillons", s3h:"Les profils avec lesquels nous travaillons", profiles:[["Entrepreneurs internationaux","Fondateurs construisant des entreprises dans plusieurs juridictions — de l'entrée initiale sur le marché et la création d'entités jusqu'aux structures de groupe complexes, la paie et la conformité continue."],["Investisseurs privés & Family Offices","Capitaux privés déployés sur les marchés internationaux — structuration de véhicules d'investissement, gestion de l'efficacité fiscale transfrontalière."],["Multinationales","Entreprises établies en expansion dans de nouveaux marchés ou rationalisant des structures internationales complexes."],["Personnes fortunées","Personnes mobiles à l'international nécessitant une planification de résidence, des programmes de visa et des conseils en citoyenneté."],["Entreprises Web3 & Crypto","Exchanges, protocoles, émetteurs de tokens et entreprises d'infrastructure Web3 nécessitant des licences VARA, MiCA et autres."],["Cabinets de services professionnels","Cabinets d'avocats, cabinets comptables et consultants cherchant à étendre leur offre internationale."]], s4eye:"Notre standard", s4h:"Ce que nos clients attendent de nous.", s4p:"Chaque client d'ARM Management reçoit le même niveau de service, quelle que soit la taille du mandat : un conseiller senior dédié, des évaluations honnêtes, des honoraires fixes et transparents, et une confidentialité totale.", standards:[["Confidentialité totale","Toutes les informations clients sont traitées avec une discrétion absolue. Nous ne publions pas les noms des clients sans autorisation écrite explicite."],["Continuité senior","Le conseiller qui évalue votre situation est celui qui la gère. Pas de transferts, pas de responsables de compte, pas d'associés juniors."],["Évaluations honnêtes","Nous disons honnêtement aux clients quand quelque chose ne fonctionnera pas, quand un calendrier est irréaliste ou quand une juridiction présente des risques."],["Honoraires transparents","Chaque mission est délimitée et tarifée avant le début des travaux. Pas de surprises de facturation. Les honoraires reflètent la valeur apportée."]], ctaH:"Planifier une consultation", ctaP:"Chaque nouvelle mission client commence par une conversation introductive confidentielle. Parlez-nous de votre situation et de ce que vous cherchez à accomplir.", ctaBtn:"Planifier une consultation →" },
  es: { title:"Con quién trabajamos | ARM Management", desc:"ARM Management trabaja con individuos y organizaciones sofisticadas que operan a nivel internacional.", eyebrow:"Clientes", h1:"Con quién trabajamos", hero:"Clientes sofisticados que operan a nivel internacional.", btn1:"Discutir su mandato →", btn2:"Explorar nuestros servicios", s2eye:"Los clientes a los que servimos", s2h:"No todos los clientes. Los clientes correctos.", s2p1:"ARM Management no atiende a todos los tipos de clientes. Trabajamos con un grupo definido de individuos y organizaciones sofisticadas que comparten una característica común: operan a nivel internacional y requieren un asesor que comprenda el panorama completo de su negocio internacional.", s2p2:"Somos selectivos con los mandatos que aceptamos. Antes de comenzar cualquier proyecto, evaluamos honestamente si podemos añadir valor real. Si no podemos, lo decimos.", s3eye:"A quién asesoramos", s3h:"Los perfiles con los que trabajamos", profiles:[["Emprendedores internacionales","Fundadores construyendo negocios en múltiples jurisdicciones — desde la entrada inicial al mercado y la constitución de entidades hasta estructuras de grupo complejas."],["Inversores privados y Family Offices","Capital privado desplegado en mercados internacionales — estructuración de vehículos de inversión, gestión de eficiencia fiscal transfronteriza."],["Corporaciones multinacionales","Empresas establecidas expandiéndose en nuevos mercados o racionalizando estructuras internacionales complejas."],["Personas de alto patrimonio neto","Personas móviles internacionalmente que requieren planificación de residencia, programas de visado y asesoría en ciudadanía."],["Empresas Web3 y Crypto","Exchanges, protocolos, emisores de tokens y empresas de infraestructura Web3 que requieren licencias VARA, MiCA y otras."],["Firmas de servicios profesionales","Bufetes de abogados, firmas contables y consultoras que buscan extender su oferta internacional."]], s4eye:"Nuestro estándar", s4h:"Lo que nuestros clientes esperan de nosotros.", s4p:"Cada cliente de ARM Management recibe el mismo estándar de servicio independientemente del tamaño del mandato: un asesor senior dedicado, evaluaciones honestas, honorarios fijos y transparentes, y confidencialidad total.", standards:[["Confidencialidad total","Toda la información del cliente se maneja con absoluta discreción. No publicamos nombres de clientes sin permiso escrito explícito."],["Continuidad senior","El asesor que evalúa su situación es el que la gestiona. Sin traspasos, sin gestores de cuenta, sin asociados junior."],["Evaluaciones honestas","Decimos honestamente a los clientes cuando algo no funcionará, cuando un plazo es irreal o cuando una jurisdicción presenta riesgos."],["Honorarios transparentes","Cada proyecto tiene alcance y precio definidos antes de comenzar. Sin sorpresas de facturación. Los honorarios reflejan el valor entregado."]], ctaH:"Programar una consulta", ctaP:"Cada nuevo proyecto de cliente comienza con una conversación introductoria confidencial. Cuéntenos su situación y lo que intenta lograr.", ctaBtn:"Programar una consulta →" },
  ar: { title:"من نعمل معهم | ARM Management", desc:"تعمل ARM Management مع أفراد ومنظمات متطورين يعملون عبر الحدود.", eyebrow:"العملاء", h1:"من نعمل معهم", hero:"عملاء متطورون يعملون عبر الحدود.", btn1:"ناقش مشروعك ←", btn2:"اكتشف خدماتنا", s2eye:"العملاء الذين نخدمهم", s2h:"ليس كل عميل. العميل المناسب.", s2p1:"لا تخدم ARM Management كل أنواع العملاء. نعمل مع مجموعة محددة من الأفراد والمنظمات المتطورة التي تشترك في خاصية واحدة: تعمل عبر الحدود وتحتاج إلى مستشار يفهم الصورة الكاملة لأعمالها الدولية.", s2p2:"نحن انتقائيون في المشاريع التي نقبلها. قبل أي مشروع، نقيّم بصدق ما إذا كنا نستطيع إضافة قيمة حقيقية. وإذا لم نستطع، نقول ذلك.", s3eye:"من نستشير", s3h:"الملامح التي نعمل معها", profiles:[["رواد الأعمال الدوليون","مؤسسون يبنون أعمالاً في ولايات قضائية متعددة — من الدخول الأولي إلى السوق وتأسيس الكيانات وصولاً إلى هياكل المجموعات المعقدة."],["المستثمرون الخاصون ومكاتب العائلة","رأس المال الخاص المنتشر عبر الأسواق الدولية — هيكلة مركبات الاستثمار وإدارة الكفاءة الضريبية العابرة للحدود."],["الشركات متعددة الجنسيات","الشركات الراسخة التي تتوسع في أسواق جديدة أو تُعيد هيكلة هياكلها الدولية المعقدة."],["الأفراد من ذوي الثروات العالية","الأفراد المتنقلون دولياً الذين يحتاجون إلى تخطيط الإقامة وبرامج التأشيرات والمشورة في الجنسية."],["شركات Web3 والعملات الرقمية","البورصات والبروتوكولات ومُصدري الرموز وشركات البنية التحتية الرقمية التي تحتاج إلى تراخيص VARA وMiCA وغيرها."],["شركات الخدمات المهنية","مكاتب المحاماة وشركات المحاسبة والاستشارات الساعية إلى توسيع عرضها الدولي."]], s4eye:"معيارنا", s4h:"ما يتوقعه عملاؤنا منا.", s4p:"يحصل كل عميل من عملاء ARM Management على نفس مستوى الخدمة بصرف النظر عن حجم المشروع: مستشار كبير مسمّى يعرف أعماله، وتقييمات صادقة قبل البدء، وأتعاب ثابتة وشفافة، وسرية تامة.", standards:[["سرية تامة","تُعامَل جميع معلومات العملاء بتكتّم مطلق. لا ننشر أسماء العملاء دون إذن كتابي صريح."],["استمرارية كبار المستشارين","المستشار الذي يقيّم وضعك هو من يديره. بلا إحالات داخلية، بلا مديري حسابات، بلا مساعدين مبتدئين."],["تقييمات صادقة","نُخبر العملاء بصدق عندما لا يعمل شيء ما، أو عندما يكون الجدول الزمني غير واقعي، أو عندما تُشكّل ولاية قضائية مخاطر تفوق الفائدة التجارية."],["أتعاب شفافة","كل مشروع له نطاق وسعر محددان قبل البدء. لا مفاجآت في الفواتير. الأتعاب تعكس القيمة المُقدَّمة."]], ctaH:"جدوِّل استشارة", ctaP:"كل مشروع عميل جديد يبدأ بمحادثة تعريفية سرية. أخبرنا بوضعك وما تسعى لتحقيقه.", ctaBtn:"جدوِّل استشارة ←" },
  ru: { title:"С кем мы работаем | ARM Management", desc:"ARM Management работает с опытными частными лицами и организациями, ведущими деятельность в нескольких юрисдикциях.", eyebrow:"Клиенты", h1:"С кем мы работаем", hero:"Опытные клиенты, работающие на международных рынках.", btn1:"Обсудить мандат →", btn2:"Наши услуги", s2eye:"Клиенты, которых мы обслуживаем", s2h:"Не все клиенты. Правильные клиенты.", s2p1:"ARM Management не работает с клиентами любого типа. Мы сотрудничаем с определённой группой опытных частных лиц и организаций, объединённых общей характеристикой: они работают в нескольких юрисдикциях и нуждаются в консультанте, который понимает полную картину их международного бизнеса.", s2p2:"Мы избирательны в вопросе принятия проектов. До начала любого сотрудничества мы честно оцениваем, можем ли добавить реальную ценность. Если нет — говорим об этом прямо.", s3eye:"Кому мы консультируем", s3h:"Профили наших клиентов", profiles:[["Международные предприниматели","Основатели, строящие бизнес в нескольких юрисдикциях — от первоначального выхода на рынок до сложных групповых структур."],["Частные инвесторы и семейные офисы","Частный капитал, размещаемый на международных рынках — структурирование инвестиционных инструментов, налоговая оптимизация."],["Транснациональные корпорации","Established businesses entering new markets or reorganising complex international structures."],["Состоятельные частные лица","Международно мобильные физические лица, нуждающиеся в планировании резидентства, программах Золотой визы и налоговой координации."],["Компании в сфере Web3 и крипто","Биржи, протоколы, эмитенты токенов и инфраструктурные Web3-компании, нуждающиеся в лицензиях VARA, MiCA и других."],["Компании профессиональных услуг","Юридические фирмы, аудиторские практики и консультанты, стремящиеся расширить международное предложение."]], s4eye:"Наш стандарт", s4h:"Чего ожидают от нас наши клиенты.", s4p:"Каждый клиент ARM Management получает одинаковый уровень сервиса вне зависимости от размера проекта: именной старший консультант, честные оценки до начала работы, фиксированные и прозрачные гонорары, полная конфиденциальность.", standards:[["Полная конфиденциальность","Вся информация о клиентах обрабатывается с абсолютной осторожностью. Мы не публикуем имена клиентов без письменного разрешения."],["Преемственность на старшем уровне","Консультант, который оценивает вашу ситуацию, и управляет ею. Никаких передач, аккаунт-менеджеров или младших сотрудников."],["Честные оценки","Мы прямо говорим клиентам, когда что-то не сработает, когда сроки нереалистичны или когда юрисдикция несёт риски."],["Прозрачные гонорары","Каждый проект оценивается до начала работы. Никаких неожиданных счетов. Гонорары отражают ценность, а не затраченное время."]], ctaH:"Записаться на консультацию", ctaP:"Каждое новое клиентское взаимодействие начинается с конфиденциального вводного разговора. Расскажите о своей ситуации и целях.", ctaBtn:"Записаться на консультацию →" },
  zh: { title:"我们的服务对象 | ARM Management", desc:"ARM Management与跨境运营的专业人士和机构合作。", eyebrow:"客户", h1:"我们的服务对象", hero:"跨境运营的专业客户。", btn1:"讨论您的委托 →", btn2:"探索我们的服务", s2eye:"我们服务的客户", s2h:"不是所有客户，而是合适的客户。", s2p1:"ARM Management并不服务所有类型的客户。我们与一个定义明确的专业人士和机构群体合作，他们有一个共同特征：跨境运营，需要一位能够理解其国际业务全貌的顾问——而不仅仅是单一司法管辖区或单一服务线。", s2p2:"我们在接受的委托上具有选择性。在任何项目开始之前，我们诚实地评估是否能够提供有意义的价值。如果不能，我们会直接说明。", s3eye:"我们的咨询对象", s3h:"我们合作的客户类型", profiles:[["国际创业者","在多个司法管辖区构建业务的创始人——从最初的市场进入和实体设立，到复杂的多实体集团架构、薪酬和持续合规。"],["私人投资者与家族办公室","跨国际市场配置的私人资本——构建投资载体、管理跨境税务效率。"],["跨国公司","进入新市场或整合复杂国际架构的成熟企业。"],["高净值个人","需要居留规划、黄金签证项目、公民身份建议的国际移动人士。"],["Web3与加密货币企业","需要VARA、MiCA及其他监管许可的交易所、协议、代币发行方和Web3基础设施企业。"],["专业服务公司","希望通过与成熟跨境咨询建立合作关系来扩展国际业务的律师事务所和会计师事务所。"]], s4eye:"我们的标准", s4h:"我们的客户对我们的期望。", s4p:"每位ARM Management客户都获得相同水平的服务，无论委托规模如何：一位了解其业务的指定资深顾问、工作开始前的诚实评估、固定且透明的费用以及完全保密。", standards:[["完全保密","所有客户信息均以绝对谨慎处理。未经书面许可，我们不发布客户名称或案例研究。"],["资深持续性","评估您情况的顾问就是管理它的顾问。无转介、无客户经理、无初级助理处理您最重要的事务。"],["诚实评估","当某些事情不可行、时间表不现实，或某司法管辖区存在风险时，我们直接告知客户。"],["透明费用","每个项目在开始工作前确定范围和定价。无计费意外。费用反映交付的价值，而非花费的时间。"]], ctaH:"预约咨询", ctaP:"每个新客户项目都从一次保密的介绍性对话开始。告诉我们您的情况以及您想要实现什么。", ctaBtn:"预约咨询 →" },
};
const c = L[lang];
---
<PageWrapper lang={lang} title={c.title} description={c.desc} canonicalPath="/clients">
<main>
  <section class="page-hero">
    <div class="page-hero__bg" style="background-image:url('https://images.unsplash.com/photo-1573164713714-d95e436ab8d6?w=1600&q=80&auto=format&fit=crop')"></div>
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content container" dir={isRTL ? 'rtl' : 'ltr'}>
      <span class="eyebrow">{c.eyebrow}</span>
      <h1>{c.h1}</h1>
      <p>{c.hero}</p>
      <div class="btn-row" style="justify-content:flex-start;margin-top:30px">
        <a href={lp('/contact')} class="btn-primary">{c.btn1}</a>
        <a href={lp('/services')} class="btn-secondary">{c.btn2}</a>
      </div>
    </div>
  </section>
  <section class="section section--cream" dir={isRTL ? 'rtl' : 'ltr'}>
    <div class="container--narrow">
      <span class="eyebrow reveal">{c.s2eye}</span>
      <h2 class="reveal">{c.s2h}</h2>
      <div class="gold-rule reveal"></div>
      <p class="reveal">{c.s2p1}</p>
      <p class="reveal" style="margin-top:20px">{c.s2p2}</p>
    </div>
  </section>
  <section class="section section--warm" style="border-top:1px solid #E2DDD6" dir={isRTL ? 'rtl' : 'ltr'}>
    <div class="container">
      <span class="eyebrow reveal">{c.s3eye}</span>
      <h2 class="reveal">{c.s3h}</h2>
      <div class="gold-rule reveal"></div>
      <div class="grid-3" style="margin-top:40px">
        {c.profiles.map(([h, p]: [string, string], i: number) => (
          <div class={`card reveal reveal-delay-${(i % 3) + 1}`}>
            <h3>{h}</h3>
            <p>{p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  <section class="section section--navy" dir={isRTL ? 'rtl' : 'ltr'}>
    <div class="container--narrow">
      <span class="eyebrow reveal" style="color:#B8960C">{c.s4eye}</span>
      <h2 class="reveal" style="color:#F7F3EC">{c.s4h}</h2>
      <div class="gold-rule reveal"></div>
      <p class="reveal" style="color:rgba(247,243,236,.78)">{c.s4p}</p>
      <div style="margin-top:48px;display:grid;grid-template-columns:repeat(2,1fr);gap:32px">
        {c.standards.map(([h, p]: [string, string], i: number) => (
          <div class={`reveal reveal-delay-${(i % 2) + 1}`} style="border-top:1px solid rgba(184,150,12,.3);padding-top:20px">
            <h4 style="font-family:'Inter',sans-serif;font-size:12px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:#B8960C;margin-bottom:10px">{h}</h4>
            <p style="color:rgba(247,243,236,.65);font-size:15px;line-height:1.75">{p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  <section class="cta-section" dir={isRTL ? 'rtl' : 'ltr'}>
    <h2 class="reveal">{c.ctaH}</h2>
    <p class="reveal reveal-delay-1">{c.ctaP}</p>
    <div class="btn-row reveal reveal-delay-2">
      <a href={lp('/contact')} class="btn-primary">{c.ctaBtn}</a>
    </div>
  </section>
</main>
</PageWrapper>
