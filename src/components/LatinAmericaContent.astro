---
import PageWrapper from './PageWrapper.astro';
import { localePath } from '../i18n/translations';
import type { Locale } from '../i18n/translations';
interface Props { lang: Locale; }
const { lang } = Astro.props;
const lp = (p: string) => localePath(lang, p);
const isRTL = lang === 'ar';
const DATA: Record<string, any> = {"en": {"title": "Latin America | ARM Management", "desc": "ARM Management advises on company formation, accounting, payroll, and transaction advisory across Mexico, Colombia, Brazil, Chile, Panama, and Uruguay.", "eyebrow": "Latin America", "h1": "Latin America", "hero": "Mexico, Colombia, Brazil, Chile, Panama, and Uruguay.", "s2h": "ARM Management in Latin America", "s2p1": "Latin America represents a rapidly expanding market for international businesses. Mexico, Colombia, Brazil, Chile, Panama, and Uruguay each offer distinct investment opportunities — but also complex local regulatory environments, significant bureaucratic processes, and jurisdiction-specific legal requirements that require experienced local coordination.", "s2p2": "ARM Management advises on market entry, entity formation, tax compliance, payroll, and transaction structuring across the region, coordinating with vetted local professionals to ensure efficient, compliant operations.", "svcsEye": "Services in Latin America", "svcsH": "What ARM Management Does Here", "svcs": [["Company Formation", "Mexico SA de CV, Colombia SAS, Brazil Ltda, Chile SpA, Panama SA, Uruguay SRL. Tax IDs and registrations."], ["Accounting & Tax", "Local GAAP, VAT and corporate tax, transfer pricing, and statutory accounts across LATAM."], ["Payroll & HR", "Mexico IMSS/INFONAVIT, Colombia pension/health, Brazil CLT, Chile AFP, Panama CSS, Uruguay BPS."], ["Transaction Advisory", "LATAM M&A and private equity. Foreign investment compliance and cross-border deal management."], ["Company Maintenance", "Annual renewals, director/shareholder changes, registered agent, and statutory compliance."], ["Banking Introduction", "Coordinating corporate bank account openings with local banks in key LATAM jurisdictions."]], "navyEye": "Key Jurisdictions", "navyH": "Where We Operate", "offices": [["Mexico", "Mexico City and Monterrey. IMSS/INFONAVIT, SAT tax, VAT, transfer pricing, SA de CV / SAPI."], ["Colombia", "Bogotá. SAS formation, DIAN tax, pension/health contributions, cross-border structuring."], ["Brazil", "São Paulo. Ltda and SA, CNPJ registration, CLT employment compliance, federal and state tax."], ["Panama / Uruguay", "Panama SA and Uruguay SRL as holding structures. Canal Zone, Colón Free Zone, Zonamérica."]]}, "fr": {"title": "Amérique latine | ARM Management", "desc": "ARM Management conseille sur la création de sociétés, la comptabilité, la paie et les transactions au Mexique, Colombie, Brésil, Chili, Panama et Uruguay.", "eyebrow": "Amérique latine", "h1": "Amérique latine", "hero": "Mexique, Colombie, Brésil, Chili, Panama et Uruguay.", "s2h": "ARM Management en Amérique latine", "s2p1": "L'Amérique latine représente un marché en expansion rapide pour les entreprises internationales. Le Mexique, la Colombie, le Brésil, le Chili, le Panama et l'Uruguay offrent chacun des opportunités d'investissement distinctes — mais aussi des environnements réglementaires locaux complexes.", "s2p2": "ARM Management conseille sur l'entrée sur le marché, la création d'entités, la conformité fiscale, la paie et la structuration des transactions dans toute la région.", "svcsEye": "Services en Amérique latine", "svcsH": "Ce qu'ARM Management fait ici", "svcs": [["Création de sociétés", "SA de CV Mexique, SAS Colombie, Ltda Brésil, SpA Chili, SA Panama, SRL Uruguay. Numéros fiscaux."], ["Comptabilité & Fiscalité", "GAAP local, TVA et impôt sur les sociétés, prix de transfert, comptes statutaires en LATAM."], ["Paie & RH", "IMSS/INFONAVIT Mexique, retraite/santé Colombie, CLT Brésil, AFP Chili, CSS Panama, BPS Uruguay."], ["Conseil en transactions", "M&A et private equity LATAM. Conformité investissements étrangers et gestion transfrontalière."], ["Maintenance de sociétés", "Renouvellements annuels, changements dirigeants/actionnaires, agent enregistré, conformité statutaire."], ["Introduction bancaire", "Coordination des introductions bancaires avec les banques locales dans les principales juridictions."]], "navyEye": "Juridictions clés", "navyH": "Où nous opérons", "offices": [["Mexique", "Mexico et Monterrey. IMSS/INFONAVIT, impôt SAT, TVA, prix de transfert, SA de CV / SAPI."], ["Colombie", "Bogotá. Constitution SAS, conformité DIAN, cotisations retraite/santé, structuration transfrontalière."], ["Brésil", "São Paulo. Ltda et SA, CNPJ, conformité CLT, déclarations fiscales fédérales et d'État."], ["Panama / Uruguay", "SA Panama et SRL Uruguay comme structures holding. Zone du Canal, Zone franche de Colón, Zonamérica."]]}, "es": {"title": "América Latina | ARM Management", "desc": "ARM Management asesora en constitución de sociedades, contabilidad, nómina y transacciones en México, Colombia, Brasil, Chile, Panamá y Uruguay.", "eyebrow": "América Latina", "h1": "América Latina", "hero": "México, Colombia, Brasil, Chile, Panamá y Uruguay.", "s2h": "ARM Management en América Latina", "s2p1": "América Latina representa un mercado en rápida expansión para las empresas internacionales. México, Colombia, Brasil, Chile, Panamá y Uruguay ofrecen distintas oportunidades de inversión — pero también entornos regulatorios locales complejos y procesos burocráticos significativos.", "s2p2": "ARM Management asesora sobre entrada al mercado, constitución de entidades, cumplimiento fiscal, nómina y estructuración de transacciones en toda la región.", "svcsEye": "Servicios en América Latina", "svcsH": "Lo que hace ARM Management aquí", "svcs": [["Constitución de sociedades", "SA de CV México, SAS Colombia, Ltda Brasil, SpA Chile, SA Panamá, SRL Uruguay. RFC y registros."], ["Contabilidad & Impuestos", "GAAP local, IVA e impuesto de sociedades, precios de transferencia, cuentas estatutarias en LATAM."], ["Nómina & RRHH", "IMSS/INFONAVIT México, pensión/salud Colombia, CLT Brasil, AFP Chile, CSS Panamá, BPS Uruguay."], ["Asesoría en Transacciones", "M&A y private equity LATAM. Cumplimiento inversión extranjera y gestión transfronteriza."], ["Mantenimiento de sociedades", "Renovaciones anuales, cambios directores/accionistas, agente registrado, cumplimiento estatutario."], ["Introducción bancaria", "Coordinación de aperturas de cuentas bancarias con bancos locales en jurisdicciones clave."]], "navyEye": "Jurisdicciones clave", "navyH": "Dónde operamos", "offices": [["México", "Ciudad de México y Monterrey. IMSS/INFONAVIT, impuesto SAT, IVA, precios de transferencia."], ["Colombia", "Bogotá. Constitución SAS, cumplimiento DIAN, cotizaciones pensión/salud, estructuración transfronteriza."], ["Brasil", "São Paulo. Ltda y SA, CNPJ, cumplimiento CLT, declaraciones fiscales federales y estatales."], ["Panamá / Uruguay", "SA Panamá y SRL Uruguay como estructuras holding. Zona del Canal, Zona Libre Colón, Zonamérica."]]}, "ar": {"title": "أمريكا اللاتينية | ARM Management", "desc": "تقدّم ARM Management المشورة في تأسيس الشركات والمحاسبة والرواتب والمعاملات في المكسيك وكولومبيا والبرازيل وتشيلي وبنما والأوروغواي.", "eyebrow": "أمريكا اللاتينية", "h1": "أمريكا اللاتينية", "hero": "المكسيك، وكولومبيا، والبرازيل، وتشيلي، وبنما، والأوروغواي.", "s2h": "ARM Management في أمريكا اللاتينية", "s2p1": "تُمثّل أمريكا اللاتينية سوقاً سريعة التوسع للشركات الدولية. تقدّم كل من المكسيك وكولومبيا والبرازيل وتشيلي وبنما والأوروغواي فرصاً استثمارية مميزة — مع بيئات تنظيمية محلية معقدة وإجراءات بيروقراطية مهمة.", "s2p2": "تقدّم ARM Management المشورة في دخول السوق وتأسيس الكيانات والامتثال الضريبي والرواتب وهيكلة المعاملات عبر المنطقة.", "svcsEye": "الخدمات في أمريكا اللاتينية", "svcsH": "ما تفعله ARM Management هنا", "svcs": [["تأسيس الشركات", "SA de CV المكسيك، وSAS كولومبيا، وLtda البرازيل، وSpA تشيلي، وSA بنما، وSRL الأوروغواي."], ["المحاسبة والضرائب", "GAAP المحلي وضريبة القيمة المضافة وضريبة الشركات وأسعار التحويل والحسابات القانونية."], ["الرواتب والموارد البشرية", "IMSS/INFONAVIT المكسيك، والتقاعد/الصحة كولومبيا، وCLT البرازيل، وAFP تشيلي، وCSS بنما، وBPS الأوروغواي."], ["استشارات المعاملات", "الاندماجات والاستحواذات والأسهم الخاصة في أمريكا اللاتينية. امتثال الاستثمار الأجنبي."], ["صيانة الشركات", "التجديدات السنوية وتغييرات المديرين/المساهمين والوكيل المسجّل والامتثال القانوني."], ["التعريف المصرفي", "تنسيق فتح الحسابات المصرفية المؤسسية مع البنوك المحلية في الولايات القضائية الرئيسية."]], "navyEye": "الولايات القضائية الرئيسية", "navyH": "أين نعمل", "offices": [["المكسيك", "مكسيكو سيتي ومونتيري. IMSS/INFONAVIT وضريبة SAT وضريبة القيمة المضافة وأسعار التحويل وSA de CV."], ["كولومبيا", "بوغوتا. تأسيس SAS والامتثال لـ DIAN واشتراكات التقاعد/الصحة والهيكلة العابرة للحدود."], ["البرازيل", "ساو باولو. Ltda وSA وCNPJ وامتثال CLT والإيداعات الضريبية الفيدرالية والولائية."], ["بنما / أوروغواي", "SA بنما وSRL أوروغواي كهياكل قابضة. منطقة القناة ومنطقة كولون الحرة وZonamérica."]]}, "ru": {"title": "Латинская Америка | ARM Management", "desc": "ARM Management консультирует по регистрации компаний, бухучёту, зарплатам и сделкам в Мексике, Колумбии, Бразилии, Чили, Панаме и Уругвае.", "eyebrow": "Латинская Америка", "h1": "Латинская Америка", "hero": "Мексика, Колумбия, Бразилия, Чили, Панама и Уругвай.", "s2h": "ARM Management в Латинской Америке", "s2p1": "Латинская Америка представляет быстро растущий рынок для международных компаний. Мексика, Колумбия, Бразилия, Чили, Панама и Уругвай предлагают уникальные инвестиционные возможности — но и сложные местные регуляторные среды.", "s2p2": "ARM Management консультирует по выходу на рынок, регистрации структур, налоговому комплаенс, расчёту зарплат и структурированию сделок по всему региону.", "svcsEye": "Услуги в Латинской Америке", "svcsH": "Что ARM Management делает здесь", "svcs": [["Регистрация компаний", "SA de CV Мексики, SAS Колумбии, Ltda Бразилии, SpA Чили, SA Панамы, SRL Уругвая."], ["Учёт и налоги", "Местные GAAP, НДС и корпоративный налог, трансфертное ценообразование, установленная отчётность."], ["Расчёт зарплат и HR", "IMSS/INFONAVIT Мексики, пенсионные/медицинские Колумбии, CLT Бразилии, AFP Чили, CSS Панамы, BPS Уругвая."], ["Транзакционный консалтинг", "M&A и прямые инвестиции LATAM. Комплаенс иностранных инвестиций и управление сделками."], ["Поддержание компаний", "Ежегодные обновления, смена директоров/акционеров, зарегистрированный агент, statutory-комплаенс."], ["Банковское знакомство", "Координация корпоративных банковских знакомств с местными банками в ключевых юрисдикциях."]], "navyEye": "Ключевые юрисдикции", "navyH": "Где мы работаем", "offices": [["Мексика", "Мехико и Монтеррей. IMSS/INFONAVIT, налог SAT, НДС, трансфертное ценообразование, SA de CV."], ["Колумбия", "Богота. Регистрация SAS, комплаенс DIAN, пенсионные/медицинские взносы, структурирование."], ["Бразилия", "Сан-Паулу. Ltda и SA, CNPJ, комплаенс CLT, федеральные и штатные налоговые декларации."], ["Панама / Уругвай", "SA Панамы и SRL Уругвая как холдинги. Зона Канала, Зона свободной торговли Колон, Zonamérica."]]}, "zh": {"title": "拉丁美洲 | ARM Management", "desc": "ARM Management在墨西哥、哥伦比亚、巴西、智利、巴拿马和乌拉圭提供公司注册、会计、薪酬及交易咨询服务。", "eyebrow": "拉丁美洲", "h1": "拉丁美洲", "hero": "墨西哥、哥伦比亚、巴西、智利、巴拿马及乌拉圭。", "s2h": "ARM Management在拉丁美洲", "s2p1": "拉丁美洲是国际企业快速扩张的市场。墨西哥、哥伦比亚、巴西、智利、巴拿马和乌拉圭各自提供独特的投资机会——但也面临复杂的当地监管环境、重大的官僚流程和特定司法管辖区的法律要求。", "s2p2": "ARM Management提供市场进入、实体设立、税务合规、薪酬及整个地区的交易架构咨询，与经过核验的当地专业人士协调合作。", "svcsEye": "拉丁美洲服务", "svcsH": "ARM Management在此的服务", "svcs": [["公司注册", "墨西哥SA de CV、哥伦比亚SAS、巴西Ltda、智利SpA、巴拿马SA、乌拉圭SRL。税务识别号及注册。"], ["会计与税务", "当地公认会计准则、增值税和企业税、转让定价、各拉丁美洲司法管辖区法定账户。"], ["薪酬与人力资源", "墨西哥IMSS/INFONAVIT、哥伦比亚养老/医疗、巴西CLT、智利AFP、巴拿马CSS、乌拉圭BPS。"], ["交易咨询", "拉丁美洲并购和私募股权。外商投资合规及跨境交易管理。"], ["公司维护", "年度更新、董事/股东变更、注册代理服务及法定合规。"], ["银行介绍", "协调与拉丁美洲主要司法管辖区当地银行的公司银行账户开设。"]], "navyEye": "主要司法管辖区", "navyH": "我们的运营区域", "offices": [["墨西哥", "墨西哥城和蒙特雷。IMSS/INFONAVIT、SAT税务、增值税、转让定价及SA de CV / SAPI。"], ["哥伦比亚", "波哥大。SAS注册、DIAN税务合规、养老/医疗缴款及跨境架构。"], ["巴西", "圣保罗。Ltda和SA、CNPJ注册、CLT劳动合规及联邦/州税务申报。"], ["巴拿马/乌拉圭", "巴拿马SA和乌拉圭SRL作为控股架构。运河区、科隆自由区及Zonamérica。"]]}};
const c = DATA[lang];
---
<PageWrapper lang={lang} title={c.title} description={c.desc} canonicalPath="/regions/latin-america">
<main dir={isRTL ? 'rtl' : 'ltr'}>
  <section class="page-hero">
    <div class="page-hero__bg" style="background-image:url('https://images.unsplash.com/photo-1483729558449-99ef09a8c325?w=1600&q=80&auto=format&fit=crop')"></div>
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content container">
      <span class="eyebrow">{c.eyebrow}</span>
      <h1>{c.h1}</h1>
      <p>{c.hero}</p>
    </div>
  </section>
  <section class="section section--cream">
    <div class="container--narrow">
      <h2 class="reveal">{c.s2h}</h2>
      <div class="gold-rule reveal"></div>
      <p class="reveal">{c.s2p1}</p>
      <p class="reveal" style="margin-top:20px">{c.s2p2}</p>
    </div>
  </section>
  <section class="section section--warm" style="border-top:1px solid #E2DDD6">
    <div class="container">
      <span class="eyebrow reveal">{c.svcsEye}</span>
      <h2 class="reveal">{c.svcsH}</h2>
      <div class="gold-rule reveal"></div>
      <div class="grid-3" style="margin-top:40px">
        {c.svcs.map(([sh, sp]: [string,string], i: number) => (
          <div class={`card reveal reveal-delay-${(i%3)+1}`}><h3>{sh}</h3><p>{sp}</p></div>
        ))}
      </div>
    </div>
  </section>
  <section class="section section--navy">
    <div class="container--narrow">
      <span class="eyebrow reveal" style="color:#B8960C">{c.navyEye}</span>
      <h2 class="reveal" style="color:#F7F3EC">{c.navyH}</h2>
      <div class="gold-rule reveal"></div>
      <div style="margin-top:40px;display:grid;grid-template-columns:repeat(2,1fr);gap:24px">
        {c.offices.map(([oh, op]: [string,string], i: number) => (
          <div class={`reveal reveal-delay-${(i%2)+1}`} style="background:rgba(247,243,236,.04);border:1px solid rgba(184,150,12,.2);padding:24px;border-radius:2px">
            <h4 style="color:#C9A227;font-family:'Inter',sans-serif;font-size:13px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;margin-bottom:10px">{oh}</h4>
            <p style="color:rgba(247,243,236,.65);font-size:14px;line-height:1.7">{op}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  <section class="cta-section">
    <h2 class="reveal">{c.ctaH}</h2>
    <p class="reveal reveal-delay-1">{c.ctaP}</p>
    <div class="btn-row reveal reveal-delay-2">
      <a href={lp('/contact')} class="btn-primary">{c.ctaBtn}</a>
      <a href={lp('/services')} class="btn-secondary">{c.btn2}</a>
    </div>
  </section>
</main>
</PageWrapper>
