  [dir="rtl"] .ed-eyebrow.is-center::after { content: ""; width: 30px; height: 1px; background: var(--gold); }
</style>

<script>
  // editorial reveals
  const io = new IntersectionObserver((es) => {
    es.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
  }, { threshold: 0.18 });
  document.querySelectorAll('.ed-rise, .ed-fade').forEach((el) => io.observe(el));

  // parallax on full-bleed photo plates
  const phs = Array.prototype.slice.call(document.querySelectorAll('.ed-plate .ed-ph'));
  function loop() {
    const vh = window.innerHeight;
    for (let i = 0; i < phs.length; i++) {
      const ph = phs[i];
      const r = ph.parentElement.getBoundingClientRect();
      if (r.bottom < -200 || r.top > vh + 200) continue;
      const c = (r.top + r.height / 2 - vh / 2);
      ph.style.transform = 'translate3d(0,' + (c * -0.08).toFixed(1) + 'px,0)';
    }
    requestAnimationFrame(loop);
  }
  requestAnimationFrame(loop);
</script>
