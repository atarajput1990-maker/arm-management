---
// src/components/HomeContent.astro
// Renders the full homepage for any locale. Import and pass lang="xx".
import Base from '../layouts/Base.astro';
import { t, localePath } from '../i18n/translations';
import type { Locale } from '../i18n/translations';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const tr  = t(lang);
const h   = tr.home;
const lp  = (p: string) => localePath(lang, p);
const isRTL = lang === 'ar';
const displayFont = isRTL ? "'Noto Naskh Arabic', serif" : "'Cormorant Garamond', serif";
---
<Base
  title={tr.meta.homeTitle}
  description={tr.meta.homeDescription}
  lang={lang}
  canonicalPath="/"
>
<main class="ed" dir={isRTL ? 'rtl' : 'ltr'}>

  <!-- HERO -->
  <header class="ed-hero">
    <div class="ed-ph" style="background-image:url('/images/ed-hero.jpg')"></div>
    <div class="ed-veil"></div>
    <div class="ed-wrap">
      <div class="ed-eyebrow is-light ed-fade">{h.eyebrow}</div>
      <h1 class="ed-h ed-rise"><span>{h.heroHeading}</span></h1>
      <p class="ed-sub ed-fade">{h.heroSub}</p>
      <div class="ed-btns ed-fade">
        <a href={lp('/contact')} class="ed-btn ed-btn--g">{tr.cta.speak}</a>
        <a href={lp('/services')} class="ed-btn ed-btn--o">{tr.cta.explore}</a>
      </div>
      <div class="ed-crow ed-fade">{h.cities}</div>
    </div>
  </header>

  <!-- STATEMENT -->
  <section class="ed-sec ed-paper ed-pad">
    <div class="ed-wrap">
      <div class="ed-eyebrow ed-fade">{h.statementEyebrow}</div>
      <div class="ed-two">
        <h2 class="ed-display ed-rise"><span>{h.statementHeading}</span></h2>
        <div><p class="ed-lead ed-fade">{h.statementBody}</p></div>
      </div>
    </div>
  </section>

  <!-- TRUST STATS -->
  <section class="ed-trust">
    <div class="ed-wrap">
      {h.stats.map(s => (
        <div class="ed-stat ed-fade"><span class="n">{s.n}</span><span class="l">{s.l}</span></div>
      ))}
    </div>
  </section>

  <!-- GATEWAYS -->
  <section class="ed-gateways" aria-label={h.gatewaysLabel}>
    {h.gateways.map(g => (
      <a class="ed-plate" href={g.href}>
        <div class="ed-ph" style={`background-image:url('/images/ed-${g.city === 'Brussels' || g.city === 'Bruxelles' || g.city === 'Bruselas' || g.city === 'بروكسل' || g.city === 'Брюссель' || g.city === '布鲁塞尔' ? 'brussels' : g.city === 'Zurich' || g.city === 'Zúrich' || g.city === 'زيورخ' || g.city === 'Цюрих' || g.city === '苏黎世' ? 'zurich' : g.city === 'Riyadh' || g.city === 'Riad' || g.city === 'Riyad' || g.city === 'الرياض' || g.city === 'Эр-Рияд' || g.city === '利雅得' ? 'riyadh' : g.city === 'Dubai' || g.city === 'Dubaï' || g.city === 'Dubái' || g.city === 'دبي' || g.city === 'Дубай' || g.city === '迪拜' ? 'dubai' : 'shenzhen'}.jpg')`}></div>
        <div class="ed-veil"></div>
        <div class="ed-wrap ed-cap">
          <span class="num">{g.num}</span>
          <div class="ed-city ed-rise"><span>{g.city}</span></div>
          <span class="ctry ed-fade">{g.ctry}</span>
          <span class="go">{tr.cta.exploreRegion}</span>
        </div>
      </a>
    ))}
  </section>

  <!-- CAPABILITIES -->
  <section class="ed-sec ed-warm ed-pad">
    <div class="ed-wrap">
      <div class="ed-eyebrow ed-fade">{h.capabilitiesEyebrow}</div>
      <h2 class="ed-display ed-rise"><span>{h.capabilitiesHeading}</span></h2>
      <div class="ed-rows">
        {h.capabilities.map(c => (
          <a class="ed-row ed-fade" href={c.href}>
            <span class="ri">{c.n}</span>
            <h3>{c.title}</h3>
            <p>{c.body}</p>
            <span class="ar">{isRTL ? '←' : '→'}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ARM VERIFY (English only — keep English for the product name) -->
  <section class="ed-verify">
    <div class="ed-wrap ed-verify-in">
      <div>
        <div class="ed-eyebrow is-light ed-fade">ARM Verify — Live</div>
        <h2 class="ed-display ed-rise" style="color:#fff"><span>{
          lang === 'fr' ? 'Vérifiez toute entité, instantanément.' :
          lang === 'es' ? 'Verifique cualquier entidad, al instante.' :
          lang === 'ar' ? 'تحقّق من أي كيان على الفور.' :
          lang === 'ru' ? 'Проверьте любое юридическое лицо мгновенно.' :
          lang === 'zh' ? '即时核验任何主体。' :
          'Verify any entity, instantly.'
        }</span></h2>
        <p class="ed-sub ed-fade" style="color:rgba(247,243,236,.72);max-width:46ch">{
          lang === 'fr' ? 'KYC en temps réel, vérification des sanctions et cartographie des UBO dans 35+ juridictions — listes OFAC, ONU, UE et UK HMT, à partir de 0,50 $.' :
          lang === 'es' ? 'KYC en tiempo real, cribado de sanciones y mapeo de UBO en más de 35 jurisdicciones — listas OFAC, ONU, UE y UK HMT, desde $0,50 por consulta.' :
          lang === 'ar' ? 'التحقق من هوية العملاء (KYC) وفحص العقوبات وتحديد المستفيدين الفعليين (UBO) في أكثر من 35 ولاية قضائية — قوائم OFAC وUN وEU وUK HMT، بدءاً من 0.50 دولار.' :
          lang === 'ru' ? 'KYC в реальном времени, проверка санкций и составление карты UBO в 35+ юрисдикциях — списки OFAC, ООН, ЕС и UK HMT, от $0,50 за запрос.' :
          lang === 'zh' ? '覆盖35+司法管辖区的实时KYC、制裁筛查及受益所有人（UBO）图谱——包括OFAC、联合国、欧盟及英国HMT名单，每次查询低至0.50美元。' :
          'Real-time KYC, sanctions screening and UBO mapping across 35+ jurisdictions — OFAC, UN, EU and UK HMT lists, from $0.50 per check.'
        }</p>
      </div>
      <div class="ed-verify-cta ed-fade">
        <a href="https://verify.arm-management.com" class="ed-btn ed-btn--g" target="_blank" rel="noopener">{
          lang === 'ar' ? 'تحقّق من كيان ←' :
          lang === 'fr' ? 'Vérifier une entité →' :
          lang === 'es' ? 'Verificar una entidad →' :
          lang === 'ru' ? 'Проверить юридическое лицо →' :
          lang === 'zh' ? '核验主体 →' :
          'Verify an Entity →'
        }</a>
        <div class="ed-pills"><span>OFAC · UN · EU · UK HMT</span><span>35+ Jurisdictions</span><span>From $0.50</span></div>
      </div>
    </div>
  </section>

  <!-- THE ARM STANDARD -->
  <section class="ed-sec ed-paper ed-pad">
    <div class="ed-wrap">
      <div class="ed-eyebrow ed-fade">{h.differenceEyebrow}</div>
      <h2 class="ed-display ed-rise" style="max-width:18ch"><span>{h.differenceHeading}</span></h2>
      <div class="ed-principles">
        {[
          {
            title: lang === 'fr' ? 'Évaluation honnête, d\'abord' : lang === 'es' ? 'Evaluación honesta, primero' : lang === 'ar' ? 'التقييم الصادق أولاً' : lang === 'ru' ? 'Сначала — честная оценка' : lang === 'zh' ? '坦诚评估，优先于一切' : 'Honest Assessment First',
            body:  lang === 'fr' ? 'Nous évaluons chaque mandat et vous disons directement ce qui est réaliste — et avons décliné des engagements que nous ne pouvions pas bien servir.' : lang === 'es' ? 'Evaluamos cada mandato y le decimos directamente qué es realista — y hemos rechazado encargos que no podíamos servir bien.' : lang === 'ar' ? 'نقيّم كل مهمة ونخبركم بصراحة بما هو قابل للتحقيق — لقد رفضنا في مناسبات عدة الالتزامات التي لم نكن قادرين على خدمتها جيداً.' : lang === 'ru' ? 'Мы оцениваем каждый мандат и прямо говорим, что реалистично — и отказывались от проектов, которые не могли выполнить должным образом.' : lang === 'zh' ? '我们评估每一个委托，直接告知可行的结果——并曾拒绝我们无法有效服务的项目。' : 'We evaluate every mandate and tell you directly what is realistic — and have declined engagements we could not serve well.',
          },
          {
            title: lang === 'fr' ? 'Conseillers seniors. Toujours.' : lang === 'es' ? 'Asesores senior. Siempre.' : lang === 'ar' ? 'مستشارون متمرّسون. دائماً.' : lang === 'ru' ? 'Старшие консультанты. Всегда.' : lang === 'zh' ? '资深顾问，始终如一。' : 'Senior Advisors. Always.',
            body:  lang === 'fr' ? 'Le conseiller de votre premier entretien est la personne qui gère votre dossier. Pas de transfert, pas de collaborateurs juniors.' : lang === 'es' ? 'El asesor de su primera conversación es quien gestiona su caso. Sin traspasos, sin asociados junior.' : lang === 'ar' ? 'المستشار في أول محادثة هو المسؤول عن ملفكم. لا إحالات داخلية، لا مساعدين مبتدئين.' : lang === 'ru' ? 'Консультант вашей первой беседы — это тот же человек, который ведёт ваш проект. Никаких передач, никаких младших сотрудников.' : lang === 'zh' ? '第一次沟通时的顾问，就是全程负责您项目的顾问。无转介，无初级助理。' : 'The advisor in your first conversation is the person managing your engagement. No handoffs, no junior associates.',
          },
          {
            title: lang === 'fr' ? 'Nous trouvons l\'alternative' : lang === 'es' ? 'Encontramos la alternativa' : lang === 'ar' ? 'نجد البديل دائماً' : lang === 'ru' ? 'Мы находим альтернативу' : lang === 'zh' ? '我们寻找替代路径' : 'We Find the Alternative',
            body:  lang === 'fr' ? 'Quand la voie principale est bloquée, nous identifions le chemin viable suivant. Nous n\'avons jamais clôturé un engagement sans solution.' : lang === 'es' ? 'Cuando la vía principal está bloqueada, identificamos el siguiente camino viable. Nunca hemos cerrado un encargo sin una solución.' : lang === 'ar' ? 'عندما يكون الطريق الأساسي مسدوداً، نحدّد المسار البديل القابل للتطبيق. لم نُغلق أي ملف دون حل.' : lang === 'ru' ? 'Когда основной путь закрыт, мы находим следующий рабочий маршрут. Мы ни разу не закрывали проект без решения.' : lang === 'zh' ? '当主要路径受阻时，我们识别下一条可行路径。我们从未在没有找到解决方案的情况下结束项目。' : 'When the primary route is blocked, we identify the next viable path. We have never closed an engagement without one.',
          },
          {
            title: lang === 'fr' ? 'Disponibles en permanence' : lang === 'es' ? 'Disponibles en todo momento' : lang === 'ar' ? 'متاحون على مدار الساعة' : lang === 'ru' ? 'Доступны круглосуточно' : lang === 'zh' ? '全天候响应' : 'Available Around the Clock',
            body:  lang === 'fr' ? 'Les affaires internationales ne respectent pas un seul fuseau horaire. Les clients actifs ont un accès direct à leur conseiller, à toute heure.' : lang === 'es' ? 'Los negocios transfronterizos no se ajustan a una única zona horaria. Los clientes activos tienen acceso directo a su asesor a cualquier hora.' : lang === 'ar' ? 'الأعمال الدولية لا تتقيّد بمنطقة زمنية واحدة. عملاؤنا النشطون يصلون مباشرة إلى مستشارهم في أي وقت.' : lang === 'ru' ? 'Международный бизнес не привязан к одному часовому поясу. Активные клиенты имеют прямой доступ к своему консультанту в любое время.' : lang === 'zh' ? '跨境业务不受单一时区限制。活跃客户可在任何时间直接联系其专属顾问。' : 'Cross-border business does not keep to one time zone. Active clients have direct access to their advisor at any hour.',
          },
        ].map(p => (
          <div class="ed-principle ed-fade">
            <h4>{p.title}</h4>
            <p>{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- QUOTE -->
  <section class="ed-quote ed-pad">
    <div class="ed-wrap">
      <blockquote class="ed-fade">{
        lang === 'fr' ? 'Ce qu\'un conseiller international peut offrir de plus précieux n\'est pas un réseau, et ce n\'est pas un processus. C\'est le courage de vous dire la vérité sur ce qui est possible — et l\'expertise pour trouver une meilleure voie quand la solution évidente échoue.' :
        lang === 'es' ? 'Lo más valioso que puede ofrecer un asesor internacional no es una red, ni es un proceso. Es el coraje de decirle la verdad sobre lo que es posible — y la experiencia para encontrar un camino mejor cuando la solución obvia falla.' :
        lang === 'ar' ? 'أثمن ما يمكن أن يقدّمه المستشار الدولي ليس شبكة علاقات، وليس منهجاً. إنه الشجاعة لإخباركم بالحقيقة حول ما هو ممكن — والخبرة للعثور على مسار أفضل عندما يفشل الطريق الواضح.' :
        lang === 'ru' ? 'Самое ценное, что может предложить международный консультант, — это не сеть контактов и не отлаженный процесс. Это смелость сказать вам правду о том, что возможно, — и экспертиза, чтобы найти лучший путь, когда очевидное решение не работает.' :
        lang === 'zh' ? '一位国际顾问所能给予的最宝贵之物，既非人脉，也非流程。而是如实告知您何为可能的勇气——以及当显而易见的路径行不通时，找到更好出路的专业能力。' :
        'The most valuable thing an international advisor can offer is not a network, and it is not a process. It is the courage to tell you the truth about what is possible — and the expertise to find a better way when the obvious path fails.'
      }</blockquote>
      <cite class="ed-fade">— ARM Management</cite>
    </div>
  </section>

  <!-- REGIONS -->
  <section class="ed-sec ed-cream ed-pad">
    <div class="ed-wrap" style="text-align:center">
      <div class="ed-eyebrow is-center ed-fade">{
        lang === 'fr' ? 'Couverture mondiale' :
        lang === 'es' ? 'Alcance global' :
        lang === 'ar' ? 'حضور عالمي' :
        lang === 'ru' ? 'Глобальный охват' :
        lang === 'zh' ? '全球覆盖' :
        'Global Reach'
      }</div>
      <h2 class="ed-display ed-rise" style="margin:0 auto"><span>{
        lang === 'fr' ? 'Quatre régions. Quarante juridictions. Un seul interlocuteur.' :
        lang === 'es' ? 'Cuatro regiones. Cuarenta jurisdicciones. Un solo punto de contacto.' :
        lang === 'ar' ? 'أربع مناطق. أربعون ولاية قضائية. نقطة تواصل واحدة.' :
        lang === 'ru' ? 'Четыре региона. Сорок юрисдикций. Один контакт.' :
        lang === 'zh' ? '四大区域。四十个司法管辖区。一个联络点。' :
        'Four regions. Forty jurisdictions. One point of contact.'
      }</span></h2>
      <div class="ed-reglist ed-fade">
        <a class="ed-reglink" href={lp('/regions/european-union')}>{tr.nav.regionsDropdown.eu}</a>
        <a class="ed-reglink" href={lp('/regions/gcc-middle-east')}>{tr.nav.regionsDropdown.gcc}</a>
        <a class="ed-reglink" href={lp('/regions/asia-pacific')}>{tr.nav.regionsDropdown.asia}</a>
        <a class="ed-reglink" href={lp('/regions/latin-america')}>{tr.nav.regionsDropdown.latam}</a>
      </div>
    </div>
  </section>

  <!-- CLOSE -->
  <section class="ed-close ed-pad">
    <div class="ed-wrap">
      <div class="ed-eyebrow is-center ed-fade">{h.closingEyebrow}</div>
      <h2 class="ed-display ed-rise" style="margin:0 auto;max-width:20ch"><span>{h.closingHeading}</span></h2>
      <div class="ed-rule" style="margin:30px auto"></div>
      <p class="ed-lead ed-fade" style="margin:0 auto 36px;max-width:60ch;text-align:center">{h.closingBody}</p>
      <div class="ed-btns ed-fade" style="justify-content:center">
        <a href={lp('/contact')} class="ed-btn ed-btn--g">{tr.cta.speak}</a>
        <a href="mailto:info@arm-management.com" class="ed-btn ed-btn--n">info@arm-management.com</a>
      </div>
    </div>
  </section>

</main>

<style define:vars={{ displayFont }}>
  .ed { background: var(--warm); }
  .ed-wrap { max-width: 1240px; margin: 0 auto; padding: 0 clamp(24px,7vw,110px); }
  .ed-pad  { padding: clamp(88px,13vh,164px) 0; }
  .ed-paper{ background: var(--warm); } .ed-warm{ background:#FBF7EF; } .ed-cream{ background: var(--cream); }

  .ed-eyebrow{ font-family:'Inter',sans-serif; font-weight:500; font-size:10.5px; letter-spacing:.4em; text-transform:uppercase; color:var(--gold); display:flex; align-items:center; gap:14px; margin-bottom:30px; }
  .ed-eyebrow::before{ content:""; width:30px; height:1px; background:var(--gold); }
  .ed-eyebrow.is-light{ color:#E9C766; } .ed-eyebrow.is-light::before{ background:#E9C766; }
  .ed-eyebrow.is-center{ justify-content:center; }
  .ed-eyebrow.is-center::after{ content:""; width:30px; height:1px; background:var(--gold); }

  .ed-display{ font-family: var(--displayFont); font-weight:300; line-height:1.04; letter-spacing:.004em; color:var(--navy); font-size:clamp(32px,5vw,64px); }

  .ed-rise{ display:block; overflow:hidden; padding-bottom:.16em; }
  .ed-rise > span{ display:block; transform:translateY(112%); transition:transform 1.1s cubic-bezier(.16,1,.3,1); }
  .ed-rise.in > span{ transform:translateY(0); }
  .ed-fade{ opacity:0; transform:translateY(26px); transition:opacity 1.1s cubic-bezier(.16,1,.3,1), transform 1.1s cubic-bezier(.16,1,.3,1); }
  .ed-fade.in{ opacity:1; transform:none; }

  /* HERO */
  .ed-hero{ position:relative; height:100vh; min-height:620px; overflow:hidden; color:#fff; display:flex; align-items:flex-end; }
  .ed-hero .ed-ph{ position:absolute; inset:0; background-position:center; background-size:cover; transform:scale(1.06); animation:edken 22s ease-out forwards; }
  @keyframes edken{ to{ transform:scale(1.16) translateY(-1.5%); } }
  .ed-hero .ed-veil{ position:absolute; inset:0; background:linear-gradient(180deg,rgba(8,14,20,.36),rgba(8,14,20,.06) 32%,rgba(8,14,20,.5) 76%,rgba(8,14,20,.8)); }
  .ed-hero .ed-wrap{ position:relative; z-index:2; width:100%; padding-bottom:clamp(60px,11vh,118px); }
  .ed-hero .ed-h{ font-family: var(--displayFont); font-weight:300; line-height:1.06; font-size:clamp(34px,5vw,68px); color:#fff; max-width:28ch; margin:0; }
  .ed-sub{ font-family:'Inter',sans-serif; font-weight:300; font-size:clamp(14px,1.3vw,17px); line-height:1.85; color:rgba(255,255,255,.82); max-width:56ch; margin:24px 0 0; }
  .ed-rule{ width:66px; height:1px; background:#E9C766; margin:28px 0; }
  .ed-btns{ display:flex; gap:14px; flex-wrap:wrap; margin-top:30px; }
  .ed-btn{ font-family:'Inter',sans-serif; font-weight:600; font-size:12px; letter-spacing:.1em; text-transform:uppercase; padding:15px 26px; border-radius:2px; transition:background .25s,color .25s,opacity .25s; }
  .ed-btn--g{ background:var(--gold); color:var(--navy); } .ed-btn--g:hover{ background:#cca91d; }
  .ed-btn--o{ border:1px solid rgba(255,255,255,.5); color:#fff; } .ed-btn--o:hover{ background:#fff; color:var(--navy); }
  .ed-btn--n{ border:1px solid var(--navy); color:var(--navy); } .ed-btn--n:hover{ background:var(--navy); color:#fff; }
  .ed-crow{ margin-top:30px; font-family:'Inter',sans-serif; font-size:11px; letter-spacing:.26em; text-transform:uppercase; color:rgba(255,255,255,.72); }

  /* STATEMENT */
  .ed-two{ display:grid; grid-template-columns:1.35fr .9fr; gap:clamp(28px,5vw,76px); align-items:start; margin-top:4px; }
  .ed-two .ed-lead{ margin-top:6px; }
  .ed-lead{ font-size:clamp(15px,1.15vw,17px); line-height:1.95; color:#2C3240; max-width:48ch; }
  @media (max-width:820px){ .ed-two{ grid-template-columns:1fr; } }

  /* TRUST */
  .ed-trust{ background:var(--navy); }
  .ed-trust .ed-wrap{ display:grid; grid-template-columns:repeat(4,1fr); gap:30px; padding-top:48px; padding-bottom:48px; }
  .ed-stat .n{ display:block; font-family: var(--displayFont); font-weight:600; font-size:clamp(2rem,3.4vw,2.6rem); color:var(--gold); }
  .ed-stat .l{ display:block; font-family:'Inter',sans-serif; font-weight:500; font-size:11px; letter-spacing:.16em; text-transform:uppercase; color:rgba(247,243,236,.6); margin-top:8px; }
  @media (max-width:680px){ .ed-trust .ed-wrap{ grid-template-columns:1fr 1fr; gap:30px; } }

  /* GATEWAYS */
  .ed-plate{ position:relative; display:block; height:100vh; min-height:560px; overflow:hidden; color:#fff; }
  .ed-plate .ed-ph{ position:absolute; left:0; right:0; top:-14%; height:128%; background-position:center; background-size:cover; will-change:transform; }
  .ed-plate .ed-veil{ position:absolute; inset:0; background:linear-gradient(180deg,rgba(8,14,20,.26),rgba(8,14,20,.12) 40%,rgba(8,14,20,.62) 88%,rgba(8,14,20,.82)); }
  .ed-cap{ position:absolute; left:0; right:0; bottom:clamp(54px,10vh,106px); z-index:2; }
  .ed-cap .num{ display:block; font-family:'Inter',sans-serif; font-weight:500; font-size:12px; letter-spacing:.3em; text-transform:uppercase; color:#E9C766; margin-bottom:14px; }
  .ed-city{ font-family: var(--displayFont); font-weight:300; line-height:.9; font-size:clamp(54px,11vw,148px); color:#fff; }
