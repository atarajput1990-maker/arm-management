  .ed-row{ display:grid; grid-template-columns:58px 1.05fr 1.45fr 30px; gap:clamp(14px,3vw,42px); align-items:baseline; padding:30px 6px; border-bottom:1px solid var(--border); transition:padding-left .5s cubic-bezier(.16,1,.3,1),background .5s; }
