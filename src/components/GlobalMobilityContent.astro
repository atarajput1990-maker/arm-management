---
import PageWrapper from './PageWrapper.astro';
import { localePath } from '../i18n/translations';
import type { Locale } from '../i18n/translations';
interface Props { lang: Locale; }
const { lang } = Astro.props;
const lp = (p: string) => localePath(lang, p);
const isRTL = lang === 'ar';
const DATA: Record<string, any> = {"en": {"title": "Global Mobility & Residence Permits | ARM Management", "desc": "UAE Golden Visa, EU investor residency, citizenship by investment, and international mobility solutions.", "eye": "Global Mobility", "h1": "Global Mobility &\nResidence Permits", "hero": "Investor residency, work permits, and citizenship advisory across 20+ countries.", "whatEye": "What We Do", "whatH": "Freedom of Movement as a Strategic Asset", "whatP1": "For internationally mobile investors, entrepreneurs, and professionals, the ability to live, work, and travel freely across key markets is a fundamental strategic asset. The right residency or citizenship programme can transform your personal and commercial options.", "whatP2": "ARM Management advises across more than 20 countries, managing residency applications from document preparation and government submissions through to collection and post-approval support. We handle the process; you retain focus on your business.", "svcEye": "Our Services", "svcH": "Programmes We Advise On", "svcs": [["UAE Golden Visa", "UAE Golden Visa applications for investors, entrepreneurs, professionals, and exceptional talents — a 10-year renewable residency without the need for a local sponsor."], ["EU Golden Visa Programmes", "EU residency through investment in Portugal, Spain, Greece, Malta, and other EU member states. Pathway to permanent residency and EU citizenship."], ["Investor & Entrepreneur Visas", "Investor and entrepreneur visa programmes in the UK, UAE, and other jurisdictions — structured to meet investment thresholds and business establishment requirements."], ["Company-Sponsored Work Permits", "Employment authorisations for international employees, including UAE employment visas, EU Blue Cards, and other work permit categories."], ["Family Member Inclusion", "Extending residency rights to spouses, dependents, and parents under relevant family reunification and dependant visa programmes."], ["Citizenship by Investment", "Citizenship by investment programmes in Caribbean jurisdictions, Malta, Vanuatu, and other countries offering second passport solutions."]], "ctaH": "Discuss Your Residency Options", "ctaP": "Tell us about your situation — where you want to live, work, and travel — and we will identify the programmes that best fit your profile, timeline, and budget.", "ctaBtn": "Schedule a Consultation →", "btn2": "Our Services"}, "fr": {"title": "Mobilité internationale & Titres de séjour | ARM Management", "desc": "Visa doré des EAU, résidence investisseur européenne, citoyenneté par investissement et solutions de mobilité internationale.", "eye": "Mobilité internationale", "h1": "Mobilité internationale\net Titres de séjour", "hero": "Résidence investisseur, permis de travail et conseil en citoyenneté dans plus de 20 pays.", "whatEye": "Ce que nous faisons", "whatH": "La liberté de circulation comme atout stratégique", "whatP1": "Pour les investisseurs, entrepreneurs et professionnels mobiles à l'international, la capacité de vivre, travailler et voyager librement dans les marchés clés est un atout stratégique fondamental. Le bon programme de résidence ou de citoyenneté peut transformer vos options personnelles et commerciales.", "whatP2": "ARM Management intervient dans plus de 20 pays, gérant les demandes de résidence de la préparation des documents aux soumissions gouvernementales jusqu'à la collecte et le soutien post-approbation.", "svcEye": "Nos services", "svcH": "Programmes sur lesquels nous conseillons", "svcs": [["Visa doré des EAU", "Demandes de visa doré des EAU pour investisseurs, entrepreneurs, professionnels et talents exceptionnels — une résidence renouvelable de 10 ans sans besoin de sponsor local."], ["Programmes de visa doré européens", "Résidence dans l'UE via investissement au Portugal, en Espagne, en Grèce, à Malte et dans d'autres États membres. Voie vers la résidence permanente et la citoyenneté européenne."], ["Visas investisseur & entrepreneur", "Programmes de visa investisseur et entrepreneur au Royaume-Uni, aux EAU et dans d'autres juridictions — structurés pour répondre aux seuils d'investissement."], ["Permis de travail parrainés par l'entreprise", "Autorisations de travail pour les employés internationaux, incluant les visas d'emploi des EAU, les Cartes bleues européennes et autres catégories de permis de travail."], ["Inclusion des membres de la famille", "Extension des droits de résidence aux conjoints, enfants à charge et parents dans le cadre des programmes pertinents de regroupement familial."], ["Citoyenneté par investissement", "Programmes de citoyenneté par investissement dans les Caraïbes, à Malte, au Vanuatu et dans d'autres pays offrant des solutions de deuxième passeport."]], "ctaH": "Discutez de vos options de résidence", "ctaP": "Parlez-nous de votre situation — où vous souhaitez vivre, travailler et voyager — et nous identifierons les programmes qui correspondent le mieux à votre profil, calendrier et budget.", "ctaBtn": "Planifier une consultation →", "btn2": "Nos services"}, "es": {"title": "Movilidad Global y Permisos de Residencia | ARM Management", "desc": "Visa dorada de los EAU, residencia de inversor europeo, ciudadanía por inversión y soluciones de movilidad internacional.", "eye": "Movilidad Global", "h1": "Movilidad Global y\nPermisos de Residencia", "hero": "Residencia de inversor, permisos de trabajo y asesoría en ciudadanía en más de 20 países.", "whatEye": "Lo que hacemos", "whatH": "La libertad de movimiento como activo estratégico", "whatP1": "Para inversores, emprendedores y profesionales con movilidad internacional, la capacidad de vivir, trabajar y viajar libremente en los mercados clave es un activo estratégico fundamental. El programa de residencia o ciudadanía adecuado puede transformar sus opciones personales y comerciales.", "whatP2": "ARM Management asesora en más de 20 países, gestionando solicitudes de residencia desde la preparación de documentos hasta las presentaciones gubernamentales y el apoyo post-aprobación.", "svcEye": "Nuestros servicios", "svcH": "Programas en los que asesoramos", "svcs": [["Visa Dorada de los EAU", "Solicitudes de visa dorada de los EAU para inversores, emprendedores, profesionales y talentos excepcionales — una residencia renovable de 10 años sin necesidad de patrocinador local."], ["Programas de Visa Dorada Europea", "Residencia en la UE mediante inversión en Portugal, España, Grecia, Malta y otros Estados miembros. Vía hacia la residencia permanente y la ciudadanía europea."], ["Visados de Inversor y Emprendedor", "Programas de visado de inversor y emprendedor en el Reino Unido, los EAU y otras jurisdicciones — estructurados para cumplir con los umbrales de inversión."], ["Permisos de Trabajo Patrocinados", "Autorizaciones de trabajo para empleados internacionales, incluyendo visados de empleo de los EAU, Tarjetas Azules de la UE y otras categorías de permisos de trabajo."], ["Inclusión de Familiares", "Extensión de los derechos de residencia a cónyuges, dependientes y padres en el marco de los programas pertinentes de reagrupación familiar."], ["Ciudadanía por Inversión", "Programas de ciudadanía por inversión en jurisdicciones del Caribe, Malta, Vanuatu y otros países que ofrecen soluciones de segundo pasaporte."]], "ctaH": "Discuta sus opciones de residencia", "ctaP": "Cuéntenos su situación — dónde quiere vivir, trabajar y viajar — y identificaremos los programas que mejor se adapten a su perfil, plazo y presupuesto.", "ctaBtn": "Programar una consulta →", "btn2": "Nuestros servicios"}, "ar": {"title": "التنقل الدولي وتصاريح الإقامة | ARM Management", "desc": "التأشيرة الذهبية الإماراتية، وإقامة المستثمر الأوروبية، والجنسية عن طريق الاستثمار وحلول التنقل الدولي.", "eye": "التنقل الدولي", "h1": "التنقل الدولي\nوتصاريح الإقامة", "hero": "إقامة المستثمر، وتصاريح العمل، واستشارات الجنسية في أكثر من 20 دولة.", "whatEye": "ما نقدّمه", "whatH": "حرية التنقل كأصل استراتيجي", "whatP1": "بالنسبة للمستثمرين ورجال الأعمال والمهنيين المتنقلين دولياً، تُعدّ القدرة على العيش والعمل والسفر بحرية في الأسواق الرئيسية أصلاً استراتيجياً أساسياً. يمكن لبرنامج الإقامة أو الجنسية المناسب أن يحوّل خياراتك الشخصية والتجارية.", "whatP2": "تقدّم ARM Management المشورة في أكثر من 20 دولة، وتدير طلبات الإقامة من إعداد الوثائق إلى التقديم الحكومي وما بعد الموافقة.", "svcEye": "خدماتنا", "svcH": "البرامج التي نستشير فيها", "svcs": [["التأشيرة الذهبية الإماراتية", "طلبات التأشيرة الذهبية الإماراتية للمستثمرين ورجال الأعمال والمهنيين والمواهب الاستثنائية — إقامة قابلة للتجديد لمدة 10 سنوات دون الحاجة إلى كفيل محلي."], ["برامج التأشيرة الذهبية الأوروبية", "الإقامة في الاتحاد الأوروبي عبر الاستثمار في البرتغال وإسبانيا واليونان ومالطا وغيرها من الدول الأعضاء. طريق نحو الإقامة الدائمة والجنسية الأوروبية."], ["تأشيرات المستثمر ورائد الأعمال", "برامج تأشيرات المستثمر ورائد الأعمال في المملكة المتحدة والإمارات وولايات قضائية أخرى."], ["تصاريح العمل الممنوحة من الشركة", "تصاريح العمل للموظفين الدوليين، بما في ذلك تأشيرات العمل الإماراتية والبطاقات الزرقاء الأوروبية."], ["ضم أفراد الأسرة", "تمديد حقوق الإقامة للأزواج والمعالين والوالدين في إطار برامج لمّ الشمل الأسري ذات الصلة."], ["الجنسية عن طريق الاستثمار", "برامج الجنسية عن طريق الاستثمار في دول الكاريبي ومالطا وفانواتو وغيرها من الدول التي تقدم حلول جواز السفر الثاني."]], "ctaH": "ناقش خيارات إقامتك", "ctaP": "أخبرنا عن وضعك — أين تريد أن تعيش وتعمل وتسافر — وسنحدد البرامج التي تتناسب مع ملفك وجدولك الزمني وميزانيتك.", "ctaBtn": "جدوِّل استشارة ←", "btn2": "خدماتنا"}, "ru": {"title": "Международная мобильность и виды на жительство | ARM Management", "desc": "Золотая виза ОАЭ, резидентство для инвесторов в ЕС, гражданство через инвестиции и решения по международной мобильности.", "eye": "Мобильность", "h1": "Международная мобильность\nи виды на жительство", "hero": "Резидентство для инвесторов, разрешения на работу и консультирование по гражданству в 20+ странах.", "whatEye": "Что мы делаем", "whatH": "Свобода передвижения как стратегический актив", "whatP1": "Для международно мобильных инвесторов, предпринимателей и профессионалов способность свободно жить, работать и путешествовать в ключевых рынках является фундаментальным стратегическим активом.", "whatP2": "ARM Management консультирует в более чем 20 странах, сопровождая заявки на резидентство от подготовки документов до получения статуса.", "svcEye": "Услуги", "svcH": "Программы, по которым мы консультируем", "svcs": [["Золотая виза ОАЭ", "Заявки на Золотую визу ОАЭ для инвесторов, предпринимателей, профессионалов и выдающихся талантов — возобновляемое резидентство на 10 лет без необходимости местного спонсора."], ["Европейские программы Золотой визы", "Резидентство в ЕС через инвестиции в Португалии, Испании, Греции, Мальте и других государствах-членах. Путь к постоянному резидентству и гражданству ЕС."], ["Инвесторские и предпринимательские визы", "Программы инвесторских и предпринимательских виз в Великобритании, ОАЭ и других юрисдикциях."], ["Корпоративные разрешения на работу", "Разрешения на работу для международных сотрудников, включая рабочие визы ОАЭ, Голубые карты ЕС и другие категории."], ["Включение членов семьи", "Распространение прав резидентства на супругов, иждивенцев и родителей в рамках соответствующих программ воссоединения семьи."], ["Гражданство через инвестиции", "Программы гражданства через инвестиции в странах Карибского бассейна, Мальте, Вануату и других странах."]], "ctaH": "Обсудите варианты резидентства", "ctaP": "Расскажите нам о вашей ситуации — где вы хотите жить, работать и путешествовать — и мы определим наиболее подходящие программы.", "ctaBtn": "Записаться на консультацию →", "btn2": "Наши услуги"}, "zh": {"title": "全球移民与居留许可 | ARM Management", "desc": "阿联酋黄金签证、欧洲投资人居留、投资入籍及20+国家国际移民解决方案。", "eye": "全球移民", "h1": "全球移民与\n居留许可", "hero": "在20余个国家提供投资人居留、工作许可及国籍咨询服务。", "whatEye": "我们的服务内容", "whatH": "行动自由作为战略资产", "whatP1": "对于国际移动的投资者、创业者和专业人士而言，在关键市场自由生活、工作和旅行的能力是一项根本性的战略资产。正确的居留或国籍项目可以彻底改变您的个人和商业选择。", "whatP2": "ARM Management在20余个国家提供咨询，从文件准备和政府申请到领取及批准后支持，全程管理居留申请。", "svcEye": "服务", "svcH": "我们咨询的项目", "svcs": [["阿联酋黄金签证", "为投资者、创业者、专业人士和杰出人才申请阿联酋黄金签证——无需当地担保人的10年可续居留权。"], ["欧洲黄金签证项目", "通过在葡萄牙、西班牙、希腊、马耳他及其他欧盟成员国投资获得欧盟居留权。通往永久居留权和欧盟国籍的途径。"], ["投资人和创业者签证", "英国、阿联酋及其他司法管辖区的投资人和创业者签证项目——按照投资门槛和商业设立要求构建。"], ["公司担保工作许可", "国际员工的工作授权，包括阿联酋就业签证、欧盟蓝卡及其他工作许可类别。"], ["家庭成员随行", "根据相关家庭团聚和附属签证项目，将居留权延伸至配偶、受抚养人和父母。"], ["投资入籍", "加勒比海司法管辖区、马耳他、瓦努阿图及其他提供第二护照解决方案国家的投资入籍项目。"]], "ctaH": "讨论您的居留选择", "ctaP": "告诉我们您的情况——您希望在哪里生活、工作和旅行——我们将识别最适合您的项目、时间线和预算。", "ctaBtn": "预约咨询 →", "btn2": "我们的服务"}};
const c = DATA[lang];
---
<PageWrapper lang={lang} title={c.title} description={c.desc} canonicalPath="/services/global-mobility">
<main dir={isRTL ? 'rtl' : 'ltr'}>
  <section class="page-hero">
    <div class="page-hero__bg" style="background-image:url('https://images.unsplash.com/photo-1530521954074-e64f6810b32d?w=1600&q=80&auto=format&fit=crop')"></div>
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content container">
      <span class="eyebrow">{c.eye}</span>
      <h1 set:html={c.h1.replace('\n','<br>')}></h1>
      <p>{c.hero}</p>
      <div class="btn-row" style="justify-content:flex-start;margin-top:30px">
        <a href={lp('/contact')} class="btn-primary">{c.ctaBtn}</a>
        <a href={lp('/services')} class="btn-secondary">{c.btn2}</a>
      </div>
    </div>
  </section>
  <section class="section section--cream">
    <div class="container--narrow">
      <span class="eyebrow reveal">{c.whatEye}</span>
      <h2 class="reveal">{c.whatH}</h2>
      <div class="gold-rule reveal"></div>
      <p class="reveal">{c.whatP1}</p>
      <p class="reveal" style="margin-top:20px">{c.whatP2}</p>
    </div>
  </section>
  <section class="section section--warm" style="border-top:1px solid #E2DDD6">
    <div class="container">
      <span class="eyebrow reveal">{c.svcEye}</span>
      <h2 class="reveal">{c.svcH}</h2>
      <div class="gold-rule reveal"></div>
      <div class="grid-3" style="margin-top:40px">
        {c.svcs.map(([h, p]: [string,string], i: number) => (
          <div class={`card reveal reveal-delay-${(i%3)+1}`}><h3>{h}</h3><p>{p}</p></div>
        ))}
      </div>
    </div>
  </section>
  <section class="cta-section">
    <h2 class="reveal">{c.ctaH}</h2>
    <p class="reveal reveal-delay-1">{c.ctaP}</p>
    <div class="btn-row reveal reveal-delay-2">
      <a href={lp('/contact')} class="btn-primary">{c.ctaBtn}</a>
    </div>
  </section>
</main>
</PageWrapper>
