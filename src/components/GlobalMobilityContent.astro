const DATA: Record<string, any> = {"en": {"title": "Global Mobility & Residence Permits | ARM Management", "desc": "UAE Golden Visa, EU investor residency, citizenship by investment, and international mobility solutions.", "eye": "Global Mobility", "h1": "Global Mobility &\nResidence Permits", "hero": "Investor residency, work permits, and citizenship advisory across 20+ countries.", "whatEye": "What We Do", "whatH": "Freedom of Movement as a Strategic Asset", "whatP1": "For internationally mobile investors, entrepreneurs, and professionals, the ability to live, work, and travel freely across key markets is a fundamental strategic asset. The right residency or citizenship programme can transform your personal and commercial options.", "whatP2": "ARM Management advises across more than 20 countries, managing residency applications from document preparation and government submissions through to collection and post-approval support. We handle the process; you retain focus on your business.", "svcEye": "Our Services", "svcH": "Programmes We Advise On", "svcs": [["UAE Golden Visa", "UAE Golden Visa applications for investors, entrepreneurs, professionals, and exceptional talents — a 10-year renewable residency without the need for a local sponsor."], ["EU Golden Visa Programmes", "EU residency through investment in Portugal, Spain, Greece, Malta, and other EU member states. Pathway to permanent residency and EU citizenship."], ["Investor & Entrepreneur Visas", "Investor and entrepreneur visa programmes in the UK, UAE, and other jurisdictions — structured to meet investment thresholds and business establishment requirements."], ["Company-Sponsored Work Permits", "Employment authorisations for international employees, including UAE employment visas, EU Blue Cards, and other work permit categories."], ["Family Member Inclusion", "Extending residency rights to spouses, dependents, and parents under relevant family reunification and dependant visa programmes."], ["Citizenship by Investment", "Citizenship by investment programmes in Caribbean jurisdictions, Malta, Vanuatu, and other countries offering second passport solutions."]], "ctaH": "Discuss Your Residency Options", "ctaP": "Tell us about your situation — where you want to live, work, and travel — and we will identify the programmes that best fit your profile, timeline, and budget.", "ctaBtn": "Schedule a Consultation →", "btn2": "Our Services", "apprEye": "The ARM Approach", "apprH": "Residency Aligned to Your Life.", "apprP": "Every residency or citizenship application ARM manages begins with a frank conversation about what you are actually trying to achieve — not which programme has the highest commission. We assess your situation, your timeline, your travel pattern, and your tax position before recommending any programme.", "principles": [["Programme Fit Before Application", "We assess your eligibility before submitting any application. ARM does not submit applications it does not believe will succeed."], ["Tax Coordination", "Residency changes have significant tax implications. ARM coordinates with your tax advisors to ensure residency planning does not create unintended liabilities."], ["Full Document Management", "ARM manages the complete document preparation, authentication, translation, and submission process — you do not chase governments."], ["Post-Approval Support", "Residency card collection, ID registration, bank account opening, and ongoing renewal management after approval."]], "jurEye": "Jurisdictions", "jurH": "Where We Advise", "regions": [["UAE", "Golden Visa (10-year), investor visa, employment visa, Green Visa for freelancers and skilled employees. Mainland and free zone."], ["European Union", "Portugal D7/D8, Spain non-lucrative and digital nomad, Greece Golden Visa, Malta residency and citizenship, Estonia e-Residency."], ["UK", "Innovator Founder, Global Talent, Skilled Worker, and Investor visas. British National (Overseas) routes."], ["Asia Pacific", "Singapore EP and EntrePass, Hong Kong IANG and Top Talent Pass, Malaysia MM2H, Thailand LTR."]]}, "fr": {"title": "Mobilité internationale & Titres de séjour | ARM Management", "desc": "Visa doré des EAU, résidence investisseur européenne, citoyenneté par investissement et solutions de mobilité internationale.", "eye": "Mobilité internationale", "h1": "Mobilité internationale\net Titres de séjour", "hero": "Résidence investisseur, permis de travail et conseil en citoyenneté dans plus de 20 pays.", "whatEye": "Ce que nous faisons", "whatH": "La liberté de circulation comme atout stratégique", "whatP1": "Pour les investisseurs, entrepreneurs et professionnels mobiles à l'international, la capacité de vivre, travailler et voyager librement dans les marchés clés est un atout stratégique fondamental. Le bon programme de résidence ou de citoyenneté peut transformer vos options personnelles et commerciales.", "whatP2": "ARM Management intervient dans plus de 20 pays, gérant les demandes de résidence de la préparation des documents aux soumissions gouvernementales jusqu'à la collecte et le soutien post-approbation.", "svcEye": "Nos services", "svcH": "Programmes sur lesquels nous conseillons", "svcs": [["Visa doré des EAU", "Demandes de visa doré des EAU pour investisseurs, entrepreneurs, professionnels et talents exceptionnels — une résidence renouvelable de 10 ans sans besoin de sponsor local."], ["Programmes de visa doré européens", "Résidence dans l'UE via investissement au Portugal, en Espagne, en Grèce, à Malte et dans d'autres États membres. Voie vers la résidence permanente et la citoyenneté européenne."], ["Visas investisseur & entrepreneur", "Programmes de visa investisseur et entrepreneur au Royaume-Uni, aux EAU et dans d'autres juridictions — structurés pour répondre aux seuils d'investissement."], ["Permis de travail parrainés par l'entreprise", "Autorisations de travail pour les employés internationaux, incluant les visas d'emploi des EAU, les Cartes bleues européennes et autres catégories de permis de travail."], ["Inclusion des membres de la famille", "Extension des droits de résidence aux conjoints, enfants à charge et parents dans le cadre des programmes pertinents de regroupement familial."], ["Citoyenneté par investissement", "Programmes de citoyenneté par investissement dans les Caraïbes, à Malte, au Vanuatu et dans d'autres pays offrant des solutions de deuxième passeport."]], "ctaH": "Discutez de vos options de résidence", "ctaP": "Parlez-nous de votre situation — où vous souhaitez vivre, travailler et voyager — et nous identifierons les programmes qui correspondent le mieux à votre profil, calendrier et budget.", "ctaBtn": "Planifier une consultation →", "btn2": "Nos services", "apprEye": "L'approche ARM", "apprH": "La résidence alignée sur votre vie.", "apprP": "Chaque demande de résidence ou de citoyenneté qu'ARM gère commence par une conversation franche sur ce que vous cherchez réellement à accomplir. Nous évaluons votre situation, votre calendrier, vos habitudes de voyage et votre position fiscale avant de recommander tout programme.", "principles": [["Adéquation du programme avant la candidature", "Nous évaluons votre éligibilité avant de soumettre toute demande. ARM ne soumet pas de demandes qu'il ne croit pas susceptibles de réussir."], ["Coordination fiscale", "Les changements de résidence ont des implications fiscales importantes. ARM coordonne avec vos conseillers fiscaux pour que la planification de résidence ne crée pas de passifs involontaires."], ["Gestion complète des documents", "ARM gère l'ensemble de la préparation, authentification, traduction et soumission des documents — vous ne courez pas après les gouvernements."], ["Support post-approbation", "Collecte de la carte de résidence, inscription au registre d'identité, ouverture de compte bancaire et gestion des renouvellements continus après approbation."]], "jurEye": "Juridictions", "jurH": "Où nous conseillons", "regions": [["EAU", "Visa doré (10 ans), visa investisseur, visa emploi, Visa vert pour freelances et employés qualifiés. Continental et zone franche."], ["Union européenne", "Portugal D7/D8, Espagne non-lucrative et nomade numérique, Grèce visa doré, Malte résidence et citoyenneté, Estonie e-Résidence."], ["Royaume-Uni", "Innovateur Fondateur, Talent Mondial, Travailleur Qualifié et visas Investisseur. Voies BN(O)."], ["Asie-Pacifique", "EP et EntrePass de Singapour, IANG et Top Talent Pass de Hong Kong, MM2H de Malaisie, LTR de Thaïlande."]]}, "es": {"title": "Movilidad Global y Permisos de Residencia | ARM Management", "desc": "Visa dorada de los EAU, residencia de inversor europeo, ciudadanía por inversión y soluciones de movilidad internacional.", "eye": "Movilidad Global", "h1": "Movilidad Global y\nPermisos de Residencia", "hero": "Residencia de inversor, permisos de trabajo y asesoría en ciudadanía en más de 20 países.", "whatEye": "Lo que hacemos", "whatH": "La libertad de movimiento como activo estratégico", "whatP1": "Para inversores, emprendedores y profesionales con movilidad internacional, la capacidad de vivir, trabajar y viajar libremente en los mercados clave es un activo estratégico fundamental. El programa de residencia o ciudadanía adecuado puede transformar sus opciones personales y comerciales.", "whatP2": "ARM Management asesora en más de 20 países, gestionando solicitudes de residencia desde la preparación de documentos hasta las presentaciones gubernamentales y el apoyo post-aprobación.", "svcEye": "Nuestros servicios", "svcH": "Programas en los que asesoramos", "svcs": [["Visa Dorada de los EAU", "Solicitudes de visa dorada de los EAU para inversores, emprendedores, profesionales y talentos excepcionales — una residencia renovable de 10 años sin necesidad de patrocinador local."], ["Programas de Visa Dorada Europea", "Residencia en la UE mediante inversión en Portugal, España, Grecia, Malta y otros Estados miembros. Vía hacia la residencia permanente y la ciudadanía europea."], ["Visados de Inversor y Emprendedor", "Programas de visado de inversor y emprendedor en el Reino Unido, los EAU y otras jurisdicciones — estructurados para cumplir con los umbrales de inversión."], ["Permisos de Trabajo Patrocinados", "Autorizaciones de trabajo para empleados internacionales, incluyendo visados de empleo de los EAU, Tarjetas Azules de la UE y otras categorías de permisos de trabajo."], ["Inclusión de Familiares", "Extensión de los derechos de residencia a cónyuges, dependientes y padres en el marco de los programas pertinentes de reagrupación familiar."], ["Ciudadanía por Inversión", "Programas de ciudadanía por inversión en jurisdicciones del Caribe, Malta, Vanuatu y otros países que ofrecen soluciones de segundo pasaporte."]], "ctaH": "Discuta sus opciones de residencia", "ctaP": "Cuéntenos su situación — dónde quiere vivir, trabajar y viajar — y identificaremos los programas que mejor se adapten a su perfil, plazo y presupuesto.", "ctaBtn": "Programar una consulta →", "btn2": "Nuestros servicios", "apprEye": "El enfoque ARM", "apprH": "Residencia alineada a su vida.", "apprP": "Cada solicitud de residencia o ciudadanía que ARM gestiona comienza con una conversación franca sobre lo que realmente intenta lograr. Evaluamos su situación, su calendario, su patrón de viaje y su posición fiscal antes de recomendar cualquier programa.", "principles": [["Adecuación del programa antes de la solicitud", "Evaluamos su elegibilidad antes de presentar cualquier solicitud. ARM no presenta solicitudes que no cree que vayan a tener éxito."], ["Coordinación fiscal", "Los cambios de residencia tienen implicaciones fiscales significativas. ARM coordina con sus asesores fiscales para garantizar que la planificación de residencia no cree pasivos no deseados."], ["Gestión completa de documentos", "ARM gestiona todo el proceso de preparación, autenticación, traducción y presentación de documentos — usted no persigue a los gobiernos."], ["Apoyo post-aprobación", "Recogida de tarjeta de residencia, registro de identidad, apertura de cuenta bancaria y gestión continua de renovaciones después de la aprobación."]], "jurEye": "Jurisdicciones", "jurH": "Dónde asesoramos", "regions": [["EAU", "Visa dorada (10 años), visa de inversor, visa de empleo, Visa verde para freelancers y empleados calificados. Continental y zona franca."], ["Unión Europea", "Portugal D7/D8, España no lucrativa y nómada digital, Grecia visa dorada, Malta residencia y ciudadanía, Estonia e-Residencia."], ["Reino Unido", "Fundador Innovador, Talento Global, Trabajador Calificado y visas de Inversor. Rutas BN(O)."], ["Asia-Pacífico", "EP y EntrePass de Singapur, IANG y Top Talent Pass de Hong Kong, MM2H de Malasia, LTR de Tailandia."]]}, "ar": {"title": "التنقل الدولي وتصاريح الإقامة | ARM Management", "desc": "التأشيرة الذهبية الإماراتية، وإقامة المستثمر الأوروبية، والجنسية عن طريق الاستثمار وحلول التنقل الدولي.", "eye": "التنقل الدولي", "h1": "التنقل الدولي\nوتصاريح الإقامة", "hero": "إقامة المستثمر، وتصاريح العمل، واستشارات الجنسية في أكثر من 20 دولة.", "whatEye": "ما نقدّمه", "whatH": "حرية التنقل كأصل استراتيجي", "whatP1": "بالنسبة للمستثمرين ورجال الأعمال والمهنيين المتنقلين دولياً، تُعدّ القدرة على العيش والعمل والسفر بحرية في الأسواق الرئيسية أصلاً استراتيجياً أساسياً. يمكن لبرنامج الإقامة أو الجنسية المناسب أن يحوّل خياراتك الشخصية والتجارية.", "whatP2": "تقدّم ARM Management المشورة في أكثر من 20 دولة، وتدير طلبات الإقامة من إعداد الوثائق إلى التقديم الحكومي وما بعد الموافقة.", "svcEye": "خدماتنا", "svcH": "البرامج التي نستشير فيها", "svcs": [["التأشيرة الذهبية الإماراتية", "طلبات التأشيرة الذهبية الإماراتية للمستثمرين ورجال الأعمال والمهنيين والمواهب الاستثنائية — إقامة قابلة للتجديد لمدة 10 سنوات دون الحاجة إلى كفيل محلي."], ["برامج التأشيرة الذهبية الأوروبية", "الإقامة في الاتحاد الأوروبي عبر الاستثمار في البرتغال وإسبانيا واليونان ومالطا وغيرها من الدول الأعضاء. طريق نحو الإقامة الدائمة والجنسية الأوروبية."], ["تأشيرات المستثمر ورائد الأعمال", "برامج تأشيرات المستثمر ورائد الأعمال في المملكة المتحدة والإمارات وولايات قضائية أخرى."], ["تصاريح العمل الممنوحة من الشركة", "تصاريح العمل للموظفين الدوليين، بما في ذلك تأشيرات العمل الإماراتية والبطاقات الزرقاء الأوروبية."], ["ضم أفراد الأسرة", "تمديد حقوق الإقامة للأزواج والمعالين والوالدين في إطار برامج لمّ الشمل الأسري ذات الصلة."], ["الجنسية عن طريق الاستثمار", "برامج الجنسية عن طريق الاستثمار في دول الكاريبي ومالطا وفانواتو وغيرها من الدول التي تقدم حلول جواز السفر الثاني."]], "ctaH": "ناقش خيارات إقامتك", "ctaP": "أخبرنا عن وضعك — أين تريد أن تعيش وتعمل وتسافر — وسنحدد البرامج التي تتناسب مع ملفك وجدولك الزمني وميزانيتك.", "ctaBtn": "جدوِّل استشارة ←", "btn2": "خدماتنا", "apprEye": "نهج ARM", "apprH": "الإقامة المتوافقة مع حياتك.", "apprP": "كل طلب إقامة أو جنسية تديره ARM يبدأ بمحادثة صريحة حول ما تسعى فعلاً إلى تحقيقه. نقيّم وضعك وجدولك الزمني ونمط سفرك وموقفك الضريبي قبل التوصية بأي برنامج.", "principles": [["ملاءمة البرنامج قبل التقديم", "نقيّم أهليتك قبل تقديم أي طلب. ARM لا تقدّم طلبات لا تعتقد أنها ستنجح."], ["التنسيق الضريبي", "لتغييرات الإقامة آثار ضريبية كبيرة. ARM تنسّق مع مستشاريك الضريبيين لضمان أن تخطيط الإقامة لا يُنشئ التزامات غير مقصودة."], ["إدارة المستندات الكاملة", "تدير ARM عملية إعداد المستندات والمصادقة والترجمة والتقديم بالكامل — أنت لا تطارد الحكومات."], ["دعم ما بعد الموافقة", "استلام بطاقة الإقامة وتسجيل الهوية وفتح الحسابات المصرفية وإدارة التجديدات المستمرة بعد الموافقة."]], "jurEye": "الولايات القضائية", "jurH": "أين نستشير", "regions": [["الإمارات", "التأشيرة الذهبية (10 سنوات) وتأشيرة المستثمر وتأشيرة العمل والتأشيرة الخضراء للمستقلين والموظفين المهرة. البر الرئيسي والمناطق الحرة."], ["الاتحاد الأوروبي", "البرتغال D7/D8، وإسبانيا غير الربحية والبدو الرقميين، واليونان التأشيرة الذهبية، ومالطا الإقامة والجنسية، وإستونيا الإقامة الإلكترونية."], ["المملكة المتحدة", "مؤسس مبتكر وموهبة عالمية وعامل ماهر وتأشيرات مستثمر. مسارات BN(O)."], ["آسيا والمحيط الهادئ", "EP وEntrePass في سنغافورة، وIANG وTop Talent Pass في هونغ كونغ، وMM2H في ماليزيا، وLTR في تايلاند."]]}, "ru": {"title": "Международная мобильность и виды на жительство | ARM Management", "desc": "Золотая виза ОАЭ, резидентство для инвесторов в ЕС, гражданство через инвестиции и решения по международной мобильности.", "eye": "Мобильность", "h1": "Международная мобильность\nи виды на жительство", "hero": "Резидентство для инвесторов, разрешения на работу и консультирование по гражданству в 20+ странах.", "whatEye": "Что мы делаем", "whatH": "Свобода передвижения как стратегический актив", "whatP1": "Для международно мобильных инвесторов, предпринимателей и профессионалов способность свободно жить, работать и путешествовать в ключевых рынках является фундаментальным стратегическим активом.", "whatP2": "ARM Management консультирует в более чем 20 странах, сопровождая заявки на резидентство от подготовки документов до получения статуса.", "svcEye": "Услуги", "svcH": "Программы, по которым мы консультируем", "svcs": [["Золотая виза ОАЭ", "Заявки на Золотую визу ОАЭ для инвесторов, предпринимателей, профессионалов и выдающихся талантов — возобновляемое резидентство на 10 лет без необходимости местного спонсора."], ["Европейские программы Золотой визы", "Резидентство в ЕС через инвестиции в Португалии, Испании, Греции, Мальте и других государствах-членах. Путь к постоянному резидентству и гражданству ЕС."], ["Инвесторские и предпринимательские визы", "Программы инвесторских и предпринимательских виз в Великобритании, ОАЭ и других юрисдикциях."], ["Корпоративные разрешения на работу", "Разрешения на работу для международных сотрудников, включая рабочие визы ОАЭ, Голубые карты ЕС и другие категории."], ["Включение членов семьи", "Распространение прав резидентства на супругов, иждивенцев и родителей в рамках соответствующих программ воссоединения семьи."], ["Гражданство через инвестиции", "Программы гражданства через инвестиции в странах Карибского бассейна, Мальте, Вануату и других странах."]], "ctaH": "Обсудите варианты резидентства", "ctaP": "Расскажите нам о вашей ситуации — где вы хотите жить, работать и путешествовать — и мы определим наиболее подходящие программы.", "ctaBtn": "Записаться на консультацию →", "btn2": "Наши услуги", "apprEye": "Подход ARM", "apprH": "Резидентство под вашу жизнь.", "apprP": "Каждая заявка на резидентство или гражданство, которую ведёт ARM, начинается с откровенного разговора о том, чего вы реально хотите достичь. Мы оцениваем вашу ситуацию, временной горизонт, режим поездок и налоговое положение до рекомендации какой-либо программы.", "principles": [["Соответствие программе до подачи заявки", "Мы оцениваем вашу приемлемость до подачи любой заявки. ARM не подаёт заявки, в успехе которых не уверена."], ["Налоговая координация", "Изменения резидентства имеют значительные налоговые последствия. ARM координирует с вашими налоговыми консультантами, чтобы планирование резидентства не создавало непредвиденных обязательств."], ["Полное управление документами", "ARM управляет полным процессом подготовки, аутентификации, перевода и подачи документов — вы не гонитесь за государственными органами."], ["Поддержка после одобрения", "Получение карты резидента, регистрация, открытие банковского счёта и управление продлением после одобрения."]], "jurEye": "Юрисдикции", "jurH": "Где мы консультируем", "regions": [["ОАЭ", "Золотая виза (10 лет), инвесторская виза, рабочая виза, Зелёная виза для фрилансеров и квалифицированных специалистов. Материк и свободные зоны."], ["Европейский союз", "Португалия D7/D8, Испания non-lucrative и цифровые кочевники, Греция Золотая виза, Мальта резидентство и гражданство, Эстония e-Residency."], ["Великобритания", "Innovator Founder, Global Talent, Skilled Worker и инвесторские визы. Маршруты BN(O)."], ["Азиатско-Тихоокеанский регион", "EP и EntrePass Сингапура, IANG и Top Talent Pass Гонконга, MM2H Малайзии, LTR Таиланда."]]}, "zh": {"title": "全球移民与居留许可 | ARM Management", "desc": "阿联酋黄金签证、欧洲投资人居留、投资入籍及20+国家国际移民解决方案。", "eye": "全球移民", "h1": "全球移民与\n居留许可", "hero": "在20余个国家提供投资人居留、工作许可及国籍咨询服务。", "whatEye": "我们的服务内容", "whatH": "行动自由作为战略资产", "whatP1": "对于国际移动的投资者、创业者和专业人士而言，在关键市场自由生活、工作和旅行的能力是一项根本性的战略资产。正确的居留或国籍项目可以彻底改变您的个人和商业选择。", "whatP2": "ARM Management在20余个国家提供咨询，从文件准备和政府申请到领取及批准后支持，全程管理居留申请。", "svcEye": "服务", "svcH": "我们咨询的项目", "svcs": [["阿联酋黄金签证", "为投资者、创业者、专业人士和杰出人才申请阿联酋黄金签证——无需当地担保人的10年可续居留权。"], ["欧洲黄金签证项目", "通过在葡萄牙、西班牙、希腊、马耳他及其他欧盟成员国投资获得欧盟居留权。通往永久居留权和欧盟国籍的途径。"], ["投资人和创业者签证", "英国、阿联酋及其他司法管辖区的投资人和创业者签证项目——按照投资门槛和商业设立要求构建。"], ["公司担保工作许可", "国际员工的工作授权，包括阿联酋就业签证、欧盟蓝卡及其他工作许可类别。"], ["家庭成员随行", "根据相关家庭团聚和附属签证项目，将居留权延伸至配偶、受抚养人和父母。"], ["投资入籍", "加勒比海司法管辖区、马耳他、瓦努阿图及其他提供第二护照解决方案国家的投资入籍项目。"]], "ctaH": "讨论您的居留选择", "ctaP": "告诉我们您的情况——您希望在哪里生活、工作和旅行——我们将识别最适合您的项目、时间线和预算。", "ctaBtn": "预约咨询 →", "btn2": "我们的服务", "apprEye": "ARM方法", "apprH": "与您生活相匹配的居留权。", "apprP": "ARM管理的每一份居留或国籍申请都从一次坦诚的对话开始——关于您真正想要实现什么，而不是哪个项目佣金最高。在推荐任何项目之前，我们评估您的情况、时间线、出行规律和税务状况。", "principles": [["申请前的项目适配性", "在提交任何申请之前，我们评估您的资格。ARM不提交它认为不会成功的申请。"], ["税务协调", "居留权变更有重大税务影响。ARM与您的税务顾问协调，确保居留规划不会产生意外负债。"], ["完整文件管理", "ARM管理完整的文件准备、认证、翻译和提交流程——您不必追逐政府部门。"], ["批准后支持", "批准后的居留卡领取、身份证注册、银行账户开设和持续更新管理。"]], "jurEye": "司法管辖区", "jurH": "咨询覆盖范围", "regions": [["阿联酋", "黄金签证（10年）、投资人签证、就业签证、针对自由职业者和技术员工的绿色签证。大陆及自由区。"], ["欧盟", "葡萄牙D7/D8、西班牙非营利和数字游民、希腊黄金签证、马耳他居留权和国籍、爱沙尼亚e-Residency。"], ["英国", "创新创始人、全球人才、技术工人和投资人签证。BN(O)路径。"], ["亚太地区", "新加坡EP和EntrePass、香港IANG和顶尖人才通行证、马来西亚MM2H、泰国LTR。"]]}};
const c = DATA[lang];
---
<PageWrapper lang={lang} title={c.title} description={c.desc} canonicalPath="/services/global-mobility">
<main dir={isRTL ? 'rtl' : 'ltr'}>
  <section class="page-hero">
    <div class="page-hero__bg" style="background-image:url('https://images.unsplash.com/photo-1530521954074-e64f6810b32d?w=1600&q=80&auto=format&fit=crop')"></div>
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content container">
      <span class="eyebrow">{c.eye}</span>
      <h1 set:html={c.h1.replace('\n','<br>')}></h1>
      <p>{c.hero}</p>
      <div class="btn-row" style="justify-content:flex-start;margin-top:30px">
        <a href={lp('/contact')} class="btn-primary">{c.ctaBtn}</a>
        <a href={lp('/services')} class="btn-secondary">{c.btn2}</a>
      </div>
    </div>
  </section>
  <section class="section section--cream">
    <div class="container--narrow">
      <span class="eyebrow reveal">{c.whatEye}</span>
      <h2 class="reveal">{c.whatH}</h2>
      <div class="gold-rule reveal"></div>
      <p class="reveal">{c.whatP1}</p>
      <p class="reveal" style="margin-top:20px">{c.whatP2}</p>
    </div>
  </section>
  <section class="section section--warm" style="border-top:1px solid #E2DDD6">
    <div class="container">
      <span class="eyebrow reveal">{c.svcEye}</span>
      <h2 class="reveal">{c.svcH}</h2>
      <div class="gold-rule reveal"></div>
      <div class="grid-3" style="margin-top:40px">
        {c.svcs.map(([h, p]: [string,string], i: number) => (
          <div class={`card reveal reveal-delay-${(i%3)+1}`}><h3>{h}</h3><p>{p}</p></div>
        ))}
      </div>
    </div>
  </section>
  <section class="section section--navy">
    <div class="container--narrow">
      <span class="eyebrow reveal" style="color:#B8960C">{c.apprEye}</span>
      <h2 class="reveal" style="color:#F7F3EC">{c.apprH}</h2>
      <div class="gold-rule reveal"></div>
      <p class="reveal" style="color:rgba(247,243,236,.78)">{c.apprP}</p>
      <div style="margin-top:48px;display:grid;grid-template-columns:repeat(2,1fr);gap:32px">
        {c.principles.map(([h, p]: [string,string], i: number) => (
          <div class={`reveal reveal-delay-${(i%2)+1}`} style="border-top:1px solid rgba(184,150,12,.3);padding-top:20px">
            <h4 style="font-family:'Inter',sans-serif;font-size:12px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:#B8960C;margin-bottom:10px">{h}</h4>
            <p style="color:rgba(247,243,236,.65);font-size:15px;line-height:1.75">{p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  <section class="section section--cream" style="border-top:1px solid #E2DDD6">
    <div class="container--narrow">
      <span class="eyebrow reveal">{c.jurEye}</span>
      <h2 class="reveal">{c.jurH}</h2>
      <div class="gold-rule reveal"></div>
      <div class="reveal" style="display:grid;grid-template-columns:repeat(2,1fr);gap:24px;margin-top:32px">
        {c.regions.map(([h, p]: [string,string]) => (
          <div style="padding:24px;background:#FDFAF6;border:1px solid #E2DDD6;border-radius:2px">
            <h4 style="font-size:16px;margin-bottom:8px">{h}</h4>
            <p style="font-size:14px;color:#6B7280;line-height:1.65">{p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  <section class="cta-section">
    <h2 class="reveal">{c.ctaH}</h2>
    <p class="reveal reveal-delay-1">{c.ctaP}</p>
    <div class="btn-row reveal reveal-delay-2">
      <a href={lp('/contact')} class="btn-primary">{c.ctaBtn}</a>
    </div>
  </section>
</main>
</PageWrapper>
