---
import PageWrapper from './PageWrapper.astro';
import { localePath } from '../i18n/translations';
import type { Locale } from '../i18n/translations';
interface Props { lang: Locale; }
const { lang } = Astro.props;
const lp = (p: string) => localePath(lang, p);
const isRTL = lang === 'ar';
const DATA: Record<string, any> = {"en": {"title": "Partnership | ARM Management", "desc": "Professional partnerships built on mutual expertise, shared standards, and complementary capabilities.", "eyebrow": "Partnership", "h1": "Build Something Together.", "hero": "Professional partnerships built on mutual expertise, shared standards, and complementary capabilities.", "btn1": "Become a Partner →", "btn2": "About ARM", "apprEye": "Our Approach to Partnership", "apprH": "Not a Referral Arrangement. A Professional Relationship.", "apprP1": "ARM Management works with a select network of professional partners across the EU, GCC, Asia, and Latin America. Partnership with ARM is not a referral arrangement with a finder's fee — it is a professional relationship built on mutual expertise, shared standards, and complementary capabilities.", "apprP2": "We partner with firms and individuals who advise clients with international business requirements that align with ARM's practice areas. We are selective about the partnerships we form for the same reason we are selective about the clients we serve.", "typesEye": "Partnership Types", "typesH": "How We Work Together", "types": [["Law Firms & Legal Practices", "Corporate and commercial law firms whose clients require cross-border entity formation, compliance coordination, or regulatory advisory beyond the firm's core jurisdictions."], ["Accounting & Tax Advisory Firms", "Accounting practices and tax advisory firms with clients expanding internationally who require local compliance coordination or entity formation outside their coverage."], ["Private Banks & Wealth Managers", "Private banks and wealth management firms whose clients require operational business advisory — entity formation, payroll, compliance — alongside their financial planning."], ["M&A Advisors & Investment Banks", "Transaction advisory and investment banking firms requiring cross-border structuring, regulatory compliance, and post-acquisition operational support for their deal clients."], ["Real Estate & Investment Platforms", "Real estate agents, investment platforms, and family office intermediaries whose clients are relocating or investing internationally."], ["Local Expert Networks", "Jurisdiction-specific lawyers, accountants, and compliance professionals who wish to offer their clients access to a broader international advisory capability."]], "stdEye": "The ARM Partnership Standard", "stdH": "What We Look For.", "stdP": "ARM Management's reputation is built on consistent quality and honest dealing. We extend that standard to every professional relationship we form.", "standards": [["Genuine Expertise", "We partner with professionals who are genuinely expert in their field. We do not build referral networks for volume — we build professional relationships for quality."], ["Shared Client Standards", "Our clients are introduced to partners we would trust with our own matters. The standard of advice and confidentiality must match what ARM clients already receive from us."], ["Complementary Coverage", "The best partnerships fill genuine gaps. We look for partners whose jurisdiction or service coverage complements ARM's without competing with it directly."], ["Long-Term Orientation", "We are building relationships, not transaction flows. The right partnership develops over time as both parties better understand each other's clients and capabilities."]], "ctaH": "Ready to Begin?", "ctaP": "If you advise clients with international business requirements and believe there is a basis for a professional relationship with ARM Management, we would welcome an initial conversation.", "ctaBtn": "Schedule a Consultation →"}, "fr": {"title": "Partenariat | ARM Management", "desc": "Des partenariats professionnels fondés sur l'expertise mutuelle, des normes partagées et des capacités complémentaires.", "eyebrow": "Partenariat", "h1": "Construisons quelque chose ensemble.", "hero": "Des partenariats professionnels fondés sur l'expertise mutuelle, des normes partagées et des capacités complémentaires.", "btn1": "Devenir partenaire →", "btn2": "À propos d'ARM", "apprEye": "Notre approche du partenariat", "apprH": "Pas un arrangement de référencement. Une relation professionnelle.", "apprP1": "ARM Management travaille avec un réseau sélectionné de partenaires professionnels à travers l'UE, le CCG, l'Asie et l'Amérique latine. Le partenariat avec ARM n'est pas un arrangement de référencement — c'est une relation professionnelle fondée sur l'expertise mutuelle, des normes partagées et des capacités complémentaires.", "apprP2": "Nous sommes sélectifs dans les partenariats que nous formons pour la même raison que nous le sommes dans les clients que nous servons.", "typesEye": "Types de partenariat", "typesH": "Comment nous travaillons ensemble", "types": [["Cabinets d'avocats", "Cabinets d'avocats d'affaires dont les clients ont besoin de création d'entités transfrontalières, de coordination de conformité ou de conseil réglementaire au-delà des juridictions principales du cabinet."], ["Cabinets comptables & fiscaux", "Cabinets comptables et de conseil fiscal dont les clients se développent à l'international et ont besoin de coordination de conformité locale ou de création d'entités."], ["Banques privées & gestionnaires de patrimoine", "Banques privées et sociétés de gestion de patrimoine dont les clients ont besoin de conseils opérationnels — création d'entités, paie, conformité — en plus de leur planification financière."], ["Conseillers en M&A & banques d'investissement", "Cabinets de conseil en transactions et banques d'investissement ayant besoin de structuration transfrontalière et de support opérationnel post-acquisition."], ["Plateformes immobilières & d'investissement", "Agents immobiliers, plateformes d'investissement et intermédiaires de family offices dont les clients se délocalisent ou investissent à l'international."], ["Réseaux d'experts locaux", "Avocats, comptables et professionnels de la conformité spécialisés dans une juridiction souhaitant offrir à leurs clients un accès à une capacité de conseil internationale plus large."]], "stdEye": "Le standard de partenariat ARM", "stdH": "Ce que nous recherchons.", "stdP": "La réputation d'ARM Management repose sur la qualité constante et l'honnêteté. Nous étendons ce standard à chaque relation professionnelle que nous formons.", "standards": [["Expertise authentique", "Nous nous associons avec des professionnels qui sont véritablement experts dans leur domaine. Nous ne construisons pas de réseaux de référencement pour le volume — nous construisons des relations professionnelles pour la qualité."], ["Standards clients partagés", "Nos clients sont présentés à des partenaires en qui nous aurions confiance pour nos propres affaires. Le niveau de conseil et de confidentialité doit correspondre à ce que les clients d'ARM reçoivent déjà."], ["Couverture complémentaire", "Les meilleurs partenariats comblent de véritables lacunes. Nous recherchons des partenaires dont la couverture juridictionnelle ou de service complète celle d'ARM sans lui faire directement concurrence."], ["Orientation long terme", "Nous construisons des relations, pas des flux de transactions. Le bon partenariat se développe dans le temps à mesure que les deux parties comprennent mieux les clients et les capacités de l'autre."]], "ctaH": "Prêt à commencer ?", "ctaP": "Si vous conseillez des clients ayant des besoins en affaires internationales et pensez qu'il y a une base pour une relation professionnelle avec ARM Management, nous vous accueillerions volontiers pour une première conversation.", "ctaBtn": "Planifier une consultation →"}, "es": {"title": "Alianzas | ARM Management", "desc": "Alianzas profesionales basadas en experiencia mutua, estándares compartidos y capacidades complementarias.", "eyebrow": "Alianzas", "h1": "Construyamos algo juntos.", "hero": "Alianzas profesionales basadas en experiencia mutua, estándares compartidos y capacidades complementarias.", "btn1": "Convertirse en socio →", "btn2": "Sobre ARM", "apprEye": "Nuestro enfoque de las alianzas", "apprH": "No es un acuerdo de derivación. Es una relación profesional.", "apprP1": "ARM Management trabaja con una red selecta de socios profesionales en la UE, el CCG, Asia y América Latina. La asociación con ARM no es un acuerdo de derivación — es una relación profesional basada en experiencia mutua, estándares compartidos y capacidades complementarias.", "apprP2": "Somos selectivos con las alianzas que formamos por la misma razón que lo somos con los clientes que servimos.", "typesEye": "Tipos de alianza", "typesH": "Cómo trabajamos juntos", "types": [["Bufetes de Abogados", "Bufetes de abogados corporativos y mercantiles cuyos clientes requieren constitución de entidades transfronterizas, coordinación de cumplimiento o asesoría regulatoria más allá de las jurisdicciones principales del bufete."], ["Firmas Contables y Fiscales", "Firmas contables y de asesoría fiscal con clientes en expansión internacional que requieren coordinación de cumplimiento local o constitución de entidades fuera de su cobertura."], ["Banca Privada y Gestión de Patrimonio", "Bancos privados y firmas de gestión de patrimonio cuyos clientes requieren asesoría operativa — constitución de entidades, nómina, cumplimiento — además de su planificación financiera."], ["Asesores de M&A y Banca de Inversión", "Firmas de asesoría en transacciones y banca de inversión que requieren estructuración transfronteriza y soporte operativo post-adquisición."], ["Plataformas Inmobiliarias y de Inversión", "Agentes inmobiliarios, plataformas de inversión e intermediarios de family offices cuyos clientes se reubican o invierten internacionalmente."], ["Redes de Expertos Locales", "Abogados, contadores y profesionales de cumplimiento específicos de jurisdicción que desean ofrecer a sus clientes acceso a una capacidad de asesoría internacional más amplia."]], "stdEye": "El estándar de alianza ARM", "stdH": "Lo que buscamos.", "stdP": "La reputación de ARM Management se construye sobre la calidad consistente y el trato honesto. Extendemos ese estándar a cada relación profesional que formamos.", "standards": [["Experiencia genuina", "Nos asociamos con profesionales que son genuinamente expertos en su campo. No construimos redes de derivación por volumen — construimos relaciones profesionales por calidad."], ["Estándares de cliente compartidos", "Nuestros clientes son presentados a socios en quienes confiaríamos con nuestros propios asuntos. El nivel de asesoría y confidencialidad debe coincidir con lo que los clientes de ARM ya reciben."], ["Cobertura complementaria", "Las mejores alianzas llenan brechas genuinas. Buscamos socios cuya cobertura jurisdiccional o de servicio complementa la de ARM sin competir directamente."], ["Orientación a largo plazo", "Estamos construyendo relaciones, no flujos de transacciones. La alianza correcta se desarrolla con el tiempo a medida que ambas partes entienden mejor los clientes y capacidades del otro."]], "ctaH": "¿Listo para comenzar?", "ctaP": "Si asesora a clientes con requisitos de negocios internacionales y cree que hay base para una relación profesional con ARM Management, nos complacería mantener una conversación inicial.", "ctaBtn": "Programar una consulta →"}, "ar": {"title": "الشراكة | ARM Management", "desc": "شراكات مهنية مبنية على الخبرة المتبادلة والمعايير المشتركة والقدرات التكاملية.", "eyebrow": "الشراكة", "h1": "لنبني شيئاً معاً.", "hero": "شراكات مهنية مبنية على الخبرة المتبادلة والمعايير المشتركة والقدرات التكاملية.", "btn1": "كن شريكاً ←", "btn2": "عن ARM", "apprEye": "نهجنا في الشراكة", "apprH": "ليست ترتيب إحالة. إنها علاقة مهنية.", "apprP1": "تعمل ARM Management مع شبكة مختارة من الشركاء المهنيين عبر الاتحاد الأوروبي ودول الخليج وآسيا وأمريكا اللاتينية. الشراكة مع ARM ليست ترتيب إحالة بمكافأة — إنها علاقة مهنية مبنية على الخبرة المتبادلة والمعايير المشتركة والقدرات التكاملية.", "apprP2": "نحن انتقائيون في الشراكات التي نُبرمها للسبب نفسه الذي يجعلنا انتقائيين في العملاء الذين نخدمهم.", "typesEye": "أنواع الشراكة", "typesH": "كيف نعمل معاً", "types": [["مكاتب المحاماة", "مكاتب المحاماة التجارية والتجارية التي يحتاج عملاؤها إلى تأسيس كيانات عابرة للحدود أو تنسيق الامتثال أو الاستشارات التنظيمية خارج الولايات القضائية الرئيسية للمكتب."], ["شركات المحاسبة والاستشارات الضريبية", "شركات المحاسبة والاستشارات الضريبية التي لديها عملاء يتوسعون دولياً ويحتاجون إلى تنسيق امتثال محلي أو تأسيس كيانات."], ["البنوك الخاصة ومديرو الثروات", "البنوك الخاصة وشركات إدارة الثروات التي يحتاج عملاؤها إلى استشارات أعمال تشغيلية — تأسيس الكيانات والرواتب والامتثال — إلى جانب تخطيطهم المالي."], ["مستشارو الاندماجات والاستحواذات والبنوك الاستثمارية", "شركات استشارات المعاملات والبنوك الاستثمارية التي تحتاج إلى هيكلة عابرة للحدود ودعم تشغيلي بعد الاستحواذ."], ["منصات العقارات والاستثمار", "الوكلاء العقاريون ومنصات الاستثمار ووسطاء مكاتب العائلة الذين يتطلع عملاؤهم إلى الانتقال أو الاستثمار دولياً."], ["شبكات الخبراء المحليين", "المحامون والمحاسبون ومتخصصو الامتثال المتخصصون في ولايات قضائية معينة الراغبون في تقديم وصول أوسع للاستشارات الدولية لعملائهم."]], "stdEye": "معيار شراكة ARM", "stdH": "ما نبحث عنه.", "stdP": "تُبنى سمعة ARM Management على الجودة المتسقة والتعامل الصادق. نحن نمتد بهذا المعيار إلى كل علاقة مهنية نُبرمها.", "standards": [["خبرة حقيقية", "نتعاون مع متخصصين ذوي خبرة حقيقية في مجالهم. لا نبني شبكات إحالة للحجم — نبني علاقات مهنية للجودة."], ["معايير عملاء مشتركة", "يتعرّف عملاؤنا على شركاء نثق بهم في شؤوننا الخاصة. يجب أن تتطابق مستويات المشورة والسرية مع ما يتلقاه عملاء ARM منّا بالفعل."], ["تغطية تكاملية", "أفضل الشراكات تسدّ فجوات حقيقية. نبحث عن شركاء تُكمّل تغطيتهم الجغرافية أو الخدمية تغطية ARM دون أن تنافسها مباشرةً."], ["توجه طويل الأمد", "نحن نبني علاقات، لا تدفقات معاملات. تتطور الشراكة الصحيحة بمرور الوقت مع تعمّق فهم الطرفين لعملاء وقدرات بعضهما."]], "ctaH": "هل أنت مستعد للبدء؟", "ctaP": "إذا كنت تقدّم المشورة للعملاء ذوي المتطلبات التجارية الدولية وتعتقد أن هناك أساساً لعلاقة مهنية مع ARM Management، فنحن نرحّب بمحادثة أولية.", "ctaBtn": "جدوِّل استشارة ←"}, "ru": {"title": "Партнёрство | ARM Management", "desc": "Профессиональные партнёрства, основанные на взаимной экспертизе, общих стандартах и взаимодополняющих возможностях.", "eyebrow": "Партнёрство", "h1": "Создадим что-то вместе.", "hero": "Профессиональные партнёрства, основанные на взаимной экспертизе, общих стандартах и взаимодополняющих возможностях.", "btn1": "Стать партнёром →", "btn2": "Об ARM", "apprEye": "Наш подход к партнёрству", "apprH": "Не реферальный договор. Профессиональное партнёрство.", "apprP1": "ARM Management работает с избранной сетью профессиональных партнёров в ЕС, Заливе, Азии и Латинской Америке. Партнёрство с ARM — это не реферальное соглашение — это профессиональные отношения, основанные на взаимной экспертизе, общих стандартах и взаимодополняющих возможностях.", "apprP2": "Мы столь же избирательны в партнёрствах, как и в клиентах, которых обслуживаем.", "typesEye": "Типы партнёрства", "typesH": "Как мы работаем вместе", "types": [["Юридические фирмы", "Корпоративные и коммерческие юридические фирмы, чьи клиенты нуждаются в трансграничной регистрации структур, координации комплаенс или регуляторном консалтинге."], ["Аудиторские и налоговые фирмы", "Аудиторские практики и налоговые консалтинговые фирмы с клиентами, расширяющимися международно."], ["Частные банки и управляющие активами", "Частные банки и компании по управлению активами, чьи клиенты нуждаются в операционном бизнес-консалтинге наряду с финансовым планированием."], ["Консультанты по M&A и инвестиционные банки", "Транзакционные консалтинговые фирмы и инвестиционные банки, нуждающиеся в трансграничном структурировании и пост-приобретационной операционной поддержке."], ["Платформы недвижимости и инвестиций", "Агенты по недвижимости, инвестиционные платформы и посредники семейных офисов, чьи клиенты переезжают или инвестируют за рубежом."], ["Локальные экспертные сети", "Специализированные юристы, аудиторы и комплаенс-специалисты в конкретных юрисдикциях, желающие предложить клиентам более широкий международный консалтинг."]], "stdEye": "Стандарт партнёрства ARM", "stdH": "Что мы ищем.", "stdP": "Репутация ARM Management построена на последовательном качестве и честных отношениях. Мы распространяем этот стандарт на каждые профессиональные отношения.", "standards": [["Реальная экспертиза", "Мы сотрудничаем с профессионалами, которые действительно являются экспертами в своей области. Мы не строим реферальные сети ради объёма — мы строим профессиональные отношения ради качества."], ["Общие стандарты работы с клиентами", "Наши клиенты знакомятся с партнёрами, которым мы бы доверили собственные дела. Уровень консультирования и конфиденциальности должен соответствовать тому, что клиенты ARM уже получают от нас."], ["Дополняющее покрытие", "Лучшие партнёрства заполняют реальные пробелы. Мы ищем партнёров, чьё юрисдикционное или сервисное покрытие дополняет ARM, не конкурируя с ним напрямую."], ["Долгосрочная ориентация", "Мы строим отношения, а не потоки транзакций. Правильное партнёрство развивается со временем по мере того, как обе стороны лучше понимают клиентов и возможности друг друга."]], "ctaH": "Готовы начать?", "ctaP": "Если вы консультируете клиентов с международными бизнес-потребностями и считаете, что есть основание для профессиональных отношений с ARM Management, мы будем рады первоначальному разговору.", "ctaBtn": "Записаться на консультацию →"}, "zh": {"title": "合作 | ARM Management", "desc": "建立在共同专业知识、共同标准和互补能力之上的专业合作关系。", "eyebrow": "合作", "h1": "共同构建未来。", "hero": "建立在共同专业知识、共同标准和互补能力之上的专业合作关系。", "btn1": "成为合作伙伴 →", "btn2": "关于ARM", "apprEye": "我们的合作理念", "apprH": "不是转介安排，而是专业关系。", "apprP1": "ARM Management与欧盟、海湾、亚洲和拉丁美洲精选的专业合作伙伴网络合作。与ARM的合作不是带有介绍费的转介安排——而是建立在相互专业知识、共同标准和互补能力基础上的专业关系。", "apprP2": "我们在合作伙伴关系上的选择性与我们在客户服务上的选择性出于同样的原因。", "typesEye": "合作类型", "typesH": "我们如何共同合作", "types": [["律师事务所", "公司和商业律师事务所，其客户需要跨境实体设立、合规协调或超出事务所核心司法管辖区的监管咨询。"], ["会计和税务咨询公司", "会计师事务所和税务咨询公司，其正在国际扩张的客户需要当地合规协调或实体设立。"], ["私人银行和财富管理公司", "私人银行和财富管理公司，其客户需要在财务规划之外的运营业务咨询——实体设立、薪酬、合规。"], ["并购顾问和投资银行", "交易咨询公司和投资银行，需要为其交易客户提供跨境架构、监管合规和收购后运营支持。"], ["房地产和投资平台", "房地产中介、投资平台和家族办公室中介，其客户正在国际移民或投资。"], ["本地专家网络", "特定司法管辖区的律师、会计师和合规专业人士，希望为其客户提供更广泛的国际咨询能力。"]], "stdEye": "ARM合作标准", "stdH": "我们的要求。", "stdP": "ARM Management的声誉建立在一贯的质量和诚实的交往之上。我们将这一标准延伸到我们建立的每一段专业关系。", "standards": [["真正的专业知识", "我们与在其领域真正具备专业知识的人合作。我们不为数量建立转介网络——我们为质量建立专业关系。"], ["共同的客户标准", "我们的客户被介绍给我们信任处理自己事务的合作伙伴。建议和保密的标准必须与ARM客户已经从我们这里获得的相匹配。"], ["互补的业务范围", "最好的合作关系填补真正的空白。我们寻找在司法管辖区或服务范围上与ARM互补而不直接竞争的合作伙伴。"], ["长期导向", "我们正在建立关系，而不是交易流量。随着双方更好地了解彼此的客户和能力，正确的合作关系随时间发展。"]], "ctaH": "准备好开始了吗？", "ctaP": "如果您为有国际业务需求的客户提供咨询，并认为与ARM Management建立专业关系有基础，我们欢迎进行初步交流。", "ctaBtn": "预约咨询 →"}};
const c = DATA[lang];
---
<PageWrapper lang={lang} title={c.title} description={c.desc} canonicalPath="/partnership">
<main dir={isRTL ? 'rtl' : 'ltr'}>
  <section class="page-hero">
    <div class="page-hero__bg" style="background-image:url('https://images.unsplash.com/photo-1560472354-b33ff0c44a43?w=1600&q=80&auto=format&fit=crop')"></div>
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content container">
      <span class="eyebrow">{c.eyebrow}</span>
      <h1>{c.h1}</h1>
      <p>{c.hero}</p>
      <div class="btn-row" style="justify-content:flex-start;margin-top:30px">
        <a href={lp('/contact')} class="btn-primary">{c.btn1}</a>
        <a href={lp('/about')} class="btn-secondary">{c.btn2}</a>
      </div>
    </div>
  </section>
  <section class="section section--cream">
    <div class="container--narrow">
      <span class="eyebrow reveal">{c.apprEye}</span>
      <h2 class="reveal">{c.apprH}</h2>
      <div class="gold-rule reveal"></div>
      <p class="reveal">{c.apprP1}</p>
      <p class="reveal" style="margin-top:20px">{c.apprP2}</p>
    </div>
  </section>
  <section class="section section--warm" style="border-top:1px solid #E2DDD6">
    <div class="container">
      <span class="eyebrow reveal">{c.typesEye}</span>
      <h2 class="reveal">{c.typesH}</h2>
      <div class="gold-rule reveal"></div>
      <div class="grid-3" style="margin-top:40px">
        {c.types.map(([h, p]: [string,string], i: number) => (
          <div class={`card reveal reveal-delay-${(i%3)+1}`}><h3>{h}</h3><p>{p}</p></div>
        ))}
      </div>
    </div>
  </section>
  <section class="section section--navy">
    <div class="container--narrow">
      <span class="eyebrow reveal" style="color:#B8960C">{c.stdEye}</span>
      <h2 class="reveal" style="color:#F7F3EC">{c.stdH}</h2>
      <div class="gold-rule reveal"></div>
      <p class="reveal" style="color:rgba(247,243,236,.78)">{c.stdP}</p>
      <div style="margin-top:48px;display:grid;grid-template-columns:repeat(2,1fr);gap:32px">
        {c.standards.map(([h, p]: [string,string], i: number) => (
          <div class={`reveal reveal-delay-${(i%2)+1}`} style="border-top:1px solid rgba(184,150,12,.3);padding-top:20px">
            <h4 style="font-family:'Inter',sans-serif;font-size:12px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:#B8960C;margin-bottom:10px">{h}</h4>
            <p style="color:rgba(247,243,236,.65);font-size:15px;line-height:1.75">{p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  <section class="cta-section">
    <h2 class="reveal">{c.ctaH}</h2>
    <p class="reveal reveal-delay-1">{c.ctaP}</p>
    <div class="btn-row reveal reveal-delay-2">
      <a href={lp('/contact')} class="btn-primary">{c.ctaBtn}</a>
    </div>
  </section>
</main>
</PageWrapper>
