---
import PageWrapper from './PageWrapper.astro';
import { localePath } from '../i18n/translations';
import type { Locale } from '../i18n/translations';
interface Props { lang: Locale; }
const { lang } = Astro.props;
const lp = (p: string) => localePath(lang, p);
const isRTL = lang === 'ar';
const DATA: Record<string, any> = {"en": {"title": "GCC & Middle East | ARM Management", "desc": "ARM Management's home market — company formation, transaction advisory, and VARA crypto licensing across UAE, Saudi Arabia, Qatar, and the wider GCC.", "eyebrow": "GCC & Middle East", "h1": "GCC & Middle East", "hero": "UAE, Saudi Arabia, Qatar, Bahrain, Kuwait, and Oman — with offices in Dubai and Riyadh.", "s2h": "ARM Management in GCC & Middle East", "s2p1": "The GCC is ARM Management's home market. We are headquartered in the UAE with deep operational experience across Dubai mainland, all major free zones, DIFC, and ADGM — as well as a dedicated office in Riyadh serving the Kingdom of Saudi Arabia directly, and active practices across Qatar, Bahrain, Kuwait, and Oman.", "s2p2": "Our GCC practice covers the full range of ARM services: company formation, transaction advisory, accounting and tax compliance, payroll and HR, global mobility and Golden Visa, and crypto/Web3 advisory under the VARA framework.", "svcsEye": "Services in GCC & Middle East", "svcsH": "What ARM Management Does Here", "svcs": [["Company Formation", "UAE mainland, DIFC, ADGM, JAFZA and all major free zones. Saudi Arabia, Qatar, Bahrain registration."], ["VARA & Crypto", "UAE VARA licensing from eligibility assessment to post-licence compliance. ADGM and DIFC crypto frameworks."], ["Accounting & Tax", "UAE corporate tax and VAT. Free zone and mainland compliance. Saudi Zakat. Qatar and Bahrain tax."], ["Global Mobility", "UAE Golden Visa, investor visa, employment visa, Green Visa. Saudi iqama. Qatar QID."], ["Transaction Advisory", "UAE and GCC M&A, private equity, and deal structuring. Foreign ownership compliance."], ["Payroll & HR", "UAE WPS, DEWS end of service, DIFC/ADGM employment. Saudi GOSI and Saudisation compliance."]], "navyEye": "Key Jurisdictions", "navyH": "Where We Operate", "offices": [["Dubai", "ARM headquarters. Mainland, DIFC, ADGM, all free zones. VARA licensing, Golden Visa, UAE corporate tax."], ["Riyadh", "Dedicated Saudi office. CR registration, GOSI, Saudisation compliance, Saudi-UAE cross-border structuring."], ["Qatar", "QFC structures, QFCRA advisory, and cross-border GCC structuring from the Doha market."], ["Bahrain", "CBB licensing, company registration, and financial services regulatory advisory."]]}, "fr": {"title": "CCG & Moyen-Orient | ARM Management", "desc": "Le marché d'origine d'ARM Management — création de sociétés, conseil en transactions et licences crypto VARA aux EAU, en Arabie Saoudite, au Qatar et dans le CCG.", "eyebrow": "CCG & Moyen-Orient", "h1": "CCG & Moyen-Orient", "hero": "EAU, Arabie Saoudite, Qatar, Bahreïn, Koweït et Oman — avec des bureaux à Dubaï et Riyad.", "s2h": "ARM Management dans le CCG & Moyen-Orient", "s2p1": "Le CCG est le marché d'origine d'ARM Management. Nous sommes basés aux EAU avec une expérience opérationnelle approfondie à Dubaï, dans toutes les zones franches majeures, le DIFC et l'ADGM — ainsi qu'un bureau dédié à Riyad.", "s2p2": "Notre pratique CCG couvre toute la gamme des services ARM : création de sociétés, conseil en transactions, conformité comptable et fiscale, paie et RH, mobilité internationale et Visa doré, et conseil crypto/Web3 sous le cadre VARA.", "svcsEye": "Services dans le CCG & Moyen-Orient", "svcsH": "Ce qu'ARM Management fait ici", "svcs": [["Création de sociétés", "Continental UAE, DIFC, ADGM, JAFZA et toutes les principales zones franches. Arabie Saoudite, Qatar, Bahreïn."], ["VARA & Crypto", "Licences VARA des EAU de l'éligibilité à la conformité post-licence. Cadres crypto ADGM et DIFC."], ["Comptabilité & Fiscalité", "Impôt sur les sociétés et TVA des EAU. Conformité zone franche et continent. Zakat saoudien."], ["Mobilité internationale", "Visa doré EAU, visa investisseur, emploi, visa vert. Iqama saoudienne. QID Qatar."], ["Conseil en transactions", "M&A EAU et CCG, private equity et structuration. Conformité propriété étrangère."], ["Paie & RH", "WPS EAU, DEWS, emploi DIFC/ADGM. GOSI saoudien. Conformité Saudisation."]], "navyEye": "Juridictions clés", "navyH": "Où nous opérons", "offices": [["Dubaï", "Siège ARM. Continental, DIFC, ADGM, toutes les zones franches. VARA, Visa doré, impôt EAU."], ["Riyad", "Bureau saoudien dédié. CR, GOSI, Saudisation et structuration transfrontalière Arabie Saoudite-EAU."], ["Qatar", "Structures QFC, conseil QFCRA et structuration CCG transfrontalière depuis Doha."], ["Bahreïn", "Licences CBB, enregistrement de sociétés et conseil réglementaire en services financiers."]]}, "es": {"title": "CCG y Oriente Medio | ARM Management", "desc": "El mercado de origen de ARM Management — constitución de sociedades, asesoría en transacciones y licencias crypto VARA en los EAU, Arabia Saudita, Qatar y el CCG.", "eyebrow": "CCG y Oriente Medio", "h1": "CCG y Oriente Medio", "hero": "EAU, Arabia Saudita, Qatar, Bahréin, Kuwait y Omán — con oficinas en Dubái y Riad.", "s2h": "ARM Management en el CCG y Oriente Medio", "s2p1": "El CCG es el mercado de origen de ARM Management. Tenemos sede en los EAU con profunda experiencia operativa en Dubai mainland, todas las principales zonas francas, DIFC y ADGM — así como una oficina dedicada en Riad.", "s2p2": "Nuestra práctica en el CCG cubre toda la gama de servicios ARM: constitución de sociedades, asesoría en transacciones, cumplimiento contable y fiscal, nómina y RRHH, movilidad global y visa dorada, y asesoría crypto/Web3 bajo el marco VARA.", "svcsEye": "Servicios en el CCG y Oriente Medio", "svcsH": "Lo que hace ARM Management aquí", "svcs": [["Constitución de sociedades", "Continental EAU, DIFC, ADGM, JAFZA y todas las principales zonas francas. Arabia Saudita, Qatar, Bahréin."], ["VARA & Crypto", "Licencias VARA EAU de elegibilidad a cumplimiento post-licencia. Marcos crypto ADGM y DIFC."], ["Contabilidad & Impuestos", "Impuesto de sociedades y IVA EAU. Cumplimiento zona franca y continental. Zakat saudita."], ["Movilidad Global", "Visa dorada EAU, visa inversor, empleo, visa verde. Iqama saudita. QID Qatar."], ["Asesoría en Transacciones", "M&A EAU y CCG, private equity y estructuración. Cumplimiento propiedad extranjera."], ["Nómina & RRHH", "WPS EAU, DEWS, empleo DIFC/ADGM. GOSI saudita. Cumplimiento Saudización."]], "navyEye": "Jurisdicciones clave", "navyH": "Dónde operamos", "offices": [["Dubái", "Sede ARM. Continental, DIFC, ADGM, todas las zonas francas. VARA, Visa Dorada, impuesto EAU."], ["Riad", "Oficina saudita dedicada. CR, GOSI, Saudización y estructuración transfronteriza Arabia Saudita-EAU."], ["Qatar", "Estructuras QFC, asesoría QFCRA y estructuración CCG transfronteriza desde Doha."], ["Bahréin", "Licencias CBB, registro de empresas y asesoría regulatoria de servicios financieros."]]}, "ar": {"title": "دول الخليج والشرق الأوسط | ARM Management", "desc": "السوق الرئيسية لـ ARM Management — تأسيس الشركات، واستشارات المعاملات، وتراخيص العملات الرقمية وفق VARA في الإمارات والسعودية وقطر ودول الخليج.", "eyebrow": "دول الخليج والشرق الأوسط", "h1": "دول الخليج والشرق الأوسط", "hero": "الإمارات العربية المتحدة، والمملكة العربية السعودية، وقطر، والبحرين، والكويت، وعُمان — مع مكاتب في دبي والرياض.", "s2h": "ARM Management في دول الخليج والشرق الأوسط", "s2p1": "دول الخليج هي السوق الرئيسية لـ ARM Management. مقرّنا في الإمارات العربية المتحدة مع خبرة تشغيلية عميقة في البر الرئيسي لدبي وجميع المناطق الحرة الرئيسية ومركز دبي المالي العالمي وسوق أبوظبي العالمي — إضافةً إلى مكتب مخصص في الرياض.", "s2p2": "تغطي ممارستنا في دول الخليج النطاق الكامل لخدمات ARM: تأسيس الشركات، واستشارات المعاملات، والامتثال المحاسبي والضريبي، والرواتب والموارد البشرية، والتنقل الدولي والتأشيرة الذهبية، واستشارات العملات الرقمية/Web3 تحت إطار VARA.", "svcsEye": "الخدمات في دول الخليج", "svcsH": "ما تفعله ARM Management هنا", "svcs": [["تأسيس الشركات", "البر الرئيسي الإماراتي وDIFC وADGM وJAFZA وجميع المناطق الحرة الرئيسية. السعودية وقطر والبحرين."], ["VARA والعملات الرقمية", "تراخيص VARA الإماراتية من تقييم الأهلية إلى الامتثال بعد الترخيص. أطر ADGM وDIFC."], ["المحاسبة والضرائب", "ضريبة الشركات وضريبة القيمة المضافة الإماراتية. امتثال المناطق الحرة والبر الرئيسي. الزكاة السعودية."], ["التنقل الدولي", "التأشيرة الذهبية وتأشيرة المستثمر والعمل والتأشيرة الخضراء. الإقامة السعودية. QID قطر."], ["استشارات المعاملات", "الاندماجات والاستحواذات والأسهم الخاصة وهيكلة الصفقات في الإمارات ودول الخليج."], ["الرواتب والموارد البشرية", "WPS الإماراتية وDEWS وتوظيف DIFC/ADGM. GOSI السعودي. الامتثال للسعودة."]], "navyEye": "الولايات القضائية الرئيسية", "navyH": "أين نعمل", "offices": [["دبي", "مقر ARM. البر الرئيسي وDIFC وADGM وجميع المناطق الحرة. VARA والتأشيرة الذهبية وضريبة الشركات."], ["الرياض", "مكتب سعودي مخصص. السجل التجاري وGOSI والامتثال للسعودة والهيكلة العابرة للحدود."], ["قطر", "هياكل QFC ومشورة QFCRA والهيكلة الخليجية العابرة للحدود من سوق الدوحة."], ["البحرين", "تراخيص CBB وتسجيل الشركات والاستشارات التنظيمية للخدمات المالية."]]}, "ru": {"title": "Страны Залива и Ближний Восток | ARM Management", "desc": "Домашний рынок ARM Management — регистрация компаний, транзакционный консалтинг и крипто-лицензирование VARA в ОАЭ, Саудовской Аравии, Катаре и шире по региону.", "eyebrow": "Залив и Ближний Восток", "h1": "Залив и Ближний Восток", "hero": "ОАЭ, Саудовская Аравия, Катар, Бахрейн, Кувейт и Оман — с офисами в Дубае и Эр-Рияде.", "s2h": "ARM Management в Заливе и на Ближнем Востоке", "s2p1": "Страны Залива — домашний рынок ARM Management. Штаб-квартира в ОАЭ с глубоким операционным опытом на материке Дубая, во всех основных свободных зонах, DIFC и ADGM — а также выделенный офис в Эр-Рияде.", "s2p2": "Наша практика в Заливе охватывает полный спектр услуг ARM: регистрацию компаний, транзакционный консалтинг, налоговый комплаенс, расчёт зарплат, международную мобильность и Золотую визу, а также крипто/Web3-консалтинг в рамках VARA.", "svcsEye": "Услуги в Заливе и на Ближнем Востоке", "svcsH": "Что ARM Management делает здесь", "svcs": [["Регистрация компаний", "Материк ОАЭ, DIFC, ADGM, JAFZA и все основные свободные зоны. Саудовская Аравия, Катар, Бахрейн."], ["VARA и крипто", "Лицензирование VARA ОАЭ от оценки до пост-лицензионного комплаенс. Фреймворки ADGM и DIFC."], ["Учёт и налоги", "Корпоративный налог и НДС ОАЭ. Комплаенс свободных зон и материка. Зякят Саудовской Аравии."], ["Международная мобильность", "Золотая виза ОАЭ, инвесторская, рабочая и зелёная виза. Саудовская икама. QID Катара."], ["Транзакционный консалтинг", "M&A ОАЭ и Залива, прямые инвестиции и структурирование. Комплаенс иностранного владения."], ["Расчёт зарплат и HR", "WPS ОАЭ, DEWS, трудоустройство DIFC/ADGM. Saudi GOSI. Комплаенс Сауди-изации."]], "navyEye": "Ключевые юрисдикции", "navyH": "Где мы работаем", "offices": [["Дубай", "Штаб-квартира ARM. Материк, DIFC, ADGM, все свободные зоны. VARA, Золотая виза, корпоративный налог."], ["Эр-Рияд", "Выделенный саудовский офис. CR, GOSI, Сауди-изация и трансграничное структурирование."], ["Катар", "Структуры QFC, консалтинг QFCRA и трансграничное структурирование в Заливе из Дохи."], ["Бахрейн", "Лицензирование CBB, регистрация компаний и регуляторный консалтинг по финансовым услугам."]]}, "zh": {"title": "海湾合作委员会及中东 | ARM Management", "desc": "ARM Management的核心市场——阿联酋、沙特阿拉伯、卡塔尔及更广泛海湾地区的公司注册、交易咨询及VARA加密货币许可。", "eyebrow": "海湾及中东地区", "h1": "海湾合作委员会及中东", "hero": "阿联酋、沙特阿拉伯、卡塔尔、巴林、科威特及阿曼——在迪拜和利雅得设有办公室。", "s2h": "ARM Management在海湾及中东", "s2p1": "海湾合作委员会是ARM Management的核心市场。总部位于阿联酋，在迪拜大陆、所有主要自由区、DIFC和ADGM拥有深厚的运营经验——并在利雅得设有专门办公室直接服务沙特阿拉伯王国。", "s2p2": "我们的海湾业务涵盖ARM全系列服务：公司注册、交易咨询、会计和税务合规、薪酬与人力资源、全球移民和黄金签证，以及VARA框架下的加密货币/Web3咨询。", "svcsEye": "海湾及中东服务", "svcsH": "ARM Management在此的服务", "svcs": [["公司注册", "阿联酋大陆、DIFC、ADGM、JAFZA及所有主要自由区。沙特阿拉伯、卡塔尔、巴林注册。"], ["VARA及加密货币", "阿联酋VARA许可证从资格评估到许可后合规。ADGM和DIFC加密货币框架。"], ["会计与税务", "阿联酋企业所得税和增值税。自由区及大陆合规。沙特天课。卡塔尔和巴林税务。"], ["全球移民", "阿联酋黄金签证、投资人签证、就业签证和绿色签证。沙特居留证。卡塔尔QID。"], ["交易咨询", "阿联酋和海湾并购、私募股权及交易架构。外商投资合规。"], ["薪酬与人力资源", "阿联酋WPS、DEWS、DIFC/ADGM用工。沙特GOSI。沙特化合规。"]], "navyEye": "主要司法管辖区", "navyH": "我们的运营区域", "offices": [["迪拜", "ARM总部。大陆、DIFC、ADGM及所有自由区。VARA许可证、黄金签证及企业所得税。"], ["利雅得", "沙特专属办公室。CR注册、GOSI、沙特化合规及沙特-阿联酋跨境架构。"], ["卡塔尔", "QFC架构、QFCRA咨询及从多哈市场开展的跨海湾架构。"], ["巴林", "CBB许可证、公司注册及金融服务监管咨询。"]]}};
const c = DATA[lang];
---
<PageWrapper lang={lang} title={c.title} description={c.desc} canonicalPath="/regions/gcc-middle-east">
<main dir={isRTL ? 'rtl' : 'ltr'}>
  <section class="page-hero">
    <div class="page-hero__bg" style="background-image:url('/images/riyadh-day.jpg')"></div>
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content container">
      <span class="eyebrow">{c.eyebrow}</span>
      <h1>{c.h1}</h1>
      <p>{c.hero}</p>
    </div>
  </section>
  <section class="section section--cream">
    <div class="container--narrow">
      <h2 class="reveal">{c.s2h}</h2>
      <div class="gold-rule reveal"></div>
      <p class="reveal">{c.s2p1}</p>
      <p class="reveal" style="margin-top:20px">{c.s2p2}</p>
    </div>
  </section>
  <section class="section section--warm" style="border-top:1px solid #E2DDD6">
    <div class="container">
      <span class="eyebrow reveal">{c.svcsEye}</span>
      <h2 class="reveal">{c.svcsH}</h2>
      <div class="gold-rule reveal"></div>
      <div class="grid-3" style="margin-top:40px">
        {c.svcs.map(([sh, sp]: [string,string], i: number) => (
          <div class={`card reveal reveal-delay-${(i%3)+1}`}><h3>{sh}</h3><p>{sp}</p></div>
        ))}
      </div>
    </div>
  </section>
  <section class="section section--navy">
    <div class="container--narrow">
      <span class="eyebrow reveal" style="color:#B8960C">{c.navyEye}</span>
      <h2 class="reveal" style="color:#F7F3EC">{c.navyH}</h2>
      <div class="gold-rule reveal"></div>
      <div style="margin-top:40px;display:grid;grid-template-columns:repeat(2,1fr);gap:24px">
        {c.offices.map(([oh, op]: [string,string], i: number) => (
          <div class={`reveal reveal-delay-${(i%2)+1}`} style="background:rgba(247,243,236,.04);border:1px solid rgba(184,150,12,.2);padding:24px;border-radius:2px">
            <h4 style="color:#C9A227;font-family:'Inter',sans-serif;font-size:13px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;margin-bottom:10px">{oh}</h4>
            <p style="color:rgba(247,243,236,.65);font-size:14px;line-height:1.7">{op}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  <section class="cta-section">
    <h2 class="reveal">{c.ctaH}</h2>
    <p class="reveal reveal-delay-1">{c.ctaP}</p>
    <div class="btn-row reveal reveal-delay-2">
      <a href={lp('/contact')} class="btn-primary">{c.ctaBtn}</a>
      <a href={lp('/services')} class="btn-secondary">{c.btn2}</a>
    </div>
  </section>
</main>
</PageWrapper>
